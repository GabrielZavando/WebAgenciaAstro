---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    slug: string;
    image?: string;
    class?: string;
    [key: string]: any; // Allow data attributes
}

const {
    title,
    description,
    pubDate,
    slug,
    image,
    class: className = "",
    ...rest
} = Astro.props;

// Format date
const formattedDate = pubDate.toLocaleDateString("es-CL", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article class={`blog-card ${className}`} {...rest}>
    <div class="blog-card__inner">
        {
            image && (
                <div class="blog-card__image-container">
                    <img
                        src={image}
                        alt={title}
                        class="blog-card__image"
                        loading="lazy"
                    />
                </div>
            )
        }

        <div class="blog-card__content">
            <time datetime={pubDate.toISOString()} class="blog-card__date">
                {formattedDate}
            </time>

            <h3 class="blog-card__title">
                <a href={`/blog/${slug}`}>{title}</a>
            </h3>

            <p class="blog-card__description">{description}</p>

            <a
                href={`/blog/${slug}`}
                class="btn-link"
                aria-label={`Leer artículo: ${title}`}
            >
                Leer más <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    </div>
</article>

<style lang="scss">
    @use "../styles/config" as *;

    .blog-card {
        // Contenedor lógico (captura eventos, define tamaño en grid)
        height: 100%;
        display: block; // Asegura comportamiento de bloque
        position: relative; // Crea el contexto de posicionamiento para elementos absolutos hijos

        &:hover {
            .blog-card__inner {
                border-color: var(--color-primary);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
                transform: translateY(-5px);
            }

            .blog-card__title a {
                color: var(--color-primary);
            }

            .blog-card__image {
                transform: scale(1.05);
            }
        }

        // Nuevo contenedor visual (styles movidos aquí)
        &__inner {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: 0;
            transition: all var(--transition-normal) ease;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        &__image-container {
            width: 100%;
            height: 200px;
            overflow: hidden;
            border-bottom: 1px solid var(--color-border);
        }

        &__image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform var(--transition-normal) ease;
        }

        &__content {
            padding: var(--space-lg);
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        &__date {
            font-size: 0.875rem;
            color: var(--color-text-secondary);
            margin-bottom: var(--space-xs);
            font-family: var(--font-primary);
        }

        &__title {
            font-family: var(--font-headings);
            font-weight: 600;
            font-size: 1.25rem;
            line-height: 1.3;
            margin-bottom: var(--space-sm);

            a {
                color: var(--color-text);
                text-decoration: none;
                transition: color var(--transition-normal) ease;

                &::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    z-index: 1; // Para que el enlace cubra toda la tarjeta
                }
            }
        }

        &__description {
            color: var(--color-text-secondary);
            line-height: 1.6;
            font-size: 0.95rem;
            margin-bottom: var(--space-md);
            flex-grow: 1;
        }

        .btn-link {
            font-weight: 600;
            color: var(--color-primary);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            width: fit-content;
            position: relative;
            z-index: 2; // Por encima del enlace global

            &:hover {
                color: var(--color-primary-dark);
                gap: 0.75rem;
            }

            i {
                transition: all 0.3s ease;
            }
        }
    }
</style>
