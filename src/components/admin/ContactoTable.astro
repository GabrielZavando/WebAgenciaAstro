---
import type { ContactoResponseDto } from '../../types/api'

interface Props {
  contacts: ContactoResponseDto[]
}

const { contacts } = Astro.props

const statusLabels: Record<string, string> = {
  lead: 'Lead',
  client: 'Cliente',
  inactive: 'Inactivo',
}
---

{contacts.length === 0 ? (
  <div class="empty-state">
    <span class="material-symbols-outlined empty-icon">contacts_product</span>
    <h3>No hay contactos registrados</h3>
    <p>Aún no se han recibido formularios de contacto.</p>
  </div>
) : (
  <div class="table-responsive">
    <table class="users-table" id="contactosTable">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Teléfono</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {contacts.map((contact) => (
          <tr class="user-row contact-row">
            <td>
              <div class="user-info">
                <div class="user-avatar">
                  {contact.name.charAt(0).toUpperCase()}
                </div>
                <span class="user-name">{contact.name}</span>
              </div>
            </td>
            <td class="contact-email">{contact.email}</td>
            <td class="contact-phone">
              {contact.phone || (
                <span class="text-muted">—</span>
              )}
            </td>
            <td>
              <span class={`role-badge ${contact.status}`}>
                {statusLabels[contact.status] ?? contact.status}
              </span>
            </td>
            <td>
              <a href={`/admin/contacto/${contact.id}`} class="btn-details">
                <span class="material-symbols-outlined">visibility</span>
                ver detalles
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
