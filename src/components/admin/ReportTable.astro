---
import ModalConfirm from '../shared/ModalConfirm.astro';
import ModalMessage from '../shared/ModalMessage.astro';

interface Props {
  clientId?: string;
  role: 'admin' | 'client';
  id?: string;
  allowDelete?: boolean;
}

const { clientId, role, id = "reportsTableBody", allowDelete = false } = Astro.props;
---

<div 
  class="reports-component" 
  data-client-id={clientId} 
  data-role={role} 
  data-table-id={id}
  data-allow-delete={allowDelete ? "true" : "false"}
>
  <div class="filters-bar">
    <form class="search-form" onsubmit="return false;">
      <input type="text" class="reportSearchInput search-input" placeholder="Buscar por título..." autocomplete="off" />
      <button type="submit" class="search-btn">Buscar</button>
    </form>
    <div class="filter-group">
      <div class="select-wrapper">
        <select class="reportProjectFilter select-filter">
          <option value="">Todos los proyectos</option>
        </select>
      </div>
    </div>
  </div>

  <div class="report-table-container fade-in">
    <table class="unified-report-table">
      <thead>
        <tr>
          {role === 'admin' && !clientId && <th class="col-client">Cliente</th>}
          <th class="sortable col-project" data-sort="projectName">Proyecto <span class="material-symbols-outlined">unfold_more</span></th>
          <th class="sortable col-title" data-sort="title">Título <span class="material-symbols-outlined">unfold_more</span></th>
          <th class="col-desc">Descripción</th>
          <th class="sortable active col-date" data-sort="date">Fecha <span class="material-symbols-outlined">expand_more</span></th>
          <th class="col-actions text-center">Acciones</th>
        </tr>
      </thead>
      <tbody id={id}>
        <tr>
          <td colspan={role === 'admin' && !clientId ? "6" : "5"}>
            <div class="loading-state">
              <span class="material-symbols-outlined spin">sync</span>
              <p>Cargando informes...</p>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
  
  {allowDelete && (
    <ModalConfirm 
      id={`deleteReportModal-${id}`}
      title="¿Eliminar Informe?"
      message="¿Estás seguro de que deseas eliminar este informe permanentemente? Esta acción no se puede deshacer."
      confirmText="Eliminar permanentemente"
      type="danger"
    />
  )}

    <ModalMessage 
      id={`errorReportModal-${id}`}
      title="Error"
      message="Hubo un problema al procesar el informe."
      type="error"
    />
  </div>

<script>
  import { db, auth } from "../../lib/firebase/client";
  import { onAuthStateChanged, type User } from "firebase/auth";
  import { 
    collection, 
    query, 
    where, 
    orderBy, 
    onSnapshot,
    Timestamp,
    getDocs
  } from "firebase/firestore";

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

  function initReports() {
    // Inicializar todas las tablas de informes en la página
    document.querySelectorAll('.reports-component').forEach(async container => {
      // Evitar doble inicialización si el componente persiste (raro en Astro pero posible)
      if (container.hasAttribute('data-initialized')) return;
      container.setAttribute('data-initialized', 'true');

      const clientId = container.getAttribute('data-client-id');
      const role = container.getAttribute('data-role');
      const tableId = container.getAttribute('data-table-id');
      const allowDelete = container.getAttribute('data-allow-delete') === 'true';
      
      const tableBody = document.getElementById(tableId!) as HTMLTableSectionElement;
      const searchInput = container.querySelector('.reportSearchInput') as HTMLInputElement;
      const projectFilter = container.querySelector('.reportProjectFilter') as HTMLSelectElement;
      const sortHeaders = container.querySelectorAll('.sortable');

      let allReports: any[] = [];
      let allClients: any[] = [];
      let currentToken = '';
      let currentSort = { field: 'date', direction: 'desc' };
      let unsubscribe: (() => void) | null = null;

      // Cargar clientes en segundo plano si es admin y no hay clientId específico
      if (role === 'admin' && !clientId) {
        getDocs(collection(db, 'users')).then(snapshot => {
          allClients = snapshot.docs.map(doc => ({ uid: doc.id, ...doc.data() }));
          if (allReports.length > 0) applyFiltersAndSort();
        }).catch(e => console.error("Error cargando clientes:", e));
      }

      const setupRealtimeListener = (userUid: string) => {
        if (unsubscribe) {
          unsubscribe();
          unsubscribe = null;
        }

        let reportsQuery;
        const reportsCol = collection(db, 'reports');

        if (role === 'client') {
          reportsQuery = query(
            reportsCol, 
            where('clientId', '==', userUid),
            orderBy('createdAt', 'desc')
          );
        } else if (role === 'admin' && clientId) {
          reportsQuery = query(
            reportsCol, 
            where('clientId', '==', clientId),
            orderBy('createdAt', 'desc')
          );
        } else {
          reportsQuery = query(
            reportsCol, 
            orderBy('createdAt', 'desc')
          );
        }

        unsubscribe = onSnapshot(reportsQuery, (snapshot) => {
          allReports = snapshot.docs.map(doc => ({
            id: doc.id,
            ...doc.data()
          }));
          
          populateProjectFilter();
          applyFiltersAndSort();
        }, (error) => {
          console.error("Error en el listener de informes:", error);
          if (tableBody) {
            const colSpan = role === 'admin' && !clientId ? 6 : 5;
            tableBody.innerHTML = `<tr><td colspan="${colSpan}" class="text-center py-5 text-error">Error al sincronizar informes.</td></tr>`;
          }
        });
      };

      const populateProjectFilter = () => {
        if (!projectFilter) return;
        const projects = [...new Set(allReports.map(r => r.projectName).filter(Boolean))];
        const options = projects.map(p => `<option value="${p}">${p}</option>`);
        projectFilter.innerHTML = '<option value="">Todos los proyectos</option>' + options.join('');
      };

      const applyFiltersAndSort = () => {
        let filtered = [...allReports];
        
        const q = searchInput?.value.toLowerCase().trim();
        if (q) {
          filtered = filtered.filter(r => 
            r.title.toLowerCase().includes(q) || 
            (r.projectName || '').toLowerCase().includes(q)
          );
        }

        const proj = projectFilter?.value;
        if (proj) {
          filtered = filtered.filter(r => r.projectName === proj);
        }

        filtered.sort((a, b) => {
          let valA, valB;
          
          if (currentSort.field === 'date') {
            valA = getTimestamp(a.createdAt);
            valB = getTimestamp(b.createdAt);
          } else {
            valA = (a[currentSort.field] || '').toString().toLowerCase();
            valB = (b[currentSort.field] || '').toString().toLowerCase();
          }

          if (valA < valB) return currentSort.direction === 'asc' ? -1 : 1;
          if (valA > valB) return currentSort.direction === 'asc' ? 1 : -1;
          return 0;
        });

        renderReports(filtered);
      };

      const getTimestamp = (raw: any) => {
        if (raw instanceof Timestamp) return raw.toMillis();
        if (raw?._seconds) return raw._seconds * 1000;
        return new Date(raw).getTime();
      };

      const renderReports = (reports: any[]) => {
        if (!tableBody) return;
        const colSpan = role === 'admin' && !clientId ? 6 : 5;

        if (reports.length === 0) {
          tableBody.innerHTML = `<tr><td colspan="${colSpan}" class="text-center py-5"><div class="empty-state"><span class="material-symbols-outlined">folder_open</span><h3>No se encontraron informes</h3></div></td></tr>`;
          return;
        }

        tableBody.innerHTML = reports.map(r => {
          const client = allClients.find(c => c.uid === r.clientId);
          const clientName = client ? (client.displayName || client.name) : 'Cargando...';
          
          return `
          <tr>
            ${role === 'admin' && !clientId ? `<td class="col-client" data-label="Cliente"><span class="client-name">${clientName}</span></td>` : ''}
            <td class="col-project" data-label="Proyecto"><span class="project-badge">${r.projectName || 'General'}</span></td>
            <td class="col-title" data-label="Título"><span class="report-title">${r.title}</span></td>
            <td class="col-desc" data-label="Descripción"><span class="report-desc-col">${r.description || '-'}</span></td>
            <td class="col-date col-date-data" data-label="Fecha">${fmtDate(r.createdAt)}</td>
            <td class="col-actions text-center" data-label="Acciones">
              <div class="td-actions">
                <button class="btn-icon view-btn" data-id="${r.id}" title="Ver informe">
                  <span class="material-symbols-outlined">visibility</span>
                </button>
                <button class="btn-icon dl-btn" data-id="${r.id}" title="Descargar informe">
                  <span class="material-symbols-outlined">download</span>
                </button>
                ${allowDelete ? `<button class="btn-icon delete-btn" data-id="${r.id}" title="Eliminar informe"><span class="material-symbols-outlined">delete</span></button>` : ''}
              </div>
            </td>
          </tr>`}).join('');

        tableBody.querySelectorAll('.view-btn').forEach(b =>
          b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'view')));
        tableBody.querySelectorAll('.dl-btn').forEach(b =>
          b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'download')));
        tableBody.querySelectorAll('.delete-btn').forEach(b =>
          b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'delete')));
      };

      const handleAction = async (id: string, action: string) => {
        if (action === 'delete') {
          const modalId = `deleteReportModal-${tableId}`;
          window.confirmModalHelpers.open(modalId, async () => {
            try {
              const res = await fetch(`${API_URL}/reports/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${currentToken}` },
              });
              if (!res.ok) throw new Error();
              if (window.showToast) window.showToast('Informe eliminado correctamente', 'success');
            } catch {
              if (window.showToast) window.showToast('Error al eliminar el informe.', 'error');
            }
          });
          return;
        }

        try {
          const isDownload = action === 'download';
          const res = await fetch(`${API_URL}/reports/${id}/download?download=${isDownload}`, {
            headers: { 'Authorization': `Bearer ${currentToken}` },
          });
          if (!res.ok) throw new Error();
          const { url } = await res.json();
          
          if (action === 'view') {
            window.open(url, '_blank');
          } else {
            if (window.showToast) window.showToast('Iniciando descarga...', 'info');
            const a = document.createElement('a');
            a.href = url;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          }
        } catch (err) {
          console.error('Error al procesar el informe:', err);
          if (window.modalHelpers) {
            window.modalHelpers.openModal(`errorReportModal-${tableId}`);
          } else {
            alert('Error al obtener el informe.');
          }
        }
      };

      const fmtDate = (raw: any) => {
        const d = new Date(getTimestamp(raw));
        return d.toLocaleDateString('es-CL', { day: '2-digit', month: '2-digit', year: 'numeric' });
      };

      // Event Listeners
      searchInput?.addEventListener('input', applyFiltersAndSort);
      projectFilter?.addEventListener('change', applyFiltersAndSort);

      sortHeaders.forEach(h => {
        h.addEventListener('click', () => {
          const field = h.getAttribute('data-sort');
          if (currentSort.field === field) {
            currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
          } else {
            currentSort.field = field!;
            currentSort.direction = 'asc';
          }
          
          sortHeaders.forEach(header => {
            header.classList.remove('active');
            const icon = header.querySelector('.material-symbols-outlined');
            if (icon) icon.textContent = 'unfold_more';
          });
          
          h.classList.add('active');
          const icon = h.querySelector('.material-symbols-outlined');
          if (icon) icon.textContent = currentSort.direction === 'asc' ? 'expand_less' : 'expand_more';
          
          applyFiltersAndSort();
        });
      });

      // Auth Listener
      onAuthStateChanged(auth, async (user: User | null) => {
        if (!user) {
          if (unsubscribe) unsubscribe();
          return;
        }
        currentToken = await user.getIdToken();
        setupRealtimeListener(user.uid);
      });
    });
  }

  // Inicializar en cada carga de página
  document.addEventListener('astro:page-load', initReports);
</script>


