---
interface Props {
  usedFormatted: string;
  limitFormatted: string;
  usedBytes: number;
  limitBytes: number;
  variant?: 'compact' | 'full' | 'icon';
  id?: string;
}

const { 
  usedFormatted, 
  limitFormatted, 
  usedBytes, 
  limitBytes, 
  variant = 'full',
  id = 'storage-chart'
} = Astro.props;

const pct = limitBytes > 0 ? (usedBytes / limitBytes) * 100 : 0;
const isWarning = pct >= 90;
---

<div class={`storage-visualizer-comp ${variant} ${isWarning ? 'warning' : ''}`} id={id}>
  <div class="circular-chart-wrapper">
    <svg viewBox="0 0 36 36" class="circular-chart">
      <path class="circle-bg"
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />
      <path class="circle chart-progress"
        data-pct={pct}
        stroke-dasharray={`${pct}, 100`}
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />
      {(variant === 'full' || variant === 'icon') && (
        <text x="18" y="20.35" class="percentage">{Math.round(pct)}%</text>
      )}
    </svg>
    
    {variant !== 'icon' && (
      <div class="chart-info">
        {variant === 'full' ? (
          <>
            <div class="info-item">
              <span class="dot used"></span>
              <div class="info-text">
                <span class="label">Usado</span>
                <span class="value used-value">{usedFormatted}</span>
              </div>
            </div>
            <div class="info-item">
              <span class="dot total"></span>
              <div class="info-text">
                <span class="label">Límite Total</span>
                <span class="value limit-value">{limitFormatted}</span>
              </div>
            </div>
          </>
        ) : (
          <div class="mini-data">
            <span class="mini-percent">{Math.round(pct)}%</span>
            <p class="mini-text">{usedFormatted} de {limitFormatted}</p>
          </div>
        )}
      </div>
    )}
  </div>
</div>

