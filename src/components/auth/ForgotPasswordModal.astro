---
import ModalMessage from '../shared/ModalMessage.astro';
---
<div id="forgotPasswordModal" class="forgot-password-modal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="modal-auth__overlay">
    <div class="modal-auth__content" tabindex="-1">
      <button class="modal-auth__close" id="closeForgotModal" aria-label="Cerrar modal">&times;</button>
      
      <div class="modal-auth__icon">
        <i class="fas fa-key"></i>
      </div>
      
      <h3 class="modal-auth__title">¿Olvidaste tu contraseña?</h3>
      <p class="modal-auth__text">Ingresa tu correo electrónico y te enviaremos un enlace para restablecerla.</p>
      
      <div class="modal-auth__form">
        <div class="form-group">
          <label for="forgotEmail" class="form-label">Correo Electrónico</label>
          <input 
            type="email" 
            id="forgotEmail" 
            placeholder="tu@email.com" 
            class="form-input"
          />
        </div>
        
        <div id="forgotFeedback" class="feedback-msg hidden"></div>
        
        <div class="modal-auth__actions">
          <button class="btn-primary" id="sendResetBtn">
            <span class="btn-text">Enviar enlace</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<ModalMessage 
  id="resetPasswordSuccessModal"
  type="success"
  title="Enlace enviado"
  message="Si el correo está registrado, recibirás un enlace para restablecer tu contraseña en unos minutos."
/>

<style lang="scss">
  .forgot-password-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);

    &.active {
      opacity: 1;
      visibility: visible;
    }
  }

  .modal-auth__overlay {
    background: rgba(0, 0, 0, 0.4);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-auth__content {
    background: var(--card-bg, #fff);
    padding: 3rem 2.5rem;
    max-width: 440px;
    width: 100%;
    text-align: center;
    position: relative;
    transform: scale(0.9) translateY(20px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    border: 1px solid var(--color-border);

    .forgot-password-modal.active & {
      transform: scale(1) translateY(0);
    }
  }

  .modal-auth__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.75rem;
    cursor: pointer;
    color: var(--color-text-muted);
    line-height: 1;
    transition: color 0.2s;
    
    &:hover {
      color: var(--color-text);
    }
  }

  .modal-auth__icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
    background: rgba(var(--color-primary-rgb), 0.1);
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    margin-right: auto;
    border-radius: 50%;
  }

  .modal-auth__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .modal-auth__text {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .modal-auth__form {
    text-align: left;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-label {
    display: block;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-input {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 1px solid var(--input-border, #ddd);
    background: var(--input-bg, #fff);
    font-size: 1rem;
    color: var(--input-text, #333);
    outline: none;
    transition: all 0.2s;

    &:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.1);
    }
  }

  .modal-auth__actions {
    margin-top: 1.5rem;
  }

  .btn-primary {
    width: 100%;
    padding: 1rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.5rem;

    &:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgba(var(--color-primary-rgb), 0.3);
    }

    &:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    &.loading {
      .btn-text { opacity: 0; }
      &::after {
        content: "";
        position: absolute;
        width: 20px;
        height: 20px;
        border: 2px solid transparent;
        border-top: 2px solid white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
    }
  }

  .feedback-msg {
    padding: 1rem;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    text-align: center;
    font-weight: 500;

    &.error {
      background: rgba(var(--color-error-rgb), 0.1);
      color: var(--color-error);
      border: 1px solid rgba(var(--color-error-rgb), 0.2);
    }

    &.success {
      background: rgba(34, 197, 94, 0.1);
      color: #16a34a;
      border: 1px solid rgba(34, 197, 94, 0.2);
    }

    &.hidden {
      display: none;
    }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  import { sendPasswordResetEmail } from "firebase/auth";
  import { auth } from "../../lib/firebase/client";

  const modal = document.getElementById('forgotPasswordModal');
  const closeBtn = document.getElementById('closeForgotModal');
  const sendBtn = document.getElementById('sendResetBtn');
  const emailInput = document.getElementById('forgotEmail') as HTMLInputElement;
  const feedback = document.getElementById('forgotFeedback');
  const overlay = modal?.querySelector('.modal-auth__overlay');

  const showFeedback = (msg: string, type: 'error' | 'success') => {
    if (!feedback) return;
    feedback.textContent = msg;
    feedback.className = `feedback-msg ${type}`;
    feedback.classList.remove('hidden');
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Reset form
    if (emailInput) emailInput.value = '';
    if (feedback) feedback.classList.add('hidden');
    if (sendBtn) {
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  sendBtn?.addEventListener('click', async () => {
    if (!sendBtn || !emailInput || !feedback) return;
    
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      showFeedback('Por favor, ingresa un correo electrónico válido.', 'error');
      return;
    }

    sendBtn.classList.add('loading');
    (sendBtn as HTMLButtonElement).disabled = true;
    feedback.classList.add('hidden');

    try {
      auth.languageCode = 'es';
      await sendPasswordResetEmail(auth, email);
      
      // Limpiamos el input y devolvemos el botón a su estado normal
      emailInput.value = '';
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
      
      // Cerramos el modal de "Olvidaste tu contraseña" y regresamos al login
      closeModal();
      
      // Abrimos el componente ModalMessage para informar el éxito
      if ((window as any).modalHelpers) {
        (window as any).modalHelpers.openModal('resetPasswordSuccessModal');
      }
    } catch (err: any) {
      console.error('Error sendPasswordResetEmail:', err);
      let msg = 'Ocurrió un error al enviar el correo.';
      if (err.code === 'auth/invalid-email') msg = 'El correo electrónico no es válido.';
      if (err.code === 'auth/too-many-requests') msg = 'Demasiadas solicitudes. Intentalo más tarde.';
      
      showFeedback(msg, 'error');
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
    }
  });

  // Global helper to open the modal
  (window as any).openForgotPasswordModal = () => {
    if (!modal) return;
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => emailInput?.focus(), 100);
  };
</script>
