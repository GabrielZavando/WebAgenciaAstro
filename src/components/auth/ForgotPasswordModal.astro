---
import ModalMessage from '../shared/ModalMessage.astro';
---
<div id="forgotPasswordModal" class="forgot-password-modal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="modal-auth__overlay">
    <div class="modal-auth__content" tabindex="-1">
      <button class="modal-auth__close" id="closeForgotModal" aria-label="Cerrar modal">&times;</button>
      
      <div class="modal-auth__icon">
        <span class="material-symbols-outlined">key</span>
      </div>
      
      <h3 class="modal-auth__title">¿Olvidaste tu contraseña?</h3>
      <p class="modal-auth__text">Ingresa tu correo electrónico y te enviaremos un enlace para restablecerla.</p>
      
      <div class="modal-auth__form">
        <div class="form-group">
          <label for="forgotEmail" class="form-label">Correo Electrónico</label>
          <input 
            type="email" 
            id="forgotEmail" 
            placeholder="tu@email.com" 
            class="form-input"
          />
        </div>
        
        <div id="forgotFeedback" class="feedback-msg hidden"></div>
        
        <div class="modal-auth__actions">
          <button class="btn-primary" id="sendResetBtn">
            <span class="btn-text">Enviar enlace</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<ModalMessage 
  id="resetPasswordSuccessModal"
  type="success"
  title="Enlace enviado"
  message="Si el correo está registrado, recibirás un enlace para restablecer tu contraseña en unos minutos."
/>


<script>
  import { sendPasswordResetEmail } from "firebase/auth";
  import { auth } from "../../lib/firebase/client";

  const modal = document.getElementById('forgotPasswordModal');
  const closeBtn = document.getElementById('closeForgotModal');
  const sendBtn = document.getElementById('sendResetBtn');
  const emailInput = document.getElementById('forgotEmail') as HTMLInputElement;
  const feedback = document.getElementById('forgotFeedback');
  const overlay = modal?.querySelector('.modal-auth__overlay');

  const showFeedback = (msg: string, type: 'error' | 'success') => {
    if (!feedback) return;
    feedback.textContent = msg;
    feedback.className = `feedback-msg ${type}`;
    feedback.classList.remove('hidden');
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Reset form
    if (emailInput) emailInput.value = '';
    if (feedback) feedback.classList.add('hidden');
    if (sendBtn) {
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  sendBtn?.addEventListener('click', async () => {
    if (!sendBtn || !emailInput || !feedback) return;
    
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      showFeedback('Por favor, ingresa un correo electrónico válido.', 'error');
      return;
    }

    sendBtn.classList.add('loading');
    (sendBtn as HTMLButtonElement).disabled = true;
    feedback.classList.add('hidden');

    try {
      auth.languageCode = 'es';
      await sendPasswordResetEmail(auth, email);
      
      // Limpiamos el input y devolvemos el botón a su estado normal
      emailInput.value = '';
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
      
      // Cerramos el modal de "Olvidaste tu contraseña" y regresamos al login
      closeModal();
      
      // Abrimos el componente ModalMessage para informar el éxito
      if (window.modalHelpers) {
        window.modalHelpers.openModal('resetPasswordSuccessModal');
      }
    } catch (err: any) {
      console.error('Error sendPasswordResetEmail:', err);
      let msg = 'Ocurrió un error al enviar el correo.';
      if (err.code === 'auth/invalid-email') msg = 'El correo electrónico no es válido.';
      if (err.code === 'auth/too-many-requests') msg = 'Demasiadas solicitudes. Intentalo más tarde.';
      
      showFeedback(msg, 'error');
      sendBtn.classList.remove('loading');
      (sendBtn as HTMLButtonElement).disabled = false;
    }
  });

  // Global helper to open the modal
  window.openForgotPasswordModal = () => {
    if (!modal) return;
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => emailInput?.focus(), 100);
  };
</script>
