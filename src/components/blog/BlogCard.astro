---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    slug: string;
    image?: string;
    class?: string;
    [key: string]: any; // Allow data attributes
}

const {
    title,
    description,
    pubDate,
    slug,
    image,
    class: className = "",
    ...rest
} = Astro.props;

// Format date
const formattedDate = pubDate.toLocaleDateString("es-CL", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article class={`blog-card ${className}`} {...rest}>
    <div class="blog-card__inner">
        {
            image && (
                <div class="blog-card__image-container">
                    <img
                        src={image}
                        alt={title}
                        class="blog-card__image"
                        loading="lazy"
                    />
                </div>
            )
        }

        <div class="blog-card__content">
            <time datetime={pubDate.toISOString()} class="blog-card__date">
                {formattedDate}
            </time>

            <h3 class="blog-card__title">
                <a href={`/blog/${slug}`}>{title}</a>
            </h3>

            <p class="blog-card__description">{description}</p>

            <a
                href={`/blog/${slug}`}
                class="btn-link"
                aria-label={`Leer artículo: ${title}`}
            >
                Leer más <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    </div>
</article>

