---
interface Breadcrumb {
  label: string;
  href?: string;
}

interface Props {
  paths: Breadcrumb[];
}

const { paths } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {paths.map((path, index) => (
      <li class={index === paths.length - 1 ? "current" : ""}>
        {path.href && index !== paths.length - 1 ? (
          <a href={path.href}>{path.label}</a>
        ) : (
          <span aria-current={index === paths.length - 1 ? "page" : undefined}>{path.label}</span>
        )}
        {index < paths.length - 1 && <span class="material-symbols-outlined separator">chevron_right</span>}
      </li>
    ))}
  </ol>
</nav>

