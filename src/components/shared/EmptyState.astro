---
interface Props {
  icon?: string;
  title: string;
  message: string;
  actionHref?: string;
  actionText?: string;
}

const { 
  icon = "inbox", 
  title, 
  message, 
  actionHref, 
  actionText 
} = Astro.props;
---

<div class="empty-state fade-in">
  <span class="material-symbols-outlined empty-icon">{icon}</span>
  <h3 class="empty-title">{title}</h3>
  <p class="empty-message">{message}</p>
  
  {actionHref && actionText && (
    <a href={actionHref} class="btn-primary mt-4">
      <span class="material-symbols-outlined">add</span> {actionText}
    </a>
  )}
</div>

