---
import StorageVisualizer from '../admin/StorageVisualizer.astro';
import ModalConfirm from './ModalConfirm.astro';
import ModalMessage from './ModalMessage.astro';

interface Props {
  role: 'admin' | 'client';
  limitGB: number;
  title?: string;
  description?: string;
}

const { 
  role, 
  limitGB, 
  title = "Gestión de Archivos", 
  description = "Administra tus documentos y recursos multimedia." 
} = Astro.props;
---

<div class="files-page" data-role={role} data-limit-gb={limitGB}>
  <!-- Header con Cuota (Diseño Original) -->
  <div class="page-header">
    <div class="header-text">
      <h1>{title}</h1>
      <p class="text-muted">{description}</p>
    </div>

    <div class="storage-banner-wrapper" id="storageBanner">
      <StorageVisualizer 
        id={`storage-chart-${role}`}
        usedFormatted="..." 
        limitFormatted={`${limitGB} GB`} 
        usedBytes={0} 
        limitBytes={limitGB * 1024 * 1024 * 1024} 
        variant="full"
      />
    </div>
  </div>

  <!-- Acciones y Búsqueda (Diseño Original) -->
  <div class="actions-row">
    <form class="search-form" id="searchFilesForm" onsubmit="return false;">
      <input type="text" id="filesSearchInput" class="search-input" placeholder="Buscar por título, nombre o descripción..." autocomplete="off" />
      <button type="submit" class="search-btn">Buscar</button>
    </form>
    
    <button class="btn btn-cta" id="openUploadBtn">
      <span class="material-symbols-outlined">cloud_upload</span> Subir Archivo
    </button>
  </div>

  <!-- Tabla de Archivos (Clases del Sistema de Diseño) -->
  <div class="table-container">
    <table class="files-table">
      <thead>
        <tr>
          <th class="col-type">Tipo</th>
          <th class="col-name">Nombre</th>
          <th class="col-desc">Descripción</th>
          <th class="col-size">Tamaño</th>
          <th class="col-date">Fecha de carga</th>
          <th class="col-actions">Acciones</th>
        </tr>
      </thead>
      <tbody id="filesTableBody">
        <tr>
          <td colspan="6">
            <div class="loading-state">
              <span class="material-symbols-outlined spinning">sync</span>
              <p>Sincronizando archivos con el sistema...</p>
            </div>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Modales (Clases del Sistema de Diseño) -->
  <div class="manager-modals">
    <div class="modal modal--files-upload" id="fileUploadModal">
      <div class="modal__content">
        <div class="modal__header">
          <h3><span class="material-symbols-outlined">upload_file</span> Subir Archivo</h3>
          <button class="modal__close" id="closeFileModal">&times;</button>
        </div>
        
        <form id="fileUploadForm" class="upload-form">
          <div class="form-group">
            <label for="fTitle" class="form-label">Título del Archivo <span class="required">*</span></label>
            <input type="text" id="fTitle" name="title" required placeholder="Ej: Manual de Identidad Corporativa" />
          </div>
          
          <div class="form-group">
            <label for="fDesc" class="form-label">Descripción Corta</label>
            <input type="text" id="fDesc" name="description" placeholder="Ej: Versión final aprobada en PDF" />
          </div>
          
          <div class="form-group toggle-group">
            <label class="toggle">
              <input type="checkbox" id="fIsPublic" name="isPublic" value="true" />
              <div class="toggle-col-text">
                <span class="label-text">Acceso Público</span>
                <span class="toggle-hint-text">Si es público, otros usuarios podrán descargarlo.</span>
              </div>
            </label>
          </div>

          <div class="form-group">
            <label class="form-label">Archivo <span class="required">*</span></label>
            <div class="file-drop" id="fDrop">
              <input type="file" id="fInput" name="file" required class="file-input-hidden" />
              <div class="drop-info">
                 <span class="material-symbols-outlined">cloud_upload</span>
                 <p id="fLabel">Arrastra o selecciona un archivo aquí</p>
                 <span class="file-types">Formatos: PDF, Office, Imágenes (Máx 20MB)</span>
              </div>
            </div>
          </div>

          <div class="form-actions" style="justify-content: flex-end;">
            <button type="submit" class="btn btn-cta" id="fSubmit">
              <span class="material-symbols-outlined">upload</span>
              Cargar archivo
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modales de Confirmación y Mensajes del Sistema -->
    <ModalConfirm 
      id="fDeleteModal"
      title="¿Eliminar archivo?"
      message="Esta acción no se puede deshacer. El archivo se borrará permanentemente."
      confirmText="Eliminar permanentemente"
      cancelText="Cancelar"
      type="danger"
    />
    <ModalMessage id="fSuccessModal" title="Subida Exitosa" message="El archivo se ha subido correctamente." type="success" />
    <ModalMessage id="fErrorModal" title="Error de Subida" message="No se pudo procesar el archivo. Revisa el formato y tamaño." type="error" />
  </div>
</div>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";
  import { filesStore, quotaStore, setFiles, addFile, removeFile, updateQuota } from "../../lib/stores/filesStore";
  import type { FileResponseDto } from "../../types/api";

  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const manager = document.querySelector('.files-page') as HTMLElement;
  
  if (manager) {
    document.addEventListener('astro:page-load', () => {
      const tableBody = document.getElementById('filesTableBody');
      const openBtn = document.getElementById('openUploadBtn');
      const uploadModal = document.getElementById('fileUploadModal');
      const closeBtn = document.getElementById('closeFileModal');
      const uploadForm = document.getElementById('fileUploadForm') as HTMLFormElement;
      const fileInput = document.getElementById('fInput') as HTMLInputElement;
      const fileLabel = document.getElementById('fLabel');
      const fileDrop = document.getElementById('fDrop');
      const searchInput = document.getElementById('filesSearchInput') as HTMLInputElement;

      let token = "";

      const loadFiles = async () => {
        try {
          const res = await fetch(`${API}/files`, { headers: { 'Authorization': `Bearer ${token}` } });
          if (!res.ok) throw new Error();
          const files = await res.json();
          setFiles(files);
        } catch {
          if (tableBody) tableBody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><span class="material-symbols-outlined">report</span><p>Error al sincronizar archivos.</p></div></td></tr>';
        }
      };

      const loadQuota = async () => {
        try {
          const res = await fetch(`${API}/files/storage/quota`, { headers: { 'Authorization': `Bearer ${token}` } });
          if (!res.ok) throw new Error();
          const quota = await res.json();
          updateQuota(quota);
        } catch (e) { console.error("Quota error", e); }
      };

      const render = (files: readonly FileResponseDto[]) => {
        if (!tableBody) return;
        if (files.length === 0) {
          tableBody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><span class="material-symbols-outlined">folder_open</span><h3>Sin archivos</h3><p>No hay archivos en esta vista todavía.</p></div></td></tr>';
          return;
        }

        tableBody.innerHTML = files.map(f => `
          <tr class="file-row">
            <td class="col-type-data">${getFileIcon(f.mimeType)}</td>
            <td class="col-name-data">
              <div class="name-wrapper">
                <span class="file-title" title="${f.title}">${f.title}</span>
                ${f.title !== f.fileName ? `<span class="file-name-sub">(${f.fileName})</span>` : ''}
              </div>
            </td>
            <td class="col-desc-data"><span class="file-desc-text" title="${f.description || ''}">${f.description || '-'}</span></td>
            <td class="col-size-data">${fmtSize(f.size)}</td>
            <td class="col-date-data">${fmtDate(f.createdAt)}</td>
            <td class="col-actions-data">
              <div class="td-actions">
                <button class="btn-cta__border btn-sm v-btn" data-id="${f.id}" title="Ver"><span class="material-symbols-outlined">visibility</span></button>
                <button class="btn-cta__warning btn-sm d-btn" data-id="${f.id}" title="Descargar"><span class="material-symbols-outlined">download</span></button>
                <button class="btn-cta__danger btn-sm r-btn" data-id="${f.id}" title="Eliminar"><span class="material-symbols-outlined">delete</span></button>
              </div>
            </td>
          </tr>
        `).join('');

        tableBody.querySelectorAll('.v-btn').forEach(b => b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'view')));
        tableBody.querySelectorAll('.d-btn').forEach(b => b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'download')));
        tableBody.querySelectorAll('.r-btn').forEach(b => b.addEventListener('click', () => handleAction(b.getAttribute('data-id')!, 'delete')));
      };

      const handleAction = async (id: string, action: string) => {
        if (action === 'delete') {
          if (window.confirmModalHelpers) {
            window.confirmModalHelpers.open('fDeleteModal', async () => {
              await fetch(`${API}/files/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
              removeFile(id);
              loadQuota();
              if (window.showToast) window.showToast('Archivo eliminado', 'success');
            });
          }
          return;
        }
        const isDl = action === 'download';
        const res = await fetch(`${API}/files/${id}/download?download=${isDl}`, { headers: { 'Authorization': `Bearer ${token}` } });
        const { url } = await res.json();
        if (action === 'view') window.open(url, '_blank');
        else {
          const a = document.createElement('a'); a.href = url; a.click();
        }
      };

      filesStore.subscribe(files => render(files));
      quotaStore.subscribe(q => {
        if (!q) return;
        const banner = document.getElementById('storageBanner');
        if (banner) {
          const circle = banner.querySelector('.chart-progress');
          const percent = banner.querySelector('.percentage');
          const used = banner.querySelector('.used-value');
          const pct = q.limitBytes > 0 ? (q.usedBytes / q.limitBytes) * 100 : 0;
          if (used) used.textContent = q.usedFormatted;
          if (circle) circle.setAttribute('stroke-dasharray', `${Math.min(pct, 100)}, 100`);
          if (percent) percent.textContent = `${Math.round(pct)}%`;
        }
      });

      openBtn?.addEventListener('click', () => uploadModal?.classList.add('active'));
      closeBtn?.addEventListener('click', () => uploadModal?.classList.remove('active'));
      fileInput?.addEventListener('change', () => {
        if (fileInput.files?.length && fileLabel) {
          fileLabel.textContent = fileInput.files[0].name;
          fileDrop?.classList.add('has-file');
        }
      });

      searchInput?.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase().trim();
        const all = filesStore.get();
        render(all.filter(f => f.title.toLowerCase().includes(q) || f.fileName.toLowerCase().includes(q)));
      });

      uploadForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('fSubmit') as HTMLButtonElement;
        const file = fileInput?.files?.[0];
        if (!file || btn.disabled) return;

        btn.disabled = true;
        btn.classList.add('btn-loading');

        try {
          const fd = new FormData();
          fd.append('file', file);
          fd.append('title', (document.getElementById('fTitle') as HTMLInputElement).value);
          fd.append('description', (document.getElementById('fDesc') as HTMLInputElement).value);
          if ((document.getElementById('fIsPublic') as HTMLInputElement).checked) fd.append('isPublic', 'true');

          const res = await fetch(`${API}/files`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
            body: fd
          });
          if (!res.ok) throw new Error();
          const newFile = await res.json();
          
          addFile(newFile);
          loadQuota();
          uploadModal?.classList.remove('active');
          uploadForm.reset();
          if (fileLabel) fileLabel.textContent = 'Arrastra o selecciona un archivo aquí';
          fileDrop?.classList.remove('has-file');
          
          if (window.modalHelpers) window.modalHelpers.openModal('fSuccessModal');
        } catch {
          if (window.modalHelpers) window.modalHelpers.openModal('fErrorModal');
        } finally {
          btn.disabled = false;
          btn.classList.remove('btn-loading');
        }
      });

      onAuthStateChanged(auth, async (user) => {
        if (user) {
          token = await user.getIdToken();
          await Promise.all([loadFiles(), loadQuota()]);
        }
      });
    });
  }

  function getFileIcon(m: string) {
    if (m.includes('pdf')) return '<span class="material-symbols-outlined" style="color:#ef4444">picture_as_pdf</span>';
    if (m.includes('image')) return '<span class="material-symbols-outlined" style="color:#3b82f6">image</span>';
    if (m.includes('word') || m.includes('document')) return '<span class="material-symbols-outlined" style="color:#2563eb">description</span>';
    if (m.includes('sheet') || m.includes('excel')) return '<span class="material-symbols-outlined" style="color:#22c55e">table_chart</span>';
    return '<span class="material-symbols-outlined" style="color:#6b7280">draft</span>';
  }
  function fmtSize(b: number) {
    if (b < 1024) return `${b} B`;
    if (b < 1048576) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / 1048576).toFixed(1)} MB`;
  }
  function fmtDate(r: any) {
    const d = r?._seconds ? new Date(r._seconds * 1000) : new Date(r);
    if (isNaN(d.getTime())) return '-';
    const m = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
    return `${d.getDate()} ${m[d.getMonth()]}, ${d.getFullYear()}`;
  }
</script>
