---
interface Option {
  label: string;
  value: string;
}

interface Props {
  options: Option[];
  placeholder?: string;
  currentSort?: string;
}

const { options, placeholder = "Filtrar resultados...", currentSort } = Astro.props;
---

<div class="filter-bar">
  <form class="search-form" onsubmit="return false;">
    <input 
      type="text" 
      class="search-input" 
      placeholder={placeholder}
      id="globalSearchInput"
      autocomplete="off"
    />
    <button type="submit" class="search-btn">Buscar</button>
  </form>
  
  {options && options.length > 0 && (
    <div class="select-wrapper sort-wrapper">
      <select class="sort-select" id="globalSortSelect">
        {options.map(opt => (
          <option value={opt.value} selected={opt.value === currentSort}>{opt.label}</option>
        ))}
      </select>
    </div>
  )}
</div>

