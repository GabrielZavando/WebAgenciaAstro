---
interface Props {
  id: string;
  title: string;
  icon?: string;
  maxWidth?: string;
  width?: string;
  largeHeader?: boolean;
}

const { id, title, icon = 'form', maxWidth = '800px', width = '95%', largeHeader = false } = Astro.props;
---

<div class="modal" id={id} role="dialog" aria-modal="true" aria-hidden="true">
  <div class="modal__content" style={`max-width: ${maxWidth}; width: ${width}`}>
    <header class:list={["modal__header", { "modal__header--large": largeHeader }]}>
      <h3>
        {icon && <span class="material-symbols-outlined">{icon}</span>}
        {title}
      </h3>
      <button class="modal__close" aria-label="Cerrar modal" data-close-modal>
        <span class="material-symbols-outlined">close</span>
      </button>
    </header>
    <div class="modal__body">
      <slot />
    </div>
  </div>
</div>

<style>
  /* Local overrides if needed, but using global _modal.scss mostly */
  .modal__close {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .modal__close:hover {
    color: var(--color-primary);
    transform: rotate(90deg);
  }

  /* Large Header Variant */
  .modal__header--large {
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }
  .modal__header--large h3 {
    font-size: 2.5rem !important; /* Double 1.25rem */
    gap: 1.5rem !important;
  }
  .modal__header--large h3 .material-symbols-outlined {
    font-size: 3rem !important; /* Double 1.5rem */
  }

  @media (max-width: 768px) {
    .modal__header--large h3 {
      font-size: 1.75rem !important;
      gap: 1rem !important;
    }
    .modal__header--large h3 .material-symbols-outlined {
      font-size: 2.25rem !important;
    }
  }
</style>

<script is:inline>
  // Simple helper attached to window if not present
  if (typeof window !== 'undefined' && !window.formModalHelpers) {
    window.formModalHelpers = {
      open: function(id) {
        const modal = document.getElementById(id);
        if (modal) {
          modal.classList.add('active');
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }
      },
      close: function(id) {
        const modal = typeof id === 'string' ? document.getElementById(id) : id;
        if (modal) {
          modal.classList.remove('active');
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
      }
    };

    // Close on overlay click or data-close
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (target.classList.contains('modal') || target.closest('[data-close-modal]')) {
        const modal = target.closest('.modal');
        if (modal) window.formModalHelpers.close(modal);
      }
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const activeModal = document.querySelector('.modal.active');
        if (activeModal) window.formModalHelpers.close(activeModal);
      }
    });
  }
</script>
