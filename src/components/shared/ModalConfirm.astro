---
export interface Props {
  id: string;
  title: string;
  message: string;
  confirmText?: string;
  cancelText?: string;
  type?: 'danger' | 'warning' | 'info';
}

const { 
  id, 
  title, 
  message, 
  confirmText = 'Confirmar', 
  cancelText = 'Cancelar', 
  type = 'warning' 
} = Astro.props;

const iconMap = {
  danger: 'fa-exclamation-triangle',
  warning: 'fa-exclamation-circle',
  info: 'fa-info-circle'
};

const modalClass = `confirm-modal ${type}-modal`;
---

<div id={id} class={modalClass} role="dialog" aria-modal="true" aria-hidden="true">
  <div class="modal-confirm__overlay">
    <div class="modal-confirm__content" tabindex="-1">
      <button class="modal-confirm__close" aria-label="Cerrar modal" data-close>&times;</button>
      
      <div class="modal-confirm__icon">
        <i class={`fas ${iconMap[type]}`}></i>
      </div>
      
      <h3 class="modal-confirm__title">{title}</h3>
      <p class="modal-confirm__text">{message}</p>
      
      <div class="modal-confirm__actions">
        <button class="modal-confirm__btn btn-cancel" data-close>{cancelText}</button>
        <button class="modal-confirm__btn btn-confirm" data-confirm>{confirmText}</button>
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  .confirm-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 99999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);
    overflow: hidden;

    &.active {
      opacity: 1;
      visibility: visible;
    }
  }

  .modal-confirm__overlay {
    background: rgba(0, 0, 0, 0.6);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-confirm__content {
    background: var(--color-surface);
    border-radius: 0;
    padding: 2.5rem 2rem;
    max-width: 420px;
    width: 100%;
    text-align: center;
    position: relative;
    transform: scale(0.9) translateY(10px);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1px solid var(--color-border);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);

    .confirm-modal.active & {
      transform: scale(1) translateY(0);
    }
  }

  .modal-confirm__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--color-text-muted);
    line-height: 1;
    padding: 0.25rem;
    transition: color 0.2s;
    
    &:hover {
      color: var(--color-text);
    }
  }

  .modal-confirm__icon {
    font-size: 3.5rem;
    margin-bottom: 1.25rem;
    
    .danger-modal & { color: var(--color-error); }
    .warning-modal & { color: #f59e0b; }
    .info-modal & { color: var(--color-primary); }
  }

  .modal-confirm__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .modal-confirm__text {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
  }

  .modal-confirm__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .modal-confirm__btn {
    padding: 0.875rem 1.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    flex: 1;
    font-family: inherit;
  }

  .btn-cancel {
    background: var(--color-border);
    color: var(--color-text);
    
    &:hover {
      background: var(--color-surface-hover);
    }
  }

  .btn-confirm {
    background: var(--color-primary);
    color: white;
    
    &:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    .danger-modal & {
      background: var(--color-error);
    }
  }
</style>

<script is:inline>
  (function() {
    function initConfirmModal() {
      if (typeof window !== 'undefined' && !window.confirmModalHelpers) {
        window.confirmModalHelpers = {
          modals: {},
          
          open: function(id, onConfirm) {
            const modal = document.getElementById(id);
            if (!modal) return;
            
            modal.classList.add('active');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            
            const confirmBtn = modal.querySelector('[data-confirm]');
            
            // Limpiar listener anterior si existe
            const newConfirmBtn = confirmBtn.cloneNode(true);
            confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
            
            newConfirmBtn.addEventListener('click', () => {
              if (onConfirm) onConfirm();
              this.close(id);
            });
            
            modal.querySelector('.modal-confirm__content').focus();
          },
          
          close: function(id) {
            const modal = typeof id === 'string' ? document.getElementById(id) : id;
            if (!modal) return;
            
            modal.classList.remove('active');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
          }
        };

        // Click events
        document.addEventListener('click', (e) => {
          const target = e.target;
          
          // Close triggers
          if (target.hasAttribute('data-close') || target.classList.contains('modal-confirm__overlay')) {
            const modal = target.closest('.confirm-modal');
            if (modal) window.confirmModalHelpers.close(modal);
          }
        });

        // ESC key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            const activeModal = document.querySelector('.confirm-modal.active');
            if (activeModal) window.confirmModalHelpers.close(activeModal);
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initConfirmModal);
    } else {
      initConfirmModal();
    }
  })();
</script>
