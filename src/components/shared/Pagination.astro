---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Navegación de páginas">
    <a 
      href={hasPrev ? `${baseUrl}?page=${currentPage - 1}` : '#'} 
      class={`pagination-btn ${!hasPrev ? 'disabled' : ''}`}
      aria-disabled={!hasPrev}
      aria-label="Página anterior"
    >
      <span class="material-symbols-outlined">chevron_left</span>
    </a>
    
    <div class="pagination-info">
      <span class="current-page">{currentPage}</span>
      <span class="separator">/</span>
      <span class="total-pages">{totalPages}</span>
    </div>
    
    <a 
      href={hasNext ? `${baseUrl}?page=${currentPage + 1}` : '#'} 
      class={`pagination-btn ${!hasNext ? 'disabled' : ''}`}
      aria-disabled={!hasNext}
      aria-label="Página siguiente"
    >
      <span class="material-symbols-outlined">chevron_right</span>
    </a>
  </nav>
)}

