---
interface Props {
    placeholder?: string;
    actionUrl?: string;
    outlined?: boolean;
}

const { placeholder = "Buscar artículos...", actionUrl = "/blog", outlined = false } = Astro.props;

// Componente de buscador reutilizable. 
// - Si se usa en la página principal del blog (index.astro), el script interceptará el submit y filtrará los posts vía JS.
// - Si se usa en un artículo individiual o en otro lado, su actionUrl dirigirá a "/blog?q=termino"
---

<div class="search-container fade-in">
    <form action={actionUrl} method="GET" class="search-form global-search-form">
        <input 
            type="text" 
            name="q"
            class={`search-input global-search-input ${outlined ? 'is-outlined' : ''}`} 
            placeholder={placeholder} 
            autocomplete="off"
        />
        <button type="submit" class="search-btn">Buscar</button>
    </form>
</div>

<style>
  .search-container {
    display: flex;
    justify-content: center;
    margin: 3rem 0 4.5rem 0; /* Márgenes top y bottom */
    padding: 0 1rem;
    width: 100%;
  }

  .search-form {
    display: flex;
    width: 100%;
    max-width: 600px;
    background: var(--color-surface);
    border-radius: 0; /* Flat */
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .search-form:focus-within {
    box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb, 99, 102, 241), 0.15); /* Color primary */
  }

  .search-input {
    flex: 1;
    padding: 0.85rem 1.5rem; /* Reducido de 1.15 a 0.85 para hacerlo más delgado */
    background: transparent;
    border: none;
    color: var(--color-text);
    font-size: 1.05rem; /* Ajustado sutilmente */
    outline: none;
    width: 100%;
    transition: box-shadow 0.2s ease-in-out; /* Animación suave solicitada */
  }

  /* Estilos específicos cuando outlined=true (ej: entradas individuales) */
  .search-input.is-outlined {
    box-shadow: inset 0 0 0 2px var(--color-primary); /* Borde interno primario */
  }

  .search-input.is-outlined:focus {
    box-shadow: inset 0 0 0 2px var(--color-secondary); /* Borde interno secundario en focus */
  }

  .search-btn {
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
    border-radius: 0;
    margin: 0;
    padding: 0 2rem; /* Reducido ligeramente el ancho del botón */
    font-size: 1rem; /* Acorde al nuevo tamaño del input */
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
  }

  .search-btn:hover {
    background-color: var(--color-secondary);
  }
</style>

<script>
  function initializeSearchComponent() {
    const searchForms = document.querySelectorAll('.global-search-form');
    const postCards = document.querySelectorAll('.post-card');
    const noResultsMsg = document.getElementById('noResultsMsg');

    // Si estamos en la página del índice del blog (donde existen '.post-card'), interceptamos la búsqueda en este componente.
    const isBlogIndex = postCards.length > 0;

    searchForms.forEach(form => {
        const searchInput = form.querySelector('.global-search-input') as HTMLInputElement;
        if (!searchInput) return;

        // Detectar query params iniciales en caso de venir de otra vista o por URL compartida
        if (isBlogIndex) {
            const urlParams = new URLSearchParams(window.location.search);
            const initialQuery = urlParams.get('q');
            const initialCategory = urlParams.get('category');

            if (initialCategory) {
                filterByCategory(initialCategory);
            } else if (initialQuery) {
                searchInput.value = initialQuery;
                filterPosts(initialQuery);
            }

            form.addEventListener('submit', (e) => {
                e.preventDefault();
                filterPosts(searchInput.value);
                updateUrlParam('q', searchInput.value);
            });

            searchInput.addEventListener('input', () => {
                filterPosts(searchInput.value);
                updateUrlParam('q', searchInput.value);
            });
        }
    });

    // Funciones Helper    
    function filterPosts(query: string) {
      if (!isBlogIndex) return;

      const term = query.toLowerCase().trim();
      let visibleCount = 0;

      postCards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        // Extendemos la búsqueda de texto base para que también abarque categorías
        const category = card.getAttribute('data-category') || '';
        
        if (title.includes(term) || category.includes(term)) {
          (card as HTMLElement).style.display = 'flex';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      toggleNoResults(visibleCount);
    }

    function filterByCategory(category: string) {
      if (!isBlogIndex) return;

      const term = category.toLowerCase().trim();
      let visibleCount = 0;

      postCards.forEach((card) => {
        const cat = card.getAttribute('data-category') || '';
        
        if (cat === term) {
          (card as HTMLElement).style.display = 'flex';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      toggleNoResults(visibleCount);
    }

    function toggleNoResults(visibleCount: number) {
      if (noResultsMsg) {
        if (visibleCount === 0) {
          (noResultsMsg as HTMLElement).style.display = 'flex';
        } else {
          (noResultsMsg as HTMLElement).style.display = 'none';
        }
      }
    }

    function updateUrlParam(key: string, value: string) {
       const newUrl = new URL(window.location.href);
       // Si el usuario empieza a buscar, borramos la categoria inicial para no estancarlo
       newUrl.searchParams.delete('category'); 
       
       if (value.trim()) {
           newUrl.searchParams.set(key, value.trim());
       } else {
           newUrl.searchParams.delete(key);
       }
       window.history.replaceState({}, "", newUrl);
    }
  }

  // Inicializar al cargar por primera vez y manejar transiciones de vista fluidas en Astro
  document.addEventListener('DOMContentLoaded', initializeSearchComponent);
  document.addEventListener('astro:page-load', initializeSearchComponent);
</script>
