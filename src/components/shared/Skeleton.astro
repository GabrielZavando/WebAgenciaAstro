---
interface Props {
  count?: number;
  type?: 'card' | 'row' | 'text' | 'avatar';
  className?: string;
}

const { count = 1, type = 'row', className = '' } = Astro.props;
---

<div class={`skeleton-container ${className}`}>
  {Array.from({ length: count }).map(() => (
    <div class={`skeleton skeleton--${type}`}></div>
  ))}
</div>


