---
interface Props {
  usedFormatted: string;
  limitFormatted: string;
  usedBytes: number;
  limitBytes: number;
  variant?: 'compact' | 'full';
  id?: string;
}

const { 
  usedFormatted, 
  limitFormatted, 
  usedBytes, 
  limitBytes, 
  variant = 'full',
  id = 'storage-chart'
} = Astro.props;

const pct = limitBytes > 0 ? (usedBytes / limitBytes) * 100 : 0;
const isWarning = pct >= 90;
---

<div class={`storage-visualizer-comp ${variant} ${isWarning ? 'warning' : ''}`} id={id}>
  <div class="circular-chart-wrapper">
    <svg viewBox="0 0 36 36" class="circular-chart">
      <path class="circle-bg"
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />
      <path class="circle chart-progress"
        data-pct={pct}
        stroke-dasharray={`${pct}, 100`}
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />
      {variant === 'full' && (
        <text x="18" y="20.35" class="percentage">{Math.round(pct)}%</text>
      )}
    </svg>
    
    <div class="chart-info">
      {variant === 'full' ? (
        <>
          <div class="info-item">
            <span class="dot used"></span>
            <div class="info-text">
              <span class="label">Usado</span>
              <span class="value used-value">{usedFormatted}</span>
            </div>
          </div>
          <div class="info-item">
            <span class="dot total"></span>
            <div class="info-text">
              <span class="label">Límite Total</span>
              <span class="value limit-value">{limitFormatted}</span>
            </div>
          </div>
        </>
      ) : (
        <div class="mini-data">
          <span class="mini-percent">{Math.round(pct)}%</span>
          <p class="mini-text">{usedFormatted} de {limitFormatted}</p>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .storage-visualizer-comp {
    width: 100%;
  }

  .circular-chart-wrapper {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .circular-chart {
    display: block;
    width: 120px;
    height: 120px;
  }

  .compact .circular-chart {
    width: 60px;
    height: 60px;
  }

  .circle-bg {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 3.8;
  }

  .circle {
    fill: none;
    stroke-width: 3.8;
    stroke-linecap: round;
    stroke: var(--color-primary);
    transition: stroke-dasharray 1s ease-out;
  }

  .warning .circle {
    stroke: #f59e0b;
  }

  .percentage {
    fill: var(--color-text);
    font-family: inherit;
    font-size: 8px;
    font-weight: 700;
    text-anchor: middle;
  }

  .chart-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .compact .chart-info {
    gap: 0.15rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .info-item .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .info-item .dot.used { background: var(--color-primary); }
  .warning .info-item .dot.used { background: #f59e0b; }
  .info-item .dot.total { background: var(--color-border); }

  .info-text {
    display: flex;
    flex-direction: column;
  }

  .info-text .label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-text .value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .mini-percent {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .warning .mini-percent {
    color: #f59e0b;
  }

  .mini-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
