---
interface Props {
  role: 'admin' | 'client';
  id: string; // HTML ID for the tbody
  showClientColumn?: boolean;
}

const { role, id, showClientColumn = role === 'admin' } = Astro.props;
---

<div class="ticket-table-container">
  <table class="unified-ticket-table">
    <thead>
      <tr>
        {showClientColumn && <th class="col-client">Cliente</th>}
        <th class="col-project">Proyecto</th>
        {role === 'client' && <th class="col-tickets" style="text-align: center;">Tickets</th>}
        <th class="col-status">Estado</th>
        <th class="col-priority">Prioridad</th>
        <th class="col-subject">Asunto</th>
        <th class="col-date">Fecha Enviado</th>
        <th class="col-date">Fecha Resuelto</th>
        <th class="col-actions">Ver Ticket</th>
      </tr>
    </thead>
    <tbody id={id}>
      <tr>
        <td colspan={showClientColumn ? (role === 'admin' ? "8" : "8") : (role === 'admin' ? "7" : "8")}>
          <div class="loading-state">
            <span class="material-symbols-outlined spin">sync</span>
            <p>Cargando tickets...</p>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>


