---
interface Props {
  role: 'admin' | 'client';
  id: string; // HTML ID for the tbody
  showClientColumn?: boolean;
}

const { role, id, showClientColumn = role === 'admin' } = Astro.props;
---

<div class="ticket-table-container">
  <table class="unified-ticket-table">
    <thead>
      <tr>
        {showClientColumn && <th class="col-client">Cliente</th>}
        <th class="col-project">Proyecto</th>
        {role === 'client' && <th class="col-tickets" style="text-align: center;">Tickets</th>}
        <th class="col-status">Estado</th>
        <th class="col-priority">Prioridad</th>
        <th class="col-subject">Asunto</th>
        <th class="col-date">Fecha Enviado</th>
        <th class="col-date">Fecha Resuelto</th>
        <th class="col-actions">Ver Ticket</th>
      </tr>
    </thead>
    <tbody id={id}>
      <tr>
        <td colspan={showClientColumn ? (role === 'admin' ? "8" : "8") : (role === 'admin' ? "7" : "8")}>
          <div class="loading-state">
            <i class="fas fa-spinner fa-spin"></i>
            <p>Cargando tickets...</p>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>

<style>
  .ticket-table-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    margin-top: 1rem;
  }
  
  .unified-ticket-table { width: 100%; border-collapse: collapse; text-align: left; }

  /* Cabeceras */
  .unified-ticket-table thead { background: rgba(0, 0, 0, 0.02); border-bottom: 2px solid var(--color-border); }
  .unified-ticket-table th {
    padding: 1.25rem 1.5rem; font-size: 0.8rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-right: 1px solid var(--color-border); vertical-align: middle;
  }
  .unified-ticket-table th:last-child { border-right: none; }
  
  /* Celdas - Using :global because rows are injected by JS */
  .unified-ticket-table :global(td) { padding: 1.5rem; border-bottom: 1px solid var(--color-border); border-right: 1px solid var(--color-border); vertical-align: middle; }
  .unified-ticket-table :global(td:last-child) { border-right: none; }
  .unified-ticket-table :global(tbody tr:last-child td) { border-bottom: none; }
  .unified-ticket-table :global(tbody tr) { transition: background-color 0.2s; }
  .unified-ticket-table :global(tbody tr:hover) { background-color: rgba(var(--color-primary-rgb), 0.03); }

  /* Anchos de columnas */
  .col-status { width: 140px; text-align: center; }
  .col-priority { width: 120px; text-align: center; }
  .col-subject { width: auto; }
  .col-date { width: 14%; text-align: center; }
  .col-actions { width: 110px; text-align: center; }
  .col-tickets { width: 100px; }

  /* Elementos de tabla compartidos via :global */
  .unified-ticket-table :global(.status-badge) {
    font-size: 0.8rem; font-weight: 600; padding: 0.3rem 0.8rem; border-radius: 999px; display: inline-flex; align-items: center; gap: 0.4rem; white-space: nowrap;
  }
  .unified-ticket-table :global(.status-open) { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .unified-ticket-table :global(.status-progress) { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .unified-ticket-table :global(.status-resolved) { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

  .unified-ticket-table :global(.priority-badge-wrapper) {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--color-text); text-transform: capitalize;
  }
  .unified-ticket-table :global(.priority-dot) { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

  .unified-ticket-table :global(.project-badge) { font-size: 0.85rem; font-weight: 600; color: var(--color-primary); }
  
  .unified-ticket-table :global(.file-title) { font-weight: 500; font-size: 1rem; color: var(--color-text); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; }
  
  .unified-ticket-table :global(.col-date-data) { text-align: center; color: var(--color-text-muted); font-size: 0.95rem; vertical-align: middle; }
  .unified-ticket-table :global(.resolved-date) { color: #22c55e; font-weight: 500;}

  .unified-ticket-table :global(.td-actions) { display: flex; justify-content: center; gap: 0.75rem; }
  
  .unified-ticket-table :global(.btn-action) { 
    padding: 0.5rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); 
    background: transparent; color: var(--color-text); cursor: pointer; 
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: all 0.2s; font-size: 0.85rem; font-weight: 600; text-decoration: none;
  }
  .unified-ticket-table :global(.btn-action:hover) { 
    border-color: var(--color-primary); color: var(--color-primary); 
    background: rgba(var(--color-primary-rgb), 0.05); transform: translateY(-1px);
  }

  .loading-state { text-align: center; padding: 3rem; color: var(--color-text-muted); }
  .loading-state i { font-size: 2rem; margin-bottom: 1rem; display: block; }

  .unified-ticket-table :global(.empty-state) { text-align: center; padding: 3rem; color: var(--color-text-muted); }
  .unified-ticket-table :global(.empty-state i) { font-size: 2.5rem; margin-bottom: 1rem; display: block; opacity: 0.5; }
  .unified-ticket-table :global(.empty-state h3) { margin: 0 0 0.5rem; color: var(--color-text); font-size: 1.25rem; }

  @media (max-width: 1024px) {
    .unified-ticket-table thead { display: none; }
    .unified-ticket-table :global(tr), .unified-ticket-table :global(td) { display: block; width: 100%; border: none !important; }
    .unified-ticket-table :global(tr) { border-bottom: 2px solid var(--color-border) !important; padding: 1.5rem 0; }
    .unified-ticket-table :global(td) { padding: 0.5rem 1.5rem !important; }
    .unified-ticket-table :global(td::before) {
      content: attr(data-label);
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.7rem;
      color: var(--color-text-muted);
      display: block;
      margin-bottom: 0.25rem;
    }
  }
</style>
