---
import type { TicketResponseDto } from "../../types/api";

interface Props {
  ticket: TicketResponseDto;
  role: 'admin' | 'client';
}

const { ticket, role } = Astro.props;

// Formateo de fecha inicial (server-side)
function formatFullDate(raw: any): string {
  let d: Date;
  if (typeof raw === 'string') d = new Date(raw);
  else if (raw && raw._seconds) d = new Date(raw._seconds * 1000);
  else return '-';

  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()} a las ${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
}
---

<div class="conversation" id="conversationBox" data-ticket-id={ticket.id} data-role={role}>
  <!-- Mensaje inicial del cliente -->
  <div class={`message client-message ${role === 'client' ? 'is-me' : 'is-other'}`}>
    <div class="message-header">
      <div class="user-info">
        <div class="avatar-wrapper">
          {ticket.clientPhotoUrl ? (
            <img src={ticket.clientPhotoUrl} alt="Avatar" class="msg-avatar-img" />
          ) : (
            <div class="msg-avatar-placeholder client"></div>
          )}
        </div>
        <div class="name-time">
          <strong>{ticket.clientName || 'Cliente'}</strong>
          <span class="time">{formatFullDate(ticket.createdAt)}</span>
        </div>
      </div>
    </div>
    <div class="message-body" style="padding-top: 1rem;">
      {ticket.message.split('\n').map((line: string) => (<p>{line}</p>))}
      {ticket.attachmentUrl && (
        <div class="attachment-container">
          <hr class="attachment-divider" />
          <p class="attachment-label"><span class="material-symbols-outlined">attach_file</span> Archivo Adjunto</p>
          <a href={ticket.attachmentUrl} target="_blank" rel="noopener noreferrer" class="attachment-link">
            <img src={ticket.attachmentUrl} alt="Adjunto" class="ticket-attachment-img" />
          </a>
        </div>
      )}
    </div>
  </div>
  
  <!-- Aquí se cargarán los mensajes adicionales vía JS -->
  <div id="additionalMessages" style="display: contents;"></div>
</div>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  function initConversation() {
    const box = document.getElementById('conversationBox');
    if (!box) return;

    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
    const ticketId = box.dataset.ticketId!;
    const userRole = box.dataset.role!; // Rol del espectador ('admin' o 'client')
    const additionalMessagesBox = document.getElementById('additionalMessages');

    function fmtDate(raw: any): string {
      if (!raw) return '';
      const d = raw._seconds ? new Date(raw._seconds * 1000) : new Date(raw);
      if (isNaN(d.getTime())) return '';
      const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
      return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()} ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
    }

    async function loadMessages() {
      if (!additionalMessagesBox) return;
      const user = auth.currentUser;
      const token = user ? await user.getIdToken() : '';
      if (!token) return;

      try {
        const res = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
          const messages = await res.json();
          renderMessages(messages);
        }
      } catch (err) {
        console.error("Error loading messages:", err);
      }
    }

    function renderMessages(messages: any[]) {
      if (!additionalMessagesBox) return;
      
      const clientPhotoUrl = document.querySelector('.client-message .msg-avatar-img')?.getAttribute('src') || '';
      const clientName = document.querySelector('.client-message .name-time strong')?.textContent || 'Cliente';

      additionalMessagesBox.innerHTML = messages.map(m => {
        const isAdmin = m.senderRole === 'admin';
        // LÓGICA DE ALINEACIÓN:
        // Si el rol del que envía coincide con el rol del que ve = is-me (Derecha)
        const alignmentClass = m.senderRole === userRole ? 'is-me' : 'is-other';
        
        let avatarHtml = '';
        if (m.senderPhotoUrl) {
          avatarHtml = `<img src="${m.senderPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
        } else if (!isAdmin && clientPhotoUrl) {
          avatarHtml = `<img src="${clientPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
        } else if (!isAdmin) {
          avatarHtml = `<div class="msg-avatar-placeholder client"></div>`;
        } else {
          avatarHtml = `<div class="msg-avatar-placeholder admin"><span class="material-symbols-outlined">headset_mic</span></div>`;
        }

        const senderDisplayName = isAdmin ? 'Equipo de Soporte' : (m.senderRole === 'client' ? (userRole === 'client' ? 'Tú' : clientName) : clientName);

        return `
          <div class="message ${isAdmin ? 'admin-message' : 'client-message'} ${alignmentClass}">
            <div class="message-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; border-bottom: none;">
              <div class="user-info" style="display: flex; align-items: center; gap: 1rem;">
                <div class="avatar-wrapper" style="width: 40px; height: 40px; flex-shrink: 0;">${avatarHtml}</div>
                <div class="name-time" style="display: flex; flex-direction: column;">
                  <strong style="font-size: 0.95rem; color: var(--color-text);">${senderDisplayName}</strong>
                  <span class="time" style="font-size: 0.8rem; color: var(--color-text-muted);">${fmtDate(m.createdAt)}</span>
                </div>
              </div>
            </div>
            <div class="message-body" style="padding-top: 0.5rem;">
              ${m.body.split('\n').map((l: string) => `<p style="margin: 0 0 1rem 0;">${l}</p>`).join('')}
              ${m.attachmentUrl ? `
                <div class="attachment-container" style="margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--color-border);">
                  <p class="attachment-label" style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
                    <span class="material-symbols-outlined">attach_file</span> Archivo Adjunto
                  </p>
                  <a href="${m.attachmentUrl}" target="_blank" rel="noopener noreferrer">
                    <img src="${m.attachmentUrl}" alt="Adjunto" class="ticket-attachment-img" style="max-width: 100%; max-height: 300px; border: 1px solid var(--color-border);" />
                  </a>
                </div>` : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    document.addEventListener('ticket:message-sent', () => {
      loadMessages();
    });

    onAuthStateChanged(auth, (user) => {
      if (user) loadMessages();
    });
  }

  document.addEventListener('astro:page-load', initConversation);
</script>
