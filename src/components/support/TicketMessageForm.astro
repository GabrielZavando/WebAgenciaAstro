---
interface Props {
  ticketId: string;
  role: 'admin' | 'client';
}

const { ticketId, role } = Astro.props;
---

<div class={`message ${role === 'admin' ? 'admin-message' : 'client-message'}`} id="replyArea">
  <div class="message-header">
    <div class="user-info">
      <div class="avatar-wrapper">
        <div class={`msg-avatar-placeholder ${role}`} id="replyAvatarContainer">
          {role === 'admin' ? <span class="material-symbols-outlined">headset_mic</span> : null}
        </div>
      </div>
      <div class="name-time"><strong>{role === 'admin' ? 'Responder (Soporte)' : 'Responder al Equipo de Soporte'}</strong></div>
    </div>
  </div>
  <div class="message-body">
    <form id="unifiedReplyForm" data-id={ticketId} data-role={role}>
      <textarea 
        id="newMessageBody" 
        name="body" 
        placeholder={role === 'admin' ? "Escribe tu respuesta para el cliente..." : "Escribe tu mensaje para el equipo de soporte..."} 
        rows="4" 
        required
      ></textarea>
      
      <div class="attachment-input-wrapper">
        <label for="ticketAttachment" class="attachment-label-btn" id="attachmentLabelBtn">
          <span class="material-symbols-outlined" id="attachmentIcon">image</span>
          <span class="attachment-label-text" id="attachmentLabelText">Adjuntar imagen (opcional)</span>
          <input 
            type="file" 
            id="ticketAttachment" 
            name="attachment" 
            accept="image/*" 
            style="display: none;" 
          />
        </label>
      </div>

      <div class="form-actions-wrapper">
        <button type="submit" class="btn-cta" id="submitReplyBtn">
          <span class="material-symbols-outlined">send</span> 
          Enviar Mensaje
        </button>
      </div>
      <div class="feedback-message hidden" id="replyFeedback"></div>
    </form>
  </div>
</div>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  function initUnifiedReplyForm() {
    const form = document.getElementById('unifiedReplyForm') as HTMLFormElement;
    if (!form) return;

    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
    const ticketId = form.dataset.id!;
    const role = form.dataset.role!;
    
    // Elementos de UI
    const fileInput = form.querySelector('#ticketAttachment') as HTMLInputElement;
    const labelBtn = form.querySelector('#attachmentLabelBtn') as HTMLElement;
    const labelText = form.querySelector('#attachmentLabelText') as HTMLElement;
    const labelIcon = form.querySelector('#attachmentIcon') as HTMLElement;
    const textArea = form.querySelector('#newMessageBody') as HTMLTextAreaElement;
    const submitBtn = form.querySelector('#submitReplyBtn') as HTMLButtonElement;
    const feedback = document.getElementById('replyFeedback') as HTMLElement;

    // ── Feedback Visual de Adjuntos ──
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) {
        labelText.textContent = file.name;
        labelBtn.classList.add('has-file');
        labelIcon.textContent = 'check_circle';
      } else {
        resetFileState();
      }
    });

    function resetFileState() {
      if (fileInput) fileInput.value = '';
      if (labelText) labelText.textContent = 'Adjuntar imagen (opcional)';
      if (labelBtn) labelBtn.classList.remove('has-file');
      if (labelIcon) labelIcon.textContent = 'image';
    }

    // ── Envío de Formulario ──
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const body = textArea.value.trim();
      if (!body) return;

      submitBtn.disabled = true;
      submitBtn.classList.add('btn-loading');

      try {
        const token = auth.currentUser ? await auth.currentUser.getIdToken() : '';
        if (!token) throw new Error("No hay sesión activa");

        const formData = new FormData();
        formData.append('body', body);
        formData.append('senderRole', role);
        if (auth.currentUser?.photoURL) {
          formData.append('senderPhotoUrl', auth.currentUser.photoURL);
        }
        if (fileInput?.files?.[0]) {
          formData.append('attachment', fileInput.files[0]);
        }

        const res = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: formData
        });
        
        if (!res.ok) {
          const errData = await res.json().catch(() => ({}));
          throw new Error(errData.message || 'Error al enviar el mensaje.');
        }

        // Éxito: Limpiar formulario
        textArea.value = '';
        resetFileState();
        
        // Notificar recarga de mensajes (evento custom para que otros componentes escuchen)
        document.dispatchEvent(new CustomEvent('ticket:message-sent', { detail: { ticketId } }));

      } catch (err: any) {
        if (window.modalHelpers) {
          window.modalHelpers.updateModalMessage('ticketResponseErrorModal', err.message);
          window.modalHelpers.openModal('ticketResponseErrorModal');
        } else {
          feedback.textContent = err.message;
          feedback.className = 'feedback-message error';
          setTimeout(() => { feedback.className = 'feedback-message hidden'; }, 4000);
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('btn-loading');
      }
    });

    // ── Manejo de Avatar ──
    onAuthStateChanged(auth, async (user) => {
      const replyAvatarContainer = document.getElementById('replyAvatarContainer');
      if (replyAvatarContainer) {
        if (user?.photoURL) {
          replyAvatarContainer.innerHTML = `<img src="${user.photoURL}" alt="Avatar" class="msg-avatar-img" />`;
        } else {
          // Fallback placeholders ya en CSS/HTML
        }
      }
    });
  }

  // Soporte para Astro View Transitions
  document.addEventListener('astro:page-load', initUnifiedReplyForm);
</script>
