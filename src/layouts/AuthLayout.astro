---
import Head from "../components/shared/Head.astro";

interface Props {
  title?: string;
  description?: string;
  forcedTheme?: 'light' | 'dark';
}
const {
  title = "Iniciar Sesión | Agencia Digital",
  description = "Panel de control y administración.",
  forcedTheme,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme={forcedTheme} data-forced-theme={forcedTheme}>
  <head>
    <Head title={title} description={description} forcedTheme={forcedTheme} />
  </head>
  <body>
    {import.meta.env.PUBLIC_GTM_ID && (
      <!-- Google Tag Manager (noscript) -->
      <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${import.meta.env.PUBLIC_GTM_ID}`}
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
      <!-- End Google Tag Manager (noscript) -->
    )}
    <!-- Sin Header ni Footer -->
    <slot />

    <script>
            document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate');
            }
          });
        }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });

        const fadeElements = document.querySelectorAll('.fade-in');
        fadeElements.forEach((el) => {
          observer.observe(el);
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            setTimeout(() => {
              el.classList.add('animate');
            }, 50);
          }
        });
      });
    </script>
  </body>
</html>
