---
import { Image } from "astro:assets";
import Logo from "../assets/img/logo-medium.png";
import ToastContainer from "../components/shared/ToastContainer.astro";
import Head from "../components/shared/Head.astro";
import AdminFooter from "../components/shared/AdminFooter.astro";
import { adminNav, clientNav } from "../data/navigation";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";

interface Props {
  title: string;
  role?: 'admin' | 'client';
  breadcrumbs?: {label: string, href?: string}[];
}

const { title, role = 'admin', breadcrumbs } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <Head title={`${title} | Gabriel Zavando`} />
</head>
<body class="dashboard-body">
  {import.meta.env.PUBLIC_GTM_ID && (
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${import.meta.env.PUBLIC_GTM_ID}`}
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
  )}
  <div class="dashboard-layout">
    <!-- Sidebar -->
    <aside id="main-sidebar" class="sidebar" transition:persist>
      <div class="sidebar-header">
        <a href={role === 'admin' ? '/admin' : '/dashboard'} class="logo">
          <Image 
            src={Logo} 
            alt="Gabriel Zavando Logo" 
            height={30}
            class="sidebar-img-logo"
          />
        </a>
        <button id="sidebarCollapseBtn" class="sidebar-collapse-btn">
          <span class="material-symbols-outlined">chevron_left</span>
        </button>
      </div>
      
      <nav class="sidebar-nav">
        {
          (role === 'admin' ? adminNav : clientNav).map((item) => {
            if (item.children) {
              return (
                <div class="nav-item-group">
                  <button class="nav-item nav-item-toggle" aria-expanded="false">
                    <span class="material-symbols-outlined">{item.icon}</span> <span class="nav-text">{item.label}</span>
                    <span class="material-symbols-outlined nav-chevron">expand_more</span>
                  </button>
                  <div class="nav-submenu">
                    {item.children.map((child) => (
                      <a href={child.href} class="nav-item sub-item">
                        <span class="material-symbols-outlined">{child.icon}</span> <span class="nav-text">{child.label}</span>
                      </a>
                    ))}
                  </div>
                </div>
              );
            }

            return (
              <a href={item.href} class="nav-item">
                <span class="material-symbols-outlined">{item.icon}</span> <span class="nav-text">{item.label}</span>
              </a>
            );
          })
        }
      </nav>

      <div class="sidebar-footer">
        <button id="logoutBtn" class="nav-item text-error">
          <span class="material-symbols-outlined">logout</span> <span class="nav-text">Cerrar Sesión</span>
        </button>
      </div>
    </aside>

    <!-- Content -->
    <main class="dashboard-content">
      <header id="main-topbar" class="topbar" transition:persist>
        <div class="topbar-left">
          <button id="sidebarToggle" class="mobile-toggle">
            <span class="material-symbols-outlined">menu</span>
          </button>
          <h2>{title}</h2>
        </div>
        <div class="topbar-right">
          <div class="topbar-actions">
            <!-- Notificaciones -->
            <div class="notifications-container">
              <button id="notificationsBtn" class="topbar-btn" aria-label="Notificaciones" aria-expanded="false" aria-haspopup="true">
                <span class="material-symbols-outlined">notifications</span>
                <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
              </button>

              <div id="notificationsDropdown" class="notifications-dropdown">
                <header class="notifications-dropdown__header">
                  <h3>Notificaciones</h3>
                </header>
                <ul class="notifications-dropdown__list" id="notificationsList">
                  <div class="notification-empty text-muted">Cargando...</div>
                </ul>
              </div>
            </div>

            <div class="user-menu-container">
            <button id="userMenuBtn" class="user-menu-btn" aria-expanded="false" aria-haspopup="true">
              <img id="userAvatar" src="https://ui-avatars.com/api/?name=User&background=random" alt="Avatar" class="user-avatar" />
              <div class="user-info-text">
                <span id="userNameDisplay" class="user-name">Cargando...</span>
                <span class="material-symbols-outlined">expand_more</span>
              </div>
            </button>

            <!-- Dropdown -->
            <div id="userDropdown" class="user-dropdown">
              <div class="dropdown-header">
                <p id="userEmailDisplay" class="text-muted">Cargando...</p>
              </div>
              <ul class="dropdown-menu">
                <li>
                  <a href={role === 'admin' ? '/admin/perfil' : '/dashboard/perfil'} class="dropdown-item">
                    <span class="material-symbols-outlined">person</span> Mi Perfil
                  </a>
                </li>
                <li>
                  <button id="theme-toggle" class="dropdown-item theme-toggle">
                    <span class="dark-icon-txt"><span class="material-symbols-outlined">light_mode</span> Modo Claro</span>
                    <span class="light-icon-txt"><span class="material-symbols-outlined">dark_mode</span> Modo Oscuro</span>
                  </button>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <button id="logoutDropdownBtn" class="dropdown-item text-error">
                    <span class="material-symbols-outlined">logout</span> Cerrar Sesión
                  </button>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </header>

      <div class="content-wrapper">
        <div class="fade-in">
          {breadcrumbs && <Breadcrumbs paths={breadcrumbs} />}
          <slot />
        </div>
      </div>

      <AdminFooter />
    </main>
  </div>

  <slot name="modals" />
  <ToastContainer />



  <script>
    import "../scripts/dashboard/init.ts";
  </script>
</body>
</html>
