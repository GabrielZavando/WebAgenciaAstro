---
import { Image } from "astro:assets";
import Logo from "../assets/img/logo-medium.png";
import ToastContainer from "../components/shared/ToastContainer.astro";
import Head from "../components/shared/Head.astro";

interface Props {
  title: string;
  role?: 'admin' | 'client';
}

const { title, role = 'admin' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <Head title={`${title} | Gabriel Zavando`} />
</head>
<body class="dashboard-body">
  <div class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href={role === 'admin' ? '/admin' : '/dashboard'} class="logo">
          <Image 
            src={Logo} 
            alt="Gabriel Zavando Logo" 
            height={30}
            class="sidebar-img-logo"
          />
        </a>
        <button id="sidebarCollapseBtn" class="sidebar-collapse-btn">
          <i class="fas fa-angle-left"></i>
        </button>
      </div>
      
      <nav class="sidebar-nav">
        <!-- Enlaces COMUNES / ADMIN -->
        {role === 'admin' && (
          <>
            <a href="/admin" class="nav-item">
              <i class="fas fa-home"></i> <span class="nav-text">Resumen</span>
            </a>
            <a href="/admin/usuarios" class="nav-item">
              <i class="fas fa-users"></i> <span class="nav-text">Usuarios</span>
            </a>
            <a href="/admin/archivos" class="nav-item">
              <i class="fas fa-folder-open"></i> <span class="nav-text">Archivos</span>
            </a>
            <a href="/admin/suscriptores" class="nav-item">
              <i class="fas fa-envelope-open-text"></i> <span class="nav-text">Suscriptores</span>
            </a>
            <a href="/admin/contacto" class="nav-item">
              <i class="fas fa-address-book"></i> <span class="nav-text">Contacto</span>
            </a>
            <div class="nav-item-group">
              <button class="nav-item nav-item-toggle" aria-expanded="false">
                <i class="fas fa-pen-nib"></i> <span class="nav-text">Blog</span>
                <i class="fas fa-chevron-down nav-chevron" style="margin-left:auto; font-size: 0.8rem; transition: transform 0.2s;"></i>
              </button>
              <div class="nav-submenu">
                <a href="/admin/blog" class="nav-item sub-item">
                  <i class="fas fa-file-alt" style="font-size: 0.85em;"></i> <span class="nav-text">Artículos</span>
                </a>
                <a href="/admin/blog/categorias" class="nav-item sub-item">
                  <i class="fas fa-tags" style="font-size: 0.85em;"></i> <span class="nav-text">Categorías</span>
                </a>
              </div>
            </div>
            <a href="/admin/tickets" class="nav-item">
              <i class="fas fa-ticket-alt"></i> <span class="nav-text">Tickets</span>
            </a>
            <a href="/admin/informes" class="nav-item">
              <i class="fas fa-file-pdf"></i> <span class="nav-text">Informes</span>
            </a>
            <a href="/admin/ideas" class="nav-item">
              <i class="fas fa-lightbulb"></i> <span class="nav-text">Ideas</span>
            </a>
          </>
        )}

        <!-- Enlaces CLIENTE -->
        {role === 'client' && (
          <>
            <a href="/dashboard" class="nav-item">
              <i class="fas fa-home"></i> <span class="nav-text">Inicio</span>
            </a>
            <a href="/dashboard/proyectos" class="nav-item">
              <i class="fas fa-tasks"></i> <span class="nav-text">Proyectos</span>
            </a>
            <a href="/dashboard/informes" class="nav-item">
              <i class="fas fa-file-pdf"></i> <span class="nav-text">Informes</span>
            </a>
            <a href="/dashboard/archivos" class="nav-item">
              <i class="fas fa-folder-open"></i> <span class="nav-text">Archivos</span>
            </a>
            <a href="/dashboard/soporte" class="nav-item">
              <i class="fas fa-headset"></i> <span class="nav-text">Soporte</span>
            </a>
            <a href="/dashboard/herramientas" class="nav-item">
              <i class="fas fa-tools"></i> <span class="nav-text">Herramientas</span>
            </a>

          </>
        )}
      </nav>

      <div class="sidebar-footer">
        <button id="logoutBtn" class="nav-item text-error">
          <i class="fas fa-sign-out-alt"></i> <span class="nav-text">Cerrar Sesión</span>
        </button>
      </div>
    </aside>

    <!-- Content -->
    <main class="dashboard-content">
      <header class="topbar">
        <div class="topbar-left">
          <button id="sidebarToggle" class="mobile-toggle">
            <i class="fas fa-bars"></i>
          </button>
          <h2>{title}</h2>
        </div>
        <div class="topbar-right">
          <div class="topbar-actions">
            <!-- Notificaciones -->
            <div class="notifications-container">
              <button id="notificationsBtn" class="topbar-btn" aria-label="Notificaciones" aria-expanded="false" aria-haspopup="true">
                <i class="fas fa-bell"></i>
                <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
              </button>

              <div id="notificationsDropdown" class="user-dropdown notifications-dropdown">
                <div class="dropdown-header" style="display: flex; justify-content: space-between; align-items: center;">
                  <p style="font-weight: 600; font-size: 0.9rem; color: var(--color-text);">Notificaciones</p>
                </div>
                <div class="notifications-list" id="notificationsList">
                  <div class="notification-empty text-muted" style="padding: 1.5rem 1rem; text-align: center; font-size: 0.85rem;">Cargando...</div>
                </div>
              </div>
            </div>

            <div class="user-menu-container">
            <button id="userMenuBtn" class="user-menu-btn" aria-expanded="false" aria-haspopup="true">
              <img id="userAvatar" src="https://ui-avatars.com/api/?name=User&background=random" alt="Avatar" class="user-avatar" />
              <div class="user-info-text">
                <span id="userNameDisplay" class="user-name">Cargando...</span>
                <i class="fas fa-chevron-down"></i>
              </div>
            </button>

            <!-- Dropdown -->
            <div id="userDropdown" class="user-dropdown">
              <div class="dropdown-header">
                <p id="userEmailDisplay" class="text-muted">Cargando...</p>
              </div>
              <ul class="dropdown-menu">
                <li>
                  <a href={role === 'admin' ? '/admin/perfil' : '/dashboard/perfil'} class="dropdown-item">
                    <i class="fas fa-user"></i> Mi Perfil
                  </a>
                </li>
                <li>
                  <button id="theme-toggle" class="dropdown-item theme-toggle">
                    <span class="dark-icon-txt"><i class="fas fa-sun"></i> Modo Claro</span>
                    <span class="light-icon-txt"><i class="fas fa-moon"></i> Modo Oscuro</span>
                  </button>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <button id="logoutDropdownBtn" class="dropdown-item text-error">
                    <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                  </button>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </header>

      <div class="content-wrapper">
        <div class="fade-in">
          <slot />
        </div>
      </div>

      <slot name="modals" />
      <ToastContainer />
    </main>
  </div>

  <style>
    .dashboard-body {
      margin: 0;
      padding: 0;
      background-color: var(--color-background);
      color: var(--color-text);
      overflow-x: hidden;
    }
    
    .dashboard-layout {
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      width: 260px;
      background-color: var(--color-surface);
      border-right: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      position: fixed;
      height: 100vh;
      z-index: 100;
      transition: width 0.3s ease, transform 0.3s ease;
      padding: 0; /* Forzar padding zero */
      overflow: hidden;
    }

    .sidebar.collapsed {
      width: 70px;
    }

    .sidebar-header {
      height: 70px;
      padding: 0 1rem;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
    }

    .sidebar.collapsed .sidebar-header {
      justify-content: center;
      padding: 0;
    }
    
    .sidebar.collapsed .logo {
      display: none;
    }

    .sidebar-collapse-btn {
      background: rgba(var(--color-primary-rgb), 0.05);
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      width: 28px;
      height: 28px;
      border-radius: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .sidebar-collapse-btn:hover {
      background: var(--color-primary);
      color: white;
      border-color: var(--color-primary);
    }
    .logo {
      display: flex;
      align-items: center;
      text-decoration: none;
    }
    .sidebar-img-logo {
      height: 30px;
      width: auto;
    }

    .sidebar-nav {
      flex: 1;
      padding: 0.5rem 0;
      overflow-y: auto;
    }

    .nav-item {
      display: flex;
      align-items: center;
      padding: 0.75rem 1rem;
      color: var(--color-text-muted);
      text-decoration: none;
      transition: all 0.2s;
      gap: 1rem;
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
      font-family: inherit;
      font-size: 1rem;
      cursor: pointer;
      white-space: nowrap;
    }

    .sidebar.collapsed .nav-item {
      justify-content: center;
      padding: 0.75rem 0;
    }

    .nav-text {
      transition: opacity 0.2s;
    }

    .sidebar.collapsed .nav-text {
      display: none;
    }

    .nav-item:hover {
      color: var(--color-primary);
      background-color: rgba(var(--color-primary-rgb), 0.1);
    }
    .nav-item i {
      width: 20px;
      text-align: center;
    }
    
    .nav-item-group {
      width: 100%;
      display: flex;
      flex-direction: column;
    }
    .nav-submenu {
      display: none;
      flex-direction: column;
      background: rgba(0,0,0,0.02);
      padding-left: 1rem;
    }
    html[data-theme='dark'] .nav-submenu { background: rgba(255,255,255,0.02); }
    .nav-submenu.open { display: flex; }
    .nav-item.sub-item {
      padding: 0.6rem 1rem;
      font-size: 0.95rem;
    }
    .nav-item-toggle[aria-expanded="true"] .nav-chevron {
      transform: rotate(180deg);
    }
    .text-error {
      color: var(--color-error);
    }
    .text-error:hover {
      color: var(--color-error);
      background-color: rgba(var(--color-error-rgb), 0.1);
    }

    .sidebar-footer {
      padding: 1rem 0;
      border-top: 1px solid var(--color-border);
    }

    /* Content Area */
    .dashboard-content {
      flex: 1;
      margin-left: 260px;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      transition: margin-left 0.3s ease;
    }

    .sidebar.collapsed + .dashboard-content {
      margin-left: 70px;
    }

    .topbar {
      height: 70px;
      background-color: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      position: sticky;
      top: 0;
      z-index: 90;
    }
    .topbar-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .topbar-btn {
      background: none;
      border: none;
      color: var(--color-text-muted);
      font-size: 1.25rem;
      cursor: pointer;
      position: relative;
      padding: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s;
    }
    .topbar-btn:hover {
      color: var(--color-primary);
    }
    .notifications-container {
      position: relative;
    }
    .notification-badge {
      position: absolute;
      top: 2px;
      right: 2px;
      min-width: 16px;
      height: 16px;
      padding: 0 4px;
      background-color: var(--color-error);
      border-radius: 8px;
      border: 2px solid var(--color-surface);
      font-size: 0.6rem;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }
    .topbar h2 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 600;
    }
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--color-text);
      font-size: 1.25rem;
      cursor: pointer;
    }

    .content-wrapper {
      width: 95%;
      max-width: 1620px;
      margin: 0 auto;
      padding: 2rem 0;
      flex: 1;
    }

    .theme-toggle {
      background: none;
      border: none;
      color: inherit;
      font-size: 1rem;
      cursor: pointer;
      padding: 0;
      transition: color 0.3s;
      width: 100%;
      text-align: left;
    }
    
    html[data-theme='dark'] .light-icon-txt { display: none; }
    html[data-theme='light'] .dark-icon-txt { display: none; }

    /* Estilos del User Dropdown */
    .user-menu-container {
      position: relative;
    }
    .user-menu-btn {
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.35rem 0.5rem;
      border-radius: var(--radius-md);
      transition: background-color 0.2s;
    }
    .user-menu-btn:hover {
      background-color: rgba(var(--color-primary-rgb), 0.05);
    }
    .user-avatar {
      width: 38px;
      height: 38px;
      border-radius: 0; /* Square design */
      object-fit: cover;
      border: 1px solid var(--color-border);
    }
    .user-info-text {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .user-info-text i {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      transition: transform 0.25s;
    }
    .user-menu-btn[aria-expanded="true"] .user-info-text i {
      transform: rotate(180deg);
    }
    
    .user-dropdown {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 240px;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      pointer-events: none;
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .user-dropdown.show {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      pointer-events: auto;
    }
    .user-dropdown.hidden {
      display: block; /* overwritten by opacity/pointer-events */
    }
    .dropdown-header {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--color-border);
    }
    .dropdown-header p {
      margin: 0;
      font-size: 0.75rem;
      word-break: break-all;
    }
    .dropdown-menu {
      list-style: none;
      margin: 0;
      padding: 0.5rem 0;
    }
    .dropdown-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1.25rem;
      color: var(--color-text);
      text-decoration: none;
      font-size: 0.95rem;
      background: none;
      border: none;
      width: 100%;
      text-align: left;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .dropdown-item:hover {
      background-color: rgba(var(--color-primary-rgb), 0.05);
      color: var(--color-primary);
    }
    .dropdown-item i {
      width: 18px;
      text-align: center;
      color: var(--color-text-muted);
    }
    .dropdown-item:hover i {
      color: inherit;
    }
    .dropdown-divider {
      height: 1px;
      background-color: var(--color-border);
      margin: 0.5rem 0;
      border: none;
    }
    .text-error {
      color: var(--color-error);
    }
    .dropdown-item.text-error:hover {
      color: var(--color-error);
      background-color: rgba(var(--color-error-rgb), 0.05);
    }

    /* Estilos del Notifications Dropdown (Contenedores estáticos) */
    .notifications-dropdown {
      width: 320px;
      right: -10px;
    }
    .notifications-list {
      max-height: 350px;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 0;
      margin: 0;
    }

    /* Estilos Globales para contenido inyectado dinámicamente */
    :global(.notification-item) {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      padding: 0.85rem 1.25rem;
      border-bottom: 1px solid var(--color-border);
      text-decoration: none;
      color: var(--color-text);
      transition: all 0.2s ease;
      cursor: pointer;
    }
    :global(.notification-item:last-child) {
      border-bottom: none;
    }
    :global(.notification-item:hover) {
      background-color: rgba(var(--color-primary-rgb), 0.08);
      transform: translateX(2px);
    }
    :global(.notification-item.unread) {
      background-color: rgba(var(--color-primary-rgb), 0.03);
      border-left: 4px solid var(--color-primary);
      padding-left: calc(1.25rem - 4px);
    }
    :global(.notification-title) {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--color-text);
      margin: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    :global(.notification-message) {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      margin: 0;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    :global(.notification-time) {
      font-size: 0.7rem;
      color: var(--color-text-muted);
      margin-top: 0.25rem;
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.open {
        transform: translateX(0);
      }
      .dashboard-content {
        margin-left: 0;
      }
      .mobile-toggle {
        display: block;
      }
    }
  </style>

  <script>
    import { auth } from "../lib/firebase/client";
    import { signOut, onAuthStateChanged } from "firebase/auth";

    // Dropdown functionality
    const userMenuBtn = document.getElementById('userMenuBtn');
    const userDropdown = document.getElementById('userDropdown');
    const userNameDisplay = document.getElementById('userNameDisplay');
    const userEmailDisplay = document.getElementById('userEmailDisplay');
    const userAvatar = document.getElementById('userAvatar') as HTMLImageElement;

    const notificationsBtn = document.getElementById('notificationsBtn');
    const notificationsDropdown = document.getElementById('notificationsDropdown');
    const notificationBadge = document.getElementById('notificationBadge');
    const notificationsList = document.getElementById('notificationsList');

    userMenuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = userMenuBtn.getAttribute('aria-expanded') === 'true';
      
      // Close notifications if open
      notificationsDropdown?.classList.remove('show');
      notificationsBtn?.setAttribute('aria-expanded', 'false');

      if (isExpanded) {
        userDropdown?.classList.remove('show');
        userMenuBtn.setAttribute('aria-expanded', 'false');
      } else {
        userDropdown?.classList.add('show');
        userMenuBtn.setAttribute('aria-expanded', 'true');
      }
    });

    notificationsBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = notificationsBtn.getAttribute('aria-expanded') === 'true';
      
      // Close user dropdown if open
      userDropdown?.classList.remove('show');
      userMenuBtn?.setAttribute('aria-expanded', 'false');

      if (isExpanded) {
        notificationsDropdown?.classList.remove('show');
        notificationsBtn.setAttribute('aria-expanded', 'false');
      } else {
        notificationsDropdown?.classList.add('show');
        notificationsBtn.setAttribute('aria-expanded', 'true');
      }
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.user-menu-container')) {
        userDropdown?.classList.remove('show');
        userMenuBtn?.setAttribute('aria-expanded', 'false');
      }
      if (!target.closest('.notifications-container')) {
        notificationsDropdown?.classList.remove('show');
        notificationsBtn?.setAttribute('aria-expanded', 'false');
      }
    });

    // Helpers para notificaciones
    const loadNotifications = async () => {
      try {
        const token = await auth.currentUser?.getIdToken();
        if (!token) return;
        
        const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
        const res = await fetch(`${API_URL}/notifications`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (res.ok) {
          const dt = await res.json();
          renderNotifications(dt);
        }
      } catch (e) {
        console.error('Error fetching notifications:', e);
      }
    };
    const renderNotifications = (notifications: any[]) => {
      if (!notificationsList) return;
      const unreadNotifications = notifications.filter((n: any) => !n.read);
      
      if (unreadNotifications.length === 0) {
        notificationsList.innerHTML = '<div class="notification-empty text-muted" style="padding: 1.5rem 1rem; text-align: center; font-size: 0.85rem;">No tienes notificaciones pendientes.</div>';
        if (notificationBadge) notificationBadge.style.display = 'none';
        return;
      }

      if (notificationBadge) {
        notificationBadge.textContent = unreadNotifications.length > 99 ? '99+' : String(unreadNotifications.length);
        notificationBadge.style.display = 'flex';
      }

      notificationsList.innerHTML = unreadNotifications.map((notif: any) => {
        let timestamp = notif.createdAt;
        if (notif.createdAt && notif.createdAt._seconds) {
          timestamp = notif.createdAt._seconds * 1000;
        }
        const d = new Date(timestamp);
        
        // Truncar mensaje si es muy largo (aunque el CSS también lo hace)
        const displayMessage = notif.message.length > 70 
          ? notif.message.substring(0, 67) + '...' 
          : notif.message;

        return `
          <a href="${notif.link || '#'}" class="notification-item unread" data-id="${notif.id}">
            <p class="notification-title">${notif.title}</p>
            <p class="notification-message">${displayMessage}</p>
            <span class="notification-time">${d.toLocaleDateString()} a las ${d.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
          </a>
        `;
      }).join('');

      // Mark as read onClick
      const items = notificationsList.querySelectorAll('.notification-item');
      items.forEach(item => {
        item.addEventListener('click', async (e) => {
          const id = item.getAttribute('data-id');
          try {
            const token = await auth.currentUser?.getIdToken();
            const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
            
            // Mark as read in DB (don't await to avoid blocking navigation)
            fetch(`${API_URL}/notifications/${id}/read`, {
              method: 'PATCH',
              headers: { 'Authorization': `Bearer ${token}` }
            });
            
            // Eliminar el elemento del DOM inmediatamente
            item.remove();
            
            // Recalcular conteo basado en lo que queda en el DOM
            const remainingCount = notificationsList.querySelectorAll('.notification-item').length;
            
            if (notificationBadge) {
              if (remainingCount > 0) {
                notificationBadge.textContent = remainingCount > 99 ? '99+' : String(remainingCount);
                notificationBadge.style.display = 'flex';
              } else {
                notificationBadge.style.display = 'none';
                notificationsList.innerHTML = '<div class="notification-empty text-muted" style="padding: 1.5rem 1rem; text-align: center; font-size: 0.85rem;">No tienes notificaciones pendientes.</div>';
              }
            }
          } catch (err) {
            console.error('Error marking notification as read:', err);
          }
        });
      });
    };

    let notifPoller: number | null = null;

    // Hydrate user data
    onAuthStateChanged(auth, (user) => {
      if (user) {
        if (userNameDisplay) userNameDisplay.textContent = user.displayName || 'Usuario';
        if (userEmailDisplay) userEmailDisplay.textContent = user.email || '';
        if (userAvatar) {
          userAvatar.src = user.photoURL 
            ? user.photoURL 
            : `https://ui-avatars.com/api/?name=${encodeURIComponent(user.displayName || user.email || 'U')}&background=random`;
        }
        
        loadNotifications();
        if (notifPoller === null) {
           notifPoller = window.setInterval(loadNotifications, 60000); // refresh every min
        }
      } else {
        if (notifPoller !== null) {
          window.clearInterval(notifPoller);
          notifPoller = null;
        }
      }
    });

    // Logout
    const handleLogout = async () => {
      try {
        await signOut(auth);
        window.location.href = '/login';
      } catch (error) {
        console.error('Error cerrando sesión', error);
      }
    };

    const logoutBtn = document.getElementById('logoutBtn');
    const logoutDropdownBtn = document.getElementById('logoutDropdownBtn');
    logoutBtn?.addEventListener('click', handleLogout);
    logoutDropdownBtn?.addEventListener('click', handleLogout);

    // Mobile Sidebar Toggle
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebar = document.querySelector('.sidebar');
    sidebarToggle?.addEventListener('click', () => {
      sidebar?.classList.toggle('open');
    });

    // Sidebar Collapse Logic
    const collapseBtn = document.getElementById('sidebarCollapseBtn');
    const icon = collapseBtn?.querySelector('i');
    
    const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
    if (isCollapsed && sidebar) {
      sidebar.classList.add('collapsed');
      if (icon) {
        icon.classList.remove('fa-angle-left');
        icon.classList.add('fa-angle-right');
      }
    }

    collapseBtn?.addEventListener('click', () => {
      sidebar?.classList.toggle('collapsed');
      const nowCollapsed = sidebar?.classList.contains('collapsed');
      localStorage.setItem('sidebar-collapsed', String(nowCollapsed));
      
      if (icon) {
        if (nowCollapsed) {
          icon.classList.remove('fa-angle-left');
          icon.classList.add('fa-angle-right');
        } else {
          icon.classList.remove('fa-angle-right');
          icon.classList.add('fa-angle-left');
        }
      }
    });

    // Theme Toggle
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle?.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
    });

    // Logic for submenus
    const navToggles = document.querySelectorAll('.nav-item-toggle');
    navToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const submenu = toggle.nextElementSibling as HTMLElement;
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isExpanded));
        submenu?.classList.toggle('open');
      });
    });

    // Marcar item activo según la URL
    const currentPath = window.location.pathname;
    const navItems = document.querySelectorAll('.nav-item') as NodeListOf<HTMLElement>;
    
    navItems.forEach(item => {
      const href = item.getAttribute('href');
      if (!href) return;

      // Coincidencia exacta para las rutas base o si es la ruta actual
      const isExactMatch = currentPath === href;
      // Coincidencia de subruta (evitando que /dashboard coincida con /dashboard/archivos si no es exacto)
      const isSubPathMatch = href !== '/admin' && href !== '/dashboard' && href !== '/' && currentPath.startsWith(href) && !item.classList.contains('nav-item-toggle');

      if (isExactMatch || isSubPathMatch) {
        item.style.color = 'var(--color-primary)';
        item.style.backgroundColor = 'rgba(var(--color-primary-rgb), 0.1)';
        item.style.fontWeight = '600';
        
        // Auto-open parent submenu if active
        const parentSubmenu = item.closest('.nav-submenu');
        if (parentSubmenu) {
          parentSubmenu.classList.add('open');
          const toggle = parentSubmenu.previousElementSibling;
          if (toggle) toggle.setAttribute('aria-expanded', 'true');
        }
      } else {
        // Limpiar estilos si no coincide
        item.style.color = '';
        item.style.backgroundColor = '';
        item.style.fontWeight = '';
      }
    });

    // Fade-in effect
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('.fade-in');
      setTimeout(() => {
        elements.forEach(el => el.classList.add('animate'));
      }, 50);
    });
    // Global Select Icon Rotation Logic
    // Uses mousedown to set the open class BEFORE the native OS dropdown opens.
    // Uses blur (triggered by change or external click) to remove it.
    function bindSelectRotation(sel: HTMLSelectElement) {
      if (sel.dataset.rotationBound) return;
      sel.dataset.rotationBound = 'true';

      const wrapper = sel.closest<HTMLElement>('.input-with-icon, .select-wrapper');
      if (!wrapper) return;

      // Mark as open on mousedown — fires before the native dropdown
      sel.addEventListener('mousedown', () => {
        wrapper.classList.toggle('is-open');
      });

      // Always close on blur (handles change & external click)
      sel.addEventListener('blur', () => {
        wrapper.classList.remove('is-open');
      });
    }

    // Bind all selects inside wrappers at load and on any future DOM changes
    function bindAllSelects() {
      document.querySelectorAll<HTMLSelectElement>('.input-with-icon select, .select-wrapper select')
        .forEach(bindSelectRotation);
    }

    bindAllSelects();

    // Observe late-injected dynamic selects (e.g. populated via JS)
    const observer = new MutationObserver(() => bindAllSelects());
    observer.observe(document.body, { childList: true, subtree: true });
  </script>
</body>
</html>
