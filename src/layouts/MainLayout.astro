---
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import Head from "../components/shared/Head.astro";
import { getSystemConfig } from "../utils/config";

const config = await getSystemConfig();

interface Props {
  title?: string;
  description?: string;
  alwaysScrolledNav?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
  forcedTheme?: 'light' | 'dark';
}
const {
  title = config.name,
  description = config.description,
  alwaysScrolledNav = false,
  hideHeader = false,
  hideFooter = false,
  forcedTheme,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <Head title={title} description={description} faviconUrl={config.faviconUrl} forcedTheme={forcedTheme} />
    {/* Cloudflare Turnstile - Centralizado */}
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>
  <body>
    {import.meta.env.PUBLIC_GTM_ID && (
      <!-- Google Tag Manager (noscript) -->
      <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${import.meta.env.PUBLIC_GTM_ID}`}
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
      <!-- End Google Tag Manager (noscript) -->
    )}
    {!hideHeader && <Header alwaysScrolled={alwaysScrolledNav} config={config} />}
    <slot />
    {!hideFooter && <Footer config={config} />}
    {!hideFooter && (
      <button id="scroll-top" class="btn-up" aria-label="Volver arriba">
        <span class="material-symbols-outlined">north</span>
      </button>
    )}

    <!-- Scripts -->
    <script>
      function initLayout() {
        // Scroll top button
        const scrollBtn = document.getElementById('scroll-top');
        if (scrollBtn) {
          // Limpiar listener global previo si existe para evitar duplicados en SPA
          window.removeEventListener('scroll', (window as any)._scrollHandler);
          (window as any)._scrollHandler = () => {
            if (window.scrollY > 200) scrollBtn.classList.add('visible');
            else scrollBtn.classList.remove('visible');
          };
          window.addEventListener('scroll', (window as any)._scrollHandler);
          
          scrollBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
            scrollBtn.classList.remove('visible');
          });
        }

        // Sistema unificado de animaciones fade-in
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate');
            }
          });
        }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });

        // Observar todos los elementos con fade-in
        const fadeElements = document.querySelectorAll('.fade-in');
        fadeElements.forEach((el) => {
          observer.observe(el);
          
          // Si está visible al cargar, animar inmediatamente respetando delays
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            // Forzar un pequeño delay para que CSS transitions funcionen
            setTimeout(() => {
              el.classList.add('animate');
            }, 50);
          }
        });
      }

      // Ejecutar en la carga inicial
      document.addEventListener('DOMContentLoaded', initLayout);
      // Ejecutar en cada navegación con View Transitions
      document.addEventListener('astro:page-load', initLayout);
    </script>
  </body>
</html>
