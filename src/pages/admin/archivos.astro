---
import AdminLayout from '../../layouts/AdminLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
---

<AdminLayout title="Archivos">
  <div class="files-page">
    <div class="page-header">
      <h1>Gestión de Archivos</h1>
      <p class="sub">Sube y administra tus archivos. El almacenamiento es ilimitado para administradores.</p>
    </div>

    <!-- Info Storage Banner -->
    <div class="storage-banner" id="storageBanner">
      <div class="storage-info">
        <i class="fas fa-database"></i>
        <div class="storage-texts">
          <span class="storage-title">Almacenamiento Global</span>
          <span id="storageText" class="storage-desc">Cargando datos...</span>
        </div>
      </div>
    </div>

    <!-- Controles (Buscador y Subir) -->
    <div class="actions-row">
      <div class="search-wrap">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por título, nombre o descripción..." autocomplete="off" />
      </div>
      <button class="btn-upload" id="uploadBtn">
        <i class="fas fa-cloud-upload-alt"></i> Subir Archivo
      </button>
    </div>

    <!-- Modal de subida -->
    <div class="upload-modal hidden" id="uploadModal">
      <div class="modal-bg" id="modalBg"></div>
      <div class="modal-box">
        <div class="modal-top">
          <h3><i class="fas fa-file-upload"></i> Nuevo Archivo</h3>
          <button class="modal-x" id="closeModal">&times;</button>
        </div>
        <form id="uploadForm" class="uf">
          <div class="fg">
            <label for="fTitle">Título</label>
            <input type="text" id="fTitle" name="title" required placeholder="Nombre descriptivo" />
          </div>
          <div class="fg">
            <label for="fDesc">Descripción (opcional)</label>
            <input type="text" id="fDesc" name="description" placeholder="Información adicional" />
          </div>
          <div class="fg">
            <label>Seleccionar Archivo</label>
            <div class="file-drop" id="fileDrop">
              <i class="fas fa-cloud-upload-alt"></i>
              <p id="fileLabel">Arrastra o haz clic aquí</p>
              <span class="ft">PDF, Word, Excel, Imágenes, CSV, TXT</span>
              <input type="file" id="fileInput" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.webp,.txt,.csv" required class="fih" />
            </div>
          </div>
          <div id="fb" class="fb hidden"></div>
          <div class="fa">
            <button type="submit" class="btn-primary" id="submitUpload">
              <span class="bt">Subir Archivo</span>
              <span class="ld hidden"></span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Tabla de lista de archivos -->
    <div class="table-container">
      <table class="files-table">
        <thead>
          <tr>
            <th class="col-type">Tipo</th>
            <th class="col-name">Nombre</th>
            <th class="col-size">Tamaño</th>
            <th class="col-date">Fecha de carga</th>
            <th class="col-actions">Acciones</th>
          </tr>
        </thead>
        <tbody id="filesListBody">
          <tr>
            <td colspan="5">
              <div class="ls">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Cargando archivos del servidor...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const tableBody = document.getElementById('filesListBody');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const storageText = document.getElementById('storageText');

  interface FileItem {
    id: string;
    title: string;
    description: string;
    fileName: string;
    mimeType: string;
    size: number;
    createdAt: { _seconds?: number } | string;
  }

  let allFiles: FileItem[] = [];
  let token = '';

  onAuthStateChanged(auth, async (u) => {
    if (!u) return;
    token = await u.getIdToken();
    await Promise.all([loadQuota(), loadFiles()]);
  });

  async function loadQuota() {
    try {
      const r = await fetch(`${API}/files/storage/quota`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      const q = await r.json();
      if (storageText) storageText.innerHTML = `<strong>${q.usedFormatted}</strong> utilizados en total`;
    } catch {
      if (storageText) storageText.textContent = 'Error al cargar estadísticas';
    }
  }

  async function loadFiles() {
    try {
      const r = await fetch(`${API}/files`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      allFiles = await r.json();
      renderFiles(allFiles);
    } catch {
      if (tableBody) tableBody.innerHTML = `<tr><td colspan="4"><div class="es"><i class="fas fa-exclamation-triangle"></i><p>Error cargando archivos del servidor.</p></div></td></tr>`;
    }
  }

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    if (!q) { renderFiles(allFiles); return; }
    renderFiles(allFiles.filter(f => 
      f.title.toLowerCase().includes(q) || 
      f.fileName.toLowerCase().includes(q) || 
      (f.description && f.description.toLowerCase().includes(q))
    ));
  });

  function renderFiles(files: FileItem[]) {
    if (!tableBody) return;
    if (!files.length) {
      tableBody.innerHTML = `<tr><td colspan="5"><div class="es"><i class="fas fa-folder-open"></i><h3>Sin archivos</h3><p>No hay archivos almacenados actualmente.</p></div></td></tr>`;
      return;
    }

    tableBody.innerHTML = files.map(f => `
      <tr class="file-row">
        <td class="col-type-data">
          ${getIcon(f.mimeType)}
        </td>
        <td class="col-name-data">
          <div class="name-wrapper">
            <span class="file-title" title="${f.title}">${f.title}</span>
            ${f.title !== f.fileName ? `<span class="file-name-sub">(${f.fileName})</span>` : ''}
          </div>
        </td>
        <td class="col-size-data">
          ${fmtSize(f.size)}
        </td>
        <td class="col-date-data">
          ${fmtDate(f.createdAt)}
        </td>
        <td class="col-actions-data">
          <div class="td-actions">
            <button class="btn-action vb" data-id="${f.id}" title="Ver"><i class="fas fa-eye"></i></button>
            <button class="btn-action db" data-id="${f.id}" title="Descargar"><i class="fas fa-download"></i></button>
            <button class="btn-action xb" data-id="${f.id}" title="Eliminar permanentemente"><i class="fas fa-trash-alt"></i></button>
          </div>
        </td>
      </tr>
    `).join('');

    tableBody.querySelectorAll('.vb').forEach(b => b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'view')));
    tableBody.querySelectorAll('.db').forEach(b => b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'download')));
    tableBody.querySelectorAll('.xb').forEach(b => b.addEventListener('click', () => handleDelete(b.getAttribute('data-id')!)));
  }

  async function handleDl(id: string, action: 'view' | 'download') {
    try {
      const r = await fetch(`${API}/files/${id}/download`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      const { url, fileName } = await r.json();
      if (action === 'view') { window.open(url, '_blank'); } 
      else {
        const a = document.createElement('a');
        a.href = url; a.download = fileName; a.target = '_blank';
        document.body.appendChild(a); a.click(); a.remove();
      }
    } catch { alert('Error obteniendo el archivo.'); }
  }

  async function handleDelete(id: string) {
    if (!confirm('¿Estás seguro de eliminar este archivo permanentemente?')) return;
    try {
      const r = await fetch(`${API}/files/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${token}` } });
      if (!r.ok) throw new Error();
      await Promise.all([loadQuota(), loadFiles()]);
    } catch { alert('Error al eliminar archivo.'); }
  }

  // --- Modal de Subida ---
  const um = document.getElementById('uploadModal');
  const ub = document.getElementById('uploadBtn');
  const cm = document.getElementById('closeModal');
  const mb = document.getElementById('modalBg');
  const uf = document.getElementById('uploadForm') as HTMLFormElement;
  const su = document.getElementById('submitUpload') as HTMLButtonElement;
  const fb = document.getElementById('fb');
  const fin = document.getElementById('fileInput') as HTMLInputElement;
  const fl = document.getElementById('fileLabel');
  const fd = document.getElementById('fileDrop');

  ub?.addEventListener('click', () => um?.classList.remove('hidden'));
  cm?.addEventListener('click', cu);
  mb?.addEventListener('click', cu);

  function cu() {
    um?.classList.add('hidden');
    uf?.reset();
    if (fl) fl.textContent = 'Arrastra o haz clic aquí';
    fd?.classList.remove('has-file');
    if (fb) fb.className = 'fb hidden';
  }

  fin?.addEventListener('change', () => {
    if (fin.files?.length && fl) {
      fl.textContent = fin.files[0].name;
      fd?.classList.add('has-file');
    }
  });

  fd?.addEventListener('dragover', e => { e.preventDefault(); fd.classList.add('drag-over'); });
  fd?.addEventListener('dragleave', () => fd?.classList.remove('drag-over'));
  fd?.addEventListener('drop', e => {
    e.preventDefault(); fd?.classList.remove('drag-over');
    const f = e.dataTransfer?.files;
    if (f?.length && fin) {
      fin.files = f;
      if (fl) fl.textContent = f[0].name;
      fd?.classList.add('has-file');
    }
  });

  uf?.addEventListener('submit', async e => {
    e.preventDefault();
    if (!su || !fb) return;
    const title = (document.getElementById('fTitle') as HTMLInputElement).value;
    const desc = (document.getElementById('fDesc') as HTMLInputElement).value;
    const file = fin?.files?.[0];
    if (!file) {
      fb.textContent = 'Selecciona un archivo válido';
      fb.className = 'fb error';
      return;
    }

    su.disabled = true;
    su.querySelector('.bt')?.classList.add('hidden');
    su.querySelector('.ld')?.classList.remove('hidden');

    try {
      const fData = new FormData();
      fData.append('file', file);
      fData.append('title', title);
      fData.append('description', desc);
      
      const r = await fetch(`${API}/files`, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` }, body: fData });
      if (!r.ok) {
        const e2 = await r.json();
        throw new Error(e2.message || 'Error en el servidor');
      }
      
      fb.textContent = '¡Archivo subido con éxito!';
      fb.className = 'fb success';
      setTimeout(cu, 1200);
      await Promise.all([loadQuota(), loadFiles()]);
    } catch (err: unknown) {
      fb.textContent = err instanceof Error ? err.message : 'Error desconocido';
      fb.className = 'fb error';
    } finally {
      su.disabled = false;
      su.querySelector('.bt')?.classList.remove('hidden');
      su.querySelector('.ld')?.classList.add('hidden');
    }
  });

  function getIcon(m: string): string {
    if (m.includes('pdf')) return '<i class="fas fa-file-pdf" style="color:#ef4444"></i>';
    if (m.includes('image')) return '<i class="fas fa-file-image" style="color:#3b82f6"></i>';
    if (m.includes('word') || m.includes('document')) return '<i class="fas fa-file-word" style="color:#2563eb"></i>';
    if (m.includes('sheet') || m.includes('excel')) return '<i class="fas fa-file-excel" style="color:#22c55e"></i>';
    if (m.includes('csv')) return '<i class="fas fa-file-csv" style="color:#f59e0b"></i>';
    return '<i class="fas fa-file-alt" style="color:#9ca3af"></i>';
  }
  function fmtDate(raw: { _seconds?: number } | string): string {
    let d: Date;
    if (typeof raw === 'string') d = new Date(raw);
    else if (raw?._seconds) d = new Date(raw._seconds * 1000);
    else return '-';
    
    const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
    return `${d.getDate()}, ${months[d.getMonth()]}, ${d.getFullYear()}`;
  }
  function fmtSize(b: number): string {
    if (!b) return '-';
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(1) + ' MB';
  }
</script>

<style>
  .files-page { max-width: 1000px; margin: 0 auto; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin: 0 0 0.5rem; font-size: 2rem; color: #f9fafb; font-weight: 700; }
  .sub { color: #9ca3af; margin: 0; font-size: 1.05rem; }

  /* Info Banner */
  .storage-banner { background: #1f2937; border: 1px solid #374151; border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
  .storage-info { display: flex; align-items: center; gap: 1rem; color: #e5e7eb; }
  .storage-info i { color: #ec4899; font-size: 1.75rem; background: rgba(236,72,153,0.1); padding: 0.75rem; border-radius: 8px; }
  .storage-texts { display: flex; flex-direction: column; }
  .storage-title { font-size: 0.85rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .storage-desc { font-size: 1.1rem; color: #f9fafb; margin-top: 0.2rem; }

  /* Controles (Buscador y Subir) */
  .actions-row { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: stretch; justify-content: space-between; }
  .search-wrap { flex: 1; max-width: 450px; position: relative; }
  .search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: #9ca3af; }
  .search-wrap input {
    width: 100%; padding: 0.875rem 1.2rem 0.875rem 3rem; border: 1px solid #374151;
    border-radius: 8px; background: #1f2937; color: #f9fafb;
    font-family: inherit; font-size: 0.95rem; box-sizing: border-box; transition: all 0.2s;
  }
  .search-wrap input:focus { outline: none; border-color: #ec4899; box-shadow: 0 0 0 3px rgba(236,72,153, 0.15); }
  
  .btn-upload {
    padding: 0 1.75rem; background: #ec4899; color: #fff; border: none;
    border-radius: 8px; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 0.6rem; font-size: 0.95rem; white-space: nowrap; transition: all 0.2s;
  }
  .btn-upload:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 12px rgba(236,72,153, 0.2); }

  /* Tabla de Archivos (Premium Dark UI) */
  .table-container {
    background: #1f2937;
    border: 1px solid #374151;
    border-radius: 12px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  
  .table-container table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  /* Cabeceras */
  .files-table thead {
    background: #111827;
    border-bottom: 1px solid #374151;
  }
  .files-table th {
    padding: 1.25rem 1.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-right: 1px solid #374151;
    vertical-align: middle;
  }
  .files-table th:last-child { border-right: none; }
  
  /* Celdas */
  .files-table :global(td) {
    padding: 1.5rem;
    border-bottom: 1px solid #374151;
    border-right: 1px solid #374151;
    vertical-align: middle;
  }
  .files-table :global(td:last-child) { border-right: none; }
  .files-table :global(tbody tr:last-child td) {
    border-bottom: none;
  }
  .files-table :global(tbody tr) {
    transition: background-color 0.2s;
  }
  .files-table :global(tbody tr:hover) {
    background-color: rgba(255,255,255,0.02);
  }

  /* Anchos de columnas */
  .col-type { width: 80px; text-align: center; }
  .col-name { width: auto; }
  .col-size { width: 12%; text-align: center; }
  .col-date { width: 18%; text-align: center; }
  .col-actions { width: 120px; text-align: center; }

  /* Fila principal (icono + info) */
  .files-table :global(.col-type-data) { text-align: center; font-size: 1.6rem; vertical-align: middle; }
  
  .files-table :global(.col-name-data) { vertical-align: middle; }
  .files-table :global(.name-wrapper) { display: flex; flex-direction: column; }
  .files-table :global(.file-title) {
    font-weight: 500;
    font-size: 1rem;
    color: #f9fafb;
  }
  .files-table :global(.file-name-sub) {
    font-size: 0.8rem;
    color: #9ca3af;
  }
  
  /* Textos secundarios */
  .files-table :global(.col-size-data), .files-table :global(.col-date-data) { text-align: center; color: #e5e7eb; font-size: 0.95rem; vertical-align: middle; }

  /* Acciones */
  .files-table :global(.col-actions-data) { text-align: center; vertical-align: middle; }
  .files-table :global(.td-actions) {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
  }
  .files-table :global(.btn-action) {
    background: transparent;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.25rem;
    transition: color 0.2s, transform 0.2s;
  }
  .files-table :global(.btn-action:hover) {
    transform: scale(1.1);
  }
  .files-table :global(.vb:hover) { color: #3b82f6; }
  .files-table :global(.db:hover) { color: #22c55e; }
  .files-table :global(.xb:hover) { color: #ef4444; }

  /* Estados vacíos y carga */
  .files-table :global(.ls), .files-table :global(.es) {
    text-align: center;
    padding: 5rem 2rem;
    color: #9ca3af;
  }
  .files-table :global(.ls i), .files-table :global(.es i) {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    display: block;
    opacity: 0.5;
  }
  .files-table :global(.es h3) { margin: 0 0 0.5rem; color: #f9fafb; font-size: 1.25rem; font-weight: 600; }
  .files-table :global(.es p) { margin: 0; font-size: 0.95rem; }

  /* Modal de Subida */
  .upload-modal { position: fixed; inset: 0; z-index: 200; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .upload-modal.hidden { display: none; }
  .modal-bg { position: absolute; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); }
  .modal-box { position: relative; background: #1f2937; border: 1px solid #374151; border-radius: 12px; width: 100%; max-width: 500px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); overflow: hidden; }
  
  .modal-top { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-bottom: 1px solid #374151; background: #111827; }
  .modal-top h3 { margin: 0; font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.75rem; color: #f9fafb; }
  .modal-top i { color: #ec4899; }
  .modal-x { background: none; border: none; color: #9ca3af; font-size: 1.75rem; cursor: pointer; line-height: 1; padding: 0; transition: color 0.2s; }
  .modal-x:hover { color: #f9fafb; }
  
  .uf { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .fg { display: flex; flex-direction: column; gap: 0.5rem; }
  .fg label { font-weight: 600; font-size: 0.95rem; color: #e5e7eb; }
  .uf input[type="text"] { padding: 0.875rem 1rem; border: 1px solid #374151; border-radius: 8px; background: #111827; color: #f9fafb; font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s; }
  .uf input[type="text"]:focus { outline: none; border-color: #ec4899; box-shadow: 0 0 0 3px rgba(236,72,153, 0.15); }
  
  .file-drop { border: 2px dashed #374151; border-radius: 8px; padding: 2.5rem 1.5rem; text-align: center; cursor: pointer; position: relative; transition: all 0.2s; background: #111827; }
  .file-drop i { font-size: 2.5rem; margin-bottom: 1rem; display: block; color: #9ca3af; opacity: 0.6; transition: color 0.2s; }
  .file-drop p { margin: 0; font-size: 1.05rem; font-weight: 500; color: #f9fafb; }
  .ft { font-size: 0.8rem; color: #9ca3af; margin-top: 0.75rem; display: block; }
  .file-drop:hover, .file-drop.drag-over { border-color: #ec4899; background: rgba(236,72,153, 0.05); }
  .file-drop:hover i, .file-drop.drag-over i { color: #ec4899; opacity: 1; transform: scale(1.05); }
  .file-drop.has-file { border-color: #22c55e; background: rgba(34,197,94,0.05); }
  .file-drop.has-file i { color: #22c55e; opacity: 1; }
  .fih { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  
  .fa { display: flex; justify-content: flex-end; margin-top: 0.5rem; }
  .fb { padding: 0.875rem; border-radius: 8px; text-align: center; font-weight: 500; font-size: 0.95rem; }
  .fb.error { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
  .fb.success { background: rgba(34,197,94,0.1); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
  .hidden { display: none !important; }
  .ld { width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3); border-bottom-color: #fff; border-radius: 50%; display: inline-block; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Responsive */
  @media (max-width: 768px) {
    .actions-row { flex-direction: column; }
    .search-wrap { max-width: 100%; }
    .btn-upload { justify-content: center; }
    
    .files-table thead { display: none; }
    .files-table, .files-table :global(tbody), .files-table :global(tr), .files-table :global(td) { display: block; width: 100%; }
    .files-table :global(tr) {
      border-bottom: 2px solid #374151;
      padding: 1.25rem;
      position: relative;
    }
    .files-table :global(td) {
      padding: 0.35rem 0;
      border: none;
    }
    .files-table :global(.col-actions-data) {
      margin-top: 1rem;
      padding-top: 1rem !important;
      border-top: 1px solid #374151 !important;
    }
    .files-table :global(.td-actions) { justify-content: flex-start; }
    .files-table :global(.btn-action) { width: auto; padding: 0 1.5rem; height: 42px; }
  }
</style>
