---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import FileManager from '../../../components/shared/FileManager.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout 
  title="Archivos del Sistema" 
  breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Archivos' }]} 
  role="admin"
>
  <FileManager 
    role="admin" 
    limitGB={30} 
    title="Archivos del Sistema"
    description="Despídase del desorden. Visualiza, sube y administra tus archivos personales."
  />
</DashboardLayout>
