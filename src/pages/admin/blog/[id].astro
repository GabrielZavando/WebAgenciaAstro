---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
const isNew = id === 'new';
const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let post = null;
let errorMsg = null;
let initialPublishedAt = '';

if (!isNew) {
  try {
    const response = await fetch(`${API_URL}/blog/${id}`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });

    if (response.ok) {
      post = await response.json();
      
      // Format the date for the datetime-local input safely
      if (post?.publishedAt) {
        try {
           const dateVal = post.publishedAt._seconds ? new Date(post.publishedAt._seconds * 1000) : new Date(post.publishedAt);
           if (!isNaN(dateVal.getTime())) {
               const tzoffset = (new Date()).getTimezoneOffset() * 60000;
               initialPublishedAt = (new Date(dateVal.getTime() - tzoffset)).toISOString().slice(0, 16);
           }
        } catch (e) {}
      }
    } else {
      errorMsg = `Error al cargar datos: ${response.statusText}`;
    }
  } catch (e) {
    errorMsg = "No se pudo conectar con el servidor.";
  }
}

// Fetch all categories to populate the select dropdown
let categories: { id: string, name: string }[] = [];
try {
  const allCatsRes = await fetch(`${API_URL}/blog-categories`, {
    headers: { 'Authorization': `Bearer ${token}` }
  });
  if (allCatsRes.ok) {
    categories = await allCatsRes.json();
  }
} catch (e) {
  console.error("Error fetching categories:", e);
}
---

<DashboardLayout title={isNew ? "Nuevo Artículo" : `Editar Artículo: ${post?.title || ''}`} role="admin">
  <div class="header-actions">
    <a href="/admin/blog" class="back-link">
      <i class="fas fa-arrow-left"></i> Volver al Blog
    </a>
    <h2>{isNew ? "Crear Nuevo Artículo" : `Editar Artículo: ${post?.title || ''}`}</h2>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <i class="fas fa-exclamation-triangle"></i> {errorMsg}
    </div>
  )}

  {(!errorMsg && (isNew || post)) && (
    <div class="content-card fade-in">
      <form id="postForm" class="post-form" data-postid={!isNew ? id : ''} data-isnew={isNew ? 'true' : 'false'}>
        <div class="form-row">
          <div class="form-group">
            <label for="title">Título <span class="required">*</span></label>
            <input type="text" id="title" name="title" required placeholder="Título del post" value={post?.title || ''} />
          </div>

          <div class="form-group">
            <label for="slug">Slug (URL) <span class="required">*</span></label>
            <input type="text" id="slug" name="slug" required placeholder="titulo-del-post" value={post?.slug || ''} />
          </div>
        </div>

        <div class="form-group">
          <label for="content">Contenido <span class="required">*</span></label>
          <div id="editor-container" style="height: 400px; background: var(--color-background); border-bottom-left-radius: var(--radius-md); border-bottom-right-radius: var(--radius-md);"></div>
          <input type="hidden" id="content" name="content" required value={post?.content || ''} />
        </div>

        <div class="form-row">
          <div class="form-group" style="flex: 1.5;">
            <label>Imagen de Portada</label>
            <div class="image-upload-container">
              <input type="hidden" id="coverImage" name="coverImage" value={post?.coverImage || ''} />
              <div id="imagePreview" class="image-preview" style={post?.coverImage ? "display: block;" : "display: none;"}>
                <img id="previewImg" src={post?.coverImage || ''} alt="Portada" />
                <button type="button" id="removeImageBtn" class="remove-image" title="Eliminar imagen"><i class="fas fa-times"></i></button>
              </div>
              <div id="imageControls" class="image-controls" style={post?.coverImage ? "display: none;" : "display: flex; gap: 0.5rem; height: 100%;"}>
                <button type="button" id="selectFileBtn" class="btn btn-cta" style="border-radius: 0; padding: 0.75rem 1.5rem; white-space: nowrap; min-height: calc(1.5rem + 1.5rem + 2px);"><i class="fas fa-images"></i> Biblioteca</button>
                <button type="button" id="uploadFileBtn" class="btn btn-ghost" style="background: transparent; color: var(--color-text); border-radius: 0; padding: 0.75rem 1.5rem; border: 1px solid var(--color-border); white-space: nowrap; min-height: calc(1.5rem + 1.5rem + 2px); transition: border-color 0.2s;"><i class="fas fa-upload"></i> Subir Imagen</button>
                <input type="file" id="coverImageFile" accept="image/*" style="display: none;" />
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="author">Autor</label>
            <input type="text" id="author" name="author" placeholder="Ej: Juan Pérez" value={post?.author || ''} />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="category">Categoría</label>
            <div class="input-with-icon">
              <select id="category" name="category" required>
                <option value="" disabled selected={!post?.category}>Selecciona una categoría</option>
                {categories.map((cat) => (
                  <option value={cat.name} selected={post?.category === cat.name}>{cat.name}</option>
                ))}
              </select>
              <i class="fas fa-chevron-down icon-select"></i>
            </div>
          </div>

          <div class="form-group">
            <label for="publishedAt">Fecha de Publicación</label>
            <input type="datetime-local" id="publishedAt" name="publishedAt" value={initialPublishedAt} />
          </div>
        </div>

        <div class="form-group toggle-group">
          <label class="toggle">
            <input type="checkbox" id="published" name="published" value="true" checked={post ? post.published : false} />
            <span class="label-text">Publicado (Visible al público)</span>
          </label>
        </div>

        <div id="formFeedback" class="feedback-message hidden"></div>

        <div class="form-actions" style="justify-content: space-between;">
          <div class="left-actions">
            {!isNew && (
              <button type="button" class="btn btn-danger" id="deleteBtn" style="background: var(--color-error); color: white; padding: 0.875rem 2rem; border: none; border-radius: 0; font-weight: 600; cursor: pointer;">
                <i class="fas fa-trash-alt"></i> Eliminar Post
              </button>
            )}
          </div>
          <div class="right-actions">
            <button type="submit" class="btn-primary" id="submitBtn">
              <span class="btn-text">{isNew ? 'Crear Post' : 'Guardar Cambios'}</span>
            </button>
          </div>
        </div>
      </form>
    </div>
  )}

  <!-- Modal Selector de Imágenes -->
  <div id="imageSelectModal" class="modal-backdrop hidden">
    <div class="modal-content">
      <div class="modal-header">
        <h3><i class="fas fa-images"></i> Seleccionar Imagen de Portada</h3>
        <button type="button" class="modal-close" id="closeImageModal">&times;</button>
      </div>
      <div class="modal-body">
        <div class="search-bar">
          <i class="fas fa-search"></i>
          <input type="text" id="imageSearchInput" placeholder="Buscar imagen por nombre..." />
        </div>
        <div id="imageGallery" class="image-gallery">
          <div class="loading-state">
            <i class="fas fa-spinner fa-spin"></i> Cargando imágenes...
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import Quill from 'quill';
  import 'quill/dist/quill.snow.css';

  const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';
  const form = document.getElementById('postForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const deleteBtn = document.getElementById('deleteBtn') as HTMLButtonElement;
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;
  const contentInput = document.getElementById('content') as HTMLInputElement;
  const feedback = document.getElementById('formFeedback');

  if (form) {
    const isNew = form.dataset.isnew === 'true';
    const postId = form.dataset.postid;

    const quill = new Quill('#editor-container', {
      theme: 'snow',
      placeholder: 'Escribe el contenido HTML enriquecido aquí...',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike', 'blockquote'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          [{ 'color': [] }, { 'background': [] }],
          ['link', 'image', 'video'],
          ['clean']
        ]
      }
    });

    if (contentInput.value) {
      quill.root.innerHTML = contentInput.value;
    }

    quill.on('text-change', () => {
      contentInput.value = quill.root.innerHTML === '<p><br></p>' ? '' : quill.root.innerHTML;
    });

    // Auto-generate slug on blur (only if not manually edited)
    let manualSlugEdit = false;
    
    slugInput?.addEventListener('input', () => {
      manualSlugEdit = true;
    });

    titleInput?.addEventListener('blur', () => {
      if (titleInput.value && !manualSlugEdit && !slugInput.value) {
        slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
      }
    });

    if (isNew) {
      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (currentUser) {
           const authorInput = document.getElementById('author') as HTMLInputElement;
           if(authorInput && !authorInput.value) {
               authorInput.value = currentUser.displayName || currentUser.email?.split('@')[0] || 'Admin';
           }
        }
      });
    }

    // Image upload and select logic
    const coverImageInput = document.getElementById('coverImage') as HTMLInputElement;
    const coverImageFileInput = document.getElementById('coverImageFile') as HTMLInputElement;
    const imagePreview = document.getElementById('imagePreview') as HTMLDivElement;
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;
    const removeImageBtn = document.getElementById('removeImageBtn') as HTMLButtonElement;
    const imageControls = document.getElementById('imageControls') as HTMLDivElement;
    const uploadFileBtn = document.getElementById('uploadFileBtn') as HTMLButtonElement;
    const selectFileBtn = document.getElementById('selectFileBtn') as HTMLButtonElement;

    function setImage(url: string) {
      coverImageInput.value = url;
      previewImg.src = url;
      imagePreview.style.display = 'block';
      imageControls.style.display = 'none';
    }

    function removeImage() {
      coverImageInput.value = '';
      coverImageFileInput.value = '';
      previewImg.src = '';
      imagePreview.style.display = 'none';
      imageControls.style.display = 'flex';
    }

    removeImageBtn?.addEventListener('click', removeImage);

    uploadFileBtn?.addEventListener('click', () => {
        coverImageFileInput?.click();
    });

    coverImageFileInput?.addEventListener('change', async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        import('../../../lib/firebase/client').then(async ({ auth }) => {
            const currentUser = auth.currentUser;
            if (!currentUser) {
                showFeedback('Inicia sesión para subir archivos.', 'error');
                return;
            }
            const token = await currentUser.getIdToken();
            const formData = new FormData();
            formData.append('file', file);
            formData.append('title', `Portada: ${file.name}`);
            formData.append('description', 'Subida desde blog admin');
            formData.append('isPublic', 'true');
            
            showFeedback('Subiendo imagen...', 'success');
            submitBtn.disabled = true;

            try {
                const res = await fetch(`${API_URL}/files`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData,
                });
                
                if(!res.ok) throw new Error('Error al subir fichero');
                const data = await res.json();
                
                // Now get the download URL
                const dlRes = await fetch(`${API_URL}/files/${data.id}/download`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(!dlRes.ok) throw new Error('No se pudo obtener URL pública');
                const dlData = await dlRes.json();
                
                setImage(dlData.url);
                showFeedback('Imagen subida correctamente.', 'success');
                setTimeout(() => { if(feedback) feedback.className = 'feedback-message hidden'; }, 2000);
            } catch(err) {
                showFeedback('Falló la subida de imagen.', 'error');
            } finally {
                submitBtn.disabled = false;
            }
        });
    });

    // Image Selection Modal Logic
    const imageSelectModal = document.getElementById('imageSelectModal') as HTMLDivElement;
    const closeImageModalBtn = document.getElementById('closeImageModal') as HTMLButtonElement;
    const imageGallery = document.getElementById('imageGallery') as HTMLDivElement;
    const imageSearchInput = document.getElementById('imageSearchInput') as HTMLInputElement;
    
    let libraryImages: any[] = [];
    
    function openModal() {
        imageSelectModal.classList.remove('hidden');
        loadLibraryImages();
    }
    
    function closeModal() {
        imageSelectModal.classList.add('hidden');
    }

    selectFileBtn?.addEventListener('click', openModal);
    closeImageModalBtn?.addEventListener('click', closeModal);
    imageSelectModal?.addEventListener('click', (e) => {
        if (e.target === imageSelectModal) closeModal();
    });
    
    async function loadLibraryImages() {
        import('../../../lib/firebase/client').then(async ({ auth }) => {
            const currentUser = auth.currentUser;
            if (!currentUser) return;
            const token = await currentUser.getIdToken();
            
            try {
                const res = await fetch(`${API_URL}/files`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(!res.ok) throw new Error();
                const files = await res.json();
                
                // Filter only images
                libraryImages = files.filter((f: any) => f.mimeType.startsWith('image/'));
                renderGallery(libraryImages);
            } catch(e) {
                imageGallery.innerHTML = '<div class="loading-state">Error al cargar imágenes</div>';
            }
        });
    }

    function renderGallery(images: any[]) {
        if(images.length === 0) {
            imageGallery.innerHTML = '<div class="loading-state">No se encontraron imágenes en tu biblioteca.</div>';
            return;
        }
        
        imageGallery.innerHTML = images.map(img => `
            <div class="gallery-item" data-id="${img.id}">
                <div class="img-placeholder"><i class="fas fa-image"></i></div>
                <div class="img-info">
                    <span class="img-title" title="${img.title}">${img.title}</span>
                </div>
            </div>
        `).join('');
        
        // Load actual URLs
        import('../../../lib/firebase/client').then(async ({ auth }) => {
            const token = await auth.currentUser?.getIdToken();
            if(!token) return;
            
            const items = imageGallery.querySelectorAll('.gallery-item');
            items.forEach(async (item) => {
                const id = item.getAttribute('data-id');
                try {
                    const res = await fetch(`${API_URL}/files/${id}/download`, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if(res.ok) {
                        const { url } = await res.json();
                        const placeholder = item.querySelector('.img-placeholder');
                        if(placeholder) {
                            placeholder.innerHTML = `<img src="${url}" alt="Thumbnail" loading="lazy" />`;
                        }
                        item.addEventListener('click', () => {
                            setImage(url);
                            closeModal();
                        });
                    }
                } catch(e) {}
            });
        });
    }

    imageSearchInput?.addEventListener('input', (e) => {
        const q = (e.target as HTMLInputElement).value.toLowerCase();
        const filtered = libraryImages.filter(img => img.title.toLowerCase().includes(q) || img.fileName.toLowerCase().includes(q));
        renderGallery(filtered);
    });

    // Delete Post Logic
    deleteBtn?.addEventListener('click', async () => {
      if (!confirm('¿Estás seguro de eliminar este post de forma permanente?')) return;
      
      deleteBtn.disabled = true;
      submitBtn.disabled = true;

      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (!currentUser) return;
        const token = await currentUser.getIdToken();

        try {
          const response = await fetch(`${API_URL}/blog/${postId}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          
          if (response.ok) {
            showFeedback('Post eliminado.', 'success');
            setTimeout(() => { window.location.href = '/admin/blog'; }, 1000);
          } else {
            const result = await response.json();
            showFeedback(result.message || 'Error al eliminar', 'error');
            deleteBtn.disabled = false;
            submitBtn.disabled = false;
          }
        } catch (e) {
          showFeedback('Error de conexión', 'error');
          deleteBtn.disabled = false;
          submitBtn.disabled = false;
        }
      });
    });


    // Submit Logic
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !feedback) return;

      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (!currentUser) {
          showFeedback('Error: No estás autenticado.', 'error');
          return;
        }
        
        const token = await currentUser.getIdToken();
        const formData = new FormData(form);
        
        let publishedAtValue = formData.get('publishedAt') ? new Date(formData.get('publishedAt') as string).toISOString() : null;

        const data: any = {
          title: formData.get('title'),
          slug: formData.get('slug'),
          content: formData.get('content'),
          coverImage: formData.get('coverImage') || null,
          author: formData.get('author') || null,
          category: formData.get('category') || null,
          publishedAt: publishedAtValue,
          published: formData.get('published') === 'true'
        };

        if (isNew) {
          data.authorId = currentUser.uid || 'admin';
        }

        submitBtn.disabled = true;
        if(deleteBtn) deleteBtn.disabled = true;
        feedback.className = 'feedback-message hidden';

        try {
          const url = isNew ? `${API_URL}/blog` : `${API_URL}/blog/${postId}`;
          const method = isNew ? 'POST' : 'PATCH';

          const response = await fetch(url, {
            method: method,
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (response.ok) {
            showFeedback(isNew ? 'Post creado exitosamente.' : 'Post actualizado exitosamente.', 'success');
            setTimeout(() => {
              window.location.href = '/admin/blog';
            }, 1000);
          } else {
            showFeedback(result.message || `Error al ${isNew ? 'crear' : 'actualizar'} post.`, 'error');
            submitBtn.disabled = false;
            if(deleteBtn) deleteBtn.disabled = false;
          }
        } catch (error) {
          showFeedback('Error de conexión.', 'error');
          submitBtn.disabled = false;
          if(deleteBtn) deleteBtn.disabled = false;
        }
      });
    });

    function showFeedback(message: string, type: 'error' | 'success') {
      if(!feedback) return;
      feedback.textContent = message;
      feedback.className = `feedback-message ${type}`;
    }
  }
</script>

<style>
  .image-upload-container { display: flex; align-items: stretch; justify-content: flex-start; position: relative; width: 100%; }
  .image-controls { display: flex; align-items: stretch; gap: 0.5rem; width: 100%; flex-wrap: wrap; }
  .or-divider { color: var(--color-text-muted); font-size: 0.8rem; font-weight: bold; text-transform: uppercase; margin: 0 0.5rem; }
  .image-preview { position: relative; width: 100%; }
  .image-preview img { width: 100%; height: 200px; object-fit: cover; border-radius: 0; border: 1px solid var(--color-border); }
  .remove-image { position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(0,0,0,0.6); color: white; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
  .remove-image:hover { background: #e11d48; }

  /* Gallery Modal */
  .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 1rem; backdrop-filter: blur(4px); }
  .modal-content { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0; width: 100%; max-width: 800px; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.5); }
  .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .modal-header h3 { margin: 0; display: flex; align-items: center; gap: 0.5rem; color: var(--color-text); }
  .modal-close { background: transparent; border: none; color: var(--color-text-muted); font-size: 1.5rem; cursor: pointer; transition: color 0.2s; }
  .modal-close:hover { color: #ef4444; }
  .modal-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; overflow-y: auto; flex: 1; }
  .search-bar { display: flex; align-items: center; gap: 0.5rem; background: var(--color-background); border: 1px solid var(--color-border); padding: 0.5rem 1rem; border-radius: 0; }
  .search-bar input { flex: 1; border: none; background: transparent; padding: 0.25rem; outline: none !important; box-shadow: none !important; color: var(--color-text); }
  .image-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; margin-top: 1rem; }
  .loading-state { grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--color-text-muted); }
  .gallery-item { border: 1px solid var(--color-border); background: var(--color-background); cursor: pointer; transition: border-color 0.2s, transform 0.2s; border-radius: 0; overflow: hidden; }
  .gallery-item:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.2); }
  .img-placeholder { height: 120px; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.2); color: var(--color-text-muted); font-size: 2rem; }
  .img-placeholder img { width: 100%; height: 100%; object-fit: cover; }
  .img-info { padding: 0.5rem; font-size: 0.8rem; border-top: 1px solid var(--color-border); }
  .img-title { display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--color-text); }
  
  .header-actions { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-text-muted); text-decoration: none; margin-bottom: 0.5rem; font-size: 0.875rem; }
  .back-link:hover { color: var(--color-primary); }
  .content-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; }
  .error-banner { background: rgba(var(--color-error-rgb), 0.1); color: var(--color-error); padding: 1rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; border-left: 4px solid var(--color-error); }
  .post-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-row { display: flex; gap: 1.5rem; }
  .form-row > .form-group { flex: 1; }
  @media (max-width: 768px) { .form-row { flex-direction: column; gap: 1.5rem; } }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  label { font-weight: 500; color: var(--color-text); }
  .required { color: var(--color-error); }
  input, textarea, select { padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-background); color: var(--color-text); font-family: inherit; font-size: 1rem; }
  input:focus, textarea:focus, select:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 2px rgba(var(--color-primary-rgb), 0.1); }
  
  .input-with-icon { position: relative; display: flex; align-items: center; }
  .input-with-icon select { width: 100%; padding-right: 2.5rem; cursor: pointer; appearance: none; -webkit-appearance: none; -moz-appearance: none; }
