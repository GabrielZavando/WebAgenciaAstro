---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
const isNew = id === 'new';
const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let post = null;
let errorMsg = null;
let initialPublishedAt = '';

if (!isNew) {
  try {
    const response = await fetch(`${API_URL}/blog/${id}`, {
      headers: { 'Authorization': `Bearer ${token}` }
    });

    if (response.ok) {
      post = await response.json();
      
      // Format the date for the datetime-local input safely
      if (post?.publishedAt) {
        try {
           const dateVal = post.publishedAt._seconds ? new Date(post.publishedAt._seconds * 1000) : new Date(post.publishedAt);
           if (!isNaN(dateVal.getTime())) {
               const tzoffset = (new Date()).getTimezoneOffset() * 60000;
               initialPublishedAt = (new Date(dateVal.getTime() - tzoffset)).toISOString().slice(0, 16);
           }
        } catch (e) {}
      }
    } else {
      errorMsg = `Error al cargar datos: ${response.statusText}`;
    }
  } catch (e) {
    errorMsg = "No se pudo conectar con el servidor.";
  }
}

// Fetch all categories to populate the select dropdown
let categories: { id: string, name: string }[] = [];
try {
  const allCatsRes = await fetch(`${API_URL}/blog-categories`, {
    headers: { 'Authorization': `Bearer ${token}` }
  });
  if (allCatsRes.ok) {
    categories = await allCatsRes.json();
  }
} catch (e) {
  console.error("Error fetching categories:", e);
}
---

<DashboardLayout title={isNew ? "Nuevo Artículo" : `Editar Artículo: ${post?.title || ''}`} role="admin">
  <div class="header-actions">
    <a href="/admin/blog" class="back-link">
      <span class="material-symbols-outlined">arrow_back</span> Volver al Blog
    </a>
    <h2>{isNew ? "Crear Nuevo Artículo" : `Editar Artículo: ${post?.title || ''}`}</h2>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <span class="material-symbols-outlined">report</span> {errorMsg}
    </div>
  )}

  {(!errorMsg && (isNew || post)) && (
    <div class="content-card fade-in">
      <form id="postForm" class="post-form" data-postid={!isNew ? id : ''} data-isnew={isNew ? 'true' : 'false'}>
        <div class="form-row">
          <div class="form-group">
            <label for="title" class="form-label">Título <span class="required">*</span></label>
            <input type="text" id="title" name="title" class="form-input" required placeholder="Título del post" value={post?.title || ''} />
          </div>

          <div class="form-group">
            <label for="slug" class="form-label">Slug (URL) <span class="required">*</span></label>
            <input type="text" id="slug" name="slug" class="form-input" required placeholder="titulo-del-post" value={post?.slug || ''} />
          </div>
        </div>

        <div class="form-group">
          <label for="content" class="form-label">Contenido <span class="required">*</span></label>
          <div id="editor-container" class="editor-container"></div>
          <input type="hidden" id="content" name="content" required value={post?.content || ''} />
        </div>

        <div class="form-row">
          <div class="form-group form-group-image">
            <label class="form-label">Imagen de Portada</label>
            <div class="image-upload-container">
              <input type="hidden" id="coverImage" name="coverImage" value={post?.coverImage || ''} />
              <div id="imagePreview" class="image-preview" style={post?.coverImage ? "" : "display: none;"}>
                <img id="previewImg" src={post?.coverImage || ''} alt="" class="preview-img" />
                <button type="button" id="removeImageBtn" class="remove-image-btn" title="Eliminar imagen"><span class="material-symbols-outlined">close</span></button>
              </div>
              <div id="imageControls" class="image-controls" style={post?.coverImage ? "display: none;" : ""}>
                <button type="button" id="selectFileBtn" class="btn btn-cta btn-image-ctrl"><span class="material-symbols-outlined">imagesmode</span> Biblioteca</button>
                <button type="button" id="uploadFileBtn" class="btn btn-cta__border btn-image-ctrl"><span class="material-symbols-outlined">cloud_upload</span> Subir Imagen</button>
                <input type="file" id="coverImageFile" accept="image/*" style="display: none;" />
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="author" class="form-label">Autor</label>
            <input type="text" id="author" name="author" class="form-input" placeholder="Ej: Juan Pérez" value={post?.author || ''} />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="category" class="form-label">Categoría</label>
            <div class="input-with-icon">
              <select id="category" name="category" class="form-input" required>
                <option value="" disabled selected={!post?.category}>Selecciona una categoría</option>
                {categories.map((cat) => (
                  <option value={cat.name} selected={post?.category === cat.name}>{cat.name}</option>
                ))}
              </select>
              <span class="material-symbols-outlined icon-select">expand_more</span>
            </div>
          </div>

          <div class="form-group">
            <label for="publishedAt" class="form-label">Fecha de Publicación</label>
            <input type="datetime-local" id="publishedAt" name="publishedAt" class="form-input" value={initialPublishedAt} />
          </div>
        </div>

        <div class="form-group toggle-group">
          <label class="toggle">
            <input type="checkbox" id="published" name="published" value="true" checked={post ? post.published : false} />
            <span class="label-text">Publicado (Visible al público)</span>
          </label>
        </div>

        <div id="formFeedback" class="feedback-message hidden"></div>

        <div class="form-actions actions-spaced">
          <div class="left-actions">
            {!isNew && (
              <button type="button" class="btn btn-danger" id="deleteBtn">
                <span class="material-symbols-outlined">delete</span> Eliminar Post
              </button>
            )}
          </div>
          <div class="right-actions">
            <button type="submit" class="btn btn-cta" id="submitBtn">
              <span class="material-symbols-outlined">save</span> {isNew ? 'Crear Post' : 'Guardar Cambios'}
            </button>
          </div>
        </div>
      </form>
    </div>
  )}

  <div slot="modals">
    <!-- Modal de Selección de Imágenes -->
    <div id="imageSelectModal" class="modal">
      <div class="modal__content">
        <div class="modal__header">
          <h3><span class="material-symbols-outlined">imagesmode</span> Biblioteca de Imágenes</h3>
          <button type="button" id="closeImageModal" class="modal__close">&times;</button>
        </div>
        <div class="modal__body">
          <form class="search-form" onsubmit="return false;">
            <input type="text" id="imageSearchInput" class="search-input" placeholder="Buscar imágenes..." />
            <button type="submit" class="search-btn">Buscar</button>
          </form>
          <div id="imageGallery" class="image-gallery">
            <div class="loading-state">Cargando biblioteca...</div>
          </div>
        </div>
      </div>
    </div>

    <ModalConfirm 
      id="deletePostDetailModal"
      title="¿Eliminar Artículo?"
      message="¿Estás seguro de que deseas eliminar este artículo permanentemente? Esta acción no se puede deshacer."
      confirmText="Eliminar permanentemente"
      type="danger"
    />

    <ModalMessage
      id="formSuccessModal"
      type="success"
      title="¡Éxito!"
      message="El artículo ha sido procesado correctamente."
    />

    <ModalMessage
      id="formErrorModal"
      type="error"
      title="Error"
      message="Ha ocurrido un problema al procesar el artículo."
    />
  </div>
</DashboardLayout>

<script>
  import Quill from 'quill';
  import 'quill/dist/quill.snow.css';

  const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

  function initPostForm() {
    const form = document.getElementById('postForm') as HTMLFormElement;
    if (!form || form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const deleteBtn = document.getElementById('deleteBtn') as HTMLButtonElement;
    const titleInput = document.getElementById('title') as HTMLInputElement;
    const slugInput = document.getElementById('slug') as HTMLInputElement;
    const contentInput = document.getElementById('content') as HTMLInputElement;
    
    const isNew = form.dataset.isnew === 'true';
    const postId = form.dataset.postid;

    // Inicializar Quill
    const quill = new Quill('#editor-container', {
      theme: 'snow',
      placeholder: 'Escribe el contenido HTML enriquecido aquí...',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike', 'blockquote'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          [{ 'color': [] }, { 'background': [] }],
          ['link', 'image', 'video'],
          ['clean']
        ]
      }
    });

    if (contentInput.value) {
      quill.root.innerHTML = contentInput.value;
    }

    quill.on('text-change', () => {
      contentInput.value = quill.root.innerHTML === '<p><br></p>' ? '' : quill.root.innerHTML;
    });

    // Auto-generate slug
    let manualSlugEdit = false;
    slugInput?.addEventListener('input', () => { manualSlugEdit = true; });
    titleInput?.addEventListener('blur', () => {
      if (titleInput.value && !manualSlugEdit && !slugInput.value) {
        slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
      }
    });

    if (isNew) {
      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (currentUser) {
           const authorInput = document.getElementById('author') as HTMLInputElement;
           if(authorInput && !authorInput.value) {
               authorInput.value = currentUser.displayName || currentUser.email?.split('@')[0] || 'Admin';
           }
        }
      });
    }

    // Image upload and select logic
    const coverImageInput = document.getElementById('coverImage') as HTMLInputElement;
    const coverImageFileInput = document.getElementById('coverImageFile') as HTMLInputElement;
    const imagePreview = document.getElementById('imagePreview') as HTMLDivElement;
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;
    const removeImageBtn = document.getElementById('removeImageBtn') as HTMLButtonElement;
    const imageControls = document.getElementById('imageControls') as HTMLDivElement;
    const uploadFileBtn = document.getElementById('uploadFileBtn') as HTMLButtonElement;
    const selectFileBtn = document.getElementById('selectFileBtn') as HTMLButtonElement;

    function setImage(url: string) {
      coverImageInput.value = url;
      previewImg.src = url;
      imagePreview.style.display = 'block';
      imageControls.style.display = 'none';
    }

    function removeImage() {
      coverImageInput.value = '';
      coverImageFileInput.value = '';
      previewImg.src = '';
      imagePreview.style.display = 'none';
      imageControls.style.display = 'flex';
    }

    removeImageBtn?.addEventListener('click', removeImage);
    uploadFileBtn?.addEventListener('click', () => { coverImageFileInput?.click(); });

    coverImageFileInput?.addEventListener('change', async (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (!file) return;

        import('../../../lib/firebase/client').then(async ({ auth }) => {
            const currentUser = auth.currentUser;
            if (!currentUser) {
                showModalFeedback('Inicia sesión para subir archivos.', 'error');
                return;
            }
            const token = await currentUser.getIdToken();
            const formData = new FormData();
            formData.append('file', file);
            formData.append('title', `Portada: ${file.name}`);
            formData.append('description', 'Subida desde blog admin');
            formData.append('isPublic', 'true');
            
            uploadFileBtn.classList.add('btn-loading');
            submitBtn.disabled = true;

            try {
                const res = await fetch(`${API_URL}/files`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData,
                });
                
                if(!res.ok) throw new Error('Error al subir fichero');
                const data = await res.json();
                
                const dlRes = await fetch(`${API_URL}/files/${data.id}/download`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(!dlRes.ok) throw new Error('No se pudo obtener URL pública');
                const dlData = await dlRes.json();
                
                setImage(dlData.url);
            } catch(err) {
                showModalFeedback('Falló la subida de imagen.', 'error');
            } finally {
                uploadFileBtn.classList.remove('btn-loading');
                submitBtn.disabled = false;
            }
        });
    });

    // Image Selection Modal Logic
    const imageSelectModal = document.getElementById('imageSelectModal') as HTMLDivElement;
    const closeImageModalBtn = document.getElementById('closeImageModal') as HTMLButtonElement;
    const imageGallery = document.getElementById('imageGallery') as HTMLDivElement;
    const imageSearchInput = document.getElementById('imageSearchInput') as HTMLInputElement;
    
    let libraryImages: any[] = [];
    
    function openModal() {
        imageSelectModal.classList.add('active');
        loadLibraryImages();
    }
    
    function closeModal() {
        imageSelectModal.classList.remove('active');
    }

    selectFileBtn?.addEventListener('click', openModal);
    closeImageModalBtn?.addEventListener('click', closeModal);
    imageSelectModal?.addEventListener('click', (e) => {
        if (e.target === imageSelectModal) closeModal();
    });
    
    async function loadLibraryImages() {
        const gallery = document.getElementById('imageGallery');
        if (gallery) gallery.innerHTML = '<div class="loading-state">Cargando biblioteca...</div>';

        import('../../../lib/firebase/client').then(async ({ auth }) => {
            // Esperar un momento si el auth no está listo
            let user = auth.currentUser;
            if (!user) {
                await new Promise(resolve => {
                   const unsub = auth.onAuthStateChanged(u => {
                       user = u;
                       unsub();
                       resolve(u);
                   });
                   setTimeout(resolve, 3000); // Timeout de 3s
                });
            }

            if (!user) {
                if (gallery) gallery.innerHTML = '<div class="loading-state">Error: No se pudo verificar la sesión. Reintente.</div>';
                return;
            }

            const token = await user.getIdToken();
            
            try {
                const res = await fetch(`${API_URL}/files`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if(!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
                const files = await res.json();
                
                libraryImages = files.filter((f: any) => f.mimeType && f.mimeType.startsWith('image/'));
                renderGallery(libraryImages);
            } catch(e) {
                console.error("Error loading library images:", e);
                if (gallery) gallery.innerHTML = '<div class="loading-state">Error al conectar con la biblioteca.</div>';
            }
        });
    }

    function renderGallery(images: any[]) {
        if(images.length === 0) {
            imageGallery.innerHTML = '';
            return;
        }
        
        imageGallery.innerHTML = images.map(img => `
            <div class="gallery-item" data-id="${img.id}">
                <div class="img-placeholder"><span class="material-symbols-outlined">image</span></div>
                <div class="img-info"><span class="img-title" title="${img.title}">${img.title}</span></div>
            </div>
        `).join('');
        
        import('../../../lib/firebase/client').then(async ({ auth }) => {
            const token = await auth.currentUser?.getIdToken();
            if(!token) return;
            
            const items = imageGallery.querySelectorAll('.gallery-item');
            items.forEach(async (item) => {
                const id = item.getAttribute('data-id');
                try {
                    const res = await fetch(`${API_URL}/files/${id}/download`, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if(res.ok) {
                        const { url } = await res.json();
                        const placeholder = item.querySelector('.img-placeholder');
                        if(placeholder) {
                            placeholder.innerHTML = `<img src="${url}" alt="Thumbnail" loading="lazy" />`;
                        }
                        item.addEventListener('click', () => {
                            setImage(url);
                            closeModal();
                        });
                    }
                } catch(e) {}
            });
        });
    }

    imageSearchInput?.addEventListener('input', (e) => {
        const q = (e.target as HTMLInputElement).value.toLowerCase();
        const filtered = libraryImages.filter(img => img.title.toLowerCase().includes(q) || (img.fileName && img.fileName.toLowerCase().includes(q)));
        renderGallery(filtered);
    });

    // Delete Logic
    deleteBtn?.addEventListener('click', () => {
      if (!window.confirmModalHelpers) {
        if (!confirm('¿Estás seguro?')) return;
        return executeDelete();
      }
      window.confirmModalHelpers.open('deletePostDetailModal', executeDelete);
    });

    async function executeDelete() {
      deleteBtn.classList.add('btn-loading');
      deleteBtn.disabled = true;
      if (submitBtn) submitBtn.disabled = true;

      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (!currentUser) return;
        const token = await currentUser.getIdToken();

        try {
          const response = await fetch(`${API_URL}/blog/${postId}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
          });
          
          if (response.ok) {
            if (window.showToast) window.showToast('Post eliminado.', 'success');
            setTimeout(() => { window.location.href = '/admin/blog'; }, 1000);
          } else {
            const result = await response.json();
            showModalFeedback(result.message || 'Error al eliminar', 'error');
            deleteBtn.classList.remove('btn-loading');
            deleteBtn.disabled = false;
            if (submitBtn) submitBtn.disabled = false;
          }
        } catch (e) {
          showModalFeedback('Error de conexión', 'error');
          deleteBtn.classList.remove('btn-loading');
          deleteBtn.disabled = false;
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }

    // Submit Logic
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn) return;

      import('../../../lib/firebase/client').then(async ({ auth }) => {
        const currentUser = auth.currentUser;
        if (!currentUser) {
          showModalFeedback('Error: No estás autenticado.', 'error');
          return;
        }
        
        const token = await currentUser.getIdToken();
        const formData = new FormData(form);
        
        let publishedAtValue = formData.get('publishedAt') ? new Date(formData.get('publishedAt') as string).toISOString() : null;

        const data: any = {
          title: formData.get('title'),
          slug: formData.get('slug'),
          content: formData.get('content'),
          coverImage: formData.get('coverImage') || null,
          author: formData.get('author') || null,
          category: formData.get('category') || null,
          publishedAt: publishedAtValue,
          published: formData.get('published') === 'true'
        };

        if (isNew) {
          data.authorId = currentUser.uid || 'admin';
        }

        submitBtn.classList.add('btn-loading');
        submitBtn.disabled = true;
        if(deleteBtn) deleteBtn.disabled = true;

        try {
          const url = isNew ? `${API_URL}/blog` : `${API_URL}/blog/${postId}`;
          const method = isNew ? 'POST' : 'PATCH';

          const response = await fetch(url, {
            method: method,
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (response.ok) {
            showModalFeedback(isNew ? 'Post creado exitosamente.' : 'Post actualizado exitosamente.', 'success');
            setTimeout(() => { window.location.href = '/admin/blog'; }, 1500);
          } else {
            showModalFeedback(result.message || `Error al ${isNew ? 'crear' : 'actualizar'} post.`, 'error');
            submitBtn.classList.remove('btn-loading');
            submitBtn.disabled = false;
            if(deleteBtn) deleteBtn.disabled = false;
          }
        } catch (error) {
          showModalFeedback('Error de conexión.', 'error');
          submitBtn.classList.remove('btn-loading');
          submitBtn.disabled = false;
          if(deleteBtn) deleteBtn.disabled = false;
        }
      });
    });

    function showModalFeedback(message: string, type: 'error' | 'success') {
      const modalId = type === 'success' ? 'formSuccessModal' : 'formErrorModal';
      if (window.modalHelpers) {
        window.modalHelpers.updateModalMessage(modalId, message);
        window.modalHelpers.openModal(modalId);
      } else {
        alert(message);
      }
    }
  }

  // Ejecutar en cada carga de página (incluyendo navegación SPA)
  document.addEventListener('astro:page-load', initPostForm);

  // Fallback
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPostForm();
  }
</script>
