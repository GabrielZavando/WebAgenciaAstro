---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
---

<DashboardLayout title="Categorías del Blog" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Blog', href: '/admin/blog' }, { label: 'Categorias' }]} role="admin">
  <div class="categories-page">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <div>
        <h2>Categorías</h2>
        <p class="text-muted" style="margin-top: 0.5rem;">Gestiona las categorías de tus artículos del blog.</p>
      </div>
      <button class="btn btn-cta" id="openCreateModal" style="border-radius: 0;">
        <span class="material-symbols-outlined">add</span> Nueva Categoría
      </button>
    </div>

    <!-- Tabla -->
    <div class="table-container fade-in">
      <table class="files-table">
        <thead>
          <tr>
            <th class="col-name">Nombre</th>
            <th class="col-slug">Slug</th>
            <th class="col-desc">Descripción</th>
            <th class="col-actions">Acciones</th>
          </tr>
        </thead>
        <tbody id="categoryTableBody">
          <tr><td colspan="4" class="text-center" style="padding: 2rem;">Cargando categorías...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div slot="modals">
    <!-- Modal de Crear/Editar -->
    <div class="modal modal--small" id="categoryModal">
      <div class="modal__content">
        <div class="modal__header">
          <h3 id="modalTitle"><span class="material-symbols-outlined">label</span> Nueva Categoría</h3>
          <button class="modal__close" id="closeModal">&times;</button>
        </div>
        <form id="categoryForm" class="category-form">
          <input type="hidden" id="categoryId" name="id" />
          
          <div class="form-group">
            <label for="catName">Nombre</label>
            <input type="text" id="catName" name="name" required placeholder="Ej: Tecnología" />
          </div>
          
          <div class="form-group">
            <label for="catSlug">Slug (URL amigable)</label>
            <input type="text" id="catSlug" name="slug" required placeholder="Ej: tecnologia" />
          </div>
          
          <div class="form-group">
            <label for="catDesc">Descripción</label>
            <input type="text" id="catDesc" name="description" placeholder="Opcional" />
          </div>

          <div id="formFeedback" class="feedback-msg hidden"></div>
          
          <div class="form-actions">
            <button type="submit" class="btn-cta" id="submitCategory">
              Guardar Categoría
            </button>
          </div>
        </form>
      </div>
    </div>

    <ModalConfirm 
      id="deleteCategoryModal"
      title="¿Eliminar Categoría?"
      message="¿Estás seguro de que deseas eliminar esta categoría? Si tiene artículos asociados, estos podrían quedar sin categoría."
      confirmText="Eliminar Categoría"
      type="danger"
    />

    <ModalMessage 
      id="errorCategoryModal"
      title="Error"
      message="Ocurrió un error al procesar la categoría."
      type="error"
    />
  </div>
</DashboardLayout>

<style>
  .categories-page {
    width: 100%;
    margin: 0 auto;
  }
  .page-header h2 { margin: 0; font-size: 1.5rem; }
  
  .btn-cta {
    background: var(--color-primary); color: white; border: none; padding: 0.75rem 1.5rem;
    cursor: pointer; display: flex; align-items: center; gap: 0.5rem; font-weight: 500; font-size: 0.95rem;
  }
  .btn-cta:hover { opacity: 0.9; }

  .category-form { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group label { font-size: 0.9rem; font-weight: 500; color: var(--color-text); }
  .category-form input { padding: 0.75rem 1rem; background: var(--color-background); border: 1px solid var(--color-border); color: var(--color-text); font-family: inherit; font-size: 0.95rem; outline: none; }
  .category-form input:focus { border-color: var(--color-primary); }
  
  .form-actions { display: flex; justify-content: flex-end; margin-top: 0.5rem; }
  
  .feedback-msg { padding: 0.75rem; border-radius: 0; text-align: center; font-size: 0.9rem; }
  .feedback-msg.error { background: rgba(var(--color-error-rgb), 0.1); color: var(--color-error); }
  .feedback-msg.success { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
  .hidden { display: none; }

  .cat-name-cell { color: var(--color-primary); font-weight: 600; font-size: 1.05rem; display: flex; align-items: center; gap: 0.75rem; border: none; padding: 0; }
  
  .text-center { text-align: center; }
  .text-muted { color: var(--color-text-muted); }
  
  .files-table :global(.action-buttons) { display: flex; justify-content: center; gap: 1.25rem; align-items: center; }
</style>

<script define:vars={{ API_URL }}>
  // Logic
  const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
  const tableBody = document.getElementById('categoryTableBody');
  const catModal = document.getElementById('categoryModal');
  const catForm = document.getElementById('categoryForm');
  const openModalBtn = document.getElementById('openCreateModal');
  const closeModalBtns = [document.getElementById('closeModal')];
  const feedback = document.getElementById('formFeedback');
  const modalTitle = document.getElementById('modalTitle');
  
  // Elementos del form
  const idInput = document.getElementById('categoryId');
  const nameInput = document.getElementById('catName');
  const slugInput = document.getElementById('catSlug');
  const descInput = document.getElementById('catDesc');
  
  let categories = [];

  const loadCategories = async () => {
    try {
      const res = await fetch(`${API_URL}/blog-categories`);
      if(res.ok) {
        categories = await res.json();
        renderTable();
      } else {
        tableBody.innerHTML = '<tr><td colspan="4" class="text-center text-error">Error al cargar</td></tr>';
      }
    } catch(e) {
      tableBody.innerHTML = '<tr><td colspan="4" class="text-center text-error">Error de conexión</td></tr>';
    }
  };

  const renderTable = () => {
    if(categories.length === 0) {
      tableBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No hay categorías registradas</td></tr>';
      return;
    }
    
    tableBody.innerHTML = categories.map(cat => `
      <tr>
        <td>
          <div class="cat-name-cell">
            ${cat.name}
          </div>
        </td>
        <td class="text-muted">${cat.slug}</td>
        <td class="text-muted">${cat.description || '-'}</td>
        <td>
          <div class="action-buttons">
            <button class="btn-cta__border btn-sm edit" onclick="window.editCat('${cat.id}')" title="Editar"><span class="material-symbols-outlined">edit</span></button>
            <button class="btn-cta__danger btn-sm delete" onclick="window.deleteCat('${cat.id}')" title="Eliminar"><span class="material-symbols-outlined">delete</span></button>
          </div>
        </td>
      </tr>
    `).join('');
  };

  const showFeedback = (msg, isError = false) => {
    feedback.textContent = msg;
    feedback.className = `feedback-msg ${isError ? 'error' : 'success'}`;
    setTimeout(() => { feedback.classList.add('hidden'); }, 4000);
  };

  const resetForm = () => {
    catForm.reset();
    idInput.value = '';
    modalTitle.innerHTML = '<span class="material-symbols-outlined">tag</span> Nueva Categoría';
    feedback.classList.add('hidden');
  };

  const openModal = () => { catModal.classList.add('active'); };
  const closeModal = () => { catModal.classList.remove('active'); resetForm(); };

  openModalBtn.addEventListener('click', () => { resetForm(); openModal(); });
  closeModalBtns.forEach(btn => btn?.addEventListener('click', closeModal));
  catModal.addEventListener('click', (e) => { if(e.target === catModal) closeModal(); });

  // Auto-generate slug
  nameInput.addEventListener('input', (e) => {
    if(!idInput.value) { // solo autogenerar en creación
      slugInput.value = e.target.value.toLowerCase().trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
  });

  catForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = idInput.value;
    const isEditing = !!id;
    
    const payload = {
      name: nameInput.value,
      slug: slugInput.value,
      description: descInput.value
    };

    const submitBtn = document.getElementById('submitCategory');
    if (submitBtn) {
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.classList.add('btn-loading');
    }

    try {
      const url = isEditing ? `${API_URL}/blog-categories/${id}` : `${API_URL}/blog-categories`;
      const method = isEditing ? 'PATCH' : 'POST';
      
      const res = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify(payload)
      });
      
      if(res.ok) {
        await loadCategories();
        closeModal();
      } else {
        const error = await res.json();
        showFeedback(error.message || 'Error al guardar', true);
      }
    } catch(e) {
      showFeedback('Error de conexión', true);
    } finally {
      if (submitBtn) {
        submitBtn.removeAttribute('disabled');
        submitBtn.classList.remove('btn-loading');
      }
    }
  });

  window.editCat = (id) => {
    const cat = categories.find(c => c.id === id);
    if(cat) {
      idInput.value = cat.id;
      nameInput.value = cat.name;
      slugInput.value = cat.slug;
      descInput.value = cat.description || '';
      modalTitle.innerHTML = '<span class="material-symbols-outlined">edit</span> Editar Categoría';
      openModal();
    }
  };

  window.deleteCat = async (id) => {
    if (!window.confirmModalHelpers) {
      if (!confirm('¿Estás seguro?')) return;
      return executeDeleteCat(id);
    }

    window.confirmModalHelpers.open('deleteCategoryModal', () => {
      executeDeleteCat(id);
    });
  };

  async function executeDeleteCat(id) {
    try {
      const res = await fetch(`${API_URL}/blog-categories/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if(res.ok) {
        if (window.showToast) window.showToast('Categoría eliminada.', 'success');
        await loadCategories();
      } else {
        const err = await res.json();
        if (window.modalHelpers) {
          window.modalHelpers.updateModalMessage('errorCategoryModal', err.message || 'Error al eliminar');
          window.modalHelpers.openModal('errorCategoryModal');
        } else {
          alert(err.message || 'Error al eliminar');
        }
      }
    } catch(e) {
      if (window.modalHelpers) {
        window.modalHelpers.updateModalMessage('errorCategoryModal', 'Error de conexión');
        window.modalHelpers.openModal('errorCategoryModal');
      } else {
        alert('Error de conexión');
      }
    }
  }

  // Init
  loadCategories();
</script>
</DashboardLayout>
