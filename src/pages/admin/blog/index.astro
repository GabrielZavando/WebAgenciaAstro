
---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
---

<DashboardLayout title="Gestión del Blog" role="admin">
  <div class="blog-header">
      <h2>Artículos</h2>
      <a href="/admin/blog/new" class="btn btn-cta btn-new-post">+ Nuevo Post</a>
  </div>

  <div class="blog-toolbar">
      <div class="search-wrapper">
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar artículo por nombre...">
          <button type="button" class="btn btn-cta search-btn">Buscar</button>
      </div>
      <div class="select-wrapper sort-wrapper">
          <select id="sortFilter" class="sort-select">
              <option value="">Ordenar por defecto</option>
              <option value="status-pub">Estado: Publicado</option>
              <option value="status-draft">Estado: Borrador</option>
              <option value="date-desc">Fecha: Más recientes</option>
              <option value="date-asc">Fecha: Más antiguos</option>
              <option value="category">Categoría</option>
              <option value="tag">Etiqueta</option>
          </select>
          <i class="fas fa-chevron-down select-field-arrow"></i>
      </div>
  </div>

  <div id="postsList">Cargando posts...</div>

  <ModalConfirm 
    slot="modals"
    id="deletePostModal"
    title="¿Eliminar Artículo?"
    message="¿Estás seguro de que deseas eliminar este artículo permanentemente? Esta acción no se puede deshacer."
    confirmText="Eliminar permanentemente"
    type="danger"
  />

  <script define:vars={{ API_BASE_URL }}>
    let allPosts = [];

    async function loadPosts() {
        try {
            const response = await fetch(`${API_BASE_URL}/blog`);
            allPosts = await response.json();
            
            // Render by default without filters
            renderPosts(allPosts);

        } catch (error) {
            console.error(error);
            document.getElementById('postsList').innerText = 'Error cargando posts.';
        }
    }

    function renderPosts(postsToRender) {
        const container = document.getElementById('postsList');
        if (!container) return;
        
        if (postsToRender.length === 0) {
            container.innerHTML = '<p>No se encontraron posts.</p>';
            return;
        }

        let html = '<div class="posts-grid">';
        
        postsToRender.forEach(post => {
            const date = new Date(post.createdAt._seconds * 1000).toLocaleDateString(); // Firebase timestamp
            const statusColor = post.published ? '#10b981' : '#f59e0b'; // Tailwind emerald-500, amber-500
            const statusText = post.published ? 'Publicado' : 'Borrador';
            const imageUrl = post.mainImage || post.coverImage || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=300&h=200&auto=format&fit=crop';
            
            html += `
                <div class="post-card">
                    <div class="post-image" style="background-image: url('${imageUrl}');"></div>
                    <div class="post-content">
                        <div class="post-meta-header">
                            <span class="post-status-badge" style="background-color: ${statusColor};">${statusText}</span>
                        </div>
                        <h3 class="post-title">${post.title}</h3>
                        
                        <div class="post-date">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            <span>${date}</span>
                        </div>
                        
                        <div class="post-actions">
                            <a href="/admin/blog/${post.id}" class="btn post-btn-edit"><i class="fas fa-edit"></i> Editar</a>
                            <a href="/blog/${post.slug || post.id}" target="_blank" class="btn post-btn-view"><i class="fas fa-eye"></i> Ver</a>
                            <button onclick="window.deletePost('${post.id}')" class="btn-danger-outline post-btn-delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>
            `;
        });
        
        html += '</div>';
        container.innerHTML = html;
    }

    // Lógica de filtrado
    window.applyFilters = () => {
        const searchInput = document.getElementById('searchInput');
        const sortFilter = document.getElementById('sortFilter');
        
        const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
        const sortValue = sortFilter ? sortFilter.value : '';

        // 1. Buscar
        let filtered = allPosts.filter(post => 
            post.title.toLowerCase().includes(searchTerm)
        );

        // 2. Ordenar
        if (sortValue === 'date-desc') {
            filtered.sort((a, b) => b.createdAt._seconds - a.createdAt._seconds);
        } else if (sortValue === 'date-asc') {
            filtered.sort((a, b) => a.createdAt._seconds - b.createdAt._seconds);
        } else if (sortValue === 'status-pub') {
            filtered = filtered.filter(p => p.published);
        } else if (sortValue === 'status-draft') {
            filtered = filtered.filter(p => !p.published);
        } else if (sortValue === 'category') {
            filtered.sort((a, b) => (a.category || '').localeCompare(b.category || ''));
        } else if (sortValue === 'tag') {
            filtered.sort((a, b) => (a.tags?.[0] || '').localeCompare(b.tags?.[0] || ''));
        }

        renderPosts(filtered);
    };

    // Configurar listeners una vez que carga
    setTimeout(() => {
        const searchInput = document.getElementById('searchInput');
        const sortFilter = document.getElementById('sortFilter');
        const sortIconContainer = document.getElementById('sortIconContainer');

        if (searchInput) searchInput.addEventListener('input', applyFilters);
        if (sortFilter) {
            sortFilter.addEventListener('change', () => {
                applyFilters();
            });
        }
    }, 100);

    // Expose delete function globally
    window.deletePost = function(id) {
        if (!window.confirmModalHelpers) {
          console.error('confirmModalHelpers not found');
          return;
        }
        window.confirmModalHelpers.open('deletePostModal', async () => {
            try {
                const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
                const res = await fetch(`${API_BASE_URL}/blog/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!res.ok) throw new Error('Error al eliminar post');
                
                if (window.showToast) window.showToast('Post eliminado correctamente', 'success');
                loadPosts(); // Reload
            } catch (e) {
                if (window.showToast) window.showToast(e.message, 'error');
            }
        });
    };

    loadPosts();
  </script>

  <script is:inline>
    (function () {
      function init() {
        const sel = document.getElementById('sortFilter');
        if (!sel) return;
        const icon = sel.parentElement.querySelector('.select-field-arrow');
        if (!icon) return;

        function show() {
          icon.style.transition = 'transform 0.25s ease';
          icon.style.transform = 'translateY(-50%) rotate(180deg)';
        }
        function hide() {
          icon.classList.remove('rotate-180');
        }

        sel.addEventListener('mousedown', show);
        sel.addEventListener('blur', hide);
        sel.addEventListener('change', hide);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  <style>
    .blog-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .btn-new-post {
      border-radius: 0;
    }
    .blog-toolbar {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      align-items: stretch;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .search-wrapper {
      display: flex;
      flex: 1;
      max-width: 600px;
      gap: 1rem;
    }
    .search-input {
      flex: 1;
      padding: 0.75rem 1rem;
      border-radius: 0;
      border: 1px solid var(--color-border, #334155);
      background: transparent;
      color: white;
      font-family: inherit;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-btn {
      border-radius: 0;
      padding: 0.75rem 2rem;
      font-size: 1rem;
      white-space: nowrap;
      height: 100%;
    }
    .sort-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      border: 1px solid var(--color-border, #334155);
      background: transparent;
      height: 100%;
    }
    .sort-select {
      padding: 0.75rem 3.5rem 0.75rem 1rem;
      border-radius: 0;
      border: none;
      background: transparent;
      color: white;
      font-family: inherit;
      font-size: 1rem;
      cursor: pointer;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      outline: none;
      height: 100%;
    }
    .sort-select option {
      background: var(--color-surface, #0f172a);
      color: white;
    }
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }
    .post-card {
      background: var(--color-surface-secondary, #1e293b);
      border: 1px solid var(--color-border, #334155);
      border-radius: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease;
    }
    .post-image {
      height: 180px;
      width: 100%;
      background-size: cover;
      background-position: center;
    }
    .post-content {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }
    .post-meta-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.75rem;
    }
    .post-status-badge {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      border-radius: 0;
      font-size: 0.75rem;
      font-weight: 600;
      color: #ffffff;
    }
    .post-status-badge-published {
      background-color: #10b981; /* Tailwind emerald-500 */
    }
    .post-status-badge-draft {
      background-color: #f59e0b; /* Tailwind amber-500 */
    }
    .post-title {
      margin: 0 0 1rem 0;
      font-size: 1.25rem;
      font-weight: 600;
      line-height: 1.4;
      color: white;
    }
    .post-date {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      color: #94a3b8;
    }
    .post-actions {
      margin-top: auto;
      display: flex;
      gap: 0.75rem;
    }
    .post-btn-edit {
      flex: 1;
      padding: 0.5rem;
      justify-content: center;
      background: #334155;
      color: white;
      border-radius: 0;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .post-btn-view {
      flex: 1;
      padding: 0.5rem;
      justify-content: center;
      background: var(--color-primary, #6366f1);
      color: white;
      border-radius: 0;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .post-btn-delete {
      padding: 0.5rem;
      justify-content: center;
      border-radius: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      width: 42px;
      height: 42px;
    }

    /* Styles for the select arrow rotation */
    .select-field-arrow {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%) rotate(0deg);
      transition: transform 0.25s ease;
      pointer-events: none; /* Ensure clicks go through to the select */
    }

    .select-field-arrow.rotate-180 {
      transform: translateY(-50%) rotate(180deg);
    }
  </style>
</DashboardLayout>
```
