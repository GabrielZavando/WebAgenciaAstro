
---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
---

<DashboardLayout title="Gestión del Blog" role="admin">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h2>Artículos</h2>
      <a href="/admin/blog/new" class="btn btn-cta" style="border-radius: 0;">+ Nuevo Post</a>
  </div>

  <div class="toolbar" style="display: flex; gap: 1rem; margin-bottom: 2rem; align-items: stretch; justify-content: space-between; flex-wrap: wrap;">
      <div style="display: flex; flex: 1; max-width: 600px; gap: 1rem;">
          <input type="text" id="searchInput" placeholder="Buscar artículo por nombre..." style="flex: 1; padding: 0.75rem 1rem; border-radius: 0; border: 1px solid var(--color-border, #334155); background: transparent; color: white; font-family: inherit; font-size: 1rem; outline: none; transition: border-color 0.2s;">
          <button type="button" class="btn btn-cta" style="border-radius: 0; padding: 0.75rem 2rem; font-size: 1rem; white-space: nowrap; height: 100%;">Buscar</button>
      </div>
      <div style="position: relative; display: flex; align-items: center; border: 1px solid var(--color-border, #334155); background: transparent; height: 100%;">
          <select id="sortFilter" style="padding: 0.75rem 3.5rem 0.75rem 1rem; border-radius: 0; border: none; background: transparent; color: white; font-family: inherit; font-size: 1rem; cursor: pointer; appearance: none; -webkit-appearance: none; -moz-appearance: none; outline: none; height: 100%;">
              <option value="" style="background: var(--color-surface, #0f172a); color: white;">Ordenar por defecto</option>
              <option value="status-pub" style="background: var(--color-surface, #0f172a); color: white;">Estado: Publicado</option>
              <option value="status-draft" style="background: var(--color-surface, #0f172a); color: white;">Estado: Borrador</option>
              <option value="date-desc" style="background: var(--color-surface, #0f172a); color: white;">Fecha: Más recientes</option>
              <option value="date-asc" style="background: var(--color-surface, #0f172a); color: white;">Fecha: Más antiguos</option>
              <option value="category" style="background: var(--color-surface, #0f172a); color: white;">Categoría</option>
              <option value="tag" style="background: var(--color-surface, #0f172a); color: white;">Etiqueta</option>
          </select>
          <div id="sortIconContainer" style="position: absolute; right: 0; top: 0; bottom: 0; width: 3rem; background: transparent; color: var(--color-primary, #e11d48); display: flex; align-items: center; justify-content: center; pointer-events: none; transition: transform 0.3s ease;">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
      </div>
  </div>

  <div id="postsList">Cargando posts...</div>

  <script define:vars={{ API_BASE_URL }}>
    let allPosts = [];

    async function loadPosts() {
        try {
            const response = await fetch(`${API_BASE_URL}/blog`);
            allPosts = await response.json();
            
            // Render by default without filters
            renderPosts(allPosts);

        } catch (error) {
            console.error(error);
            document.getElementById('postsList').innerText = 'Error cargando posts.';
        }
    }

    function renderPosts(postsToRender) {
        const container = document.getElementById('postsList');
        if (!container) return;
        
        if (postsToRender.length === 0) {
            container.innerHTML = '<p>No se encontraron posts.</p>';
            return;
        }

        let html = '<div class="posts-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">';
        
        postsToRender.forEach(post => {
            const date = new Date(post.createdAt._seconds * 1000).toLocaleDateString(); // Firebase timestamp
            const statusColor = post.published ? '#10b981' : '#f59e0b'; // Tailwind emerald-500, amber-500
            const statusText = post.published ? 'Publicado' : 'Borrador';
            const imageUrl = post.mainImage || post.coverImage || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=300&h=200&auto=format&fit=crop';
            
            html += `
                <div style="background: var(--color-surface-secondary, #1e293b); border: 1px solid var(--color-border, #334155); border-radius: 0; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s ease;">
                    <div style="height: 180px; width: 100%; background-image: url('${imageUrl}'); background-size: cover; background-position: center;"></div>
                    <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                            <span style="display: inline-block; padding: 0.25rem 0.5rem; border-radius: 0; font-size: 0.75rem; font-weight: 600; color: #ffffff; background-color: ${statusColor};">${statusText}</span>
                        </div>
                        <h3 style="margin: 0 0 1rem 0; font-size: 1.25rem; font-weight: 600; line-height: 1.4; color: white;">${post.title}</h3>
                        
                        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-size: 0.875rem; color: #94a3b8;">
                            <svg xmlns="http://www.w3.org/-2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            <span>${date}</span>
                        </div>
                        
                        <div style="margin-top: auto; display: flex; gap: 0.75rem;">
                            <a href="/admin/blog/${post.id}" class="btn" style="flex: 1; padding: 0.5rem; justify-content: center; background: #334155; color: white; border-radius: 0; text-decoration: none;">Editar</a>
                            <a href="/blog/${post.slug || post.id}" target="_blank" class="btn" style="flex: 1; padding: 0.5rem; justify-content: center; background: var(--color-primary, #6366f1); color: white; border-radius: 0; text-decoration: none;">Ver</a>
                        </div>
                    </div>
                </div>
            `;
        });
        
        html += '</div>';
        container.innerHTML = html;
    }

    // Lógica de filtrado
    window.applyFilters = () => {
        const searchInput = document.getElementById('searchInput');
        const sortFilter = document.getElementById('sortFilter');
        
        const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
        const sortValue = sortFilter ? sortFilter.value : '';

        // 1. Buscar
        let filtered = allPosts.filter(post => 
            post.title.toLowerCase().includes(searchTerm)
        );

        // 2. Ordenar
        if (sortValue === 'date-desc') {
            filtered.sort((a, b) => b.createdAt._seconds - a.createdAt._seconds);
        } else if (sortValue === 'date-asc') {
            filtered.sort((a, b) => a.createdAt._seconds - b.createdAt._seconds);
        } else if (sortValue === 'status-pub') {
            filtered = filtered.filter(p => p.published);
        } else if (sortValue === 'status-draft') {
            filtered = filtered.filter(p => !p.published);
        } else if (sortValue === 'category') {
            filtered.sort((a, b) => (a.category || '').localeCompare(b.category || ''));
        } else if (sortValue === 'tag') {
            filtered.sort((a, b) => (a.tags?.[0] || '').localeCompare(b.tags?.[0] || ''));
        }

        renderPosts(filtered);
    };

    // Configurar listeners una vez que carga
    setTimeout(() => {
        const searchInput = document.getElementById('searchInput');
        const sortFilter = document.getElementById('sortFilter');

        if (searchInput) searchInput.addEventListener('input', applyFilters);
        if (sortFilter) {
            sortFilter.addEventListener('change', () => {
                applyFilters();
                sortFilter.blur();
            });
        }
    }, 100);

    // Expose delete function globally
    window.deletePost = async (id) => {
        if (!confirm('¿Estás seguro de borrar este post?')) return;
        
        try {
             const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
             await fetch(`${API_BASE_URL}/blog/${id}`, {
                 method: 'DELETE',
                 headers: { 'Authorization': `Bearer ${token}` }
             });
             loadPosts(); // Reload
        } catch (e) {
            alert('Error eliminando post');
        }
    };

    loadPosts();
  </script>

  <style>
    /* Rotar ícono al abrir el select */
    #sortFilter:focus + #sortIconContainer {
        transform: rotate(180deg);
    }
  </style>
</DashboardLayout>
