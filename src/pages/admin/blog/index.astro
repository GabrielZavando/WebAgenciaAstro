
---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
---

<DashboardLayout title="Gestión del Blog" role="admin">
  <div class="blog-header">
      <h2>Artículos</h2>
      <a href="/admin/blog/new" class="btn btn-cta btn-new-post">+ Nuevo Post</a>
  </div>

  <div class="blog-toolbar">
      <div class="search-wrapper">
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar artículo por nombre...">
          <button type="button" class="btn btn-cta search-btn">Buscar</button>
      </div>
      <div class="select-wrapper sort-wrapper">
          <select id="sortFilter" class="sort-select">
              <option value="">Ordenar por defecto</option>
              <option value="status-pub">Estado: Publicado</option>
              <option value="status-draft">Estado: Borrador</option>
              <option value="date-desc">Fecha: Más recientes</option>
              <option value="date-asc">Fecha: Más antiguos</option>
              <option value="category">Categoría</option>
              <option value="tag">Etiqueta</option>
          </select>
          <span class="material-symbols-outlined select-field-arrow">expand_more</span>
      </div>
  </div>

  <div id="postsList">Cargando posts...</div>

  <ModalConfirm 
    slot="modals"
    id="deletePostModal"
    title="¿Eliminar Artículo?"
    message="¿Estás seguro de que deseas eliminar este artículo permanentemente? Esta acción no se puede deshacer."
    confirmText="Eliminar permanentemente"
    type="danger"
  />

  <script define:vars={{ API_BASE_URL }}>
    // Sistema de Logs Visuales para depuración
    function logToUI(message, type = 'info') {
        const container = document.getElementById('postsList');
        console.log(`[BlogAdmin] ${message}`);
        if (container && type === 'error') {
            container.innerHTML = `
                <div class="error-state">
                    <span class="material-symbols-outlined">bug_report</span>
                    <p><strong>Error de Sistema:</strong> ${message}</p>
                    <small>API URL: ${API_BASE_URL}</small>
                    <button onclick="location.reload()" class="btn btn-cta" style="margin-top: 1rem">Reintentar Carga Forzada</button>
                </div>
            `;
        }
    }

    function formatDate(dateData) {
        if (!dateData) return 'Sin fecha';
        try {
            if (dateData._seconds) return new Date(dateData._seconds * 1000).toLocaleDateString('es-CL');
            const date = new Date(dateData);
            if (!isNaN(date.getTime())) return date.toLocaleDateString('es-CL');
        } catch (e) {
            console.error('Error parsing date:', e);
        }
        return 'Fecha inválida';
    }

    async function loadPosts() {
        const container = document.getElementById('postsList');
        if (!container) return;
        
        container.innerHTML = '<div class="loading-state"><span class="material-symbols-outlined spinning">sync</span> Cargando artículos...</div>';
        
        try {
            logToUI(`Iniciando fetch a ${API_BASE_URL}/blog...`);
            const response = await fetch(`${API_BASE_URL}/blog`);
            
            if (!response.ok) {
                throw new Error(`Servidor respondió con status ${response.status}`);
            }
            
            const allPosts = await response.json();
            window._allPosts = allPosts; // Guardar globalmente para filtros
            renderPosts(allPosts);
            logToUI('Artículos cargados con éxito');

        } catch (error) {
            logToUI(error.message, 'error');
        }
    }

    function renderPosts(postsToRender) {
        const container = document.getElementById('postsList');
        if (!container) return;
        
        if (!Array.isArray(postsToRender) || postsToRender.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <span class="material-symbols-outlined">folder_open</span>
                    <p>No se encontraron artículos.</p>
                </div>
            `;
            return;
        }

        let html = '<div class="posts-grid">';
        postsToRender.forEach(post => {
            const date = formatDate(post.createdAt);
            const statusClass = post.published ? 'status-published' : 'status-draft';
            const statusText = post.published ? 'Publicado' : 'Borrador';
            const imageUrl = post.mainImage || post.coverImage || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=300&h=200&auto=format&fit=crop';
            
            html += `
                <article class="post-card">
                    <div class="post-image-wrapper">
                        <div class="post-image" style="background-image: url('${imageUrl}');"></div>
                        <span class="post-status-badge ${statusClass}">${statusText}</span>
                    </div>
                    <div class="post-content">
                        <div class="post-meta-top">
                            <span class="post-category-tag">${post.category || 'General'}</span>
                            <span class="post-date-text"><span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1rem; margin-right: 0.2rem;">calendar_today</span> ${date}</span>
                        </div>
                        <h3 class="post-title">${post.title}</h3>
                        <div class="post-actions-footer">
                            <div class="primary-actions">
                                <a href="/admin/blog/${post.id}" class="btn-cta__border"><span class="material-symbols-outlined">edit</span> <span>Editar</span></a>
                                <a href="/blog/${post.slug || post.id}" target="_blank" class="btn-cta"><span class="material-symbols-outlined">open_in_new</span> <span>Ver</span></a>
                            </div>
                            <button onclick="window.deletePost('${post.id}')" class="btn-cta__danger"><span class="material-symbols-outlined">delete</span></button>
                        </div>
                    </div>
                </article>
            `;
        });
        html += '</div>';
        container.innerHTML = html;
    }

    // Inicialización compatible con View Transitions
    function initBlogAdmin() {
        const searchInput = document.getElementById('searchInput');
        const sortFilter = document.getElementById('sortFilter');

        if (searchInput) {
            searchInput.addEventListener('input', () => {
                const term = searchInput.value.toLowerCase();
                const filtered = (window._allPosts || []).filter(p => 
                    (p.title || '').toLowerCase().includes(term) || 
                    (p.category || '').toLowerCase().includes(term)
                );
                renderPosts(filtered);
            });
        }

        if (sortFilter) {
            sortFilter.addEventListener('change', () => {
                const val = sortFilter.value;
                let sorted = [...(window._allPosts || [])];
                if (val === 'date-desc') sorted.sort((a,b) => (b.createdAt?._seconds || 0) - (a.createdAt?._seconds || 0));
                else if (val === 'date-asc') sorted.sort((a,b) => (a.createdAt?._seconds || 0) - (b.createdAt?._seconds || 0));
                renderPosts(sorted);
            });
        }

        loadPosts();
    }

    // Ejecutar en cada carga de página (incluyendo navegación SPA)
    document.addEventListener('astro:page-load', () => {
        if (window.location.pathname === '/admin/blog') {
            initBlogAdmin();
        }
    });

    // Fallback para carga inicial directa si astro:page-load ya pasó
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        if (window.location.pathname === '/admin/blog') initBlogAdmin();
    }

    window.deletePost = function(id) {
        if (!window.confirmModalHelpers) return;
        window.confirmModalHelpers.open('deletePostModal', async () => {
            try {
                const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
                const res = await fetch(`${API_BASE_URL}/blog/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!res.ok) throw new Error('Error al eliminar');
                if (window.showToast) window.showToast('Eliminado', 'success');
                loadPosts();
            } catch (e) {
                if (window.showToast) window.showToast(e.message, 'error');
            }
        });
    };
  </script>


</DashboardLayout>
```
