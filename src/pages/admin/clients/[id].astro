
---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';
const { id } = Astro.params;
---

<DashboardLayout title="Detalle de Cliente" role="admin">
  <div style="margin-bottom: 2rem;">
      <a href="/admin/clients" class="btn" style="color: var(--text-secondary); text-decoration: none;">&larr; Volver a Clientes</a>
  </div>

  <div id="clientDetails" style="margin-bottom: 3rem;">
      <h2>Cargando datos del cliente...</h2>
  </div>



  <script>
    import { apiClient } from "../../../lib/api-client";
    
    async function loadData() {
        try {
            const id = window.location.pathname.split('/').pop();
            
            // Load Client Info
            const client = await apiClient.get<any>(`/clients/${id}`);
            
            const clientDetails = document.getElementById('clientDetails');
            if (clientDetails) clientDetails.innerHTML = `
                <h2>${client.displayName || 'Sin nombre'}</h2>
                <p style="color: var(--text-secondary);">${client.email}</p>
                <div style="margin-top: 1rem;">
                    <span style="background: #374151; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">ID: ${client.uid}</span>
                </div>
            `;


        } catch (error) {
            console.error(error);
            if (window.modalHelpers) window.modalHelpers.openModal('errorLoadingClientModal');
        }
    }


    loadData();
  </script>

  <ModalMessage 
    slot="modals"
    id="errorLoadingClientModal"
    title="Error de Carga"
    message="Hubo un problema al cargar los datos del cliente."
    type="error"
  />
</DashboardLayout>
