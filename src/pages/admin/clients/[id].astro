
---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const { id } = Astro.params;
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
---

<AdminLayout title="Detalle de Cliente">
  <div style="margin-bottom: 2rem;">
      <a href="/admin/clients" class="btn" style="color: var(--text-secondary); text-decoration: none;">&larr; Volver a Clientes</a>
  </div>

  <div id="clientDetails" style="margin-bottom: 3rem;">
      <h2>Cargando datos del cliente...</h2>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
      <h3>Proyectos Asignados</h3>
      <button class="btn btn-primary" onclick="openCreateProjectModal()">Nuevo Proyecto</button>
  </div>

  <div id="projectsList">Cargando proyectos...</div>

  <!-- Simple Modal for creating project -->
  <dialog id="projectModal" style="padding: 2rem; border-radius: 8px; border: 1px solid #374151; background: #1f2937; color: white; min-width: 400px;">
      <h3 style="margin-top: 0;">Nuevo Proyecto</h3>
      <form id="createProjectForm">
          <div style="margin-bottom: 1rem;">
              <label style="display: block; margin-bottom: 0.5rem;">Título</label>
              <input type="text" name="title" required style="width: 100%; padding: 0.5rem; border-radius: 4px; border: 1px solid #374151; background: #111827; color: white;">
          </div>
          <div style="margin-bottom: 1rem;">
              <label style="display: block; margin-bottom: 0.5rem;">Descripción</label>
              <textarea name="description" style="width: 100%; padding: 0.5rem; border-radius: 4px; border: 1px solid #374151; background: #111827; color: white;"></textarea>
          </div>
          <div style="display: flex; justify-content: flex-end; gap: 1rem;">
              <button type="button" onclick="document.getElementById('projectModal').close()" class="btn" style="background: transparent; border: 1px solid #374151; color: white;">Cancelar</button>
              <button type="submit" class="btn btn-primary">Crear</button>
          </div>
      </form>
  </dialog>

  <script define:vars={{ id, API_BASE_URL }}>
    const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
    
    async function loadData() {
        try {
            // Load Client Info
            const clientRes = await fetch(`${API_BASE_URL}/clients/${id}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const client = await clientRes.json();
            
            document.getElementById('clientDetails').innerHTML = `
                <h2>${client.displayName || 'Sin nombre'}</h2>
                <p style="color: var(--text-secondary);">${client.email}</p>
                <div style="margin-top: 1rem;">
                    <span style="background: #374151; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">ID: ${client.uid}</span>
                </div>
            `;

            // Load Projects (Need an endpoint filtering by client? Or filter in frontend? 
            // Api endpoint: GET /projects returns all if admin. 
            // Better add filtering param to API or endpoint /projects?client=ID
            // Current implementation of ProjectsController.findAll checks role. 
            // Admin gets ALL projects. We need to filter by client ID in frontend or improve API.
            // Let's improve API later. For now, filter in frontend since we have all projects as admin.
            
            const projectsRes = await fetch(`${API_BASE_URL}/projects`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const allProjects = await projectsRes.json();
            const projects = allProjects.filter(p => p.clientId === id);
            
            const container = document.getElementById('projectsList');
            if (projects.length === 0) {
                container.innerHTML = '<p>Este cliente no tiene proyectos asignados.</p>';
            } else {
                let html = '<table class="table"><thead><tr><th>Proyecto</th><th>Estado</th><th>Fecha</th></tr></thead><tbody>';
                projects.forEach(p => {
                    html += `
                        <tr>
                            <td>
                                <strong>${p.title}</strong><br>
                                <span style="font-size: 0.8rem; color: #9ca3af;">${p.description || ''}</span>
                            </td>
                            <td>${p.status || 'pending'}</td>
                            <td>${new Date(p.createdAt._seconds * 1000).toLocaleDateString()}</td>
                        </tr>
                    `;
                });
                html += '</tbody></table>';
                container.innerHTML = html;
            }

        } catch (error) {
            console.error(error);
            alert('Error cargando datos');
        }
    }

    window.openCreateProjectModal = () => {
        document.getElementById('projectModal').showModal();
    };

    document.getElementById('createProjectForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = {
            clientId: id,
            title: formData.get('title'),
            description: formData.get('description'),
            status: 'active'
        };

        try {
            const res = await fetch(`${API_BASE_URL}/projects`, {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });
            
            if (!res.ok) throw new Error('Error creating project');
            
            document.getElementById('projectModal').close();
            e.target.reset();
            loadData(); // Reload projects

        } catch (error) {
            alert('Error creando proyecto: ' + error.message);
        }
    });

    loadData();
  </script>
</AdminLayout>
