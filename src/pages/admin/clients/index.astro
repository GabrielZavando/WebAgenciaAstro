
---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';
---

<DashboardLayout title="Gestión de Clientes" role="admin">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h2>Clientes</h2>
      <!-- Crear cliente podría ser invitando por email o creando user. Por ahora solo listamos existentes -->
      <button class="btn btn-primary" id="btnInviteClient">Invitar Cliente</button>
  </div>

  <div id="clientsList">Cargando clientes...</div>

  <script>
    import { apiClient } from "../../../lib/api-client"

    async function loadClients() {
      const container = document.getElementById('clientsList')
      if (!container) return

      try {
        const clients = await apiClient.get<any[]>('/clients')
        
        if (!clients || !Array.isArray(clients) || clients.length === 0) {
          container.innerHTML = '<p>No hay clientes registrados.</p>'
          return
        }

        let html = '<table class="table"><thead><tr><th>Nombre</th><th>Email</th><th>Desde</th><th>Acciones</th></tr></thead><tbody>'
        
        clients.forEach(client => {
          let date = '-'
          if (client.createdAt) {
            const timestamp = client.createdAt._seconds 
              ? client.createdAt._seconds * 1000 
              : client.createdAt
            date = new Date(timestamp).toLocaleDateString()
          }

          const name = client.displayName || 'Sin nombre'
          const uid = client.uid || client.id
          
          html += `
            <tr>
              <td>${name}</td>
              <td>${client.email}</td>
              <td>${date}</td>
              <td>
                <a href="/admin/clients/${uid}" class="btn" style="background: #374151; color: white; font-size: 0.8rem;">Ver Proyectos</a>
              </td>
            </tr>
          `
        })
        
        html += '</tbody></table>'
        container.innerHTML = html

      } catch (error) {
        console.error('Error cargando clientes:', error)
        container.innerText = 'Error cargando clientes. Asegúrate de tener permisos de Admin.'
      }
    }

    loadClients()

    document.getElementById('btnInviteClient')?.addEventListener('click', () => {
      if (window.modalHelpers) window.modalHelpers.openModal('pendingFeatureModal')
    })
  </script>

  <ModalMessage 
    slot="modals"
    id="pendingFeatureModal"
    title="Próximamente"
    message="La funcionalidad de invitación de clientes está pendiente de implementación."
    type="info"
  />
</DashboardLayout>
