---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let prospect = null;
let error = null;

try {
  if (!id) throw new Error('ID no proporcionado');
  const res = await fetch(`${API_URL}/forms/admin/prospects/${id}`);
  if (!res.ok) throw new Error('No se pudo obtener la información.');
  prospect = await res.json();
  if (!prospect) throw new Error('Prospecto no encontrado');
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<DashboardLayout title="Detalle del Contacto" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Contacto', href: '/admin/contacto' }, { label: 'Detalle' }]} role="admin">
  <div class="admin-container">
    <header class="header-actions">
      <div class="header-content">
        <div class="back-link-wrapper">
          <a href="/admin/contacto" class="back-link">
            <span class="material-symbols-outlined">arrow_back</span> Volver a Mensajes
          </a>
        </div>
        <div class="title-section">
          <h1>Hilo de Conversación</h1>
          <p class="text-muted">
            {prospect ? `Comunicación con ${prospect.name} (${prospect.email})` : 'Cargando...'}
          </p>
        </div>
      </div>
    </header>

    <main class="admin-content">
      {error ? (
        <div class="error-banner">
          <span class="material-symbols-outlined">report</span>
          <p>Error: {error}</p>
        </div>
      ) : prospect ? (
        <div class="prospect-details-container">
          {/* Metadata Card */}
          <div class="meta-card">
            <div class="meta-item">
              <span class="meta-label">Interesado</span>
              <span class="meta-value highlight">
                <span class="material-symbols-outlined">account_circle</span> {prospect.name}
              </span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Email</span>
              <span class="meta-value">
                <span class="material-symbols-outlined">mail</span>
                <a href={`mailto:${prospect.email}`} class="text-link">{prospect.email}</a>
              </span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Teléfono</span>
              <span class="meta-value">
                <span class="material-symbols-outlined">call</span>
                {prospect.phone || 'No provisto'}
              </span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Última actividad</span>
              <span class="meta-value">
                <span class="material-symbols-outlined">schedule</span>
                {formatDate(prospect.updatedAt || prospect.createdAt)}
              </span>
            </div>
          </div>

          {/* Conversación */}
          <div class="conversation">
            {prospect.conversations?.map((conv: any) => {
              const inMsg = conv.incomingMessage;
              const outMsg = conv.outgoingResponse;

              return (
                <>
                  {/* Mensaje del Prospecto */}
                  <div class="message client-message">
                    <div class="message-header">
                      <div class="user-info">
                        <div class="avatar-wrapper">
                          {prospect.name.charAt(0).toUpperCase()}
                        </div>
                        <div class="name-time">
                          <strong>{prospect.name}</strong>
                          <span class="time">{formatDate(inMsg.receivedAt)}</span>
                        </div>
                      </div>
                    </div>
                    <div class="message-body">
                      <p>{inMsg.content}</p>
                    </div>
                  </div>

                  {/* Respuesta del Admin */}
                  {outMsg && outMsg.content && (
                    <div class="message admin-message">
                      <div class="message-header">
                        <div class="user-info">
                          <div class="avatar-wrapper admin">
                             <span class="material-symbols-outlined">headset_mic</span>
                          </div>
                          <div class="name-time">
                            <strong>Administrador</strong>
                            <span class="time">{formatDate(outMsg.sentAt)}</span>
                          </div>
                        </div>
                      </div>
                      <div class="message-body">
                        <p>{outMsg.content}</p>
                      </div>
                    </div>
                  )}
                </>
              );
            })}
          </div>

          {/* Área de Respuesta */}
          <div class="message admin-message focus-message">
            <div class="message-header">
              <div class="user-info">
                <div class="avatar-wrapper admin">
                   <span class="material-symbols-outlined">reply</span>
                </div>
                <div class="name-time">
                  <strong>Responder Consulta</strong>
                </div>
              </div>
            </div>
            <div class="reply-body">
              <form id="reply-form">
                <input type="hidden" name="prospectId" id="prospectId" value={id} />
                <textarea 
                  id="replyContent" 
                  name="replyContent" 
                  placeholder="Escribe tu respuesta aquí..." 
                  required
                ></textarea>
                <div class="form-actions-wrapper">
                  <button type="submit" class="btn-cta" id="btn-submit-reply">
                    ENVIAR RESPUESTA
                  </button>
                </div>
                <div id="reply-feedback" class="feedback-msg"></div>
              </form>
            </div>
          </div>
        </div>
      ) : null}
    </main>
  </div>
</DashboardLayout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';
  const form = document.getElementById('reply-form') as HTMLFormElement;
  const submitBtn = document.getElementById('btn-submit-reply') as HTMLButtonElement;
  const feedback = document.getElementById('reply-feedback') as HTMLDivElement;
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const prospectId = (document.getElementById('prospectId') as HTMLInputElement).value;
      const replyContent = (document.getElementById('replyContent') as HTMLTextAreaElement).value;
      
      try {
        submitBtn.disabled = true;
        submitBtn.classList.add('btn-loading');
        feedback.className = 'feedback-msg'; // Reset
        feedback.textContent = '';
        
        const res = await fetch(`${API_URL}/forms/admin/prospects/${prospectId}/reply`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ replyContent })
        });
        
        const data = await res.json();
        
        if (res.ok && data.success) {
          feedback.textContent = "¡Respuesta enviada correctamente!";
          feedback.classList.add('success');
          form.reset();
          // Recargo luego de un retraso mínimo para mostrar el feed agregado (SSR)
          setTimeout(() => window.location.reload(), 1500);
        } else {
          throw new Error(data.message || 'Error desconocido');
        }
      } catch (err: any) {
         feedback.textContent = `Error: ${err.message}`;
         feedback.classList.add('error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('btn-loading');
      }
    });
  }
</script>
