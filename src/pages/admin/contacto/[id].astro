---
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import { apiClient } from '../../../lib/api-client'
import type {
  ContactoResponseDto,
  ConsultaResponse,
  DiagnosticoResponse,
} from '../../../types/api'

// Proteger la ruta — solo admins con sesión activa
const token = Astro.cookies.get('session')?.value
if (!token) {
  return Astro.redirect('/login')
}

const { id } = Astro.params

let contact: ContactoResponseDto | null = null
let errorMsg: string | null = null

try {
  if (!id) throw new Error('ID no proporcionado')

  const raw = await apiClient.get<any>(
    `/forms/admin/contactos/${id}`,
    { token },
  )
  // Normalizar contactoId → id
  contact = { ...raw, id: raw.contactoId ?? raw.id }
} catch (error: unknown) {
  const err = error as Error & { status?: number }
  if (err.status === 403) {
    errorMsg = 'No tienes permisos de Administrador para ver esta página.'
  } else {
    errorMsg = err.message
  }
  console.error('Error fetching contacto:', error)
}

const formatDate = (dateValue: unknown): string => {
  try {
    const d = dateValue as {
      _seconds?: number
      _nanoseconds?: number
    } | string | number | null
    const ts =
      typeof d === 'object' && d !== null && '_seconds' in d
        ? new Date((d._seconds ?? 0) * 1000)
        : d
        ? new Date(d as string | number)
        : new Date()
    if (isNaN(ts.getTime())) return 'Fecha inválida'
    return new Intl.DateTimeFormat('es-CL', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(ts)
  } catch {
    return 'Fecha desconocida'
  }
}

const statusLabel: Record<string, string> = {
  lead: 'Lead',
  client: 'Cliente',
  inactive: 'Inactivo',
}

const origenLabel = (o: string) =>
  o.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())

const pillarNames: Record<string, string> = {
  cultura: 'Cultura',
  estrategia: 'Estrategia',
  procesos: 'Procesos',
  tecnologia: 'Tecnología',
  datos: 'Datos',
}

// Pre-procesar diagnósticos en el frontmatter para evitar tipos
// genéricos complejos dentro del template
interface DiagProcessed {
  id: string
  nivel: string
  score: number | null
  situacion: string
  estado: string
  createdAt: unknown
  pillars: Array<{ key: string; label: string; value: number }>
}

const diagsProcesados: DiagProcessed[] = (
  contact?.diagnosticos ?? []
).map((diag): DiagProcessed => {
  const contenido = (diag.contenido ?? {}) as Record<string, unknown>
  const rawPillars = (contenido.pillarScores ?? {}) as Record<
    string,
    number
  >
  return {
    id: diag.diagnosticoId,
    nivel: (contenido.nivel as string) ?? 'N/A',
    score:
      contenido.score != null ? (contenido.score as number) : null,
    situacion:
      (contenido.situacion_actual_text as string | undefined) ?? '',
    estado: diag.estado,
    createdAt: diag.createdAt,
    pillars: Object.entries(rawPillars).map(([key, val]) => ({
      key,
      label: pillarNames[key] ?? key,
      value: val,
    })),
  }
})
---

<DashboardLayout
  title="Ficha del Contacto"
  breadcrumbs={[
    { label: 'Admin', href: '/admin' },
    { label: 'Contacto', href: '/admin/contacto' },
    { label: contact?.name ?? 'Ficha' },
  ]}
  role="admin"
>
  <div class="contact-detail-view">

    {/* Cabecera con volver */}
    <div class="header-actions">
      <a href="/admin/contacto" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span> Volver a Contactos
      </a>
    </div>

    {errorMsg && (
      <div class="error-banner">
        <span class="material-symbols-outlined">report</span> {errorMsg}
      </div>
    )}

    {contact && (
      <div class="detail-sections fade-in">

        {/* ── Sección 1: Información del contacto ── */}
        <section class="content-card contact-info-card">
          <div class="section-header">
            <span class="material-symbols-outlined section-icon">
              account_circle
            </span>
            <div>
              <h2>Información del Contacto</h2>
              <p class="text-muted">Datos registrados en el sistema.</p>
            </div>
          </div>

          <div class="info-grid">
            {/* Avatar + nombre */}
            <div class="info-avatar-col">
              <div class="contact-avatar-lg">
                {contact.name.charAt(0).toUpperCase()}
              </div>
            </div>

            <div class="info-fields-col">
              <div class="meta-item">
                <span class="meta-label">Nombre completo</span>
                <span class="meta-value highlight">
                  <span class="material-symbols-outlined">badge</span>
                  {contact.name}
                </span>
              </div>

              {contact.empresa && (
                <div class="meta-item">
                  <span class="meta-label">Empresa</span>
                  <span class="meta-value">
                    <span class="material-symbols-outlined">business</span>
                    {contact.empresa}
                  </span>
                </div>
              )}

              {contact.industria && (
                <div class="meta-item">
                  <span class="meta-label">Industria</span>
                  <span class="meta-value">
                    <span class="material-symbols-outlined">factory</span>
                    {contact.industria}
                  </span>
                </div>
              )}

              <div class="meta-item">
                <span class="meta-label">Correo electrónico</span>
                <span class="meta-value">
                  <span class="material-symbols-outlined">mail</span>
                  <a href={`mailto:${contact.email}`} class="text-link">
                    {contact.email}
                  </a>
                </span>
              </div>

              <div class="meta-item">
                <span class="meta-label">Teléfono</span>
                <span class="meta-value">
                  <span class="material-symbols-outlined">call</span>
                  {contact.phone || (
                    <span class="text-muted">No proporcionado</span>
                  )}
                </span>
              </div>

              <div class="meta-item">
                <span class="meta-label">Estado</span>
                <span class={`role-badge ${contact.status}`}>
                  {statusLabel[contact.status] ?? contact.status}
                </span>
              </div>

              <div class="meta-item">
                <span class="meta-label">Origen</span>
                <span class="badge badge--outline">
                  {origenLabel(contact.origen)}
                </span>
              </div>

              <div class="meta-item">
                <span class="meta-label">Registrado el</span>
                <span class="meta-value text-muted">
                  {formatDate(contact.createdAt)}
                </span>
              </div>
            </div>
          </div>
        </section>

        {/* ── Sección 2: Historial de Consultas ── */}
        <section class="content-card">
          <div class="section-header">
            <span class="material-symbols-outlined section-icon">forum</span>
            <div>
              <h2>Historial de Consultas</h2>
              <p class="text-muted">Mensajes recibidos y respuestas enviadas.</p>
            </div>
          </div>

          {(!contact.consultas || contact.consultas.length === 0) ? (
            <div class="empty-state-inline">
              <span class="material-symbols-outlined">chat_bubble</span>
              <p>No se registran consultas para este contacto.</p>
            </div>
          ) : (
            <div class="conversation">
              {contact.consultas.map((consulta: ConsultaResponse) => (
                <div class="message-group">
                  {/* Mensaje del cliente */}
                  <div class="message client-message">
                    <div class="message-header">
                      <div class="user-info">
                        <div class="avatar-wrapper">
                          {contact!.name.charAt(0).toUpperCase()}
                        </div>
                        <div class="name-time">
                          <strong>
                            {consulta.asunto || 'Consulta General'}
                          </strong>
                          <span class="time">{formatDate(consulta.fecha)}</span>
                        </div>
                      </div>
                    </div>
                    <div class="message-body">
                      <p>{consulta.contenido}</p>
                    </div>
                  </div>

                  {/* Respuesta admin o formulario */}
                  {consulta.respuesta ? (
                    <div class="message admin-message">
                      <div class="message-header">
                        <div class="user-info">
                          <div class="avatar-wrapper admin">
                            <span class="material-symbols-outlined">
                              headset_mic
                            </span>
                          </div>
                          <div class="name-time">
                            <strong>Respuesta Admin</strong>
                            <span class="time">
                              {formatDate(consulta.respuesta.fecha)}
                            </span>
                          </div>
                        </div>
                      </div>
                      <div class="message-body">
                        <p>{consulta.respuesta.contenido}</p>
                      </div>
                    </div>
                  ) : (
                    <div class="message admin-message focus-message">
                      <div class="reply-body">
                        <form
                          class="dynamic-reply-form"
                          data-consulta-id={consulta.consultaId}
                        >
                          <textarea
                            name="replyContent"
                            placeholder="Escribe tu respuesta aquí..."
                            required
                          ></textarea>
                          <div class="form-actions reply-actions">
                            <div class="feedback-msg"></div>
                            <button type="submit" class="btn-cta btn-sm">
                              <span class="material-symbols-outlined">
                                send
                              </span>
                              Enviar Respuesta
                            </button>
                          </div>
                        </form>
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </section>

        {/* ── Sección 3: Diagnósticos ── */}
        <section class="content-card">
          <div class="section-header">
            <span class="material-symbols-outlined section-icon">
              assessment
            </span>
            <div>
              <h2>Diagnósticos de Madurez Digital</h2>
              <p class="text-muted">
                Resultados completos de los diagnósticos realizados.
              </p>
            </div>
          </div>

          {diagsProcesados.length === 0 ? (
            <div class="empty-state-inline">
              <span class="material-symbols-outlined">analytics</span>
              <p>No se registran diagnósticos para este contacto.</p>
            </div>
          ) : (
            <div class="diagnosticos-list">
              {diagsProcesados.map((diag) => (
                <div class="diag-card">
                  {/* Cabecera del diagnóstico */}
                  <div class="diag-header">
                    <div class="diag-meta">
                      <span class={`badge nivel-badge nivel-${diag.nivel}`}>
                        Nivel: {diag.nivel}
                      </span>
                      {diag.score !== null && (
                        <span class="diag-score">
                          Puntuación total:&nbsp;
                          <strong>{diag.score}</strong>
                        </span>
                      )}
                      <span class="time">{formatDate(diag.createdAt)}</span>
                    </div>
                    <span
                      class={`badge ${
                        diag.estado === 'enviado'
                          ? 'badge--success'
                          : 'badge--warning'
                      }`}
                    >
                      {diag.estado === 'enviado'
                        ? 'Reporte enviado'
                        : 'Pendiente de envío'}
                    </span>
                  </div>

                  {/* Situación actual */}
                  {diag.situacion && (
                    <div class="diag-situacion">
                      <p class="meta-label">Situación actual</p>
                      <p class="diag-text">"{diag.situacion}"</p>
                    </div>
                  )}

                  {/* Pilares */}
                  {diag.pillars.length > 0 && (
                    <div class="diag-pillars">
                      <p class="meta-label">Puntuación por pilar</p>
                      <div class="pillars-grid">
                        {diag.pillars.map((p) => (
                          <div class="pillar-item">
                            <span class="pillar-name">{p.label}</span>
                            <div class="pillar-bar-wrap">
                              <div
                                class="pillar-bar"
                                style={`width: ${Math.min(
                                  100,
                                  Math.round((p.value / 3) * 100),
                                )}%`}
                              ></div>
                            </div>
                            <span class="pillar-score">{p.value}/3</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </section>

      </div>
    )}
  </div>
</DashboardLayout>

<script>
  const API_URL =
    (import.meta.env.PUBLIC_API_BASE_URL as string | undefined) ||
    'http://localhost:8080'

  const replyForms = document.querySelectorAll<HTMLFormElement>(
    '.dynamic-reply-form',
  )

  replyForms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const consultaId = form.dataset.consultaId
      const contactId = window.location.pathname.split('/').pop()
      const textarea = form.querySelector(
        'textarea',
      ) as HTMLTextAreaElement
      const submitBtn = form.querySelector(
        'button',
      ) as HTMLButtonElement
      const feedback = form.querySelector(
        '.feedback-msg',
      ) as HTMLDivElement

      try {
        submitBtn.disabled = true
        feedback.textContent = 'Enviando...'
        feedback.style.color = '#666'

        const sessionMatch = document.cookie.match(
          /(^|;)\s*session=([^;]+)/,
        )
        const token = sessionMatch ? sessionMatch[2] : ''

        const res = await fetch(
          `${API_URL}/forms/admin/contactos/${contactId}/consultas/${consultaId}/reply`,
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${token}`,
            },
            body: JSON.stringify({ message: textarea.value }),
          },
        )

        const data = (await res.json()) as { success?: boolean; message?: string }
        if (res.ok && data.success) {
          feedback.textContent = '✅ Enviado'
          feedback.style.color = 'green'
          textarea.disabled = true
          submitBtn.style.display = 'none'
          setTimeout(() => window.location.reload(), 1000)
        } else {
          throw new Error(data.message || 'Error al enviar')
        }
      } catch (err: unknown) {
        feedback.textContent = '❌ Error al enviar'
        feedback.style.color = 'red'
        submitBtn.disabled = false
      }
    })
  })
</script>

<style>
  .contact-detail-view {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }
  .back-link:hover {
    color: var(--color-primary);
    transform: translateX(-4px);
  }

  /* Cabecera de sección */
  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .section-header h2 {
    font-size: 1.15rem;
    margin: 0 0 0.25rem;
  }
  .section-header .text-muted {
    font-size: 0.875rem;
    margin: 0;
  }
  .section-icon {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-top: 0.1rem;
    flex-shrink: 0;
  }

  /* Grid de info del contacto */
  .info-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 640px) {
    .info-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-avatar-lg {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .info-fields-col {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .meta-item {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .meta-label {
    min-width: 165px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }
  .meta-value {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
  }
  .meta-value.highlight {
    font-weight: 600;
    font-size: 1.05rem;
  }
  .meta-value .material-symbols-outlined {
    font-size: 1.1rem;
    color: var(--color-primary);
  }
  .text-link {
    color: var(--color-primary);
    text-decoration: none;
  }
  .text-link:hover {
    text-decoration: underline;
  }

  .badge--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  /* Consultas */
  .conversation {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .message-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .message {
    border-radius: 8px;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .message-header {
    padding: 0.75rem 1rem;
    background: var(--color-surface-secondary, #f9f9f9);
    border-bottom: 1px solid var(--color-border);
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .avatar-wrapper {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .avatar-wrapper.admin {
    background: var(--color-secondary, #6b21a8);
  }
  .avatar-wrapper.admin .material-symbols-outlined {
    font-size: 1.1rem;
  }

  .name-time {
    display: flex;
    flex-direction: column;
  }
  .name-time strong {
    font-size: 0.9rem;
  }
  .time {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .message-body {
    padding: 1rem;
  }
  .message-body p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .admin-message {
    border-left: 3px solid var(--color-secondary, #6b21a8);
  }

  .focus-message {
    background: var(--color-surface, #faf5ff);
  }

  .reply-body {
    padding: 1rem;
  }

  .reply-body textarea {
    width: 100%;
    min-height: 90px;
    resize: vertical;
  }

  .reply-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .btn-sm {
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .btn-sm .material-symbols-outlined {
    font-size: 1rem;
  }

  .feedback-msg {
    font-size: 0.85rem;
  }

  /* Estado vacío inline */
  .empty-state-inline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    color: var(--color-text-muted);
    background: var(--color-surface-secondary, #f9f9f9);
    border-radius: 8px;
  }
  .empty-state-inline .material-symbols-outlined {
    font-size: 1.5rem;
    opacity: 0.5;
  }
  .empty-state-inline p {
    margin: 0;
    font-size: 0.9rem;
  }

  /* Diagnósticos */
  .diagnosticos-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .diag-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .diag-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .diag-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .nivel-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    background: var(--color-surface-secondary, #f0f0f0);
    color: var(--color-text-muted);
  }
  .nivel-badge.nivel-semilla { background: #fef9c3; color: #854d0e; }
  .nivel-badge.nivel-brote   { background: #d1fae5; color: #065f46; }
  .nivel-badge.nivel-arbol   { background: #dbeafe; color: #1e40af; }

  .diag-score {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .diag-situacion .diag-text {
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0.35rem 0 0;
    line-height: 1.6;
  }

  /* Pilares */
  .pillars-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .pillar-item {
    display: grid;
    grid-template-columns: 110px 1fr 40px;
    align-items: center;
    gap: 0.75rem;
  }

  .pillar-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .pillar-bar-wrap {
    background: var(--color-surface-secondary, #f0f0f0);
    border-radius: 99px;
    height: 8px;
    overflow: hidden;
  }

  .pillar-bar {
    height: 100%;
    background: var(--color-primary);
    border-radius: 99px;
    transition: width 0.5s ease;
  }

  .pillar-score {
    font-size: 0.82rem;
    font-weight: 600;
    text-align: right;
    color: var(--color-text);
  }

  /* detail-sections spacing */
  .detail-sections {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
</style>
