---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let prospect = null;
let error = null;

try {
  if (!id) throw new Error('ID no proporcionado');
  const res = await fetch(`${API_URL}/forms/admin/prospects/${id}`);
  if (!res.ok) throw new Error('No se pudo obtener la información.');
  prospect = await res.json();
  if (!prospect) throw new Error('Prospecto no encontrado');
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<DashboardLayout title="Detalle del Contacto" role="admin">
  <div class="admin-container">
    <header class="admin-header">
      <div class="header-content">
        <div class="back-link">
          <a href="/admin/contacto" class="btn-back">
            <span class="material-symbols-outlined">arrow_back</span> Volver a Mensajes
          </a>
        </div>
        <div class="title-section">
          <h1>Hilo de Conversación</h1>
          <p>
            {prospect ? `Comunicación con ${prospect.name} (${prospect.email})` : 'Cargando...'}
          </p>
        </div>
      </div>
    </header>

    <main class="admin-content">
      {error ? (
        <div class="error-message">
          <p><span class="material-symbols-outlined">report</span> Error: {error}</p>
        </div>
      ) : prospect ? (
        <div class="conversation-layout">
          <!-- Detalles del usuario -->
          <div class="user-sidebar">
             <div class="user-card">
               <div class="avatar-placeholder">
                  {prospect.name.charAt(0).toUpperCase()}
               </div>
               <h3>{prospect.name}</h3>
               
               <div class="info-group">
                 <label>Email</label>
                 <span><a href={`mailto:${prospect.email}`}>{prospect.email}</a></span>
               </div>
               <div class="info-group">
                 <label>Teléfono</label>
                 <span>{prospect.phone || 'No ha provisto teléfono'}</span>
               </div>
               <div class="info-group">
                 <label>Última actividad</label>
                 <span>{formatDate(prospect.updatedAt || prospect.createdAt)}</span>
               </div>
             </div>
          </div>

          <!-- Historial de mensajes y formulario de respuesta -->
          <div class="chat-section">
            <div class="messages-container">
              {prospect.conversations?.map((conv: any) => {
                const inMsg = conv.incomingMessage;
                const outMsg = conv.outgoingResponse;

                return (
                  <>
                    {/* Mensaje Entrante del Prospecto */}
                    <div class="message-bubble from-user">
                      <div class="message-meta">
                        <span class="sender">{prospect.name}</span>
                        <span class="time">{formatDate(inMsg.receivedAt)}</span>
                      </div>
                      <div class="message-content">
                        <p>{inMsg.content}</p>
                      </div>
                    </div>

                    {/* Mensaje Saliente del Administrador (si hay uno) */}
                    {outMsg && outMsg.content && (
                      <div class="message-bubble from-admin">
                        <div class="message-meta">
                          <span class="sender">Administrador</span>
                          <span class="time">{formatDate(outMsg.sentAt)}</span>
                        </div>
                        <div class="message-content">
                          <p>{outMsg.content}</p>
                        </div>
                      </div>
                    )}
                  </>
                );
              })}
            </div>

            <!-- Zona de Respuesta -->
            <div class="reply-container">
               <form id="reply-form" class="reply-form">
                 <input type="hidden" name="prospectId" id="prospectId" value={id} />
                 <div class="input-group">
                   <label for="replyContent">Enviar respuesta</label>
                   <textarea 
                     id="replyContent" 
                     name="replyContent" 
                     rows="4" 
                     placeholder="Escribe tu mensaje aquí..." 
                     required
                   ></textarea>
                 </div>
                 <div class="form-actions">
                   <button type="submit" class="btn-primary" id="btn-submit-reply">
                     <span class="material-symbols-outlined">send</span> Enviar Mensaje
                   </button>
                 </div>
                 <div id="reply-feedback" class="feedback-msg"></div>
               </form>
            </div>
          </div>
        </div>
      ) : null}
    </main>
  </div>
</DashboardLayout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';
  const form = document.getElementById('reply-form') as HTMLFormElement;
  const submitBtn = document.getElementById('btn-submit-reply') as HTMLButtonElement;
  const feedback = document.getElementById('reply-feedback') as HTMLDivElement;
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const prospectId = (document.getElementById('prospectId') as HTMLInputElement).value;
      const replyContent = (document.getElementById('replyContent') as HTMLTextAreaElement).value;
      
      try {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="material-symbols-outlined spinner">sync</span> Enviando...';
        feedback.className = 'feedback-msg'; // Reset
        feedback.textContent = '';
        
        const res = await fetch(`${API_URL}/forms/admin/prospects/${prospectId}/reply`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ replyContent })
        });
        
        const data = await res.json();
        
        if (res.ok && data.success) {
          feedback.textContent = "¡Respuesta enviada correctamente!";
          feedback.classList.add('success');
          form.reset();
          // Recargo luego de un retraso mínimo para mostrar el feed agregado (SSR)
          setTimeout(() => window.location.reload(), 1500);
        } else {
          throw new Error(data.message || 'Error desconocido');
        }
      } catch (err: any) {
         feedback.textContent = `Error: ${err.message}`;
         feedback.classList.add('error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-symbols-outlined">send</span> Enviar Mensaje';
      }
    });
  }
</script>
