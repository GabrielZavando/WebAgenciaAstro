---
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import ContactoTable from '../../../components/admin/ContactoTable.astro'
import { apiClient } from '../../../lib/api-client'
import type { ContactoResponseDto } from '../../../types/api'

// Proteger la ruta — solo admins con sesión activa
const token = Astro.cookies.get('session')?.value
if (!token) {
  return Astro.redirect('/login')
}

let contacts: ContactoResponseDto[] = []
let errorMsg: string | null = null

try {
  const rawData = await apiClient.get<any[]>(
    '/forms/admin/contactos',
    { token },
  )
  // Normalizar contactoId → id para el frontend
  contacts = rawData.map((c) => ({
    ...c,
    id: c.contactoId ?? c.id,
  }))
} catch (error: unknown) {
  const err = error as Error & { status?: number }
  if (err.status === 403) {
    errorMsg = 'No tienes permisos de Administrador para ver esta página.'
  } else {
    errorMsg = `Error al cargar contactos: ${err.message}`
  }
  console.error('Error fetching contactos:', error)
}
---

<DashboardLayout
  title="Gestión de Contactos"
  breadcrumbs={[
    { label: 'Admin', href: '/admin' },
    { label: 'Contacto' },
  ]}
  role="admin"
>
  <div class="users-table-view">
    <div class="header-actions">
      <div class="header-title-row">
        <div>
          <h1>Contactos</h1>
          <p class="text-muted">
            Lista de todos los leads y contactos recibidos.
          </p>
        </div>
      </div>

      <div class="header-search-row">
        <form class="search-form" onsubmit="return false;">
          <input
            type="text"
            id="contactSearch"
            class="search-input"
            placeholder="Buscar por nombre, correo o teléfono..."
            autocomplete="off"
          />
          <button type="submit" class="search-btn">Buscar</button>
        </form>
      </div>
    </div>

    {errorMsg && (
      <div class="error-banner">
        <span class="material-symbols-outlined">report</span> {errorMsg}
      </div>
    )}

    <div class="content-card fade-in">
      <ContactoTable contacts={contacts} />
    </div>
  </div>
</DashboardLayout>

<script>
  const searchInput = document.getElementById(
    'contactSearch',
  ) as HTMLInputElement
  const rows = document.querySelectorAll('.contact-row')

  searchInput?.addEventListener('input', () => {
    const term = searchInput.value.toLowerCase()
    rows.forEach((row) => {
      const name =
        row.querySelector('.user-name')?.textContent?.toLowerCase() ?? ''
      const email =
        row.querySelector('.contact-email')?.textContent?.toLowerCase() ?? ''
      const phone =
        row.querySelector('.contact-phone')?.textContent?.toLowerCase() ?? ''

      const match =
        name.includes(term) ||
        email.includes(term) ||
        phone.includes(term)

      ;(row as HTMLElement).style.display = match ? '' : 'none'
    })
  })
</script>
