---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

// Obtenemos el endpoint desde el env o formamos uno por default
const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let prospects = [];
let error = null;

try {
  // Petición a la API (NestJS)
  const res = await fetch(`${API_URL}/forms/admin/prospects`);
  if (!res.ok) {
    throw new Error('No se pudo obtener la lista de contactos');
  }
  prospects = await res.json();
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

// Helper de fechas
const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<DashboardLayout title="Administrar Contactos" role="admin">
  <div class="admin-container">
    <header class="admin-header">
      <div class="header-content">
        <div>
          <h1>Formularios de Contacto</h1>
          <p>Maneja las consultas de los clientes potenciales.</p>
        </div>
      </div>
    </header>

    <main class="admin-content">
      {error && (
        <div class="error-message">
          <p>Error: {error}</p>
        </div>
      )}

      {prospects.length === 0 && !error ? (
        <div class="empty-state">
          <p>No hay mensajes de contacto actualmente.</p>
        </div>
      ) : null}

      {prospects.length > 0 && (
        <div class="prospects-grid">
          {prospects.map((prospect: any) => {
             // La respuesta tiene al menos 1 msg, así que extraemos fecha y el mensaje original
             const conversationLength = prospect.conversations ? prospect.conversations.length : 0;
             const hasReplies = conversationLength > 1;

             return (
              <a href={`/admin/contacto/${prospect.prospectId}`} class="prospect-card">
                <div class="card-header">
                  <div class="prospect-info">
                    <h3 class="prospect-name">{prospect.name}</h3>
                    <span class="prospect-email">{prospect.email}</span>
                  </div>
                  <div class="interaction-status">
                    {hasReplies ? (
                      <span class="badge replied">Respondido</span>
                    ) : (
                      <span class="badge pending">Pendiente</span>
                    )}
                  </div>
                </div>

                <div class="card-body">
                  <p class="prospect-phone">
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">call</span> {prospect.phone || 'No provisto'}
                  </p>
                  <div class="latest-message">
                    <p class="message-preview">
                       {prospect.conversations?.[0]?.incomingMessage?.content?.substring(0, 100)}...
                    </p>
                  </div>
                </div>

                <div class="card-footer">
                   <div class="meta-info">
                     <span class="date-badge" title="Última actualización">
                       <span class="material-symbols-outlined" style="font-size: 0.9rem; margin-right: 0.25rem;">schedule</span>
                       {formatDate(prospect.updatedAt || prospect.createdAt)}
                     </span>
                     <span class="msgs-count">
                       <span class="material-symbols-outlined" style="font-size: 0.9rem; margin-right: 0.25rem;">forum</span>
                       {conversationLength} mensajes
                     </span>
                   </div>
                   <div class="view-thread">
                     Ver conversación <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.1rem; margin-left: 0.25rem;">arrow_forward</span>
                   </div>
                </div>
              </a>
             )
          })}
        </div>
      )}
    </main>
  </div>
</DashboardLayout>


