---
import DashboardLayout from "../../layouts/DashboardLayout.astro";

// Este componente sirve como referencia visual para el sistema de diseño "Flat Premium"
// Utiliza EXCLUSIVAMENTE clases definidas en src/styles y Google Material Symbols
---

<DashboardLayout title="Guía de Estilos">
  <div class="header-actions">
    <p class="text-lg text-muted">
      Esta página es la referencia oficial para el sistema de diseño <strong>Flat Premium</strong>. 
      Úsala para mantener la consistencia visual en todo el panel administrativo.
    </p>
  </div>

  <div class="post-form">
    <!-- Sección: Tipografía -->
    <section id="typography">
      <h2 class="title-section">Tipografía</h2>
      <div class="content-card">
        <div class="post-form">
          <div class="form-group">
            <span class="form-label">Heading 1</span>
            <h1>Montserrat Bold - 3rem</h1>
          </div>
          <div class="form-group">
            <span class="form-label">Heading 2</span>
            <h2>Montserrat Bold - 2.5rem</h2>
          </div>
          <div class="form-group">
            <span class="form-label">Heading 3</span>
            <h3>Montserrat SemiBold - 2rem</h3>
          </div>
          <div class="form-group">
            <span class="form-label">Heading 4</span>
            <h4>Montserrat SemiBold - 1.5rem</h4>
          </div>
          <div class="form-group">
            <span class="form-label">Heading 5</span>
            <h5>Montserrat Bold - 1.25rem</h5>
          </div>
          <div class="form-group">
            <span class="form-label">Heading 6</span>
            <h6>Montserrat Bold - 1.125rem</h6>
          </div>
          <hr style="border: 0; border-top: 1px solid var(--color-border); margin: 1rem 0;" />
          <div class="form-group">
            <span class="form-label">Texto XL</span>
            <p class="text-xl">
              Open Sans - 1.25rem. Texto para introducciones o secciones destacadas.
            </p>
          </div>
          <div class="form-group">
            <span class="form-label">Texto LG (Lead)</span>
            <p class="text-lg">
              Open Sans - 1.125rem. Párrafo destacado utilizado en el banner o inicios de página.
            </p>
          </div>
          <div class="form-group">
            <span class="form-label">Párrafo Estándar</span>
            <p class="parrafo">
              Open Sans - 1rem. Este es el texto base utilizado en todo el sitio. Mantiene una legibilidad óptima con un interlineado de 1.6.
            </p>
          </div>
          <div class="form-group">
            <span class="form-label">Texto Muted / Small</span>
            <p class="text-muted text-sm">
              Open Sans - 0.875rem. Utilizado para notas secundarias, fechas o información menos relevante.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Paleta de Colores -->
    <section id="colors">
      <h2 class="title-section">Paleta de Colores</h2>
      <div class="content-card">
        <div class="post-form">
          <div>
            <h3 class="title-sm form-label">Colores de Marca</h3>
            <div class="image-gallery">
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-primary);"></div>
                <div class="img-info">
                  <p class="img-title">Primary</p>
                  <p class="text-xs text-muted">--color-primary</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-secondary);"></div>
                <div class="img-info">
                  <p class="img-title">Secondary</p>
                  <p class="text-xs text-muted">--color-secondary</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-accent);"></div>
                <div class="img-info">
                  <p class="img-title">Accent</p>
                  <p class="text-xs text-muted">--color-accent</p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="title-sm form-label">Entorno y Superficie</h3>
            <div class="image-gallery">
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-body); border: 1px solid var(--color-border);"></div>
                <div class="img-info">
                  <p class="img-title">Body</p>
                  <p class="text-xs text-muted">--color-body</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-surface); border: 1px solid var(--color-border);"></div>
                <div class="img-info">
                  <p class="img-title">Surface</p>
                  <p class="text-xs text-muted">--color-surface</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-border);"></div>
                <div class="img-info">
                  <p class="img-title">Border</p>
                  <p class="text-xs text-muted">--color-border</p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="title-sm form-label">Estados</h3>
            <div class="image-gallery">
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-success);"></div>
                <div class="img-info">
                  <p class="img-title">Success</p>
                  <p class="text-xs text-muted">--color-success</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-error);"></div>
                <div class="img-info">
                  <p class="img-title">Error</p>
                  <p class="text-xs text-muted">--color-error</p>
                </div>
              </div>
              <div class="gallery-item">
                <div class="img-placeholder" style="background: var(--color-warning);"></div>
                <div class="img-info">
                  <p class="img-title">Warning</p>
                  <p class="text-xs text-muted">--color-warning</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Botones -->
    <section id="buttons">
      <h2 class="title-section">Botones</h2>
      <div class="content-card">
        <div class="post-form">
          <div class="form-group">
            <h3 class="title-sm form-label">Variantes Principales</h3>
            <div class="form-row">
              <button class="btn-cta">Primario (.btn-cta)</button>
              <button class="btn-cta__border">Borde (.btn-cta__border)</button>
              <button class="btn-cta__danger">Peligro (.btn-cta__danger)</button>
            </div>
          </div>
          <div class="form-group">
            <h3 class="title-sm form-label">Botones de Menú</h3>
            <div class="header-actions" style="padding: 1rem; background: var(--color-surface-secondary); display: inline-flex; gap: 1rem;">
              <button class="btn-menu active"><span class="material-symbols-outlined">home</span> Activo</button>
              <button class="btn-menu"><span class="material-symbols-outlined">settings</span> Normal</button>
            </div>
          </div>
          <div class="form-group">
            <h3 class="title-sm form-label">Grupos de Botones</h3>
            <div class="btn-group">
              <button class="btn-cta">Confirmar</button>
              <button class="btn-cta__border">Cancelar</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Tarjetas -->
    <section id="cards">
      <h2 class="title-section">Tarjetas</h2>
      <div class="image-gallery">
        <article class="post-card">
          <div class="post-image" style="background: var(--color-surface-secondary); height: 150px; display: flex; align-items: center; justify-content: center;">
            <span class="material-symbols-outlined text-muted" style="font-size: 48px;">image</span>
          </div>
          <div class="post-content">
            <h3 class="post-title">Título Post Card</h3>
            <p class="post-excerpt">Ejemplo de tarjeta utilizada para el blog y administración de contenidos.</p>
            <div class="btn-group">
              <button class="btn-cta">Ver</button>
              <button class="btn-cta__border">Editar</button>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Sección: Notificaciones -->
    <section id="notifications">
      <h2 class="title-section">Notificaciones (Dropdown/Pop-out)</h2>
      <div class="post-form">
        <div class="content-card" style="background: var(--color-surface-secondary); padding: 3rem; display: flex; justify-content: center;">
          <div class="notifications-dropdown show" style="position: relative; top: 0; right: 0; opacity: 1; visibility: visible; transform: none; pointer-events: auto;">
            <header class="notifications-dropdown__header">
              <h3>Notificaciones</h3>
            </header>
            <ul class="notifications-dropdown__list">
              <!-- Item No Leído (Muestra el fondo magenta) -->
              <li class="notifications-dropdown__item unread">
                <span class="nt-title">Nuevo Informe Recibido [NO LEÍDO]</span>
                <p class="nt-content">Este es un ejemplo de cómo se ve una notificación sin leer con el fondo magenta suave.</p>
                <div class="nt-date">Hoy a las 11:15 p. m.</div>
              </li>
              <!-- Item Leído -->
              <li class="notifications-dropdown__item">
                <span class="nt-title">Ticket de Soporte Respondido</span>
                <p class="nt-content">El equipo de soporte ha respondido a tu ticket sobre el acceso FTP.</p>
                <div class="nt-date">Ayer a las 09:12 a. m.</div>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="content-card" style="background: var(--color-surface-secondary); padding: 3rem; display: flex; flex-direction: column; align-items: center; gap: 1rem;">
          <h3 class="title-sm">Estado Vacío</h3>
          <div class="notifications-dropdown show" style="position: relative; top: 0; right: 0; opacity: 1; visibility: visible; transform: none; pointer-events: auto;">
            <header class="notifications-dropdown__header">
              <h3>Notificaciones</h3>
            </header>
            <ul class="notifications-dropdown__list">
              <div class="notification-empty text-muted" style="padding: 1.5rem; text-align: center;">No tienes notificaciones pendientes.</div>
            </ul>
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- Sección: Tablas -->
    <section id="tables">
      <h2 class="title-section">Tablas</h2>
      <div class="table-container">
        <table class="files-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>#001</td>
              <td>Referencia de Fila</td>
              <td><span class="badge badge--success">Completado</span></td>
              <td>
                <div class="btn-group">
                  <button class="btn-cta__border"><span class="material-symbols-outlined">edit</span></button>
                  <button class="btn-cta__danger"><span class="material-symbols-outlined">delete</span></button>
                </div>
              </td>
            </tr>
            <tr>
              <td>#002</td>
              <td>Error de Sistema</td>
              <td><span class="badge badge--error">Error</span></td>
              <td>
                <div class="btn-group">
                  <button class="btn-cta__border"><span class="material-symbols-outlined">edit</span></button>
                  <button class="btn-cta__danger"><span class="material-symbols-outlined">delete</span></button>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Sección: Formularios -->
    <section id="forms">
      <h2 class="title-section">Formularios</h2>
      <div class="content-card">
        <div class="post-form">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Input Texto</label>
              <input type="text" placeholder="Ej: Nombre de usuario" />
            </div>
            <div class="form-group">
              <label class="form-label">Selector (Wrapper Custom)</label>
              <div class="select-wrapper">
                <select>
                  <option>Opción Administrativa</option>
                  <option>Otra Opción</option>
                </select>
                <span class="material-symbols-outlined">expand_more</span>
              </div>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Selector Genérico (Chevron Auto)</label>
              <select>
                <option value="">Selecciona un estado...</option>
                <option value="1">Activo</option>
                <option value="2">Pendiente</option>
                <option value="3">Archivado</option>
              </select>
            </div>
            <div class="form-group">
               <!-- Espacio extra en la grilla -->
            </div>
          </div>
          <div class="form-group error">
            <label class="form-label">Estado de Error</label>
            <input type="text" value="Valor con error" />
            <span class="error-message">Campo obligatorio</span>
          </div>
          <div class="form-group">
            <label class="form-label">Área de Texto</label>
            <textarea placeholder="Descripción larga del contenido..."></textarea>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección: Iconos y Avatares -->
    <section id="icons">
      <h2 class="title-section">Iconos y Avatares</h2>
      <div class="content-card">
        <div class="post-form">
          <div>
            <h3 class="title-sm form-label">Iconografía Interfaz (Material Symbols)</h3>
            <div class="image-gallery">
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">home</span>
                <span class="text-xs text-bold">home</span>
              </div>
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">person</span>
                <span class="text-xs text-bold">person</span>
              </div>
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">mail</span>
                <span class="text-xs text-bold">mail</span>
              </div>
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">settings</span>
                <span class="text-xs text-bold">settings</span>
              </div>
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">delete</span>
                <span class="text-xs text-bold">delete</span>
              </div>
              <div class="gallery-item" style="text-align: center; padding: 1.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 32px; margin-bottom: 0.5rem; display: block;">edit</span>
                <span class="text-xs text-bold">edit</span>
              </div>
            </div>
          </div>
          
          <div>
            <h3 class="title-sm form-label">Avatares de Usuario</h3>
            <div class="form-row" style="align-items: center;">
              <img 
                src="https://ui-avatars.com/api/?name=Gabriel+Zavando&background=random" 
                class="user-avatar" 
                style="width: 60px; height: 60px; border: 2px solid var(--color-primary);"
              />
              <img 
                src="https://ui-avatars.com/api/?name=Admin&background=000&color=fff" 
                class="user-avatar" 
                style="width: 45px; height: 45px; border: 2px solid var(--color-border);"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</DashboardLayout>
