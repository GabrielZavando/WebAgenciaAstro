---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Panel de Administración" breadcrumbs={[{ label: 'Admin', href: '/admin' }]} role="admin">
  <div class="admin-dashboard">
    <div class="welcome-section">
      <h1 id="welcomeTitle">Bienvenido, Administrador</h1>
      <p class="text-muted">Gestión global de la plataforma: usuarios, clientes, proyectos y soporte.</p>
    </div>

    <div class="stats-grid" id="adminStatsGrid">
      <!-- Usuarios -->
      <div class="stat-card" draggable="true" data-id="users">
        <div class="stat-icon users-icon" id="usersIconContainer">
          <span class="material-symbols-outlined">manage_accounts</span>
        </div>
        <div class="stat-details">
          <h3>Usuarios</h3>
          <p id="usersCount">Cargando usuarios...</p>
          <a href="/admin/usuarios" class="btn-stat">Ver Usuarios</a>
        </div>
      </div>

      <!-- Clientes -->
      <div class="stat-card" draggable="true" data-id="clients">
        <div class="stat-icon clients-icon">
          <span class="material-symbols-outlined">apartment</span>
        </div>
        <div class="stat-details">
          <h3>Clientes</h3>
          <p id="clientsCount">Cargando clientes...</p>
          <a href="/admin/clients" class="btn-stat">Ver Clientes</a>
        </div>
      </div>

      <!-- Proyectos -->
      <div class="stat-card" draggable="true" data-id="projects">
        <div class="stat-icon project-icon">
          <span class="material-symbols-outlined">task</span>
        </div>
        <div class="stat-details">
          <h3>Proyectos</h3>
          <p id="projectsCount">Cargando proyectos...</p>
          <a href="/admin/proyectos" class="btn-stat">Ver Proyectos</a>
        </div>
      </div>

      <!-- Soporte (Tickets) -->
      <div class="stat-card" draggable="true" data-id="support">
        <div class="stat-icon support-icon">
          <span class="material-symbols-outlined">support_agent</span>
        </div>
        <div class="stat-details">
          <h3>Soporte</h3>
          <p id="ticketsCount">Cargando tickets...</p>
          <a href="/admin/tickets" class="btn-stat">Ver Tickets</a>
        </div>
      </div>

      <!-- Blog -->
      <div class="stat-card" draggable="true" data-id="blog">
        <div class="stat-icon blog-icon">
          <span class="material-symbols-outlined">edit_note</span>
        </div>
        <div class="stat-details">
          <h3>Blog</h3>
          <p id="blogCount">Cargando artículos...</p>
          <a href="/admin/blog" class="btn-stat">Gestionar Blog</a>
        </div>
      </div>

      <!-- Archivos -->
      <div class="stat-card" draggable="true" data-id="files">
        <div class="stat-icon files-icon">
          <span class="material-symbols-outlined">folder_open</span>
        </div>
        <div class="stat-details">
          <h3>Archivos</h3>
          <p id="filesCount">Gestión de archivos</p>
          <a href="/admin/archivos" class="btn-stat">Ver Archivos</a>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";
  import { apiClient } from "../../lib/api-client";
  const welcomeTitle = document.getElementById('welcomeTitle');
  const statsGrid = document.getElementById('adminStatsGrid');
  
  // Elementos de las cards
  const usersCount = document.getElementById('usersCount');
  const clientsCount = document.getElementById('clientsCount');
  const projectsCount = document.getElementById('projectsCount');
  const ticketsCount = document.getElementById('ticketsCount');
  const blogCount = document.getElementById('blogCount');
  const filesCount = document.getElementById('filesCount');

  // Aplicar orden guardado
  const savedOrder = localStorage.getItem('admin_dashboard_cards_order');
  if (savedOrder && statsGrid) {
    try {
      const order = JSON.parse(savedOrder);
      const cards = Array.from(statsGrid.children);
      order.forEach((id: string) => {
        const card = cards.find(c => c.getAttribute('data-id') === id);
        if (card) statsGrid.appendChild(card);
      });
    } catch (e) {
      console.error("Error cargando orden del dashboard admin", e);
    }
  }

  onAuthStateChanged(auth, async (user) => {
    if (user) {
      if (welcomeTitle) welcomeTitle.textContent = `Bienvenido, ${user.displayName || 'Administrador'}`;
      const token = await user.getIdToken();
      loadAdminDashboardData(token);
    }
  });

  async function loadAdminDashboardData(token: string) {
    // Cargar Usuarios
    apiClient.get<any[]>('users', { token })
      .then(data => { if (usersCount) usersCount.textContent = `${data.length || 0} usuarios registrados`; })
      .catch(() => { if (usersCount) usersCount.textContent = "Error al cargar"; });

    // Cargar Clientes
    apiClient.get<any[]>('clients', { token })
      .then(data => { if (clientsCount) clientsCount.textContent = `${data.length || 0} clientes activos`; })
      .catch(() => { if (clientsCount) clientsCount.textContent = "Error al cargar"; });

    // Cargar Proyectos (Global)
    apiClient.get<any[]>('projects', { token })
      .then(data => { if (projectsCount) projectsCount.textContent = `${data.length || 0} proyectos en total`; })
      .catch(() => { if (projectsCount) projectsCount.textContent = "Error al cargar"; });

    // Cargar Tickets (Global)
    apiClient.get<any[]>('support/tickets', { token })
      .then(data => { 
        const pending = data.filter((t: any) => t.status !== 'resolved').length;
        if (ticketsCount) ticketsCount.textContent = `${pending} ticket(s) pendiente(s)`; 
      })
      .catch(() => { if (ticketsCount) ticketsCount.textContent = "Error al cargar"; });

    // Cargar Blog
    apiClient.get<any[]>('blog', { token })
      .then(data => { if (blogCount) blogCount.textContent = `${data.length || 0} artículos publicados`; })
      .catch(() => { if (blogCount) blogCount.textContent = "Error al cargar"; });
  }

  // --- Lógica de Drag and Drop ---
  let draggedCard: HTMLElement | null = null;

  statsGrid?.querySelectorAll('.stat-card').forEach(cardElement => {
    const card = cardElement as HTMLElement;
    card.addEventListener('dragstart', (e) => {
      const de = e as DragEvent;
      draggedCard = card;
      draggedCard.classList.add('dragging');
      statsGrid?.classList.add('is-dragging-any');
      if (de.dataTransfer) de.dataTransfer.effectAllowed = 'move';
    });

    card.addEventListener('dragend', () => {
      draggedCard?.classList.remove('dragging');
      statsGrid?.classList.remove('is-dragging-any');
      draggedCard = null;
      saveCurrentOrder();
    });

    card.addEventListener('dragover', (e) => {
      const de = e as DragEvent;
      de.preventDefault();
      if (!draggedCard || draggedCard === card) return;
      const rect = card.getBoundingClientRect();
      const midpoint = rect.left + rect.width / 2;
      if (de.clientX < midpoint) {
        statsGrid.insertBefore(draggedCard, card);
      } else {
        statsGrid.insertBefore(draggedCard, card.nextSibling);
      }
    });
  });

  function saveCurrentOrder() {
    if (!statsGrid) return;
    const order = Array.from(statsGrid.children).map(c => c.getAttribute('data-id'));
    localStorage.setItem('admin_dashboard_cards_order', JSON.stringify(order));
  }
</script>

