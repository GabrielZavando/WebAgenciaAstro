---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ReportTable from '../../../components/admin/ReportTable.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Gestión de Informes" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Informes' }]} role="admin">
  <div class="reports-admin">
    <div class="header-actions">
      <div>
        <h1>Gestión de Informes</h1>
        <p class="text-muted">Sube y gestiona informes PDF para tus clientes.</p>
      </div>
    </div>

    <!-- Formulario de Subida -->
    <div class="content-card fade-in">
      <div class="section-header">
        <h2 class="section-title"><span class="material-symbols-outlined">upload_file</span> Enviar Nuevo Informe</h2>
      </div>
      
      <form id="uploadReportForm" class="report-form">
        <div class="form-row">
          <div class="form-group">
            <label for="clientSelect">Cliente <span class="required">*</span></label>
            <div class="select-wrapper">
              <select id="clientSelect" name="clientId" required>
                <option value="">Selecciona un cliente...</option>
              </select>
            </div>
          </div>
          
          <div class="form-group">
            <label for="projectSelect">Proyecto <span class="required">*</span></label>
            <div class="select-wrapper">
              <select id="projectSelect" name="projectId" required>
                <option value="">Selecciona un proyecto...</option>
              </select>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label for="title">Título del Informe <span class="required">*</span></label>
          <input type="text" id="title" name="title" required placeholder="Ej: Informe Mensual Mantenimiento - Marzo 2024" />
        </div>

        <div class="form-group">
          <label for="description">Descripción (opcional)</label>
          <textarea id="description" name="description" rows="3" placeholder="Breve resumen del contenido del informe..."></textarea>
        </div>

        <div class="form-group">
          <label>Archivo PDF <span class="required">*</span></label>
          <div class="file-drop file-drop--mini" id="dropZone">
            <input type="file" id="reportFile" name="file" accept="application/pdf" class="file-input-hidden" required />
            <div id="uploadInfo">
              <span class="material-symbols-outlined">cloud_upload</span>
              <p>Arrastra o selecciona el archivo PDF</p>
              <small class="file-types">Máximo recomendado: 10MB</small>
            </div>
          </div>

          <div class="file-selected-info hidden" id="selectedFileInfo">
            <span class="material-symbols-outlined">picture_as_pdf</span>
            <div class="file-details">
              <span class="file-name" id="fileNameDisplay">nombre-archivo.pdf</span>
              <span class="file-size" id="fileSizeDisplay">1.2 MB</span>
            </div>
            <button type="button" class="btn-remove-file" id="removeFileBtn" title="Quitar archivo">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-cta" id="submitBtn" disabled>
            Enviar Informe
            <span class="material-symbols-outlined">send</span>
          </button>
        </div>
      </form>
    </div>

    <!-- Listado de Informes -->
    <div class="content-card fade-in">
      <div class="section-header">
        <h2 class="section-title"><span class="material-symbols-outlined">history</span> Informes Enviados</h2>
      </div>
      <ReportTable role="admin" id="adminReportsTable" allowDelete={true} />
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth, db } from "../../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const form = document.getElementById('uploadReportForm') as HTMLFormElement;
  const clientSelect = document.getElementById('clientSelect') as HTMLSelectElement;
  const projectSelect = document.getElementById('projectSelect') as HTMLSelectElement;
  const reportsTableBody = document.getElementById('reportsTableBody');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const fileInput = document.getElementById('reportFile') as HTMLInputElement;
  const dropZone = document.getElementById('dropZone');
  const uploadInfo = document.getElementById('uploadInfo');
  const selectedFileInfo = document.getElementById('selectedFileInfo');
  const fileNameDisplay = document.getElementById('fileNameDisplay');
  const fileSizeDisplay = document.getElementById('fileSizeDisplay');
  const removeFileBtn = document.getElementById('removeFileBtn');
  const titleInput = document.getElementById('title') as HTMLInputElement;

  // Declare global for showToast
  declare const showToast: (msg: string, type?: 'success' | 'error' | 'info') => void;

  let currentToken = '';
  let allClients: any[] = [];

  onAuthStateChanged(auth, async (user) => {
    if (!user) return;
    currentToken = await user.getIdToken();
    loadClients();
  });

  async function loadClients() {
    try {
      const res = await fetch(`${API_URL}/clients`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) throw new Error();
      allClients = await res.json();
      populateClientSelect();
    } catch (e) {
      console.error('Error cargando clientes:', e);
    }
  }

  function populateClientSelect() {
    if (!clientSelect) return;
    const options = allClients.map(c => `
      <option value="${c.uid || c.id}">${c.displayName || c.name || 'Sin nombre'} (${c.email})</option>
    `);
    clientSelect.innerHTML = '<option value="">Selecciona un cliente...</option>' + options.join('');
  }

  clientSelect?.addEventListener('change', async () => {
    const clientId = clientSelect.value;
    if (!clientId) {
      projectSelect.innerHTML = '<option value="">Selecciona un proyecto...</option>';
      validateForm();
      return;
    }

    try {
      projectSelect.innerHTML = '<option value="">Cargando proyectos...</option>';
      const res = await fetch(`${API_URL}/projects/client/${clientId}`, {
        headers: { 'Authorization': `Bearer ${currentToken}` }
      });
      if (!res.ok) throw new Error();
      const projects = await res.json();
      
      const options = projects.map((p: any) => `
        <option value="${p.id}" data-name="${p.name}">${p.name}</option>
      `);
      projectSelect.innerHTML = '<option value="">Selecciona un proyecto...</option>' + options.join('');
    } catch (e) {
      projectSelect.innerHTML = '<option value="">Error al cargar proyectos</option>';
    } finally {
      validateForm();
    }
  });

  titleInput?.addEventListener('input', validateForm);
  projectSelect?.addEventListener('change', validateForm);

  // --- Manejo de Archivos ---
  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) {
      updateFileUI(file);
    } else {
      resetFileUI();
    }
    validateForm();
  });

  removeFileBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    fileInput.value = '';
    resetFileUI();
    validateForm();
  });

  // Drag & Drop
  ['dragenter', 'dragover'].forEach(eventName => {
    dropZone?.addEventListener(eventName, (e) => {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });
  });

  ['dragleave', 'drop'].forEach(eventName => {
    dropZone?.addEventListener(eventName, (e) => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      
      if (eventName === 'drop') {
        const dt = (e as DragEvent).dataTransfer;
        const files = dt?.files;
        if (files && files.length > 0) {
          fileInput.files = files;
          // Disparamos el evento change manualmente para que se actualice la UI
          fileInput.dispatchEvent(new Event('change'));
        }
      }
    });
  });

  function updateFileUI(file: File) {
    if (!uploadInfo || !selectedFileInfo || !fileNameDisplay || !fileSizeDisplay) return;
    
    uploadInfo.classList.add('hidden');
    selectedFileInfo.classList.remove('hidden');
    
    fileNameDisplay.textContent = file.name;
    const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
    fileSizeDisplay.textContent = `${sizeMB} MB`;
  }

  function resetFileUI() {
    uploadInfo?.classList.remove('hidden');
    selectedFileInfo?.classList.add('hidden');
  }

  function validateForm() {
    const isClientValid = clientSelect.value !== '';
    const isProjectValid = projectSelect.value !== '';
    const isTitleValid = (document.getElementById('title') as HTMLInputElement).value.trim() !== '';
    const isFileValid = fileInput.files && fileInput.files.length > 0;

    submitBtn.disabled = !(isClientValid && isProjectValid && isTitleValid && isFileValid);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    const formData = new FormData(form);
    const selectedProjectOption = projectSelect.options[projectSelect.selectedIndex];
    const projectName = selectedProjectOption.getAttribute('data-name');
    
    if (projectName) {
      formData.append('projectName', projectName);
    }

    submitBtn.disabled = true;
    submitBtn.classList.add('btn-loading');
    showToast('Subiendo informe...', 'info');

    try {
      const res = await fetch(`${API_URL}/reports`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${currentToken}`
        },
        body: formData
      });

      if (res.ok) {
        showToast('Informe enviado correctamente', 'success');
        form.reset();
        resetFileUI();
        validateForm();
        // Ya no necesitamos loadReports() porque el listener se encarga
      } else {
        const error = await res.json();
        showToast(error.message || 'Error al enviar el informe', 'error');
        submitBtn.disabled = false;
      }
    } catch (e) {
      showToast('Error de conexión con el servidor', 'error');
      submitBtn.disabled = false;
      submitBtn.classList.remove('btn-loading');
    }
  });
</script>


