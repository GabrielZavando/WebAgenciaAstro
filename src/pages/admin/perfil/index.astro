---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

// Opcional: Obtener datos actuales del backend
let userProfile = null;
try {
  const response = await fetch(`${API_URL}/users/profile`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    userProfile = await response.json();
  }
} catch (e) {
  console.error("Error fetching profile details:", e);
}
---

<DashboardLayout title="Mi Perfil" role="admin">
  <div class="header-actions">
    <div>
      <h1>Configuración de Perfil</h1>
      <p class="text-muted">Actualiza tu información personal y contraseña.</p>
    </div>
  </div>

  <div class="profile-grid fade-in">
    <!-- Columna 1: Datos Personales (Firestore via Backend) -->
    <div class="content-card">
      <div class="card-header">
        <h3>Datos Personales</h3>
      </div>
      <div class="card-body">
        <form id="profileForm" class="user-form" enctype="multipart/form-data">
          <div class="avatar-section full-width">
            <div class="avatar-container">
              <img id="avatarPreview" src={userProfile?.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(userProfile?.displayName || 'User')}&background=random&color=fff`} alt="Profile Avatar" class="profile-avatar" />
              <button type="button" class="avatar-edit-btn" onclick="document.getElementById('avatar').click()" aria-label="Editar foto de perfil" title="Cambiar foto">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
              </button>
              <input type="file" id="avatar" name="avatar" accept=".jpg, .jpeg, .png, .webp" class="hidden-file-input" />
            </div>
            <div class="user-name-display">
              <h2>{userProfile?.displayName || 'Usuario'}</h2>
            </div>
          </div>

          <div class="form-group">
            <label for="displayName">Nombre Completo</label>
            <input type="text" id="displayName" name="displayName" value={userProfile?.displayName || ''} required />
          </div>
          
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" value={userProfile?.email || ''} disabled title="El correo no se puede cambiar" />
            <small class="help-text">Contacta a soporte principal si necesitas cambiar tu correo.</small>
          </div>

          <div class="form-group">
            <label for="phone">Teléfono de contacto</label>
            <input type="tel" id="phone" name="phone" value={userProfile?.phone || ''} placeholder="+56 9 1234 5678" />
          </div>
          <div class="form-group full-width">
            <label for="description">Descripción (Para tu perfil público)</label>
            <textarea id="description" name="description" rows="3" placeholder="Ej. Desarrollador de software con 5 años de experiencia...">{userProfile?.description || ''}</textarea>
          </div>


          <div id="profileFeedback" class="feedback-message hidden"></div>

          <div class="form-actions">
            <button type="submit" class="btn-primary" id="saveProfileBtn">
              <span class="btn-text">Guardar Cambios</span>
              <span class="loader hidden"></span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Columna 2: Seguridad (Firebase Auth Client) -->
    <div class="content-card">
      <div class="card-header">
        <h3>Seguridad</h3>
      </div>
      <div class="card-body">
        <form id="passwordForm" class="user-form">
          <div class="form-group">
            <label for="newPassword">Nueva Contraseña</label>
            <input type="password" id="newPassword" name="newPassword" placeholder="Mínimo 6 caracteres" minlength="6" required />
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirmar Nueva Contraseña</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required />
          </div>

          <div id="passwordFeedback" class="feedback-message hidden"></div>

          <div class="form-actions">
            <button type="submit" class="btn-primary" id="savePasswordBtn">
              <span class="btn-text">Cambiar Contraseña</span>
              <span class="loader hidden"></span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../../lib/firebase/client";
  import { updatePassword } from "firebase/auth";

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

  /** FORM DATOS PERSONALES **/
  const profileForm = document.getElementById('profileForm') as HTMLFormElement;
  const saveProfileBtn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
  const profileFeedback = document.getElementById('profileFeedback');
  const avatarInput = document.getElementById('avatar') as HTMLInputElement;
  const avatarPreview = document.getElementById('avatarPreview') as HTMLImageElement;

  avatarInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      if (file.size > 2 * 1024 * 1024) {
        if(profileFeedback) showFeedback(profileFeedback, 'La imagen supera los 2MB permitidos.', 'error');
        avatarInput.value = '';
        return;
      }
      avatarPreview.src = URL.createObjectURL(file);
    }
  });

  profileForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!saveProfileBtn || !profileFeedback || !auth.currentUser) return;

    setLoading(saveProfileBtn, true);
    
    try {
      const token = await auth.currentUser.getIdToken();
      const formData = new FormData(profileForm);
      // Opcionalmente podemos validar el size en cliente
      if (avatarInput?.files?.[0]) {
        if (avatarInput.files[0].size > 2 * 1024 * 1024) {
          showFeedback(profileFeedback, 'La imagen supera los 2MB permitidos.', 'error');
          setLoading(saveProfileBtn, false);
          return;
        }
      }

      const response = await fetch(`${API_URL}/users/profile`, {
        method: 'PATCH',
        headers: {
          // No seteamos Content-Type para que el browser genere el boundary correcto del multipart/form-data
          'Authorization': `Bearer ${token}`
        },
        body: formData
      });

      if (response.ok) {
        showFeedback(profileFeedback, 'Perfil actualizado correctamente.', 'success');
        // Usamos reload para que onAuthStateChanged se gatille rápido y descargue el nuevo avatar en la topbar
        setTimeout(() => window.location.reload(), 1500);
      } else {
        showFeedback(profileFeedback, 'Error al actualizar perfil.', 'error');
      }
    } catch (error) {
      showFeedback(profileFeedback, 'Error de conexión.', 'error');
    } finally {
      setLoading(saveProfileBtn, false);
    }
  });


  /** FORM CONTRASEÑA **/
  const passwordForm = document.getElementById('passwordForm') as HTMLFormElement;
  const savePasswordBtn = document.getElementById('savePasswordBtn') as HTMLButtonElement;
  const passwordFeedback = document.getElementById('passwordFeedback');

  passwordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!savePasswordBtn || !passwordFeedback || !auth.currentUser) return;

    const newPassword = (document.getElementById('newPassword') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    if (newPassword !== confirmPassword) {
      showFeedback(passwordFeedback, 'Las contraseñas no coinciden.', 'error');
      return;
    }

    setLoading(savePasswordBtn, true);
    
    try {
      await updatePassword(auth.currentUser, newPassword);
      showFeedback(passwordFeedback, 'Contraseña cambiada exitosamente.', 'success');
      passwordForm.reset();
    } catch (error: any) {
      if (error.code === 'auth/requires-recent-login') {
        showFeedback(passwordFeedback, 'Por seguridad, debes cerrar sesión y volver a entrar para cambiar tu contraseña.', 'error');
      } else {
        showFeedback(passwordFeedback, `Error: ${error.message}`, 'error');
      }
    } finally {
      setLoading(savePasswordBtn, false);
    }
  });

  // Utilidades
  function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
    const text = btn.querySelector('.btn-text');
    const loader = btn.querySelector('.loader');
    btn.disabled = isLoading;
    if (isLoading) {
      text?.classList.add('hidden');
      loader?.classList.remove('hidden');
    } else {
      text?.classList.remove('hidden');
      loader?.classList.add('hidden');
    }
  }

  function showFeedback(el: HTMLElement, message: string, type: 'error' | 'success') {
    el.textContent = message;
    el.className = `feedback-message ${type}`;
    setTimeout(() => {
      el.className = 'feedback-message hidden';
    }, 5000);
  }
</script>

<style>
  .header-actions { margin-bottom: 2rem; }
  .header-actions h1 { margin: 0 0 0.5rem 0; font-size: 1.75rem; }
  .text-muted { color: var(--color-text-muted); margin: 0; }
  .profile-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; align-items: start; }
  .content-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
  .card-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--color-border); background: rgba(0,0,0,0.02); }
  .card-header h3 { margin: 0; font-size: 1.125rem; }
  .card-body { padding: 1.5rem; }
  .user-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group.full-width { grid-column: 1 / -1; }
  label { font-weight: 500; color: var(--color-text); }
  .help-text { font-size: 0.75rem; color: var(--color-text-muted); }
  input, textarea { padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-background); color: var(--color-text); font-family: inherit; font-size: 1rem; transition: border-color 0.2s, box-shadow 0.2s; }
  input:focus, textarea:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 2px rgba(var(--color-primary-rgb), 0.1); }
  input:disabled { opacity: 0.6; cursor: not-allowed; }
  
  /* Avatar Redesign */
  .avatar-section { display: flex; align-items: center; gap: 2rem; margin-bottom: 0.5rem; }
  .avatar-container { position: relative; width: 120px; height: 120px; flex-shrink: 0; }
  .profile-avatar { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 3px solid var(--color-background); box-shadow: var(--shadow-sm); background: var(--color-surface); }
  .avatar-edit-btn { position: absolute; bottom: 0; right: 0; width: 36px; height: 36px; border-radius: 10px; background: var(--color-surface); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--color-text); transition: all 0.2s; padding: 0; }
  .avatar-edit-btn:hover { background: var(--color-background-hover); color: var(--color-primary); transform: translateY(-2px); }
  .hidden-file-input { display: none; }
  .user-name-display h2 { margin: 0; font-size: 2rem; color: var(--color-text); letter-spacing: -0.02em; }
  @media (max-width: 768px) {
    .avatar-section { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }
  .form-actions { display: flex; justify-content: flex-end; margin-top: 0.5rem; }
  .btn-primary { background: var(--color-primary); color: white; padding: 0.875rem 1.5rem; border: none; border-radius: var(--radius-md); font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; min-width: 140px; font-size: 0.95rem; transition: opacity 0.2s; }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }
  .feedback-message { padding: 1rem; border-radius: var(--radius-md); text-align: center; font-weight: 500; }
  .feedback-message.error { background: rgba(var(--color-error-rgb), 0.1); color: var(--color-error); border: 1px solid rgba(var(--color-error-rgb), 0.2); }
  .feedback-message.success { background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2); }
  .hidden { display: none; }
  .loader { width: 20px; height: 20px; border: 2px solid #ffffff; border-bottom-color: transparent; border-radius: 50%; display: inline-block; box-sizing: border-box; animation: rotation 1s linear infinite; }
  @keyframes rotation { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>
