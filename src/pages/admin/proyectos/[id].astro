---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { apiClient } from '../../../lib/api-client';

const { id } = Astro.params;

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Editar Proyecto | Panel Admin" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Proyectos', href: '/admin/proyectos' }, { label: 'Detalle' }]} role="admin">
  <div class="project-form-container" data-project-id={id}>
    <div class="form-header">
      <a href="/admin/proyectos" class="btn-back">
        <span class="material-symbols-outlined">arrow_back</span> Volver al listado
      </a>
      <h1>Editar Proyecto</h1>
      <p class="text-muted">Actualiza el estado, progreso y detalles del proyecto.</p>
    </div>

    <div class="form-card flat-card">
      <form id="editProjectForm">
        <input type="hidden" name="id" value={id} />
        
        <div class="form-grid">
          <div class="form-section-title">Información General</div>
          
          <div class="form-group full-width">
            <label for="projectName">Nombre del Proyecto</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">task</span>
              <input type="text" id="projectName" name="name" required />
            </div>
          </div>

          <div class="form-group full-width">
            <label for="projectClient">Cliente o Responsable</label>
            <div class="input-with-icon select-wrapper">
              <span class="material-symbols-outlined">account_circle</span>
              <select id="projectClient" name="clientId" required>
                <option value="" disabled>Selecciona un usuario</option>
              </select>
            </div>
          </div>

          <div class="form-section-title">Estado y Seguimiento</div>

          <div class="form-group">
            <label for="projectStatus">Estado</label>
            <div class="input-with-icon select-wrapper">
              <span class="material-symbols-outlined">toggle_on</span>
              <select id="projectStatus" name="status" required>
                <option value="pending">Pendiente</option>
                <option value="in-progress">En progreso</option>
                <option value="completed">Finalizado</option>
                <option value="on-hold">En pausa</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="projectPercentage">Progreso (%)</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">trending_up</span>
              <input 
                type="number" 
                id="projectPercentage" 
                name="percentage" 
                min="0" 
                max="100" 
                required 
              />
            </div>
          </div>

          <div class="form-group full-width">
            <label for="monthlyTicketLimit">Límite Mensual de Tickets</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">confirmation_number</span>
              <input 
                type="number" 
                id="monthlyTicketLimit" 
                name="monthlyTicketLimit" 
                min="1" 
                required 
              />
            </div>
          </div>

          <div class="form-group full-width">
            <label for="projectDescription">Descripción</label>
            <textarea id="projectDescription" name="description" rows="5" required></textarea>
          </div>
        </div>

        <div class="form-actions">
           <button type="submit" class="btn btn-cta" id="saveBtn">
             Guardar cambios <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.1rem; margin-left:0.25rem;">save</span>
           </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { initEditProject } from "../../../scripts/proyectos/edit"
  initEditProject()
</script>


