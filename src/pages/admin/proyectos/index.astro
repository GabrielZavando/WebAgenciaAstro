---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ProjectTable from '../../../components/admin/ProjectTable.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Gestión de Proyectos" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Proyectos' }]} role="admin">
  <div class="users-table-view"> <!-- Reusing existing class for layout consistency -->
    <div class="header-actions">
      <div class="header-title-row">
        <div>
          <h1>Proyectos</h1>
          <p class="text-muted">Administración de proyectos y asignaciones.</p>
        </div>
        <div class="header-right">
          <a href="/admin/proyectos/nuevo" class="btn btn-cta">
            <span class="material-symbols-outlined">add</span> Nuevo Proyecto
          </a>
        </div>
      </div>

      <div class="header-search-row">
        <form class="search-form" onsubmit="return false;">
          <input type="text" id="projectSearch" class="search-input" placeholder="Buscar por nombre de proyecto..." autocomplete="off" />
          <button type="submit" class="search-btn">Buscar</button>
        </form>
      </div>
    </div>

    <ProjectTable id="projectsListBody" />
  </div>

  <!-- Modal Confirmar Borrado -->
  <ModalConfirm 
    slot="modals"
    id="deleteProjectConfirm"
    title="Eliminar Proyecto"
    message="¿Estás seguro de que deseas eliminar este proyecto? Esta acción no se puede deshacer."
    confirmText="Eliminar Proyecto"
    type="danger"
  />

</DashboardLayout>

<script>
  import { initProjectList } from "../../../scripts/proyectos/list"
  initProjectList()
</script>


