---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { apiClient } from '../../../lib/api-client';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Nuevo Proyecto | Panel Admin" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Proyectos', href: '/admin/proyectos' }, { label: 'Nuevo' }]} role="admin">
  <div class="project-form-container">
    <div class="form-header">
      <a href="/admin/proyectos" class="btn-back">
        <span class="material-symbols-outlined">arrow_back</span> Volver al listado
      </a>
      <h1>Crear un Nuevo Proyecto</h1>
      <p class="text-muted">Completa la información para iniciar una nueva colaboración.</p>
    </div>

    <div class="form-card flat-card">
      <form id="newProjectForm">
        <div class="form-grid">
          <div class="form-group">
            <label for="projectName">Nombre del Proyecto</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">task</span>
              <input type="text" id="projectName" name="name" placeholder="Ej: Rediseño Digital" required />
            </div>
          </div>

          <div class="form-group">
            <label for="projectClient">Cliente</label>
            <div class="input-with-icon select-wrapper">
              <span class="material-symbols-outlined">account_circle</span>
              <select id="projectClient" name="clientId" required>
                <option value="" disabled selected>Selecciona un cliente</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="monthlyTicketLimit">Límite Mensual de Tickets</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">confirmation_number</span>
              <input 
                type="number" 
                id="monthlyTicketLimit" 
                name="monthlyTicketLimit" 
                min="1" 
                value="3" 
                required 
              />
            </div>
          </div>

          <div class="form-group full-width">
            <label for="projectDescription">Descripción</label>
            <textarea id="projectDescription" name="description" placeholder="Detalles del proyecto..." rows="5" required></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-cta" id="submitBtn">
             Crear Proyecto <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.1rem; margin-left:0.25rem;">add_circle</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { initNewProject } from "../../../scripts/proyectos/new"
  initNewProject()
</script>


