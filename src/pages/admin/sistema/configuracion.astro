---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

export interface SystemConfig {
  name: string;
  description: string;
  websiteUrl: string;
  logoUrl: string;
  faviconUrl?: string;
  address?: string;
  phone?: string;
  email?: string;
  servicesUrl?: string;
  social: {
    linkedinUrl?: string;
    instagramUrl?: string;
    githubUrl?: string;
    youtubeUrl?: string;
    linkedinIconUrl?: string;
    instagramIconUrl?: string;
    githubIconUrl?: string;
    youtubeIconUrl?: string;
  };
}

let config: SystemConfig | null = null;
let errorMsg: string | null = null;

try {
  const response = await fetch(`${API_URL}/system-config`, {
    headers: { 'Authorization': `Bearer ${token}` }
  });

  if (response.ok) {
    config = await response.json();
  } else {
    errorMsg = "No se pudo cargar la configuración actual.";
  }
} catch (e) {
  errorMsg = "Error de conexión con la API.";
}
---

<DashboardLayout title="Configuración del Sistema" role="admin" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Sistema', href: '#' }, { label: 'Configuración' }]}>
  <div class="header-actions">
    <div>
      <a href="/admin" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span> Volver a Inicio
      </a>
      <h1>Configuración del Sitio</h1>
      <p class="text-muted">Administra la identidad global, datos de contacto y redes sociales.</p>
    </div>
  </div>

  {errorMsg && (
    <div class="error-banner fade-in">
      <span class="material-symbols-outlined">report</span> {errorMsg}
    </div>
  )}

    <form id="configForm" class="project-form-container">
      <div class="content-card fade-in">
        <div class="form-grid">
          <!-- SECCIÓN GENERAL -->
          <h3 class="form-section-title">Información General</h3>
          
          <div class="form-group">
            <label for="name">Nombre del Sitio <span class="required">*</span></label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">info</span>
              <input type="text" id="name" name="name" required placeholder="Ej: Gabriel Zavando" value={config?.name || ''} />
            </div>
          </div>

          <div class="form-group">
            <label for="websiteUrl">URL del Sitio <span class="required">*</span></label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">link</span>
              <input type="url" id="websiteUrl" name="websiteUrl" required placeholder="https://..." value={config?.websiteUrl || ''} />
            </div>
          </div>

          <div class="form-group full-width">
            <label for="description">Descripción SEO / Slogan</label>
            <textarea id="description" name="description" rows="2" placeholder="Breve descripción del sitio...">{config?.description || ''}</textarea>
          </div>

          <!-- SECCIÓN MARCA -->
          <h3 class="form-section-title">Marca y Logotipo</h3>
          
          <div class="form-group">
            <label>Logotipo Principal</label>
            <div class="media-field-container">
              <input type="hidden" id="logoUrl" name="logoUrl" value={config?.logoUrl || ''} />
              <div class="media-preview" id="preview-logoUrl">
                <img src={config?.logoUrl || '/favicon.svg'} alt="Logo" class="preview-img-box" />
              </div>
              <button type="button" class="btn-cta select-media-btn" data-target="logoUrl">
                <span class="material-symbols-outlined">imagesmode</span> Seleccionar
              </button>
            </div>
          </div>

          <div class="form-group">
            <label>Favicon (Icono navegador)</label>
            <div class="media-field-container">
              <input type="hidden" id="faviconUrl" name="faviconUrl" value={config?.faviconUrl || ''} />
              <div class="media-preview" id="preview-faviconUrl">
                <img src={config?.faviconUrl || '/favicon.svg'} alt="Favicon" class="preview-img-box" />
              </div>
              <button type="button" class="btn-cta select-media-btn" data-target="faviconUrl">
                <span class="material-symbols-outlined">imagesmode</span> Seleccionar
              </button>
            </div>
          </div>

          <!-- SECCIÓN CONTACTO -->
          <h3 class="form-section-title">Datos de Contacto</h3>
          
          <div class="form-group">
            <label for="email">Email Público</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">mail</span>
              <input type="email" id="email" name="email" placeholder="contacto@..." value={config?.email || ''} />
            </div>
          </div>

          <div class="form-group">
            <label for="phone">Teléfono</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">phone</span>
              <input type="text" id="phone" name="phone" placeholder="+56 9..." value={config?.phone || ''} />
            </div>
          </div>

          <div class="form-group">
            <label for="servicesUrl">Link de Servicios</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">arrow_outward</span>
              <input type="text" id="servicesUrl" name="servicesUrl" placeholder="/servicios" value={config?.servicesUrl || ''} />
            </div>
          </div>

          <div class="form-group">
            <label for="address">Dirección / Ubicación</label>
            <div class="input-with-icon">
              <span class="material-symbols-outlined">location_on</span>
              <input type="text" id="address" name="address" placeholder="Ciudad, País" value={config?.address || ''} />
            </div>
          </div>

          <!-- SECCIÓN REDES SOCIALES -->
          <h3 class="form-section-title">Redes Sociales (Para Emails)</h3>
          
          <div class="social-inputs-grid full-width">
            <div class="social-item">
              <label>LinkedIn</label>
              <div class="social-controls">
                <input type="url" name="social.linkedinUrl" placeholder="URL..." value={config?.social?.linkedinUrl || ''} />
                <input type="hidden" id="social-linkedinIconUrl" name="social.linkedinIconUrl" value={config?.social?.linkedinIconUrl || ''} />
                <button type="button" class="icon-picker select-media-btn" data-target="social-linkedinIconUrl" id="preview-social-linkedinIconUrl">
                  {config?.social?.linkedinIconUrl ? <img src={config.social.linkedinIconUrl} /> : <span class="material-symbols-outlined">add_photo_alternate</span>}
                </button>
              </div>
            </div>

            <div class="social-item">
              <label>Instagram</label>
              <div class="social-controls">
                <input type="url" name="social.instagramUrl" placeholder="URL..." value={config?.social?.instagramUrl || ''} />
                <input type="hidden" id="social-instagramIconUrl" name="social.instagramIconUrl" value={config?.social?.instagramIconUrl || ''} />
                <button type="button" class="icon-picker select-media-btn" data-target="social-instagramIconUrl" id="preview-social-instagramIconUrl">
                  {config?.social?.instagramIconUrl ? <img src={config.social.instagramIconUrl} /> : <span class="material-symbols-outlined">add_photo_alternate</span>}
                </button>
              </div>
            </div>

            <div class="social-item">
              <label>GitHub</label>
              <div class="social-controls">
                <input type="url" name="social.githubUrl" placeholder="URL..." value={config?.social?.githubUrl || ''} />
                <input type="hidden" id="social-githubIconUrl" name="social.githubIconUrl" value={config?.social?.githubIconUrl || ''} />
                <button type="button" class="icon-picker select-media-btn" data-target="social-githubIconUrl" id="preview-social-githubIconUrl">
                  {config?.social?.githubIconUrl ? <img src={config.social.githubIconUrl} /> : <span class="material-symbols-outlined">add_photo_alternate</span>}
                </button>
              </div>
            </div>

            <div class="social-item">
              <label>YouTube</label>
              <div class="social-controls">
                <input type="url" name="social.youtubeUrl" placeholder="URL..." value={config?.social?.youtubeUrl || ''} />
                <input type="hidden" id="social-youtubeIconUrl" name="social.youtubeIconUrl" value={config?.social?.youtubeIconUrl || ''} />
                <button type="button" class="icon-picker select-media-btn" data-target="social-youtubeIconUrl" id="preview-social-youtubeIconUrl">
                  {config?.social?.youtubeIconUrl ? <img src={config.social.youtubeIconUrl} /> : <span class="material-symbols-outlined">add_photo_alternate</span>}
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="form-actions flat-sticky">
          <button type="submit" class="btn-primary" id="saveBtn">
            <span class="material-symbols-outlined">save</span> Guardar Configuración
          </button>
        </div>
      </div>
    </form>

  <div slot="modals">
    <div id="mediaModal" class="modal">
      <div class="modal__content modal__content--lg">
        <div class="modal__header">
          <h3><span class="material-symbols-outlined">imagesmode</span> Seleccionar Archivo</h3>
          <button type="button" id="closeMediaModal" class="modal__close">&times;</button>
        </div>
        <div class="modal__body">
          <div class="gallery-filters">
            <form class="search-form" onsubmit="return false;">
              <input type="text" id="mediaSearch" class="search-input" placeholder="Buscar imágenes..." />
              <button type="submit" class="search-btn">Buscar</button>
            </form>
          </div>
          <div id="mediaGallery" class="media-gallery">
            <div class="loading-state">Cargando biblioteca...</div>
          </div>
        </div>
        <div class="modal__footer">
          <button type="button" class="btn btn-cta__border" id="cancelMediaBtn">Cancelar</button>
          <button type="button" class="btn-primary" id="confirmMediaBtn" disabled>
            Confirmar Selección
          </button>
        </div>
      </div>
    </div>

    <ModalMessage id="successModal" type="success" title="¡Configuración Guardada!" message="Los cambios se aplicarán en todos los correos y el sitio web." />
    <ModalMessage id="errorModal" type="error" title="Error" message="No se pudieron guardar los cambios. Intente de nuevo." />
  </div>
</DashboardLayout>

<style>
  .media-field-container {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-surface-secondary);
    padding: 1rem;
    border: 1px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .media-preview {
    width: 64px;
    height: 64px;
    background: rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .preview-img-box { max-width: 100%; max-height: 100%; object-fit: contain; }

  .social-inputs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  .social-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .social-item label { font-size: 0.8rem; font-weight: 700; color: var(--color-text-secondary); text-transform: uppercase; }
  .social-controls { display: flex; gap: 0.75rem; align-items: stretch; }
  .social-controls input { flex: 1; min-width: 0; }

  .icon-picker {
    width: 48px;
    height: 48px;
    background: var(--color-surface-secondary);
    border: 1px dashed var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    padding: 0;
  }
  .icon-picker:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .icon-picker img { width: 100%; height: 100%; object-fit: contain; }

  .flat-sticky {
    position: sticky;
    bottom: -2.5rem; /* Ajuste para compensar padding del card */
    margin: 2.5rem -2.5rem -2.5rem !important;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 2.5rem;
    display: flex;
    justify-content: flex-end;
    z-index: 5;

    .btn-primary {
      width: 100%;
      max-width: 600px;
    }
  }

  /* Modal Media Gallery Overrides */
  .media-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem;
    max-height: 50vh;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .gallery-item {
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.2s;
  }
  .gallery-item:hover { border-color: var(--color-primary); transform: translateY(-2px); }
  .gallery-item.selected { border-color: var(--color-primary); background: rgba(var(--color-primary-rgb), 0.05); border-width: 2px; }
  .gallery-item.selected .img-title { color: var(--color-primary); font-weight: 700; }
  .gallery-item img { width: 100%; height: 110px; object-fit: cover; }
  .gallery-item .img-title { padding: 8px; font-size: 0.7rem; text-align: center; color: var(--color-text-muted); pointer-events: none; }

  .modal__footer {
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    background: var(--color-surface);
  }

  @media (max-width: 768px) {
    .social-inputs-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

  function initConfigPage() {
    const form = document.getElementById('configForm') as HTMLFormElement;
    if (!form || form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
    const mediaModal = document.getElementById('mediaModal') as HTMLDivElement;
    const closeMediaModal = document.getElementById('closeMediaModal') as HTMLButtonElement;
    const mediaGallery = document.getElementById('mediaGallery') as HTMLDivElement;
    const mediaSearch = document.getElementById('mediaSearch') as HTMLInputElement;

    const confirmMediaBtn = document.getElementById('confirmMediaBtn') as HTMLButtonElement;
    const cancelMediaBtn = document.getElementById('cancelMediaBtn') as HTMLButtonElement;
    
    let currentTargetFieldId = '';
    let libraryFiles: any[] = [];
    let selectedUrl = '';

    // --- Media Selector ---
    
    document.querySelectorAll('.select-media-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        currentTargetFieldId = (e.currentTarget as HTMLButtonElement).dataset.target || '';
        mediaModal.classList.add('active');
        selectedUrl = '';
        if (confirmMediaBtn) confirmMediaBtn.disabled = true;
        loadLibrary();
      });
    });

    const closeModal = () => {
      mediaModal.classList.remove('active');
      selectedUrl = '';
    };

    closeMediaModal?.addEventListener('click', closeModal);
    cancelMediaBtn?.addEventListener('click', closeModal);
    mediaModal?.addEventListener('click', (e) => { if (e.target === mediaModal) closeModal(); });

    confirmMediaBtn?.addEventListener('click', () => {
      if (!selectedUrl) return;
      const input = document.getElementById(currentTargetFieldId) as HTMLInputElement;
      const preview = document.getElementById(`preview-${currentTargetFieldId}`);
      if (input) input.value = selectedUrl;
      if (preview) {
        if (preview.tagName === 'BUTTON') preview.innerHTML = `<img src="${selectedUrl}" />`;
        else { const img = preview.querySelector('img'); if (img) img.src = selectedUrl; }
      }
      closeModal();
    });

    async function loadLibrary() {
      mediaGallery.innerHTML = '<div class="loading-state">Cargando...</div>';
      const { auth } = await import('../../../lib/firebase/client');
      const user = auth.currentUser;
      if (!user) return;
      
      const token = await user.getIdToken();
      try {
        const res = await fetch(`${API_URL}/files`, { headers: { 'Authorization': `Bearer ${token}` } });
        const files = await res.json();
        libraryFiles = files.filter((f: any) => f.mimeType?.startsWith('image/'));
        renderGallery(libraryFiles);
      } catch (e) {
        mediaGallery.innerHTML = '';
      }
    }

    function renderGallery(files: any[]) {
      if (files.length === 0) {
        mediaGallery.innerHTML = '';
        return;
      }

      mediaGallery.innerHTML = '';
      files.forEach(async (f) => {
        const item = document.createElement('div');
        item.className = 'gallery-item';
        item.dataset.id = f.id;
        item.title = f.title;
        item.innerHTML = `
          <div class="gal-img-loading" id="gal-img-${f.id}">...</div>
          <span class="img-title">${f.title}</span>
        `;
        mediaGallery.appendChild(item);

        const { auth } = await import('../../../lib/firebase/client');
        const token = await auth.currentUser?.getIdToken();
        const res = await fetch(`${API_URL}/files/${f.id}/download`, { headers: { 'Authorization': `Bearer ${token}` } });
        
        if (res.ok) {
          const { url } = await res.json();
          const container = document.getElementById(`gal-img-${f.id}`);
          if (container) {
            container.innerHTML = `<img src="${url}" />`;
            item.addEventListener('click', () => {
              // Limpiar selección previa
              mediaGallery.querySelectorAll('.gallery-item').forEach(i => i.classList.remove('selected'));
              item.classList.add('selected');
              selectedUrl = url;
              if (confirmMediaBtn) confirmMediaBtn.disabled = false;
            });
          }
        }
      });
    }

    mediaSearch?.addEventListener('input', (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      renderGallery(libraryFiles.filter(f => f.title.toLowerCase().includes(q)));
    });

    // --- Save ---

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      saveBtn.classList.add('btn-loading');

      const formData = new FormData(form);
      const data: any = {
        name: formData.get('name'),
        description: formData.get('description'),
        websiteUrl: formData.get('websiteUrl'),
        logoUrl: formData.get('logoUrl'),
        faviconUrl: formData.get('faviconUrl'),
        address: formData.get('address'),
        phone: formData.get('phone'),
        email: formData.get('email'),
        servicesUrl: formData.get('servicesUrl'),
        social: {
          linkedinUrl: formData.get('social.linkedinUrl'),
          linkedinIconUrl: formData.get('social.linkedinIconUrl'),
          instagramUrl: formData.get('social.instagramUrl'),
          instagramIconUrl: formData.get('social.instagramIconUrl'),
          githubUrl: formData.get('social.githubUrl'),
          githubIconUrl: formData.get('social.githubIconUrl'),
          youtubeUrl: formData.get('social.youtubeUrl'),
          youtubeIconUrl: formData.get('social.youtubeIconUrl'),
        }
      };

      const { auth } = await import('../../../lib/firebase/client');
      const token = await auth.currentUser?.getIdToken();
      if (!token) return;

      try {
        const res = await fetch(`${API_URL}/system-config`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify(data)
        });
        const w = window as any;
        if (w.modalHelpers) w.modalHelpers.openModal(res.ok ? 'successModal' : 'errorModal');
      } catch (err) {
        const w = window as any;
        if (w.modalHelpers) w.modalHelpers.openModal('errorModal');
      } finally {
        saveBtn.disabled = false;
        saveBtn.classList.remove('btn-loading');
      }
    });
  }

  document.addEventListener('astro:page-load', initConfigPage);
</script>
