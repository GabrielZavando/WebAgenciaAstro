---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import ModalConfirm from "../../../components/shared/ModalConfirm.astro";

// Obtenemos el endpoint desde el env o formamos uno por default
const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let subscribers = [];
let error = null;

try {
  // Petición a la API (NestJS)
  const res = await fetch(`${API_URL}/forms/admin/subscribers`);
  if (!res.ok) {
    throw new Error('No se pudo obtener la lista de suscriptores');
  }
  subscribers = await res.json();
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<DashboardLayout title="Administrar Suscriptores" role="admin">
  <div class="admin-container">
    <header class="admin-header">
      <div class="header-content">
        <div>
          <h1>Lista de Suscriptores</h1>
          <p>Maneja a los usuarios suscritos a tu boletín.</p>
        </div>
        <div class="header-actions">
          <button id="btnExport" class="btn-action btn-secondary">
            <span class="material-symbols-outlined">download</span> Exportar JSON
          </button>
          <button id="btnCampaign" class="btn-action btn-primary">
            <span class="material-symbols-outlined">mail</span> Campaña de Re-confirmación
          </button>
          <button id="btnCleanup" class="btn-action btn-danger">
            <span class="material-symbols-outlined">delete</span> Limpiar Inactivos (+7 días)
          </button>
        </div>
      </div>
    </header>

    <!-- Resultado de acciones -->
    <div id="actionResultPanel" class="action-result-panel" style="display:none">
      <div class="action-result-header">
        <span id="actionResultTitle">Resultado</span>
        <button onclick="document.getElementById('actionResultPanel').style.display='none'"
          class="close-btn">×</button>
      </div>
      <div id="actionResultBody" class="action-result-body"></div>
    </div>

    <main class="admin-content">
      {error && (
        <div class="error-message">
          <p>Error: {error}</p>
        </div>
      )}

      {subscribers.length === 0 && !error ? (
        <div class="empty-state">
          <p>No hay suscriptores actualmente.</p>
        </div>
      ) : null}

      {subscribers.length > 0 && (
        <div class="subscribers-table-container">
          <table class="subscribers-table">
            <thead>
              <tr>
                <th>Email</th>
                <th>Estado</th>
                <th>Fecha de Suscripción</th>
                <th>Navegador/User Agent</th>
              </tr>
            </thead>
            <tbody>
              {subscribers.map((sub: any) => {
                const formattedDate = formatDate(sub.subscribedAt || sub.createdAt);
                const isConfirmed = sub.status === 'confirmed';

                return (
                  <tr>
                    <td class="email-col">{sub.email}</td>
                    <td>
                      <span class={`status-badge ${isConfirmed ? 'confirmed' : 'pending'}`}>
                        {isConfirmed ? 'Confirmado' : 'Pendiente'}
                      </span>
                    </td>
                    <td>{formattedDate}</td>
                    <td class="ua-col" title={sub.meta?.userAgent || 'Desconocido'}>
                      {sub.meta?.userAgent
                        ? (sub.meta.userAgent.length > 30
                            ? sub.meta.userAgent.substring(0, 30) + '...'
                            : sub.meta.userAgent)
                        : 'Desconocido'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          <div class="table-footer">
            <span>Total de suscriptores: {subscribers.length}</span>
          </div>
        </div>
      )}
    </main>
  </div>
  <ModalConfirm 
    slot="modals"
    id="confirmCampaignModal"
    title="¿Enviar Campaña?"
    message="¿Estás seguro de que deseas enviar el email de re-confirmación a todos los suscriptores no confirmados? Esto puede tardar unos minutos."
    confirmText="Enviar ahora"
    type="info"
  />

  <ModalConfirm 
    slot="modals"
    id="confirmCleanupModal"
    title="¿Limpiar Inactivos?"
    message="¿Estás seguro de que deseas marcar como INACTIVOS a los suscriptores que no han confirmado en los últimos 7 días? Esta acción no borra los registros, solo cambia su estado."
    confirmText="Limpiar ahora"
    type="danger"
  />
</DashboardLayout>



<script define:vars={{ apiUrl: API_URL }}>
  const API = apiUrl.replace(/\/$/, '');

  function setLoading(btn, Loading) {
    btn.disabled = Loading;
    btn.style.opacity = Loading ? '0.6' : '1';
  }

  function showResult(title, content) {
    const panel = document.getElementById('actionResultPanel');
    document.getElementById('actionResultTitle').textContent = title;
    document.getElementById('actionResultBody').textContent = content;
    panel.style.display = 'block';
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Exportar
  document.getElementById('btnExport')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnExport');
    setLoading(btn, true);
    try {
      const res = await fetch(`${API}/forms/admin/subscribers/export`);
      const data = await res.json();
      const blob = new Blob([JSON.stringify(data.subscribers, null, 2)], {
        type: 'application/json',
      });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `suscriptores-${new Date().toISOString().slice(0, 10)}.json`;
      link.click();
      showResult('✅ Exportación', `${data.count} suscriptores exportados.`);
    } catch (e) {
      showResult('❌ Error', `No se pudo exportar: ${e.message}`);
    } finally {
      setLoading(btn, false);
    }
  });

  // Campaña de Re-confirmación
  document.getElementById('btnCampaign')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnCampaign');
    
    if (!window.confirmModalHelpers) return;
    
    window.confirmModalHelpers.open('confirmCampaignModal', async () => {
      setLoading(btn, true);
      try {
        const res = await fetch(
          `${API}/forms/admin/subscribers/reconfirmation-campaign`,
          { method: 'POST' },
        );
        const data = await res.json();
        const lines = [
          `✅ Enviados: ${data.sent}`,
          `⚠️  Omitidos: ${data.skipped}`,
          `❌ Errores: ${data.errors}`,
          '',
          ...(data.details ?? []),
        ].join('\n');
        showResult('📧 Resultado de la Campaña', lines);
      } catch (e) {
        showResult('❌ Error', `No se pudo ejecutar la campaña: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });

  // Limpieza de Inactivos
  document.getElementById('btnCleanup')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnCleanup');
    
    if (!window.confirmModalHelpers) return;

    window.confirmModalHelpers.open('confirmCleanupModal', async () => {
      setLoading(btn, true);
      try {
        const res = await fetch(
          `${API}/forms/admin/subscribers/cleanup-inactive`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ daysThreshold: 7 }),
          },
        );
        const data = await res.json();
        const lines = [
          `🗑️  Marcados como inactivos: ${data.marked} de ${data.total}`,
          '',
          ...(data.details ?? []),
        ].join('\n');
        showResult('🧹 Resultado de la Limpieza', lines);
      } catch (e) {
        showResult('❌ Error', `No se pudo ejecutar la limpieza: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });
</script>
