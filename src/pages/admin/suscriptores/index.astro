---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import ModalConfirm from "../../../components/shared/ModalConfirm.astro";
import { apiClient } from "../../../lib/api-client";

// Obtenemos el token de la sesión para SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

let subscribers = [];
let error = null;

try {
  // Petición a la API (NestJS) usando el cliente centralizado con token
  const rawData = await apiClient.get<any[]>('/forms/admin/subscribers', { token });
  subscribers = rawData;
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<script define:vars={{ subscribersData: subscribers }}>
  // Pasar datos al scope del cliente de forma segura
  window.subscribersData = subscribersData;
</script>

<DashboardLayout title="Administrar Suscriptores" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Suscriptores' }]} role="admin">
  <div class="users-table-view subscribers-view">
    <div class="header-actions">
      <div class="header-title-row">
        <div>
          <h1>Lista de Suscriptores</h1>
          <p class="text-muted">Maneja a los usuarios suscritos a tu boletín.</p>
        </div>
        <div class="header-right">
          <button id="btnExport" class="btn btn-cta__border btn-sm">
            <span class="material-symbols-outlined">download</span> Exportar
          </button>
          <button id="btnNewsletter" class="btn btn-cta btn-sm" disabled>
            <span class="material-symbols-outlined">campaign</span> Newsletter
          </button>
          <button id="btnCampaign" class="btn btn-cta__border btn-sm" disabled>
            <span class="material-symbols-outlined">mail</span> Enviar Confirmaciones
          </button>
          <button id="btnDeleteSelected" class="btn btn-danger btn-sm" disabled style="display: none;">
            <span class="material-symbols-outlined">delete</span> Eliminar
          </button>
          <button id="btnCleanup" class="btn btn-cta__border btn-sm">
            <span class="material-symbols-outlined">cleaning_services</span> Limpiar
          </button>
        </div>
      </div>

      <div class="header-search-row">
        <form class="search-form" onsubmit="return false;">
          <input type="text" id="subscriberSearch" class="search-input" placeholder="Buscar por email..." autocomplete="off" />
          <button type="submit" class="search-btn">Buscar</button>
        </form>
      </div>
    </div>

    <!-- Resultado de acciones -->
    <div id="actionResultPanel" class="action-result-panel" style="display:none">
      <div class="action-result-header">
        <span id="actionResultTitle">Resultado</span>
        <button onclick="document.getElementById('actionResultPanel').style.display='none'"
          class="close-btn">×</button>
      </div>
      <div id="actionResultBody" class="action-result-body"></div>
    </div>

    <main class="admin-content">
      {error && (
        <div class="error-message">
          <p>Error: {error}</p>
        </div>
      )}

      {subscribers.length === 0 && !error ? (
        <div class="empty-state">
          <p>No hay suscriptores actualmente.</p>
        </div>
      ) : null}

      {subscribers.length > 0 && (
        <div class="subscribers-table-container">
          <table class="subscribers-table">
            <thead>
              <tr>
                <th style="width: 50px; text-align: center;">
                  <input type="checkbox" id="selectAll" class="custom-checkbox" />
                </th>
                <th>Email</th>
                <th>Estado</th>
                <th>Fecha de Suscripción</th>
              </tr>
            </thead>
            <tbody>
              {subscribers.map((sub: any) => {
                const formattedDate = formatDate(sub.subscribedAt || sub.createdAt);
                const isConfirmed = sub.status === 'confirmed';

                return (
                  <tr class="subscriber-row" data-id={sub.id}>
                    <td style="text-align: center;">
                      <input type="checkbox" class="sub-checkbox custom-checkbox" data-id={sub.id} />
                    </td>
                    <td class="email-col cell-email">
                      <div class="email-wrapper">
                        <span>{sub.email}</span>
                        <button class="btn-copy-email" data-email={sub.email} title="Copiar email">
                          <span class="material-symbols-outlined">content_copy</span>
                        </button>
                      </div>
                    </td>
                    <td>
                      {(() => {
                        const s = sub.status;
                        const labels = {
                          confirmed: 'Confirmado',
                          sent: 'Enviado',
                          pending: 'Pendiente',
                          unconfirmed: 'No confirmado',
                          inactive: 'Inactivo',
                          unsubscribed: 'Desuscrito'
                        };
                        const label = (labels as any)[s] || s;
                        return (
                          <span class={`status-badge ${s}`}>{label}</span>
                        );
                      })()}
                    </td>
                    <td>{formattedDate}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          <div class="table-footer">
            <span>Total: {subscribers.length}</span>
          </div>
        </div>
      )}
    </main>
  </div>
  <ModalConfirm 
    slot="modals"
    id="confirmCampaignModal"
    title="¿Enviar Campaña?"
    message="¿Estás seguro de que deseas enviar el email de re-confirmación a todos los suscriptores no confirmados? Esto puede tardar unos minutos."
    confirmText="Enviar ahora"
    type="info"
  />

  <ModalConfirm 
    slot="modals"
    id="confirmDeleteBulkModal"
    title="¿Eliminar Suscriptores?"
    message="Estás a punto de eliminar físicamente a los suscriptores seleccionados. Esta acción es definitiva y no se puede deshacer."
    confirmText="Eliminar permanentemente"
    type="danger"
  />

  <ModalConfirm 
    slot="modals"
    id="confirmBulkCampaignModal"
    title="¿Enviar Confirmaciones?"
    message="Se enviará un correo de confirmación a cada uno de los suscriptores seleccionados."
    confirmText="Enviar ahora"
    type="info"
  />

  <ModalConfirm 
    slot="modals"
    id="confirmCleanupModal"
    title="¿Limpiar Inactivos?"
    message="¿Estás seguro de que deseas marcar como INACTIVOS a los suscriptores que no han confirmado en los últimos 7 días? Esta acción no borra los registros, solo cambia su estado."
    confirmText="Limpiar ahora"
    type="danger"
  />

  <!-- Modal Newsletter -->
  <div id="newsletterModal" class="modal" role="dialog" aria-modal="true" slot="modals">
    <div class="modal__content" style="max-width: 500px;">
      <div class="modal__header">
        <h3 class="modal__title">Enviar Newsletter</h3>
        <button class="close-modal-btn">&times;</button>
      </div>
      <div class="modal__body">
        <p>Selecciona el artículo que deseas enviar a los <strong><span id="selectedCountMsg">0</span> suscriptores</strong> seleccionados.</p>
        
        <div class="form-group" style="margin-top: 20px;">
          <label for="postSelector">Artículos Publicados:</label>
          <select id="postSelector" class="form-control" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
            <option value="">Cargando artículos...</option>
          </select>
        </div>

        <div id="postPreview" class="post-preview" style="display:none; margin-top: 20px; padding: 15px; background: #f9fafb; border-radius: 12px; border: 1px border: 1px solid #eee;">
          <img id="previewImg" src="" alt="" style="width: 100%; height: 120px; object-fit: cover; border-radius: 8px; margin-bottom: 10px;">
          <h4 id="previewTitle" style="margin: 0; font-size: 16px;"></h4>
          <p id="previewExcerpt" style="font-size: 13px; color: #666; margin-top: 5px;"></p>
        </div>
      </div>
      <div class="modal__footer" style="padding: 20px; text-align: right; border-top: 1px solid #eee; margin-top: 20px;">
        <button class="btn btn-cta__border btn-sm close-modal-btn">Cancelar</button>
        <button id="btnDoSendNewsletter" class="btn btn-cta btn-sm" disabled>Enviar a seleccionados</button>
      </div>
    </div>
  </div>
</DashboardLayout>



<script>
  import { apiClient } from "../../../lib/api-client";

  let selectedIds = new Set();
  // @ts-ignore
  const subscribersData = window.subscribersData || [];
  const allSubscribers = subscribersData;

  function setLoading(btn: HTMLElement | null, Loading: boolean) {
    if (!btn) return;
    if (btn instanceof HTMLButtonElement) {
      btn.disabled = Loading;
    }
    btn.classList.toggle('btn-loading', Loading);
  }

  function showResult(title: string, content: string) {
    const panel = document.getElementById('actionResultPanel');
    const titleEl = document.getElementById('actionResultTitle');
    const bodyEl = document.getElementById('actionResultBody');
    
    if (titleEl) titleEl.textContent = title;
    if (bodyEl) bodyEl.textContent = content;
    
    if (panel) {
      panel.style.display = 'block';
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  function updateBulkButtons() {
    const hasSelection = selectedIds.size > 0;
    const deleteBtn = document.getElementById('btnDeleteSelected') as HTMLButtonElement | null;
    
    if (deleteBtn) {
      deleteBtn.disabled = !hasSelection;
      deleteBtn.style.display = hasSelection ? 'inline-flex' : 'none';
      const icon = deleteBtn.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'delete';
      if (hasSelection) {
        deleteBtn.innerHTML = `<span class="material-symbols-outlined">delete</span> Eliminar (${selectedIds.size})`;
      }
    }

    const exportBtn = document.getElementById('btnExport');
    if (exportBtn) {
      exportBtn.innerHTML = hasSelection 
        ? `<span class="material-symbols-outlined">download</span> Exportar (${selectedIds.size})`
        : `<span class="material-symbols-outlined">download</span> Exportar`;
    }

    const campaignBtn = document.getElementById('btnCampaign') as HTMLButtonElement | null;
    if (campaignBtn) {
      campaignBtn.disabled = !hasSelection;
      if (hasSelection) {
        campaignBtn.innerHTML = `<span class="material-symbols-outlined">mail</span> Enviar Confirmaciones (${selectedIds.size})`;
      } else {
        campaignBtn.innerHTML = `<span class="material-symbols-outlined">mail</span> Enviar Confirmaciones`;
      }
    }

    const newsletterBtn = document.getElementById('btnNewsletter') as HTMLButtonElement | null;
    if (newsletterBtn) {
      newsletterBtn.disabled = !hasSelection;
      newsletterBtn.style.display = hasSelection ? 'inline-flex' : 'none';
      if (hasSelection) {
        newsletterBtn.innerHTML = `<span class="material-symbols-outlined">campaign</span> Newsletter (${selectedIds.size})`;
      }
    }
  }

  // --- Manejo de Selección ---
  const selectAll = document.getElementById('selectAll') as HTMLInputElement | null;
  const checkboxes = document.querySelectorAll('.sub-checkbox') as NodeListOf<HTMLInputElement>;

  selectAll?.addEventListener('change', () => {
    const isChecked = selectAll.checked;
    checkboxes.forEach(cb => {
      // Solo seleccionar los que están visibles actualmente (por búsqueda)
      const row = cb.closest('.subscriber-row') as HTMLElement | null;
      if (row && row.style.display !== 'none') {
        cb.checked = isChecked;
        const id = cb.dataset.id;
        if (id) {
          if (isChecked) selectedIds.add(id);
          else selectedIds.delete(id);
        }
      }
    });
    updateBulkButtons();
  });

  checkboxes.forEach(cb => {
    cb.addEventListener('change', () => {
      const id = cb.dataset.id;
      if (id) {
        if (cb.checked) selectedIds.add(id);
        else {
          selectedIds.delete(id);
          if (selectAll) selectAll.checked = false;
        }
      }
      updateBulkButtons();
    });
  });

  // Copiar Email
  document.querySelectorAll('.btn-copy-email').forEach(btnEl => {
    const btn = btnEl as HTMLElement;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const email = btn.dataset.email || '';
      navigator.clipboard.writeText(email);
      const icon = btn.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = 'check';
        setTimeout(() => icon.textContent = 'content_copy', 2000);
      }
    });
  });

  // Filtrado de Búsqueda
  const searchInput = document.getElementById('subscriberSearch') as HTMLInputElement | null;
  searchInput?.addEventListener('input', () => {
    const term = searchInput.value.toLowerCase();
    const rows = document.querySelectorAll('.subscriber-row') as NodeListOf<HTMLElement>;
    rows.forEach(row => {
      const email = row.querySelector('.cell-email')?.textContent?.toLowerCase() || '';
      if (email.includes(term)) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
        // Deseleccionar si se oculta
        const cb = row.querySelector('.sub-checkbox') as HTMLInputElement | null;
        if (cb && cb.checked) {
          cb.checked = false;
          const id = cb.dataset.id;
          if (id) selectedIds.delete(id);
        }
      }
    });
    updateBulkButtons();
    if (selectAll) selectAll.checked = false;
  });

  // Exportar (Mejorado)
  document.getElementById('btnExport')?.addEventListener('click', async () => {
    const hasSelection = selectedIds.size > 0;
    let dataToExport = allSubscribers;
    
    if (hasSelection) {
      dataToExport = allSubscribers.filter((s: any) => selectedIds.has(s.id));
    }

    const blob = new Blob([JSON.stringify(dataToExport, null, 2)], {
      type: 'application/json',
    });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `suscriptores-${hasSelection ? 'seleccionados-' : 'todos-'}${new Date().toISOString().slice(0, 10)}.json`;
    link.click();
    showResult('✅ Exportación', `${dataToExport.length} suscriptores exportados.`);
  });

  // Confirmar Selección (Bulk)
  document.getElementById('btnCampaign')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnCampaign');
    if (selectedIds.size === 0 || !window.confirmModalHelpers) return;

    window.confirmModalHelpers.open('confirmBulkCampaignModal', async () => {
      setLoading(btn, true);
      try {
        const data: any = await apiClient.post('/forms/admin/subscribers/bulk-confirm', { 
          ids: Array.from(selectedIds) 
        });
        const lines = [
          `✅ Enviados: ${data.sent || (data.success ? '?' : 0)}`,
          `⚠️  Omitidos: ${data.skipped || 0}`,
          `❌ Errores: ${data.errors || 0}`,
          '',
          ...(data.details ?? []),
        ].join('\n');
        showResult('📧 Resultado del Envío (Selección)', lines);
      } catch (e: any) {
        showResult('❌ Error', `No se pudo ejecutar la acción: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });

  // Eliminar Seleccionados (Físico)
  document.getElementById('btnDeleteSelected')?.addEventListener('click', () => {
    if (selectedIds.size === 0) return;
    
    if (!window.confirmModalHelpers) return;

    window.confirmModalHelpers.open('confirmDeleteBulkModal', async () => {
      const btn = document.getElementById('btnDeleteSelected');
      setLoading(btn, true);
      try {
        const data: any = await apiClient.post('/forms/admin/subscribers/bulk-delete', { 
          ids: Array.from(selectedIds) 
        });
        if (data.success) {
          showResult('🗑️ Eliminación Exitosa', data.message);
          // Recargar página para ver cambios
          setTimeout(() => window.location.reload(), 1500);
        } else {
          showResult('❌ Error', data.message);
        }
      } catch (e: any) {
        showResult('❌ Error', `No se pudo eliminar: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });

  // --- Newsletter ---
  const newsletterModal = document.getElementById('newsletterModal');
  const postSelector = document.getElementById('postSelector') as HTMLSelectElement | null;
  const btnDoSendNewsletter = document.getElementById('btnDoSendNewsletter') as HTMLButtonElement | null;
  let currentPosts: any[] = [];

  document.getElementById('btnNewsletter')?.addEventListener('click', async () => {
    const msgEl = document.getElementById('selectedCountMsg');
    if (msgEl) msgEl.textContent = selectedIds.size.toString();
    if (newsletterModal) newsletterModal.classList.add('active');
    
    // Cargar posts si no han sido cargados
    if (currentPosts.length === 0) {
      try {
        currentPosts = await apiClient.get<any[]>('/blog?published=true');
        
        if (postSelector) {
          postSelector.innerHTML = '<option value="">-- Seleccionar Artículo --</option>';
          currentPosts.forEach(post => {
            const option = document.createElement('option');
            option.value = post.id;
            option.textContent = post.title;
            postSelector.appendChild(option);
          });
        }
      } catch (e) {
        if (postSelector) postSelector.innerHTML = '<option value="">Error cargando artículos</option>';
      }
    }
  });

  postSelector?.addEventListener('change', () => {
    const postId = postSelector.value;
    const post = currentPosts.find(p => p.id === postId);
    const preview = document.getElementById('postPreview');
    const previewImg = document.getElementById('previewImg') as HTMLImageElement | null;
    const previewTitle = document.getElementById('previewTitle');
    const previewExcerpt = document.getElementById('previewExcerpt');
    
    if (post) {
      if (previewImg) previewImg.src = post.coverImage || '';
      if (previewTitle) previewTitle.textContent = post.title;
      if (previewExcerpt) previewExcerpt.textContent = post.excerpt || post.description || '';
      if (preview) preview.style.display = 'block';
      if (btnDoSendNewsletter) btnDoSendNewsletter.disabled = false;
    } else {
      if (preview) preview.style.display = 'none';
      if (btnDoSendNewsletter) btnDoSendNewsletter.disabled = true;
    }
  });

  // Cerrar modal newsletter
  document.querySelectorAll('.close-modal-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (newsletterModal) newsletterModal.classList.remove('active');
    });
  });

  btnDoSendNewsletter?.addEventListener('click', async () => {
    if (!postSelector) return;
    const postId = postSelector.value;
    if (!postId || selectedIds.size === 0) return;

    setLoading(btnDoSendNewsletter, true);
    try {
      const data: any = await apiClient.post('/forms/admin/subscribers/send-newsletter', {
        ids: Array.from(selectedIds),
        postId: postId
      });
      if (newsletterModal) newsletterModal.classList.remove('active');
      
      const lines = [
        `✅ Enviados: ${data.sent}`,
        `❌ Errores: ${data.errors}`,
        '',
        ...(data.details ?? []),
      ].join('\n');
      showResult('📧 Resultado del Newsletter', lines);
    } catch (e: any) {
      showResult('❌ Error', `No se pudo enviar el newsletter: ${e.message}`);
    } finally {
      setLoading(btnDoSendNewsletter, false);
    }
  });
</script>
