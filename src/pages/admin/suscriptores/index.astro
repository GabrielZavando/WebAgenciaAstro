---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import ModalConfirm from "../../../components/shared/ModalConfirm.astro";

// Obtenemos el endpoint desde el env o formamos uno por default
const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

let subscribers = [];
let error = null;

try {
  // Petición a la API (NestJS)
  const res = await fetch(`${API_URL}/forms/admin/subscribers`);
  if (!res.ok) {
    throw new Error('No se pudo obtener la lista de suscriptores');
  }
  subscribers = await res.json();
} catch (e) {
  console.error(e);
  error = (e as Error).message;
}

const formatDate = (dateValue: any) => {
  try {
    // Firestore devuelve timestamps como { _seconds, _nanoseconds }
    const timestamp =
      dateValue?._seconds
        ? new Date(dateValue._seconds * 1000)
        : dateValue
          ? new Date(dateValue)
          : new Date();
    if (isNaN(timestamp.getTime())) return 'Fecha inválida';
    return new Intl.DateTimeFormat('es-AR', {
      dateStyle: 'medium',
      timeStyle: 'short'
    }).format(timestamp);
  } catch (e) {
    return 'Fecha desconocida';
  }
};
---

<DashboardLayout title="Administrar Suscriptores" role="admin">
  <div class="admin-container">
    <header class="admin-header">
      <div class="header-content">
        <div>
          <h1>Lista de Suscriptores</h1>
          <p>Maneja a los usuarios suscritos a tu boletín.</p>
        </div>
        <div class="header-actions">
          <button id="btnExport" class="btn-action btn-secondary">
            <i class="fas fa-download"></i> Exportar JSON
          </button>
          <button id="btnCampaign" class="btn-action btn-primary">
            <i class="fas fa-envelope"></i> Campaña de Re-confirmación
          </button>
          <button id="btnCleanup" class="btn-action btn-danger">
            <i class="fas fa-trash-alt"></i> Limpiar Inactivos (+7 días)
          </button>
        </div>
      </div>
    </header>

    <!-- Resultado de acciones -->
    <div id="actionResultPanel" class="action-result-panel" style="display:none">
      <div class="action-result-header">
        <span id="actionResultTitle">Resultado</span>
        <button onclick="document.getElementById('actionResultPanel').style.display='none'"
          class="close-btn">×</button>
      </div>
      <div id="actionResultBody" class="action-result-body"></div>
    </div>

    <main class="admin-content">
      {error && (
        <div class="error-message">
          <p>Error: {error}</p>
        </div>
      )}

      {subscribers.length === 0 && !error ? (
        <div class="empty-state">
          <p>No hay suscriptores actualmente.</p>
        </div>
      ) : null}

      {subscribers.length > 0 && (
        <div class="subscribers-table-container">
          <table class="subscribers-table">
            <thead>
              <tr>
                <th>Email</th>
                <th>Estado</th>
                <th>Fecha de Suscripción</th>
                <th>Navegador/User Agent</th>
              </tr>
            </thead>
            <tbody>
              {subscribers.map((sub: any) => {
                const formattedDate = formatDate(sub.subscribedAt || sub.createdAt);
                const isConfirmed = sub.status === 'confirmed';

                return (
                  <tr>
                    <td class="email-col">{sub.email}</td>
                    <td>
                      <span class={`status-badge ${isConfirmed ? 'confirmed' : 'pending'}`}>
                        {isConfirmed ? 'Confirmado' : 'Pendiente'}
                      </span>
                    </td>
                    <td>{formattedDate}</td>
                    <td class="ua-col" title={sub.meta?.userAgent || 'Desconocido'}>
                      {sub.meta?.userAgent
                        ? (sub.meta.userAgent.length > 30
                            ? sub.meta.userAgent.substring(0, 30) + '...'
                            : sub.meta.userAgent)
                        : 'Desconocido'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          <div class="table-footer">
            <span>Total de suscriptores: {subscribers.length}</span>
          </div>
        </div>
      )}
    </main>
  </div>
  <ModalConfirm 
    slot="modals"
    id="confirmCampaignModal"
    title="¿Enviar Campaña?"
    message="¿Estás seguro de que deseas enviar el email de re-confirmación a todos los suscriptores no confirmados? Esto puede tardar unos minutos."
    confirmText="Enviar ahora"
    type="info"
  />

  <ModalConfirm 
    slot="modals"
    id="confirmCleanupModal"
    title="¿Limpiar Inactivos?"
    message="¿Estás seguro de que deseas marcar como INACTIVOS a los suscriptores que no han confirmado en los últimos 7 días? Esta acción no borra los registros, solo cambia su estado."
    confirmText="Limpiar ahora"
    type="danger"
  />
</DashboardLayout>

<style>
.admin-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  animation: fadeIn 0.4s ease-out;
}

.admin-header {
  margin-bottom: 2rem;
}

.header-content h1 {
  font-size: 2rem;
  color: var(--text-color, #ffffff);
  margin-bottom: 0.5rem;
}

.header-content p {
  color: var(--text-muted, #94a3b8);
  font-size: 1.1rem;
}

.error-message {
  background: rgba(239, 68, 68, 0.1);
  border-left: 4px solid var(--danger-color, #ef4444);
  padding: 1rem;
  border-radius: 4px;
  margin-bottom: 2rem;
  color: #f87171;
}

.empty-state {
  text-align: center;
  padding: 4rem 2rem;
  background: var(--bg-surface, #1e293b);
  border-radius: 12px;
  border: 1px dashed var(--border-color, #334155);
  color: var(--text-muted, #94a3b8);
  font-size: 1.1rem;
}

.subscribers-table-container {
  background: var(--bg-surface, #1e293b);
  border-radius: 12px;
  border: 1px solid var(--border-color, #334155);
  overflow: hidden;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.subscribers-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.subscribers-table th {
  background: rgba(15, 23, 42, 0.4);
  padding: 1.25rem 1.5rem;
  text-align: left;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-muted, #94a3b8);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border-color, #334155);
}

.subscribers-table td {
  padding: 1rem 1.5rem;
  color: var(--text-color, #ffffff);
  border-bottom: 1px solid var(--border-color, #334155);
  transition: background-color 0.2s;
  font-size: 0.95rem;
}

.subscribers-table tbody tr:hover td {
  background: rgba(255, 255, 255, 0.02);
}

.subscribers-table tbody tr:last-child td {
  border-bottom: none;
}

.email-col {
  font-weight: 500;
  color: var(--primary-color, #3b82f6) !important;
}

.ua-col {
  color: var(--text-muted, #94a3b8) !important;
  font-size: 0.875rem !important;
}

.status-badge {
  display: inline-block;
  padding: 0.25rem 0.65rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.status-badge.confirmed {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
  border: 1px solid rgba(16, 185, 129, 0.3);
}

.status-badge.pending {
  background: rgba(251, 191, 36, 0.15);
  color: #f59e0b;
  border: 1px solid rgba(251, 191, 36, 0.3);
}

.table-footer {
  padding: 1rem 1.5rem;
  background: rgba(15, 23, 42, 0.4);
  color: var(--text-muted, #94a3b8);
  font-size: 0.875rem;
  font-weight: 500;
  display: flex;
  justify-content: flex-end;
  border-top: 1px solid var(--border-color, #334155);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 768px) {
  .subscribers-table-container {
    overflow-x: auto;
  }
}

/* Botones de acción en el header */
.header-content {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}

.header-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  align-items: center;
}

.btn-action {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.55rem 1.1rem;
  border: none;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
}

.btn-action:hover:not(:disabled) {
  opacity: 0.85;
  transform: translateY(-1px);
}

.btn-action:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-action.btn-primary {
  background: #3b82f6;
  color: #fff;
}

.btn-action.btn-secondary {
  background: rgba(255,255,255,0.08);
  color: var(--text-color, #fff);
  border: 1px solid var(--border-color, #334155);
}

.btn-action.btn-danger {
  background: rgba(239, 68, 68, 0.15);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

/* Panel de resultados */
.action-result-panel {
  background: var(--bg-surface, #1e293b);
  border: 1px solid var(--border-color, #334155);
  border-radius: 12px;
  margin-bottom: 1.5rem;
  overflow: hidden;
  animation: fadeIn 0.3s ease;
}

.action-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 1.25rem;
  background: rgba(15, 23, 42, 0.4);
  font-weight: 600;
  color: var(--text-color, #fff);
  font-size: 0.9rem;
  border-bottom: 1px solid var(--border-color, #334155);
}

.close-btn {
  background: none;
  border: none;
  color: var(--text-muted, #94a3b8);
  font-size: 1.2rem;
  cursor: pointer;
  line-height: 1;
}

.action-result-body {
  padding: 1rem 1.25rem;
  font-size: 0.85rem;
  color: var(--text-secondary, #cbd5e1);
  max-height: 250px;
  overflow-y: auto;
  line-height: 1.7;
  white-space: pre-wrap;
}
</style>

<script define:vars={{ apiUrl: API_URL }}>
  const API = apiUrl.replace(/\/$/, '');

  function setLoading(btn, Loading) {
    btn.disabled = Loading;
    btn.style.opacity = Loading ? '0.6' : '1';
  }

  function showResult(title, content) {
    const panel = document.getElementById('actionResultPanel');
    document.getElementById('actionResultTitle').textContent = title;
    document.getElementById('actionResultBody').textContent = content;
    panel.style.display = 'block';
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Exportar
  document.getElementById('btnExport')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnExport');
    setLoading(btn, true);
    try {
      const res = await fetch(`${API}/forms/admin/subscribers/export`);
      const data = await res.json();
      const blob = new Blob([JSON.stringify(data.subscribers, null, 2)], {
        type: 'application/json',
      });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `suscriptores-${new Date().toISOString().slice(0, 10)}.json`;
      link.click();
      showResult('✅ Exportación', `${data.count} suscriptores exportados.`);
    } catch (e) {
      showResult('❌ Error', `No se pudo exportar: ${e.message}`);
    } finally {
      setLoading(btn, false);
    }
  });

  // Campaña de Re-confirmación
  document.getElementById('btnCampaign')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnCampaign');
    
    if (!window.confirmModalHelpers) return;
    
    window.confirmModalHelpers.open('confirmCampaignModal', async () => {
      setLoading(btn, true);
      try {
        const res = await fetch(
          `${API}/forms/admin/subscribers/reconfirmation-campaign`,
          { method: 'POST' },
        );
        const data = await res.json();
        const lines = [
          `✅ Enviados: ${data.sent}`,
          `⚠️  Omitidos: ${data.skipped}`,
          `❌ Errores: ${data.errors}`,
          '',
          ...(data.details ?? []),
        ].join('\n');
        showResult('📧 Resultado de la Campaña', lines);
      } catch (e) {
        showResult('❌ Error', `No se pudo ejecutar la campaña: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });

  // Limpieza de Inactivos
  document.getElementById('btnCleanup')?.addEventListener('click', async () => {
    const btn = document.getElementById('btnCleanup');
    
    if (!window.confirmModalHelpers) return;

    window.confirmModalHelpers.open('confirmCleanupModal', async () => {
      setLoading(btn, true);
      try {
        const res = await fetch(
          `${API}/forms/admin/subscribers/cleanup-inactive`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ daysThreshold: 7 }),
          },
        );
        const data = await res.json();
        const lines = [
          `🗑️  Marcados como inactivos: ${data.marked} de ${data.total}`,
          '',
          ...(data.details ?? []),
        ].join('\n');
        showResult('🧹 Resultado de la Limpieza', lines);
      } catch (e) {
        showResult('❌ Error', `No se pudo ejecutar la limpieza: ${e.message}`);
      } finally {
        setLoading(btn, false);
      }
    });
  });
</script>
