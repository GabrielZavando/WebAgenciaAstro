---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const { id } = Astro.params;

let ticket: any = null;
let errorMsg = null;

try {
  const response = await fetch(`${API_URL}/support/tickets/${id}`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    ticket = await response.json();
  } else {
    errorMsg = `Error al cargar datos del ticket: ${response.statusText}`;
    if (response.status === 404 || response.status === 403) {
      errorMsg = "No se encontró el ticket solicitado o no tienes permisos para verlo.";
    }
  }
} catch (e) {
  errorMsg = "No se pudo conectar con el servidor.";
  console.error("Error fetching ticket data:", e);
}

if (!ticket && !errorMsg) {
  errorMsg = "Ticket no encontrado.";
}

// Format the date properly
function formatFullDate(raw: { _seconds?: number } | string): string {
  let d: Date;
  if (typeof raw === 'string') d = new Date(raw);
  else if (raw && raw._seconds) d = new Date(raw._seconds * 1000);
  else return '-';

  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()} a las ${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
}

const getStatusInfo = (status: string) => {
  const map: Record<string, { label: string; className: string; icon: string }> = {
    open: { label: 'Enviado', className: 'status-open', icon: 'send' },
    'in-progress': { label: 'En progreso', className: 'status-progress', icon: 'schedule' },
    resolved: { label: 'Resuelto', className: 'status-resolved', icon: 'check' },
  };
  return map[status] || map.open;
};

const getPriorityInfo = (priority: string) => {
  const map: Record<string, { label: string; color: string }> = {
    low: { label: 'Baja', color: '#22c55e' },
    medium: { label: 'Media', color: '#f59e0b' },
    high: { label: 'Alta', color: '#ef4444' },
  };
  return map[priority] || map.medium;
};

let statusInfo: any = null;
let priorityInfo: any = null;
if (ticket) {
  statusInfo = getStatusInfo(ticket.status);
  priorityInfo = getPriorityInfo(ticket.priority);
}
---

<DashboardLayout title="Ver Ticket" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Tickets', href: '/admin/tickets' }, { label: 'Detalle' }]} role="admin">
    <div class="header-actions">
      <div>
        <a href="/admin/tickets" class="back-link">
          <span class="material-symbols-outlined">arrow_back</span> Volver a la Lista de Tickets
        </a>
        {ticket && <h1>Asunto: {ticket.subject}</h1>}
      </div>
      {ticket && (
        <div class="header-right-actions">
          <div class="select-wrapper status-select-wrapper">
            <select id="headerTicketStatus" class="form-select">
              <option value="open" selected={ticket.status === 'open'}>En progreso</option>
              <option value="closed" selected={ticket.status === 'closed'}>Cerrado</option>
            </select>
          </div>
          <button type="button" class="btn-cta" id="btnUpdateTicketStatus">
            ACTUALIZAR
          </button>
          <button type="button" class="btn-cta__danger btn-delete-ticket" id="openDeleteTicketModal">
            <span class="material-symbols-outlined">delete</span>
            ELIMINAR
          </button>
        </div>
      )}
    </div>

  {errorMsg && (
    <div class="error-banner">
      <span class="material-symbols-outlined">report</span> {errorMsg}
    </div>
  )}

  {!errorMsg && ticket && (
    <div class="ticket-details-container">
      <div class="ticket-meta-card">
        <div class="meta-item">
          <span class="meta-label">ID Ticket</span>
          <span class="meta-value ticket-id">#{ticket.id.slice(0, 8).toUpperCase()}</span>
        </div>
        <div class="meta-item">
           <span class="meta-label">Cliente (Email)</span>
           <span class="meta-value ticket-meta-val">
             {ticket.clientPhotoUrl ? (
               <img src={ticket.clientPhotoUrl} alt="Avatar" class="meta-avatar-img" />
             ) : (
               <span class="material-symbols-outlined tick-user-icon">account_circle</span>
             )}
             {ticket.clientEmail || 'Desconocido'}
           </span>
        </div>
        {ticket.projectName && (
          <div class="meta-item">
            <span class="meta-label">Proyecto</span>
            <span class="meta-value">{ticket.projectName}</span>
          </div>
        )}
        <div class="meta-item">
          <span class="meta-label">Estado actual</span>
          <span class={`status-badge ${statusInfo?.className}`}>
            <span class="material-symbols-outlined">{statusInfo?.icon}</span> {statusInfo?.label}
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Prioridad</span>
          <div class="priority-badge-wrapper">
            <span class="priority-dot" style={{ backgroundColor: priorityInfo?.color }}></span>
            {priorityInfo?.label}
          </div>
        </div>
        <div class="meta-item">
          <span class="meta-label">Fecha de Envío</span>
          <span class="meta-value"><span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.1rem; margin-right: 0.2rem;">calendar_today</span> {formatFullDate(ticket.createdAt)}</span>
        </div>
        {ticket.status === 'resolved' && ticket.updatedAt && (
          <div class="meta-item resolved-meta">
            <span class="meta-label">Resuelto el</span>
            <span class="meta-value resolved-date"><span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1.1rem; margin-right: 0.2rem;">done_all</span> {formatFullDate(ticket.updatedAt)}</span>
          </div>
        )}
      </div>

      <div class="conversation" id="conversationBox">
        <!-- Mensaje inicial del cliente -->
        <div class="message client-message">
          <div class="message-header">
            <div class="user-info">
              <div class="avatar-wrapper">
                {ticket.clientPhotoUrl ? (
                  <img src={ticket.clientPhotoUrl} alt="Avatar" class="msg-avatar-img" />
                ) : (
                  <div class="msg-avatar-placeholder client"></div>
                )}
              </div>
              <div class="name-time">
                <strong>{ticket.clientEmail || 'Cliente'}</strong>
                <span class="time">{formatFullDate(ticket.createdAt)}</span>
              </div>
            </div>
          </div>
          <div class="message-body">
            {ticket.message.split('\n').map((line: string) => (<p>{line}</p>))}
            {ticket.attachmentUrl && (
              <div class="attachment-container">
                <hr class="attachment-divider" />
                <p class="attachment-label"><span class="material-symbols-outlined">attach_file</span> Archivo Adjunto</p>
                <a href={ticket.attachmentUrl} target="_blank" rel="noopener noreferrer" class="attachment-link">
                  <img src={ticket.attachmentUrl} alt="Adjunto" class="ticket-attachment-img" />
                </a>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Banner de ticket resuelto -->
      {ticket.status === 'resolved' && (
        <div class="resolved-banner">
          <span class="material-symbols-outlined">check_circle</span>
          <span>Este ticket está <strong>resuelto</strong>. Ya no se pueden enviar más mensajes.</span>
        </div>
      )}

      <!-- Formulario de nuevo mensaje (solo si no está resuelto) -->
      {ticket.status !== 'resolved' && (
        <div class="message admin-message focus-message">
          <div class="message-header">
            <div class="user-info">
              <div class="avatar-wrapper">
                <div class="msg-avatar-placeholder admin" id="replyAvatarContainer"><span class="material-symbols-outlined">headset_mic</span></div>
              </div>
              <div class="name-time"><strong>Responder (Soporte)</strong></div>
            </div>
          </div>
          <div class="message-body reply-body">
            <form class="admin-reply-form" data-id={ticket.id}>
              <textarea id="newMessageBody" name="body" placeholder="Escribe tu respuesta para el cliente..." rows="4" required></textarea>
              <div class="form-group" style="margin-top: 1.5rem;">
                <div class="file-drop file-drop--mini" id="ticketFileDrop">
                  <span class="material-symbols-outlined">cloud_upload</span>
                  <p id="ticketFileLabel">Haz clic o arrastra una imagen aquí (opcional)</p>
                  <input type="file" id="adminAttachment" name="attachment" accept="image/*" class="file-input-hidden" />
                </div>
              </div>
              <div class="form-actions-wrapper">
                <!-- Selector de estado ha sido movido a la parte superior -->
                <button type="submit" class="btn-cta">
                  Enviar Mensaje
                </button>
              </div>
              <div class="feedback-message hidden" id={`feedback-${ticket.id}`}></div>
            </form>
          </div>
        </div>
      )}
    </div>
  )}

  <Fragment slot="modals">
    <ModalConfirm 
      id="deleteTicketModal"
      title="¿Eliminar Ticket?"
      message="¿Estás seguro de que deseas eliminar este ticket permanentemente? Se eliminarán todos los mensajes y archivos adjuntos asociados. Esta acción no se puede deshacer."
      confirmText="Eliminar permanentemente"
      type="danger"
    />
    <ModalMessage 
      id="ticketResponseErrorModal"
      type="error"
      title="Error"
      message="Ocurrió un error."
    />
  </Fragment>
</DashboardLayout>

<script>
  import { auth } from "../../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  function initTicketView() {
    // Solo ejecutar en la vista individual de ticket
    if (!window.location.pathname.includes('/admin/tickets/') || window.location.pathname.endsWith('/admin/tickets')) return;

    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
    const ticketId = window.location.pathname.split('/').pop()!;
    let token = '';

    // ── Helpers para fechas ──
    function fmtDate(raw: any): string {
      let d: Date;
      if (!raw) return '';
      if (raw._seconds) d = new Date(raw._seconds * 1000);
      else d = new Date(raw);
      if (isNaN(d.getTime())) return '';
      const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
      return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()} ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
    }

    // ── Renderizar mensajes ──
    function renderMessages(messages: any[]) {
      const box = document.getElementById('conversationBox');
      if (!box || !messages.length) return;
      
      // Mantener el primer mensaje (el del servidor) y limpiar el resto
      const initialMsg = box.firstElementChild;
      box.innerHTML = '';
      if (initialMsg) box.appendChild(initialMsg);
      
      const clientPhotoUrl = document.querySelector('.client-message .msg-avatar-img')?.getAttribute('src') || '';
      const clientName = document.querySelector('.client-message .name-time strong')?.textContent || 'Cliente';
      
      messages.forEach(m => {
        const isAdmin = m.senderRole === 'admin';
        
        let avatarHtml = '';
        if (m.senderPhotoUrl) {
          avatarHtml = `<img src="${m.senderPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
        } else if (!isAdmin && clientPhotoUrl) {
          avatarHtml = `<img src="${clientPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
        } else if (!isAdmin) {
          avatarHtml = `<div class="msg-avatar-placeholder client"></div>`;
        } else {
          avatarHtml = `<div class="msg-avatar-placeholder admin"><span class="material-symbols-outlined">headset_mic</span></div>`;
        }
        
        const msgDiv = document.createElement('div');
        msgDiv.className = `message ${isAdmin ? 'admin-message' : 'client-message'}`;
        msgDiv.innerHTML = `
            <div class="message-header">
              <div class="user-info">
                <div class="avatar-wrapper">
                  ${avatarHtml}
                </div>
                <div class="name-time">
                  <strong>${isAdmin ? 'Equipo de Soporte' : clientName}</strong>
                  <span class="time">${fmtDate(m.createdAt)}</span>
                </div>
              </div>
            </div>
            <div class="message-body">
              ${m.body.split('\n').map((l: string) => `<p>${l}</p>`).join('')}
              ${m.attachmentUrl ? `
                <div class="attachment-container">
                  <p class="attachment-label"><span class="material-symbols-outlined">attach_file</span> Archivo Adjunto</p>
                  <a href="${m.attachmentUrl}" target="_blank" rel="noopener noreferrer">
                    <img src="${m.attachmentUrl}" alt="Adjunto" class="ticket-attachment-img" />
                  </a>
                </div>` : ''}
            </div>`;
        box.appendChild(msgDiv);
      });
    }

    // ── Cargar mensajes ──
    async function loadMessages() {
      const currentToken = auth.currentUser ? await auth.currentUser.getIdToken() : token;
      if (!currentToken) return;
      try {
        const res = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
          headers: { 'Authorization': `Bearer ${currentToken}` }
        });
        if (res.ok) renderMessages(await res.json());
      } catch {}
    }

    // ── Form submit ──
    const form = document.querySelector('.admin-reply-form') as HTMLFormElement | null;
    if (form) {
      // Evitar listeners duplicados en View Transitions clonando y reemplazando
      const newForm = form.cloneNode(true) as HTMLFormElement;
      form.parentNode?.replaceChild(newForm, form);

      newForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = newForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const feedback = document.getElementById(`feedback-${ticketId}`) as HTMLElement;
        const bodyEl = newForm.querySelector<HTMLTextAreaElement>('[name="body"]')!;
        const body = bodyEl.value.trim();

        if (!body) return;
        setLoading(submitBtn, true);

        try {
          const formData = new FormData();
          formData.append('body', body);
          formData.append('senderRole', 'admin');
          if (auth.currentUser?.photoURL) {
            formData.append('senderPhotoUrl', auth.currentUser.photoURL);
          }
          const fileInput = newForm.querySelector<HTMLInputElement>('[name="attachment"]');
          if (fileInput?.files?.[0]) {
            formData.append('attachment', fileInput.files[0]);
          }

          const currentToken = auth.currentUser ? await auth.currentUser.getIdToken() : token;
          const msgRes = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${currentToken}` },
            body: formData
          });
          
          if (!msgRes.ok) {
            const errData = await msgRes.json().catch(() => ({}));
            throw new Error(errData.message || 'Error al enviar el mensaje al servidor.');
          }

          bodyEl.value = '';
          if (fileInput) fileInput.value = '';
          const fileLabel = newForm.querySelector('.attachment-input-wrapper span');
          if (fileLabel) fileLabel.textContent = 'Adjuntar imagen (opcional)';

          showFeedback(feedback, 'Mensaje enviado correctamente.', 'success');
          await loadMessages();

        } catch (err: any) {
          showFeedback(feedback, err.message || 'Error en el servidor', 'error');
        } finally {
          setLoading(submitBtn, false);
        }
      });
      
      // --- Lógica de Mini File Drop ---
      const ticketFileDrop = newForm.querySelector('#ticketFileDrop') as HTMLElement;
      const ticketFileLabel = newForm.querySelector('#ticketFileLabel') as HTMLElement;
      const fileInputAttach = newForm.querySelector('#adminAttachment') as HTMLInputElement;

      if (ticketFileDrop && fileInputAttach) {
        // Al hacer clic en el contenedor (que ahora es el dropzone)
        ticketFileDrop.addEventListener('click', () => fileInputAttach.click());

        fileInputAttach.addEventListener('change', () => {
          if (fileInputAttach.files?.length && ticketFileLabel) {
            ticketFileLabel.textContent = fileInputAttach.files[0].name;
            ticketFileDrop.classList.add('has-file');
          }
        });

        ticketFileDrop.addEventListener('dragover', (e) => {
          e.preventDefault();
          ticketFileDrop.classList.add('drag-over');
        });

        ticketFileDrop.addEventListener('dragleave', () => {
          ticketFileDrop.classList.remove('drag-over');
        });

        ticketFileDrop.addEventListener('drop', (e) => {
          e.preventDefault();
          ticketFileDrop.classList.remove('drag-over');
          const files = e.dataTransfer?.files;
          if (files?.length) {
            fileInputAttach.files = files;
            if (ticketFileLabel) {
              ticketFileLabel.textContent = files[0].name;
              ticketFileDrop.classList.add('has-file');
            }
          }
        });
      }
    }

    function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
      btn.disabled = isLoading;
      btn.classList.toggle('btn-loading', isLoading);
    }

    function showFeedback(el: HTMLElement, message: string, type: 'error' | 'success') {
      if (type === 'success') {
        return;
      }

      if (window.modalHelpers) {
        if (type === 'error') {
          window.modalHelpers.updateModalMessage('ticketResponseErrorModal', message);
          window.modalHelpers.openModal('ticketResponseErrorModal');
        }
      } else {
        el.textContent = message;
        el.className = `feedback-message ${type}`;
        setTimeout(() => { el.className = 'feedback-message hidden'; }, 4000);
      }
    }

    // --- Actualización de Estado ---
    const btnUpdateStatus = document.getElementById('btnUpdateTicketStatus') as HTMLButtonElement | null;
    if (btnUpdateStatus) {
      const newUpdateBtn = btnUpdateStatus.cloneNode(true) as HTMLButtonElement;
      btnUpdateStatus.parentNode?.replaceChild(newUpdateBtn, btnUpdateStatus);

      newUpdateBtn.addEventListener('click', async () => {
        const selectStatus = document.getElementById('headerTicketStatus') as HTMLSelectElement;
        const newStatus = selectStatus.value;
        const feedback = document.getElementById(`feedback-${ticketId}`) as HTMLElement; // Reutilizando feedback si existe en scope
        
        setLoading(newUpdateBtn, true);
        try {
          const currentToken = auth.currentUser ? await auth.currentUser.getIdToken(true) : token;
          const res = await fetch(`${API_URL}/support/tickets/${ticketId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${currentToken}` },
            body: JSON.stringify({ status: newStatus })
          });
          
          if (!res.ok) throw new Error("Error al actualizar el estado");
          
          // Recargar tras éxito
          setTimeout(() => window.location.reload(), 500);
        } catch (err: any) {
          if (window.modalHelpers) {
            window.modalHelpers.updateModalMessage('ticketResponseErrorModal', err.message || 'Error al actualizar estado');
            window.modalHelpers.openModal('ticketResponseErrorModal');
          } else {
            console.error('Error actualizando estado:', err);
          }
        } finally {
          setLoading(newUpdateBtn, false);
        }
      });
    }

    // --- Borrado de Ticket ---
    const openDeleteBtn = document.getElementById('openDeleteTicketModal');
    if (openDeleteBtn) {
      const newDeleteBtn = openDeleteBtn.cloneNode(true) as HTMLElement;
      openDeleteBtn.parentNode?.replaceChild(newDeleteBtn, openDeleteBtn);

      newDeleteBtn.addEventListener('click', () => {
        if (window.confirmModalHelpers) {
          window.confirmModalHelpers.open('deleteTicketModal', async () => {
            try {
              const currentToken = auth.currentUser ? await auth.currentUser.getIdToken(true) : token;
              const res = await fetch(`${API_URL}/support/tickets/${ticketId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${currentToken}` }
              });
              
              if (!res.ok) throw new Error('Error al eliminar ticket');
              
              if (window.showToast) window.showToast('Ticket eliminado correctamente', 'success');
              setTimeout(() => window.location.href = '/admin/tickets', 1500);
            } catch (err: any) {
              if (window.showToast) window.showToast(err.message, 'error');
            }
          });
        } else {
          console.error("No se encontró confirmModalHelpers");
        }
      });
    }

    onAuthStateChanged(auth, async (user) => {
      if (user) {
        token = await user.getIdToken();
        
        // Actualizar avatar en el área de respuesta
        const replyAvatarContainer = document.getElementById('replyAvatarContainer');
        if (replyAvatarContainer) {
          if (user.photoURL) {
            replyAvatarContainer.innerHTML = `<img src="${user.photoURL}" alt="Avatar" class="msg-avatar-img" />`;
          } else {
            replyAvatarContainer.innerHTML = `<div class="msg-avatar-placeholder admin"><span class="material-symbols-outlined">headset_mic</span></div>`;
          }
        }

        await loadMessages();
      }
    });
  }

  // Inicializar en cada carga de página (soporte para View Transitions)
  document.addEventListener('astro:page-load', initTicketView);
</script>



