---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Gestión de Tickets" role="admin">
  <div class="support-page">
    <div class="page-header">
      <div>
        <h1>Gestión de Tickets</h1>
        <p class="text-muted">Revisa y responde las solicitudes de soporte de los clientes.</p>
      </div>
    </div>

    <!-- Acciones principales (Filtro) -->
    <div class="actions-row">
      <div class="search-input-wrapper">
        <label for="clientSelect" class="sr-only">Filtrar por Cliente</label>
        <select id="clientSelect" class="form-select">
          <option value="">Cargando clientes...</option>
        </select>
      </div>
      <div class="search-input-wrapper">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por asunto del ticket..." autocomplete="off" />
      </div>
    </div>

    <!-- Tabla de lista de tickets, igual a dashboard/soporte.astro -->
    <div class="table-container">
      <table class="files-table">
        <thead>
          <tr>
            <th class="col-client">Cliente</th>
            <th class="col-project">Proyecto</th>
            <th class="col-status">Estado</th>
            <th class="col-priority">Prioridad</th>
            <th class="col-subject">Asunto</th>
            <th class="col-date">Fecha Enviado</th>
            <th class="col-date">Fecha Resuelto</th>
            <th class="col-actions">Acciones</th>
          </tr>
        </thead>
        <tbody id="ticketsListBody">
          <tr>
            <td colspan="8">
              <div class="loading-state">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Cargando tickets...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const ticketsListBody = document.getElementById('ticketsListBody');
  const clientSelect = document.getElementById('clientSelect') as HTMLSelectElement;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;

  interface Ticket {
    id: string;
    subject: string;
    message: string;
    priority: 'low' | 'medium' | 'high';
    status: 'open' | 'in-progress' | 'resolved';
    adminResponse: string;
    createdAt: { _seconds?: number } | string;
    updatedAt: { _seconds?: number } | string;
    clientEmail?: string;
    clientId?: string;
    projectId?: string;
    projectName?: string;
  }

  interface Client {
    id: string;
    displayName: string;
    email: string;
  }
  
  interface Project {
    id: string;
    name: string;
    clientId: string;
  }

  let allTickets: Ticket[] = [];
  let allClients: Client[] = [];
  let allProjects: Project[] = [];
  let token = '';

  onAuthStateChanged(auth, async (user) => {
    if (!user) return;
    token = await user.getIdToken();
    await Promise.all([
      loadClients(),
      loadProjects(),
      loadTickets()
    ]);
  });

  async function loadClients() {
    try {
      // Intentamos cargar clientes desde el servicio de clientes si existe
      // O los traemos desde /users si no. Basado en el backend, /clients retorna clientes válidos
      const res = await fetch(`${API_URL}/clients`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) throw new Error();
      const rawClients = await res.json();
      allClients = rawClients.map((c: { uid?: string, id?: string, displayName?: string, name?: string, email: string }) => ({
        id: c.uid || c.id || '',
        displayName: c.displayName || c.name || 'Sin nombre',
        email: c.email
      }));
      populateClientSelect();
    } catch {
      console.error("No se pudieron cargar los clientes");
      if (clientSelect) {
        clientSelect.innerHTML = '<option value="">Todos los clientes</option>';
      }
    }
  }
  
  async function loadProjects() {
    try {
      // Necesitamos cargar el catálogo de proyectos completo o por cliente
      // Asumiremos que el admin tiene un listado de proyectos o podemos obtenerlos indirectamente
      const res = await fetch(`${API_URL}/projects`, {
        headers: { 'Authorization': `Bearer ${token}` }
      }).catch(() => null);
      
      if (res && res.ok) {
        allProjects = await res.json();
      }
    } catch {
      console.error("No se pudieron cargar los proyectos de forma global, se usarán los nombres guardados en los tickets si están");
    }
  }

  function populateClientSelect() {
    if (!clientSelect) return;
    const defaultOption = '<option value="">Todos los clientes</option>';
    const options = allClients.map(c => `<option value="${c.email}">${c.displayName} (${c.email})</option>`);
    clientSelect.innerHTML = defaultOption + options.join('');
    
    clientSelect.addEventListener('change', applyFilters);
  }

  async function loadTickets() {
    try {
      const res = await fetch(`${API_URL}/support/tickets`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) throw new Error();
      allTickets = await res.json();
      applyFilters();
    } catch {
      if (ticketsListBody) {
        ticketsListBody.innerHTML = `
          <tr><td colspan="8">
            <div class="empty-state">
              <i class="fas fa-exclamation-triangle"></i>
              <p>Error al cargar tickets.</p>
            </div>
          </td></tr>`;
      }
    }
  }

  searchInput?.addEventListener('input', applyFilters);

  function applyFilters() {
    if (!ticketsListBody) return;
    
    const query = searchInput?.value.toLowerCase().trim() || '';
    const selectedClientEmail = clientSelect?.value || '';
    
    let filtered = [...allTickets];

    if (query) {
      filtered = filtered.filter(t => t.subject.toLowerCase().includes(query));
    }
    
    if (selectedClientEmail) {
      filtered = filtered.filter(t => t.clientEmail === selectedClientEmail);
    }

    renderTickets(filtered);
  }

  function renderTickets(tickets: Ticket[]) {
    if (!ticketsListBody) return;

    if (tickets.length === 0) {
      ticketsListBody.innerHTML = `
        <tr>
          <td colspan="8">
            <div class="empty-state">
              <i class="fas fa-inbox"></i>
              <h3>Sin resultados</h3>
              <p>No se encontraron tickets con esos filtros.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    ticketsListBody.innerHTML = tickets.map(ticket => {
      const dateCreated = formatDate(ticket.createdAt);
      const dateResolved = ticket.status === 'resolved' && ticket.updatedAt ? formatDate(ticket.updatedAt) : '-';
      const statusInfo = getStatusInfo(ticket.status);
      const priorityInfo = getPriorityInfo(ticket.priority);
      
      const projectName = ticket.projectName || (allProjects.find(p => p.id === ticket.projectId)?.name || 'S/P');
      const badgeHtml = projectName !== 'S/P' ? `<span class="project-badge"><i class="fas fa-folder"></i> ${projectName}</span>` : `<span class="project-badge" style="background:#e2e8f0;color:#64748b"><i class="fas fa-folder"></i> S/P</span>`;

      return `
        <tr class="file-row">
          <td class="col-client-data">
            <div style="font-size: 0.9rem; font-weight: 500;">
              ${ticket.clientEmail || 'Desconocido'}
            </div>
          </td>
          <td class="col-name-data">
            ${badgeHtml}
          </td>
          <td class="col-status-data">
            <span class="status-badge ${statusInfo.className}" title="${statusInfo.label}">
              <i class="${statusInfo.icon}"></i> ${statusInfo.label}
            </span>
          </td>
          <td class="col-priority-data">
            <div class="priority-badge-wrapper" title="${priorityInfo.label}">
              <span class="priority-dot" style="background-color: ${priorityInfo.color}"></span>
              ${priorityInfo.label}
            </div>
          </td>
          <td class="col-name-data">
            <div class="ticket-subject-cell">
              <span class="file-title" title="${ticket.subject}">${ticket.subject}</span>
            </div>
          </td>
          <td class="col-date-data">
            ${dateCreated}
          </td>
          <td class="col-date-data ${ticket.status === 'resolved' ? 'resolved-date' : ''}">
            ${dateResolved}
          </td>
          <td class="col-actions-data" style="position: relative;">
            <div class="td-actions">
               ${ticket.status !== 'resolved' ? `
              <button class="btn-action reply-btn" data-id="${ticket.id}" title="Responder" style="padding: 0.4rem 0.6rem; font-size: 0.85rem; border: 1px solid var(--color-primary); background: transparent; border-radius: 4px; color: var(--color-primary); cursor: pointer;">
                <i class="fas fa-reply"></i>
              </button>
               ` : ''}
              <a href="/admin/tickets/${ticket.id}" class="btn-action view-btn outline" data-view="${ticket.id}" title="Ver Ticket completo" style="padding: 0.4rem 0.6rem; font-size: 0.85rem; border: 1px solid var(--color-border); background: transparent; border-radius: 4px; color: var(--color-text); cursor: pointer;">
                <i class="fas fa-eye"></i>
              </a>
            </div>
            ${renderQuickReply(ticket)}
          </td>
        </tr>
      `;
    }).join('');

    // Attach form listeners for quick reply
    document.querySelectorAll('.reply-btn').forEach(btn => {
      btn.addEventListener('click', (e) => toggleReplyForm(e));
    });

    document.querySelectorAll('.admin-reply-form').forEach(form => {
      form.addEventListener('submit', handleReplySubmit);
    });
  }
  
  function renderQuickReply(ticket: Ticket): string {
    if (ticket.status === 'resolved') return '';
    return `
      <div class="quick-reply-panel hidden" id="reply-panel-${ticket.id}" style="position: absolute; right: 0; top: 100%; z-index: 50; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem; width: 320px; box-shadow: var(--shadow-md);">
        <form class="admin-reply-form" data-id="${ticket.id}">
          <label style="display:block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem;">Responder Ticket</label>
          <textarea name="adminResponse" placeholder="Escribe tu respuesta para el cliente..." rows="3" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--color-border); border-radius: 4px; resize: vertical; margin-bottom: 0.5rem; font-family: inherit; font-size: 0.85rem;">${ticket.adminResponse || ''}</textarea>
          
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <select name="status" class="status-select" style="padding: 0.4rem; font-size: 0.8rem; border-radius: 4px; border: 1px solid var(--color-border);">
              <option value="in-progress" ${ticket.status === 'in-progress' ? 'selected' : ''}>En progreso</option>
              <option value="resolved">Resuelto</option>
            </select>
            <div style="display: flex; gap: 0.5rem;">
              <button type="button" class="btn-cancel-reply" data-id="${ticket.id}" style="padding: 0.4rem 0.8rem; border: 1px solid var(--color-border); background: transparent; border-radius: 4px; font-size: 0.8rem; cursor: pointer;">Cancelar</button>
              <button type="submit" class="btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border: none; background: var(--color-primary); color: white; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 0.3rem;">
                <span class="btn-text">Enviar</span>
                <span class="loader hidden" style="width: 12px; height: 12px; border-width: 2px;"></span>
              </button>
            </div>
          </div>
          <div class="feedback-message hidden" style="margin-top: 0.5rem; font-size: 0.8rem; padding: 0.3rem; text-align: center; border-radius: 4px;"></div>
        </form>
      </div>
    `;
  }
  
  function toggleReplyForm(e: Event) {
    const btn = e.currentTarget as HTMLButtonElement;
    const ticketId = btn.getAttribute('data-id');
    const panel = document.getElementById(`reply-panel-${ticketId}`);
    
    // Close all other panels
    document.querySelectorAll('.quick-reply-panel').forEach(p => {
      if (p.id !== `reply-panel-${ticketId}`) p.classList.add('hidden');
    });
    
    if (panel) {
      panel.classList.toggle('hidden');
      
      // Add cancel listener if not added
      const cancelBtn = panel.querySelector('.btn-cancel-reply');
      if (cancelBtn && !cancelBtn.hasAttribute('data-listener')) {
        cancelBtn.setAttribute('data-listener', 'true');
        cancelBtn.addEventListener('click', () => panel.classList.add('hidden'));
      }
    }
  }

  async function handleReplySubmit(e: Event) {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const ticketId = form.getAttribute('data-id');
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const feedback = form.querySelector('.feedback-message') as HTMLElement;
    const formData = new FormData(form);
    
    const adminResponse = (formData.get('adminResponse') as string).trim();
    const status = formData.get('status') as string;

    setLoading(submitBtn, true);

    try {
      const res = await fetch(`${API_URL}/support/tickets/${ticketId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ adminResponse, status })
      });

      if (!res.ok) throw new Error('Error al actualizar el ticket');
      
      showFeedback(feedback, 'Actualizado correctamente.', 'success');
      setTimeout(() => loadTickets(), 1200); // Reload entire list
    } catch (err: any) {
      showFeedback(feedback, err.message, 'error');
      setLoading(submitBtn, false);
    }
  }

  // Utilidades (igual a dashboard/soporte.astro)
  function getStatusInfo(status: string) {
    const map: Record<string, { label: string; className: string; icon: string }> = {
      open: { label: 'Abierto', className: 'status-open', icon: 'fas fa-envelope' },
      'in-progress': { label: 'En progreso', className: 'status-progress', icon: 'fas fa-spinner' },
      resolved: { label: 'Resuelto', className: 'status-resolved', icon: 'fas fa-check-circle' },
    };
    return map[status] || map.open;
  }

  function getPriorityInfo(priority: string) {
    const map: Record<string, { label: string; color: string }> = {
      low: { label: 'Baja', color: '#22c55e' },
      medium: { label: 'Media', color: '#f59e0b' },
      high: { label: 'Alta', color: '#ef4444' },
    };
    return map[priority] || map.medium;
  }

  function getRawDate(raw: { _seconds?: number } | string | undefined): Date {
    if (!raw) return new Date();
    if (typeof raw === 'string') return new Date(raw);
    if (raw && raw._seconds) return new Date(raw._seconds * 1000);
    return new Date();
  }

  function formatDate(raw: { _seconds?: number } | string | undefined): string {
    if (!raw) return '-';
    const d = getRawDate(raw);
    const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
    return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
  }

  function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
    const text = btn.querySelector('.btn-text');
    const loader = btn.querySelector('.loader');
    btn.disabled = isLoading;
    if (isLoading) {
      text?.classList.add('hidden');
      loader?.classList.remove('hidden');
    } else {
      text?.classList.remove('hidden');
      loader?.classList.add('hidden');
    }
  }

  function showFeedback(el: HTMLElement, message: string, type: 'error' | 'success') {
    el.textContent = message;
    el.className = `feedback-message ${type}`;
    // no timeout reset if success to avoid blink before reload
    if (type === 'error') {
      setTimeout(() => { el.className = 'feedback-message hidden'; }, 4000);
    }
  }
</script>

<style>
  .support-page { width: 100%; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin: 0 0 0.5rem; font-size: 2rem; font-weight: 700; color: var(--color-text); }
  .text-muted { color: var(--color-text-muted); margin: 0; font-size: 1.05rem; }

  /* Controles (Buscador y Filtro) */
  .actions-row { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: stretch; justify-content: flex-start; }
  .search-input-wrapper { flex: 1; min-width: 250px; max-width: 350px; position: relative; }
  .search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); }
  .search-input-wrapper input, .search-input-wrapper select {
    width: 100%; padding: 0.875rem 1.2rem 0.875rem 3rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-surface); color: var(--color-text);
    font-family: inherit; font-size: 0.95rem; box-sizing: border-box; transition: all 0.2s; box-shadow: var(--shadow-sm);
  }
  .search-input-wrapper select { padding-left: 1.2rem; }
  .search-input-wrapper input:focus, .search-input-wrapper select:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1); }
  
  .btn-primary {
    padding: 0 1.75rem; background: var(--color-primary); color: white; border: none;
    border-radius: var(--radius-md); font-weight: 600; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.6rem; font-size: 0.95rem; white-space: nowrap; transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(var(--color-primary-rgb), 0.2);
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 8px -1px rgba(var(--color-primary-rgb), 0.3); }

  /* Tabla de Tickets (Premium UI) */
  .table-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  
  .table-container table { width: 100%; border-collapse: collapse; text-align: left; }

  /* Cabeceras */
  .files-table thead { background: rgba(0, 0, 0, 0.02); border-bottom: 2px solid var(--color-border); }
  .files-table th {
    padding: 1.25rem 1.5rem; font-size: 0.8rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-right: 1px solid var(--color-border); vertical-align: middle;
  }
  .files-table th:last-child { border-right: none; }
  
  /* Celdas */
  .files-table :global(td) { padding: 1.5rem; border-bottom: 1px solid var(--color-border); border-right: 1px solid var(--color-border); vertical-align: middle; }
  .files-table :global(td:last-child) { border-right: none; }
  .files-table :global(tbody tr:last-child td) { border-bottom: none; }
  .files-table :global(tbody tr) { transition: background-color 0.2s; }
  .files-table :global(tbody tr:hover) { background-color: rgba(var(--color-primary-rgb), 0.03); }

  /* Anchos de columnas */
  .col-client { width: 140px; }
  .col-status { width: 140px; text-align: center; }
  .col-priority { width: 120px; text-align: center; }
  .col-subject { width: auto; }
  .col-date { width: 10%; text-align: center; }
  .col-actions { width: 110px; text-align: center; }

  /* Elementos de tabla */
  .files-table :global(.status-badge) {
    font-size: 0.8rem; font-weight: 600; padding: 0.3rem 0.8rem; border-radius: 999px; display: inline-flex; align-items: center; gap: 0.4rem; white-space: nowrap;
  }
  .files-table :global(.status-open) { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .files-table :global(.status-progress) { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .files-table :global(.status-resolved) { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

  .files-table :global(.priority-badge-wrapper) {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; font-weight: 500; color: var(--color-text); text-transform: capitalize;
  }
  .files-table :global(.priority-dot) { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

  .files-table :global(.col-name-data) { vertical-align: middle; }
  .files-table :global(.file-title) { font-weight: 500; font-size: 1rem; color: var(--color-text); display: block; }
  .files-table :global(.project-badge) { font-size: 0.8rem; font-weight: 600; padding: 0.3rem 0.8rem; border-radius: 999px; display: inline-flex; align-items: center; gap: 0.4rem; white-space: nowrap; background: rgba(var(--color-text-rgb, 100,116,139), 0.1); color: var(--color-text-muted); }
  
  .files-table :global(.col-date-data) { text-align: center; color: var(--color-text-muted); font-size: 0.95rem; vertical-align: middle; }
  .files-table :global(.resolved-date) { color: #22c55e; font-weight: 500;}

  /* Acciones */
  .files-table :global(.col-actions-data) { text-align: center; vertical-align: middle; }
  .files-table :global(.td-actions) { display: flex; justify-content: center; align-items: center; gap: 0.75rem; }
  .files-table :global(.btn-action) {
    background: transparent; color: var(--color-text); transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center;
  }
  .files-table :global(.view-btn:hover) { background: var(--color-background); color: var(--color-text); }
  .files-table :global(.reply-btn:hover) { background: var(--color-primary); color: white !important; }

  /* Estados vacíos y carga */
  .files-table :global(.loading-state), .files-table :global(.empty-state) { text-align: center; padding: 5rem 2rem; color: var(--color-text-muted); }
  .files-table :global(.loading-state i), .files-table :global(.empty-state i) { font-size: 3rem; margin-bottom: 1.5rem; display: block; opacity: 0.4; }
  .files-table :global(.empty-state h3) { margin: 0 0 0.5rem; color: var(--color-text); font-size: 1.25rem; font-weight: 600; }
  .files-table :global(.empty-state p) { margin: 0; font-size: 0.95rem; }

  /* Misc */
  .hidden { display: none !important; }
  .loader { border: 2px solid #fff; border-bottom-color: transparent; border-radius: 50%; display: inline-block; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Responsive */
  @media (max-width: 768px) {
    .actions-row { flex-direction: column; }
    .search-input-wrapper { max-width: 100%; min-width: 100%; }
    
    .files-table thead { display: none; }
    .files-table, .files-table :global(tbody), .files-table :global(tr), .files-table :global(td) { display: block; width: 100%; }
    .files-table :global(tr) { border-bottom: 2px solid var(--color-border); padding: 1.25rem; position: relative; }
    .files-table :global(td) { padding: 0.35rem 0; border: none; text-align: left !important; }
    .files-table :global(.col-status-data) { display: inline-block; margin-bottom: 0.5rem; }
    .files-table :global(.col-priority-data) { display: inline-block; margin-left: 1rem; margin-bottom: 0.5rem; }
    .files-table :global(.col-date-data::before) { content: "Fecha: "; font-weight: 600; }
    .files-table :global(.resolved-date::before) { content: "Resuelto el: "; }
    .files-table :global(.col-actions-data) { margin-top: 1rem; padding-top: 1rem !important; border-top: 1px solid var(--color-border) !important; text-align: left !important; }
    .files-table :global(.td-actions) { justify-content: flex-start; }
    
    .files-table :global(.quick-reply-panel) { position: static !important; width: 100% !important; margin-top: 1rem; }
  }
</style>
