---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import TicketManagementSystem from '../../../components/admin/TicketManagementSystem.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Gestión de Tickets" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Tickets' }]} role="admin">
  <div class="support-page">
    <div class="page-header">
      <div>
        <h1>Gestión de Tickets</h1>
        <p class="text-muted">Revisa y responde las solicitudes de soporte de los clientes.</p>
      </div>
    </div>

    <TicketManagementSystem />
  </div>
</DashboardLayout>


