---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import TicketManagementSystem from '../../../components/admin/TicketManagementSystem.astro';
import StorageVisualizer from '../../../components/admin/StorageVisualizer.astro';
import ReportTable from '../../../components/admin/ReportTable.astro';
import ModalConfirm from '../../../components/shared/ModalConfirm.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

import { apiClient } from '../../../lib/api-client';

import type { ClientResponseDto, ProjectResponseDto, StorageQuotaDto, ReportResponseDto } from '../../../types/api';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

let user: ClientResponseDto | null = null;
let projects: ProjectResponseDto[] = [];
let storage: StorageQuotaDto | null = null;
let reports: ReportResponseDto[] = [];
let errorMsg = null;

try {
  const [userData, projectsData, storageData, reportsData] = await Promise.all([
    apiClient.get<ClientResponseDto>(`/users/${id}`, { token }).catch((e) => {
      errorMsg = e.status === 403 
        ? "No tienes permisos de Administrador para ver esta página." 
        : `Error al cargar datos del usuario: ${e.message}`;
      return null;
    }),
    apiClient.get<ProjectResponseDto[]>(`/projects/client/${id}`, { token }).catch(() => []),
    apiClient.get<StorageQuotaDto>(`/files/storage/quota/${id}`, { token }).catch(() => null),
    apiClient.get<ReportResponseDto[]>(`/reports?clientId=${id}`, { token }).catch(() => [])
  ]);

  user = userData;
  projects = projectsData;
  storage = storageData;
  reports = reportsData;
} catch (e) {
  errorMsg = "No se pudo conectar con el servidor.";
  console.error("Error fetching data:", e);
}

if (!user && !errorMsg) {
  errorMsg = "Usuario no encontrado.";
}
---

<DashboardLayout title="Editar Usuario" breadcrumbs={[{ label: 'Admin', href: '/admin' }, { label: 'Usuarios', href: '/admin/usuarios' }, { label: 'Detalle' }]} role="admin">
  <div class="header-actions">
    <div>
      <a href="/admin/usuarios" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span> Volver a Usuarios
      </a>
    </div>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <span class="material-symbols-outlined">report</span> {errorMsg}
    </div>
  )}

  {!errorMsg && user && (
    <div class="user-detail-container">
      <!-- Vista de Resumen (Cards) -->
      <div id="summaryView" class="summary-grid fade-in">
        <!-- Card: Perfil (Wider/Premium) -->
        <div class="summary-card interactive-card profile-card-premium" data-target="section-profile">
          <div class="profile-layout-horizontal">
            <div class="profile-avatar-container">
              {user.photoURL ? (
                <img src={user.photoURL} alt={user.displayName} class="user-large-avatar" />
              ) : (
                <div class="user-large-initials">
                  {user.displayName ? user.displayName.charAt(0).toUpperCase() : user.email.charAt(0).toUpperCase()}
                </div>
              )}
            </div>
            <div class="profile-details-info">
              <span class="profile-label-tag">Perfil del Usuario</span>
              <h2 class="profile-full-name">{user.displayName || 'Sin nombre'}</h2>
              <p class="profile-email-text">{user.email}</p>
              <div class="profile-role-wrapper">
                <span class={`role-badge-flat ${user.role}`}>
                  {user.role === 'admin' ? 'Administrador' : 'Cliente'}
                </span>
              </div>
            </div>
          </div>
          <div class="card-footer">
            <span>Editar perfil completo <span class="material-symbols-outlined">arrow_forward</span></span>
          </div>
        </div>

        <!-- Card: Proyectos y Tickets -->
        <div class="summary-card interactive-card" data-target="section-projects">
          <div class="dual-icons-wrapper">
            <div class="icon-box project-box" title="Proyectos">
              <span class="material-symbols-outlined">task</span>
            </div>
            <div class="icon-box ticket-box" title="Tickets">
              <span class="material-symbols-outlined">confirmation_number</span>
            </div>
          </div>
          <div class="card-content">
            <h3>Proyectos y Tickets</h3>
            <div class="stats-row">
              <span class="stat-number">{projects.length}</span>
              <span class="stat-label">Proyectos activos</span>
            </div>
          </div>
          <div class="card-footer">
            <span>Proyectos y tickets <span class="material-symbols-outlined">arrow_forward</span></span>
          </div>
        </div>

        <div class="summary-card interactive-card" data-target="section-storage">
          <div class="card-icon storage-icon">
            <span class="material-symbols-outlined">cloud</span>
          </div>
          <div class="card-content">
            <h3>Espacio en la Nube</h3>
            {storage ? (
              <div class="storage-summary-mini">
                <StorageVisualizer 
                  id="summary-storage-visualizer"
                  usedFormatted={storage.usedFormatted}
                  limitFormatted={storage.limitFormatted}
                  usedBytes={storage.usedBytes}
                  limitBytes={storage.limitBytes}
                  variant="compact"
                />
              </div>
            ) : (
              <p class="text-muted">No disponible</p>
            )}
          </div>
          <div class="card-footer">
            <span>Configurar límite <span class="material-symbols-outlined">arrow_forward</span></span>
          </div>
        </div>

        <!-- Card: Informes -->
        <div class="summary-card interactive-card" data-target="section-reports">
          <div class="card-icon reports-icon">
            <span class="material-symbols-outlined">picture_as_pdf</span>
          </div>
          <div class="card-content">
            <h3>Informes de Estado</h3>
            <div class="stats-row">
              <span class="stat-number">{reports.length}</span>
              <span class="stat-label">Informes enviados</span>
            </div>
          </div>
          <div class="card-footer">
            <span>Ver listado de informes <span class="material-symbols-outlined">arrow_forward</span></span>
          </div>
        </div>
      </div>

      <!-- Sección: Perfil Detallado -->
      <div id="section-profile" class="detail-section hidden">
        <button class="btn-back-summary"><span class="material-symbols-outlined">chevron_left</span> Volver al resumen</button>
        <div class="content-card">
          <div class="section-header">
            <h2>Editar Perfil</h2>
            <p class="text-muted">Modifica la información básica del usuario.</p>
          </div>
          <form id="editUserForm" data-userid={user.id}>
            <div class="form-row">
              <div class="form-group">
                <label for="displayName">Nombre Completo <span class="required-mark">*</span></label>
                <input type="text" id="displayName" name="displayName" required value={user.displayName || ''} />
              </div>
              <div class="form-group">
                <label for="email">Email <span class="required-mark">*</span></label>
                <input type="email" id="email" name="email" readonly value={user.email} class="readonly-field" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="role">Rol de Usuario <span class="required-mark">*</span></label>
                <div class="select-wrapper">
                  <select id="role" name="role" required>
                    <option value="client" selected={user.role === 'client'}>Cliente</option>
                    <option value="admin" selected={user.role === 'admin'}>Administrador</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label for="password">Nueva Contraseña (Opcional)</label>
                <input type="password" id="password" name="password" placeholder="Ej: Admin123!" minlength="8" />
                <p class="help-text-mini">Mínimo 8 caracteres, incluyendo mayúsculas, números y caracteres especiales.</p>
              </div>
            </div>
            <p class="form-legend">(*) Campos obligatorios</p>
            <div id="formFeedback" class="feedback-message hidden"></div>
            <div class="form-actions" style="justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
              <button type="button" class="btn-danger-outline btn-delete-user" id="openDeleteModal">
                <span class="material-symbols-outlined">person_remove</span> Eliminar Usuario
              </button>
              <div class="main-form-actions" style="display: flex; gap: 1rem;">
                <button type="button" class="btn-secondary btn-cancel-profile">Cancelar</button>
                <button type="submit" class="btn-primary" id="submitBtn" disabled>Guardar Cambios</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <ModalConfirm 
        slot="modals"
        id="deleteUserModal"
        title="¿Eliminar Usuario?"
        message="¿Estás seguro de que deseas eliminar permanentemente a este usuario? Esta acción no se puede deshacer y el usuario perderá el acceso inmediatamente."
        confirmText="Eliminar permanentemente"
        type="danger"
      />

      <ModalConfirm 
        slot="modals"
        id="confirmDeleteProjectModal"
        title="¿Eliminar Proyecto?"
        message="¿Estás seguro de que deseas eliminar este proyecto? Esta acción no se puede deshacer."
        confirmText="Eliminar proyecto"
        type="danger"
      />

      <ModalMessage 
        slot="modals"
        id="errorServerModal"
        title="Error de Conexión"
        message="Hubo un problema al conectar con el servidor. Por favor, inténtalo de nuevo más tarde."
        type="error"
      />

      <ModalMessage 
        slot="modals"
        id="successStorageModal"
        title="Cuota Actualizada"
        message="La cuota de almacenamiento ha sido actualizada correctamente."
        type="success"
      />

      <ModalMessage 
        slot="modals"
        id="successProfileModal"
        title="Perfil Actualizado"
        message="Los cambios en el perfil han sido guardados correctamente."
        type="success"
      />

      <ModalMessage 
        slot="modals"
        id="errorGenericModal"
        title="Error"
        message="Ocurrió un error inesperado al procesar la solicitud."
        type="error"
      />

      <!-- Sección: Proyectos Detallado -->
      <div id="section-projects" class="detail-section hidden">
        <button class="btn-back-summary"><span class="material-symbols-outlined">chevron_left</span> Volver al resumen</button>
        <div class="content-card">
          <div class="section-header">
            <h2>Añadir Proyectos</h2>
            <p class="text-muted">Añade o elimina proyectos para este usuario.</p>
          </div>
          
          <div class="project-form-container">
            <form id="createProjectForm" class="project-form" data-clientid={user.id}>
              <div class="form-row project-form-row">
                <div class="form-group flex-grow">
                  <label for="projectName">Nombre del Proyecto</label>
                  <input type="text" id="projectName" name="name" required placeholder="Ej: Rediseño Web" />
                </div>
                <div class="form-group">
                  <label>Tickets / mes</label>
                  <div class="tickets-stepper">
                    <button type="button" class="stepper-btn btn-minus" aria-label="Restar ticket">
                      <span class="material-symbols-outlined">remove</span>
                    </button>
                    <input type="number" id="monthlyTicketLimit" name="monthlyTicketLimit" required min="1" value="3" readonly />
                    <button type="button" class="stepper-btn btn-plus" aria-label="Sumar ticket">
                      <span class="material-symbols-outlined">add</span>
                    </button>
                  </div>
                </div>
                <div class="form-group">
                  <button type="submit" class="btn-primary" id="btnCreateProject">Añadir</button>
                </div>
              </div>
              
              <div id="projectFormFeedback" class="feedback-message hidden"></div>
            </form>
          </div>
        </div>

        <div class="projects-accordion" id="projectsAccordion">
            <button class="accordion-header" id="toggleProjects">
              <h2 class="accordion-title">Proyectos</h2>
              <div class="accordion-info">
                <span class="projects-count" id="projectsCounter">{projects.length} {projects.length === 1 ? 'proyecto' : 'proyectos'}</span>
                <span class="material-symbols-outlined accordion-icon">expand_more</span>
              </div>
            </button>
            
            <div class="accordion-content">
              <div class="accordion-inner">
                <div class="table-controls">
                  <form class="search-form" onsubmit="return false;">
                    <input type="text" id="projectSearchInput" class="search-input" placeholder="Buscar por nombre de proyecto..." autocomplete="off" />
                    <button type="submit" class="search-btn" id="btnSearchProject">Buscar</button>
                  </form>
                </div>

                {projects.length > 0 ? (
                  <div class="table-responsive">
                    <table class="data-table" id="projectsTable">
                      <thead>
                        <tr>
                          <th>Nombre</th>
                          <th>Tickets (Consumidos / Total)</th>
                          <th>Estado</th>
                          <th class="text-right">Acciones</th>
                        </tr>
                      </thead>
                      <tbody>
                        {projects.map((p: ProjectResponseDto) => (
                          <tr class="project-row" data-name={p.name.toLowerCase()}>
                            <td><strong>{p.name}</strong></td>
                            <td>
                              <span class="tickets-usage">
                                <span class="used-count">0</span> / <span class="total-count">{p.monthlyTicketLimit}</span>
                              </span>
                            </td>
                            <td>
                              <span class="status-badge status-open">Activo</span>
                            </td>
                            <td class="text-right">
                              <button class="btn-delete-project btn-icon-only text-danger" data-id={p.id} title="Eliminar Proyecto">
                                <span class="material-symbols-outlined">delete</span>
                              </button>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                ) : (
                  <p class="text-muted text-center py-4">No hay proyectos registrados para este usuario.</p>
                )}
              </div>
            </div>
          </div>

          <div class="content-card tickets-section-card">
            <div class="section-header">
              <h2>Tickets</h2>
              <p class="text-muted">Listado de soporte y consultas del usuario.</p>
            </div>
            <!-- Gestión de Tickets Proactiva filtrada por este usuario -->
            <TicketManagementSystem clientId={id} clientEmail={user.email} />
          </div>
        </div>

      <!-- Sección: Almacenamiento Detallado -->
      <div id="section-storage" class="detail-section hidden">
        <button class="btn-back-summary"><span class="material-symbols-outlined">chevron_left</span> Volver al resumen</button>
        <div class="content-card">
          <div class="section-header">
            <h2>Cuota de Almacenamiento</h2>
            <p class="text-muted">Configura el límite de GB permitidos para este usuario.</p>
          </div>
          
          <form id="editStorageForm" data-usedbytes={storage ? storage.usedBytes : 0}>
            <div class="storage-editor-layout">
              <div class="storage-controls">
                <div class="form-group">
                  <label for="storageLimitGb">Límite Total (GB)</label>
                  <div class="tickets-stepper storage-stepper">
                    <button type="button" class="stepper-btn btn-minus-storage"><span class="material-symbols-outlined">remove</span></button>
                    <input type="number" id="storageLimitGb" name="storageLimitGb" required min="1" value={user.storageLimitGb || (storage ? Math.ceil(storage.limitBytes / (1024*1024*1024)) : 5)} readonly />
                    <button type="button" class="stepper-btn btn-plus-storage"><span class="material-symbols-outlined">add</span></button>
                  </div>
                </div>
              </div>

              {storage && (
                <div class="storage-visualizer">
                  <StorageVisualizer 
                    id="detailed-storage-visualizer"
                    usedFormatted={storage.usedFormatted}
                    limitFormatted={storage.limitFormatted}
                    usedBytes={storage.usedBytes}
                    limitBytes={storage.limitBytes}
                  />
                </div>
              )}
            </div>

            <div class="form-actions" style="margin-top: 2rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
              <button type="submit" class="btn-primary" id="btnUpdateStorage">Actualizar Cuota</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Sección: Informes Detallado -->
      <div id="section-reports" class="detail-section hidden">
        <button class="btn-back-summary"><span class="material-symbols-outlined">chevron_left</span> Volver al resumen</button>
        <div class="content-card">
          <div class="section-header">
            <h2>Informes del Usuario</h2>
            <p class="text-muted">Listado completo de informes enviados a este cliente.</p>
          </div>
          <ReportTable clientId={id} role="admin" id="adminUserReportsBody" />
        </div>
      </div>
    </div>
  )}
</DashboardLayout>

<script>
  import { apiClient } from '../../../lib/api-client';
  import { validatePassword } from '../../../lib/utils/security';
  import type { ClientResponseDto, ProjectResponseDto } from '../../../types/api';

  // Lógica de navegación y eventos para la página de detalles de usuario
  function initUserDetail() {
    const editForm = document.getElementById('editUserForm') as HTMLFormElement;
    if (!editForm) return;

    const summaryView = document.getElementById('summaryView');
    const detailSections = document.querySelectorAll('.detail-section');
    const backBtns = document.querySelectorAll('.btn-back-summary');

    // --- Helpers Generales ---
    const showSection = (sectionId: string | null) => {
      // Ocultar todas las secciones y el resumen primero
      detailSections.forEach(sec => sec.classList.add('hidden'));
      if (summaryView) summaryView.classList.add('hidden');

      if (sectionId) {
        const targetSection = document.getElementById(sectionId);
        if (targetSection) {
          targetSection.classList.remove('hidden');
          targetSection.classList.add('section-show-anim');
          // Scroll suave al inicio de la sección
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      } else if (summaryView) {
        summaryView.classList.remove('hidden');
        summaryView.classList.add('section-show-anim');
      }
    };

    const setLoading = (button: HTMLButtonElement, isLoading: boolean) => {
      button.disabled = isLoading;
      button.classList.toggle('btn-loading', isLoading);
    };

    const showFeedback = (elementId: string, message: string, type: 'error' | 'success') => {
      const feedback = document.getElementById(elementId);
      if (!feedback) return;
      feedback.textContent = message;
      feedback.className = `feedback-message ${type}`;
      feedback.classList.remove('hidden');
    };

    // --- Navegación (Delegación de eventos para mayor robustez) ---
    // En lugar de click individual, escuchamos en el contenedor de resumen
    summaryView?.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.interactive-card');
      if (card) {
        const targetId = card.getAttribute('data-target');
        if (targetId) showSection(targetId);
      }
    });

    backBtns.forEach(btn => {
      btn.addEventListener('click', () => showSection(null));
    });

    // --- Formulario de Perfil ---
    const profileSubmitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const cancelProfileBtn = document.querySelector('.btn-cancel-profile') as HTMLButtonElement;

    if (editForm && profileSubmitBtn) {
      const validateForm = () => {
        const requiredFields = editForm.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLSelectElement>;
        let isValid = true;
        requiredFields.forEach(field => {
          if (!field.value.trim()) isValid = false;
        });
        profileSubmitBtn.disabled = !isValid;
      };

      editForm.addEventListener('input', validateForm);
      validateForm();

      cancelProfileBtn?.addEventListener('click', () => showSection(null));

      editForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const userId = editForm.dataset.userid;
        const formData = new FormData(editForm);
        const data = Object.fromEntries(formData.entries());

        if (data.password) {
          const validation = validatePassword(data.password as string);
          if (!validation.isValid) {
            showFeedback('formFeedback', validation.errors[0], 'error');
            return;
          }
        } else {
          delete data.password;
        }
        
        setLoading(profileSubmitBtn, true);
        try {
          await apiClient.patch<ClientResponseDto>(`/users/${userId}`, data);
          
          if (window.modalHelpers) {
            window.modalHelpers.openModal('successProfileModal');
          } else {
            showFeedback('formFeedback', 'Perfil actualizado correctamente.', 'success');
          }
        } catch (err: any) {
          if (window.modalHelpers) {
            window.modalHelpers.updateModalMessage('errorGenericModal', err.message);
            window.modalHelpers.openModal('errorGenericModal');
          } else {
            showFeedback('formFeedback', err.message, 'error');
          }
        } finally {
          setLoading(profileSubmitBtn, false);
        }
      });

      // --- Borrado de Usuario ---
      const openDeleteBtn = document.getElementById('openDeleteModal');
      openDeleteBtn?.addEventListener('click', () => {
        const userId = editForm.dataset.userid;
        if (!window.confirmModalHelpers) return;
        window.confirmModalHelpers.open('deleteUserModal', async () => {
          try {
            await apiClient.delete(`/users/${userId}`);
            window.showToast('Usuario eliminado correctamente', 'success');
            setTimeout(() => window.location.href = '/admin/usuarios', 1500);
          } catch (err: any) {
            window.showToast(err.message, 'error');
          }
        });
      });
    }

    // --- Acordeón de Proyectos ---
    const accordion = document.getElementById('projectsAccordion');
    const toggleBtn = document.getElementById('toggleProjects');
    toggleBtn?.addEventListener('click', () => {
      accordion?.classList.toggle('is-open');
    });

    // --- Filtro de Proyectos ---
    const projectSearchInput = document.getElementById('projectSearchInput') as HTMLInputElement;
    const projectRows = document.querySelectorAll('.project-row') as NodeListOf<HTMLElement>;

    projectSearchInput?.addEventListener('input', () => {
      const query = projectSearchInput.value.toLowerCase().trim();
      projectRows.forEach(row => {
        const name = row.dataset.name || '';
        row.style.display = name.includes(query) ? '' : 'none';
      });
    });

    // --- Formulario de Proyectos ---
    const projectForm = document.getElementById('createProjectForm') as HTMLFormElement;
    const stepperInput = document.getElementById('monthlyTicketLimit') as HTMLInputElement;
    const btnMinus = projectForm?.querySelector('.btn-minus');
    const btnPlus = projectForm?.querySelector('.btn-plus');

    btnMinus?.addEventListener('click', () => {
      const val = parseInt(stepperInput.value) || 1;
      if (val > 1) stepperInput.value = (val - 1).toString();
    });

    btnPlus?.addEventListener('click', () => {
      const val = parseInt(stepperInput.value) || 0;
      stepperInput.value = (val + 1).toString();
    });

    const projectNameInput = document.getElementById('projectName') as HTMLInputElement;
    const btnCreateProject = document.getElementById('btnCreateProject') as HTMLButtonElement;

    if (projectNameInput && btnCreateProject) {
      projectNameInput.addEventListener('input', () => {
        btnCreateProject.disabled = !projectNameInput.value.trim();
      });
    }

    projectForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const clientId = projectForm.dataset.clientid;
      const formData = new FormData(projectForm);
      const data = {
        clientId,
        name: formData.get('name'),
        description: formData.get('description'),
        monthlyTicketLimit: Number(formData.get('monthlyTicketLimit')) || 3
      };

      setLoading(btnCreateProject, true);
      try {
        await apiClient.post<ProjectResponseDto>(`/projects`, data);
        showFeedback('projectFormFeedback', 'Proyecto creado exitosamente.', 'success');
        setTimeout(() => window.location.reload(), 1000);
      } catch (err: any) {
        showFeedback('projectFormFeedback', err.message, 'error');
      } finally {
        setLoading(btnCreateProject, false);
      }
    });

    // --- Almacenamiento ---
    const storageForm = document.getElementById('editStorageForm') as HTMLFormElement;
    const storageInput = document.getElementById('storageLimitGb') as HTMLInputElement;
    const btnMinusStorage = storageForm?.querySelector('.btn-minus-storage');
    const btnPlusStorage = storageForm?.querySelector('.btn-plus-storage');

    btnMinusStorage?.addEventListener('click', () => {
      const val = parseInt(storageInput.value) || 1;
      if (val > 1) storageInput.value = (val - 1).toString();
    });

    btnPlusStorage?.addEventListener('click', () => {
      const val = parseInt(storageInput.value) || 0;
      storageInput.value = (val + 1).toString();
    });

    storageForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const userId = editForm.dataset.userid;
      const formData = new FormData(storageForm);
      const storageLimitGb = Number(formData.get('storageLimitGb'));
      const usedBytes = Number(storageForm.dataset.usedbytes) || 0;
      const btn = document.getElementById('btnUpdateStorage') as HTMLButtonElement;

      setLoading(btn, true);
      try {
        await apiClient.patch(`/users/${userId}`, { storageLimitGb });
        
        // Actualizar UI reactivamente
        const newLimitBytes = storageLimitGb * 1024 * 1024 * 1024;
        const newPct = Math.min(100, Math.round((usedBytes / newLimitBytes) * 100));
        const newLimitFormatted = `${storageLimitGb} GB`;

        const updateVisualizer = (id: string) => {
          const viz = document.getElementById(id);
          if (!viz) return;

          // Actualizar barra/círculo de progreso
          const progress = viz.querySelector('.chart-progress') as SVGPathElement;
          if (progress) {
            // Actualizar tanto el estilo como el atributo para evitar que la animación CSS 'forwards' lo revierta
            progress.style.strokeDasharray = `${newPct}, 100`;
            progress.setAttribute('stroke-dasharray', `${newPct}, 100`);
            progress.setAttribute('data-pct', newPct.toString());
            
            // Forzar reinicio de animación si es necesario (opcional)
            progress.style.animation = 'none';
            setTimeout(() => progress.style.animation = '', 10);
          }

          // Actualizar textos de porcentaje
          const pctTexts = viz.querySelectorAll('.percentage, .mini-percent');
          pctTexts.forEach(el => el.textContent = `${newPct}%`);

          // Actualizar textos de límite total
          const limitTexts = viz.querySelectorAll('.limit-value');
          limitTexts.forEach(el => el.textContent = newLimitFormatted);

          const miniText = viz.querySelector('.mini-text');
          if (miniText) {
            // Mantener el texto de 'usado' y actualizar solo el límite
            const parts = miniText.textContent?.split(' de ') || [];
            const usedPart = parts[0] || '0 B';
            miniText.textContent = `${usedPart} de ${newLimitFormatted}`;
          }
        };

        updateVisualizer('summary-storage-visualizer');
        updateVisualizer('detailed-storage-visualizer');

        // Actualizar el valor actual en el input y dataset para futuras operaciones
        if (storageInput) storageInput.defaultValue = storageLimitGb.toString();

        if (window.modalHelpers) {
          window.modalHelpers.openModal('successStorageModal');
        }
      } catch (err: any) {
        if (window.modalHelpers) {
          window.modalHelpers.updateModalMessage('errorGenericModal', err.message);
          window.modalHelpers.openModal('errorGenericModal');
        } else {
          alert(err.message);
        }
      } finally {
        setLoading(btn, false);
      }
    });
  }

  // Inicializar en cada carga de página (incluyendo transiciones)
  document.addEventListener('astro:page-load', initUserDetail);
</script>

