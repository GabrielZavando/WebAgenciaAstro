---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { apiClient } from '../../../lib/api-client';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

let users = [];
let errorMsg = null;

try {
  users = await apiClient.get<any[]>('/users', { token });
} catch (error: any) {
  errorMsg = "No se pudo conectar con el servidor.";
  if (error.status === 403) {
    errorMsg = "No tienes permisos de Administrador para ver esta página.";
  } else if (error.message) {
    errorMsg = `Error al cargar usuarios: ${error.message}`;
  }
  console.error("Error fetching users:", error);
}


// Mapeo para nombres de roles
const roleNames = {
  admin: 'Administrador',
  client: 'Cliente'
};
---

<DashboardLayout title="Gestión de Usuarios" role="admin">
  <div class="users-table-view">
    <div class="header-actions">
      <div>
        <h1>Usuarios</h1>
        <p class="text-muted">Lista de todos los clientes y administradores registrados.</p>
      </div>
      <div class="header-right">
        <div class="search-box">
          <span class="material-symbols-outlined">search</span>
          <input type="text" id="userSearch" placeholder="Buscar por nombre..." />
        </div>
        <a href="/admin/usuarios/nuevo" class="btn-primary">
          <span class="material-symbols-outlined">add</span> Nuevo Usuario
        </a>
      </div>
    </div>

    {errorMsg && (
      <div class="error-banner">
        <span class="material-symbols-outlined">report</span> {errorMsg}
      </div>
    )}

    <div class="content-card fade-in">
      {users.length === 0 && !errorMsg ? (
        <div class="empty-state">
          <span class="material-symbols-outlined empty-icon">group_off</span>
          <h3>No hay usuarios registrados</h3>
          <p>Aún no has creado ningún usuario en el sistema.</p>
        </div>
      ) : null}

      {users.length > 0 && (
        <div class="table-responsive">
          <table class="users-table" id="usersTable">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Fecha de Registro</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {users.map((user: any) => (
                <tr class="user-row">
                  <td>
                    <div class="user-info">
                      {user.photoURL ? (
                        <img src={user.photoURL} alt={`Avatar de ${user.displayName || user.email}`} class="user-avatar-img" />
                      ) : (
                        <div class="user-avatar">
                          {user.displayName ? user.displayName.charAt(0).toUpperCase() : user.email.charAt(0).toUpperCase()}
                        </div>
                      )}
                      <span class="user-name">{user.displayName || 'Sin nombre'}</span>
                    </div>
                  </td>
                  <td>{user.email}</td>
                  <td>
                    <span class={`role-badge ${user.role}`}>
                      {roleNames[user.role as keyof typeof roleNames] || user.role}
                    </span>
                  </td>
                  <td>{user.createdAt ? new Date(user.createdAt._seconds ? user.createdAt._seconds * 1000 : user.createdAt).toLocaleDateString() : 'Desconocida'}</td>
                  <td>
                    <a href={`/admin/usuarios/${user.uid || user.id}`} class="btn-details">
                      ver detalles
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>

<script>
  const searchInput = document.getElementById('userSearch') as HTMLInputElement;
  const userRows = document.querySelectorAll('.user-row');

  searchInput?.addEventListener('input', () => {
    const searchTerm = searchInput.value.toLowerCase();
    userRows.forEach(row => {
      const name = row.querySelector('.user-name')?.textContent?.toLowerCase() || '';
      const email = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
      
      if (name.includes(searchTerm) || email.includes(searchTerm)) {
        (row as HTMLElement).style.display = '';
      } else {
        (row as HTMLElement).style.display = 'none';
      }
    });
  });
</script>


