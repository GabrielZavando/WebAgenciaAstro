---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Nuevo Usuario" role="admin">
  <div class="user-form-container">
    <div class="header-actions">
      <div>
        <a href="/admin/usuarios" class="back-link">
          <span class="material-symbols-outlined">arrow_back</span> Volver a Usuarios
        </a>
        <h1>Registrar Nuevo Usuario</h1>
        <p class="text-muted">Crea un cliente o administrador. Se registrará automáticamente en la base de datos.</p>
      </div>
    </div>

    <div class="content-card fade-in">
      <form id="createUserForm" class="user-form">
        <div class="form-row">
          <div class="form-group">
            <label for="displayName">Nombre Completo <span class="required">*</span></label>
            <input type="text" id="displayName" name="displayName" required placeholder="Ej: Juan Pérez" />
          </div>
          
          <div class="form-group">
            <label for="role">Rol <span class="required">*</span></label>
            <select id="role" name="role" required>
              <option value="client" selected>Cliente (Acceso a Dashboard)</option>
              <option value="admin">Administrador (Acceso Total)</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="email">Correo Electrónico <span class="required">*</span></label>
            <input type="email" id="email" name="email" required placeholder="juan@ejemplo.com" />
          </div>

          <div class="form-group">
            <label for="password">Contraseña (opcional)</label>
            <input type="password" id="password" name="password" placeholder="Ej: Admin123!" minlength="8" />
            <small class="help-text">Mínimo 8 caracteres, incluyendo mayúsculas, números y caracteres especiales.</small>
          </div>
        </div>


        <div class="form-actions">
          <button type="submit" class="btn-primary" id="submitBtn">
            <span class="btn-spinner hidden"><span class="material-symbols-outlined spinner">sync</span></span>
            <span class="btn-text">Crear Usuario</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <ModalMessage
    slot="modals"
    id="successModal"
    type="success"
    title="Usuario Creado"
    message="El usuario ha sido registrado exitosamente."
  />

  <ModalMessage
    slot="modals"
    id="errorModal"
    type="error"
    title="Error"
    message="Ocurrió un error al crear el usuario."
  />
</DashboardLayout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  import { validatePassword } from '../../../lib/utils/security';
  const form = document.getElementById('createUserForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnSpinner = submitBtn?.querySelector('.btn-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    import('../../../lib/firebase/client').then(async ({ auth }) => {
      const user = auth.currentUser;
      if (!user) {
        showGlobalMessage('Error: No estás autenticado.', 'error');
        return;
      }
      
      const token = await user.getIdToken();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      if (data.password) {
        const validation = validatePassword(data.password as string);
        if (!validation.isValid) {
          showGlobalMessage(validation.errors[0], 'error');
          return;
        }
      }

      if (!data.password) delete data.password;

      // Estado de carga
      submitBtn.disabled = true;
      btnSpinner?.classList.remove('hidden');

      try {
        const response = await fetch(`${API_URL}/users/register`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok) {
          showGlobalMessage('Usuario creado exitosamente.', 'success');
          form.reset();
          setTimeout(() => {
            window.location.href = '/admin/usuarios';
          }, 2000);
        } else {
          showGlobalMessage(result.message || 'Ocurrió un error al crear el usuario.', 'error');
        }
      } catch (error) {
        showGlobalMessage('No se pudo conectar con el servidor.', 'error');
      } finally {
        submitBtn.disabled = false;
        btnSpinner?.classList.add('hidden');
      }
    });
  });

  function showGlobalMessage(message: string, type: 'error' | 'success') {
    const modalId = type === 'success' ? 'successModal' : 'errorModal';
    if ((window as any).modalHelpers) {
      (window as any).modalHelpers.updateModalMessage(modalId, message);
      (window as any).modalHelpers.openModal(modalId);
    } else {
      alert(message);
    }
  }
</script>


