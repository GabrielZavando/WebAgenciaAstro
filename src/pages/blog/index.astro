
---
import Layout from '../../layouts/MainLayout.astro';
import Banner from '../../components/landing/Banner.astro';
import Search from '../../components/shared/Search.astro';
import bannerBlogImg from '../../assets/img/banner-blog.jpg';

// Fetch posts from API (Server Side)
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
let posts = [];
let error = null;

try {
  // Fetch solo publicados
  const res = await fetch(`${API_BASE_URL}/blog?published=true`);
  if (!res.ok) throw new Error('Error fetching posts');
  posts = await res.json();
} catch (e) {
  console.error(e);
  error = 'No se pudieron cargar los artículos del blog.';
}

const getExcerpt = (post: any) => {
  if (post.excerpt) {
    return post.excerpt.length > 150 ? post.excerpt.substring(0, 150) + '...' : post.excerpt;
  }
  if (post.content) {
    // 1. Quitar bloques de estilos y su contenido
    let stripped = post.content.replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '');
    // 2. Quitar bloques de scripts y su contenido
    stripped = stripped.replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '');
    // 3. Quitar cualquier otra etiqueta HTML (e.g. <p>, <strong>)
    stripped = stripped.replace(/<[^>]*>?/gm, '');
    // 4. Limpiar espacios múltiples o saltos de línea (como un plain text real)
    stripped = stripped.replace(/\s+/g, ' ').trim();

    return stripped.length > 150 ? stripped.substring(0, 150) + '...' : stripped;
  }
  return '';
};
---

<Layout title="Blog | Agencia Digital">
  <!-- Banner Utilizando el componente unificado -->
  <Banner image={bannerBlogImg} size="half" align="center">
      <h1 class="blog-page-title fade-in">Blog</h1>
      <p class="blog-page-subtitle fade-in">Noticias, consejos y estrategias digitales.</p>
      <Search />
  </Banner>

  <section class="blog-section">
    <div class="container">
      <div id="noResultsMsg" class="no-results-message" style="display: none;">
        <span class="material-symbols-outlined">search</span>
        <p>No hay coincidencias con la búsqueda.</p>
      </div>

      {error && <div class="blog-error-message">{error}</div>}

      <div class="posts-grid">
        {posts.map((post: any) => (
          <article class="post-card fade-in" data-title={post.title.toLowerCase()} data-category={post.category ? post.category.toLowerCase() : ''}>
            {post.coverImage && (
              <div class="post-card__image">
                <img
                  src={post.coverImage}
                  alt={post.title}
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="450"
                />
              </div>
            )}
            <div class="post-card__content">
              <h2 class="post-card__title">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <div class="post-card__meta">
                <span>
                  <span class="material-symbols-outlined" aria-hidden="true">edit_note</span>
                  {post.author || 'Administrador'}
                </span>
                {post.category && (
                  <a href={`/blog?category=${encodeURIComponent(post.category)}`} class="post-card__category">
                    <span class="material-symbols-outlined" aria-hidden="true">label</span>
                    {post.category}
                  </a>
                )}
              </div>
              <p class="post-card__excerpt">
                {getExcerpt(post)}
              </p>
              <a href={`/blog/${post.slug}`} class="btn-cta">Leer más</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

