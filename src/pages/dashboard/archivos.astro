---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
---

<DashboardLayout title="Archivos" role="client">
  <div class="files-page">
    <div class="page-header">
      <h1>Mis Archivos</h1>
      <p class="text-muted">Sube, organiza y descarga tus archivos.</p>
    </div>

    <!-- Cuota de almacenamiento -->
    <div class="storage-banner" id="storageBanner">
      <div class="storage-info">
        <i class="fas fa-database"></i>
        <span id="storageText">Cargando almacenamiento...</span>
      </div>
      <div class="storage-bar-container">
        <div class="storage-bar" id="storageBar" style="width: 0%"></div>
      </div>
    </div>

    <!-- Acciones -->
    <div class="actions-row">
      <div class="search-input-wrapper">
        <i class="fas fa-search search-icon"></i>
        <input type="text" id="searchInput" placeholder="Buscar por título, nombre o descripción..." autocomplete="off" />
      </div>
      <button class="btn-upload" id="uploadBtn">
        <i class="fas fa-cloud-upload-alt"></i> Subir Archivo
      </button>
    </div>

    <!-- Modal de subida -->
    <div class="upload-modal hidden" id="uploadModal">
      <div class="modal-backdrop" id="modalBackdrop"></div>
      <div class="modal-content">
        <div class="modal-header">
          <h3><i class="fas fa-file-upload"></i> Subir Archivo</h3>
          <button class="modal-close" id="closeModal">&times;</button>
        </div>
        <form id="uploadForm" class="upload-form">
          <div class="form-group">
            <label for="fileTitle">Título</label>
            <input type="text" id="fileTitle" name="title" required placeholder="Nombre descriptivo" />
          </div>
          <div class="form-group">
            <label for="fileDesc">Descripción (opcional)</label>
            <input type="text" id="fileDesc" name="description" placeholder="Información adicional" />
          </div>
          <div class="form-group">
            <label>Archivo</label>
            <div class="file-drop" id="fileDrop">
              <i class="fas fa-cloud-upload-alt"></i>
              <p id="fileLabel">Haz clic o arrastra un archivo aquí</p>
              <span class="file-types">Permitidos: PDF, Word, Excel, Imágenes, CSV, TXT</span>
              <input type="file" id="fileInput" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.webp,.txt,.csv" required class="file-input-hidden" />
            </div>
          </div>
          <div id="uploadFeedback" class="feedback-msg hidden"></div>
          <div class="form-actions">
            <button type="submit" class="btn-primary" id="submitUpload">
              <span class="btn-text">Subir</span>
              <span class="loader hidden"></span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Tabla de lista de archivos -->
    <div class="table-container">
      <table class="files-table">
        <thead>
          <tr>
            <th class="col-type">Tipo</th>
            <th class="col-name">Nombre</th>
            <th class="col-size">Tamaño</th>
            <th class="col-date">Fecha de carga</th>
            <th class="col-actions">Acciones</th>
          </tr>
        </thead>
        <tbody id="filesListBody">
          <tr>
            <td colspan="5">
              <div class="loading-state">
                <i class="fas fa-spinner fa-spin"></i>
                <p>Cargando archivos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const tableBody = document.getElementById('filesListBody');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const storageText = document.getElementById('storageText');
  const storageBar = document.getElementById('storageBar');
  const storageBanner = document.getElementById('storageBanner');
  const uploadBtn = document.getElementById('uploadBtn');
  const uploadModal = document.getElementById('uploadModal');
  const closeModal = document.getElementById('closeModal');
  const modalBackdrop = document.getElementById('modalBackdrop');
  const uploadForm = document.getElementById('uploadForm') as HTMLFormElement;
  const submitUpload = document.getElementById('submitUpload') as HTMLButtonElement;
  const uploadFeedback = document.getElementById('uploadFeedback');
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const fileLabel = document.getElementById('fileLabel');
  const fileDrop = document.getElementById('fileDrop');

  interface FileItem {
    id: string;
    title: string;
    description: string;
    fileName: string;
    mimeType: string;
    size: number;
    createdAt: { _seconds?: number } | string;
  }

  let allFiles: FileItem[] = [];
  let token = '';

  onAuthStateChanged(auth, async (user) => {
    if (!user) return;
    token = await user.getIdToken();
    await Promise.all([loadQuota(), loadFiles()]);
  });

  async function loadQuota() {
    try {
      const res = await fetch(`${API}/files/storage/quota`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) throw new Error();
      const q = await res.json();
      if (!storageText || !storageBar || !storageBanner) return;
      const pct = q.limitBytes > 0 ? (q.usedBytes / q.limitBytes) * 100 : 0;
      storageText.textContent = `${q.usedFormatted} de ${q.limitFormatted} utilizados`;
      storageBar.style.width = `${Math.min(pct, 100)}%`;
      storageBanner.classList.toggle('storage-warning', pct >= 90);
    } catch {
      if (storageText) storageText.textContent = 'Error cargando almacenamiento';
    }
  }

  async function loadFiles() {
    try {
      const res = await fetch(`${API}/files`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) throw new Error();
      allFiles = await res.json();
      renderFiles(allFiles);
    } catch {
      if (tableBody) tableBody.innerHTML = `<tr><td colspan="4"><div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Error al cargar los archivos.</p></div></td></tr>`;
    }
  }

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    if (!q) { renderFiles(allFiles); return; }
    renderFiles(allFiles.filter(f => 
      f.title.toLowerCase().includes(q) || 
      f.fileName.toLowerCase().includes(q) || 
      (f.description && f.description.toLowerCase().includes(q))
    ));
  });

  function renderFiles(files: FileItem[]) {
    if (!tableBody) return;
    if (files.length === 0) {
      tableBody.innerHTML = `
        <tr>
          <td colspan="5">
            <div class="empty-state">
              <i class="fas fa-folder-open"></i>
              <h3>Sin archivos</h3>
              <p>No hay archivos que coincidan con tu búsqueda o aún no has subido ninguno.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    tableBody.innerHTML = files.map(f => `
      <tr class="file-row">
        <td class="col-type-data">
          ${getFileIcon(f.mimeType)}
        </td>
        <td class="col-name-data">
          <div class="name-wrapper">
            <span class="file-title" title="${f.title}">${f.title}</span>
            ${f.title !== f.fileName ? `<span class="file-name-sub">(${f.fileName})</span>` : ''}
          </div>
        </td>
        <td class="col-size-data">
          ${fmtSize(f.size)}
        </td>
        <td class="col-date-data">
          ${fmtDate(f.createdAt)}
        </td>
        <td class="col-actions-data">
          <div class="td-actions">
            <button class="btn-action view-btn" data-id="${f.id}" title="Ver en el navegador"><i class="fas fa-external-link-alt"></i></button>
            <button class="btn-action dl-btn" data-id="${f.id}" title="Descargar"><i class="fas fa-download"></i></button>
            <button class="btn-action del-btn" data-id="${f.id}" title="Eliminar archivo"><i class="fas fa-trash-alt"></i></button>
          </div>
        </td>
      </tr>
    `).join('');

    tableBody.querySelectorAll('.view-btn').forEach(b =>
      b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'view')));
    tableBody.querySelectorAll('.dl-btn').forEach(b =>
      b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'download')));
    tableBody.querySelectorAll('.del-btn').forEach(b =>
      b.addEventListener('click', () => handleDelete(b.getAttribute('data-id')!)));
  }

  async function handleDl(id: string, action: 'view' | 'download') {
    try {
      const res = await fetch(`${API}/files/${id}/download`, { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) throw new Error();
      const { url, fileName } = await res.json();
      if (action === 'view') { window.open(url, '_blank'); return; }
      const a = document.createElement('a');
      a.href = url; a.download = fileName; a.target = '_blank';
      document.body.appendChild(a); a.click(); a.remove();
    } catch { alert('Error al procesar la solicitud.'); }
  }

  async function handleDelete(id: string) {
    if (!confirm('¿Estás seguro de eliminar este archivo de forma permanente?')) return;
    try {
      const res = await fetch(`${API}/files/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) throw new Error();
      await Promise.all([loadQuota(), loadFiles()]);
    } catch { alert('Error al eliminar el archivo.'); }
  }

  // Lógica del modal de subida
  uploadBtn?.addEventListener('click', () => uploadModal?.classList.remove('hidden'));
  closeModal?.addEventListener('click', closeUploadModal);
  modalBackdrop?.addEventListener('click', closeUploadModal);
  function closeUploadModal() {
    uploadModal?.classList.add('hidden');
    uploadForm?.reset();
    if (fileLabel) fileLabel.textContent = 'Haz clic o arrastra un archivo aquí';
    fileDrop?.classList.remove('has-file');
    if (uploadFeedback) uploadFeedback.className = 'feedback-msg hidden';
  }

  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.length && fileLabel) {
      fileLabel.textContent = fileInput.files[0].name;
      fileDrop?.classList.add('has-file');
    }
  });
  fileDrop?.addEventListener('dragover', (e) => { e.preventDefault(); fileDrop.classList.add('drag-over'); });
  fileDrop?.addEventListener('dragleave', () => fileDrop?.classList.remove('drag-over'));
  fileDrop?.addEventListener('drop', (e) => {
    e.preventDefault(); fileDrop?.classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    if (files?.length && fileInput) {
      fileInput.files = files;
      if (fileLabel) fileLabel.textContent = files[0].name;
      fileDrop?.classList.add('has-file');
    }
  });

  uploadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitUpload || !uploadFeedback) return;
    const title = (document.getElementById('fileTitle') as HTMLInputElement).value;
    const desc = (document.getElementById('fileDesc') as HTMLInputElement).value;
    const file = fileInput?.files?.[0];
    if (!file) { showFb(uploadFeedback, 'Selecciona un archivo para subir.', 'error'); return; }

    setLoading(submitUpload, true);
    try {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('title', title);
      fd.append('description', desc);
      const res = await fetch(`${API}/files`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: fd,
      });
      if (!res.ok) { const err = await res.json(); throw new Error(err.message || 'Error del servidor'); }
      showFb(uploadFeedback, '¡Archivo subido con éxito!', 'success');
      setTimeout(closeUploadModal, 1200);
      await Promise.all([loadQuota(), loadFiles()]);
    } catch (error: unknown) {
      const msg = error instanceof Error ? error.message : 'Error de conexión';
      showFb(uploadFeedback, msg, 'error');
    } finally { setLoading(submitUpload, false); }
  });

  function getFileIcon(mime: string): string {
    if (mime.includes('pdf')) return '<i class="fas fa-file-pdf" style="color:#ef4444"></i>';
    if (mime.includes('image')) return '<i class="fas fa-file-image" style="color:#3b82f6"></i>';
    if (mime.includes('word') || mime.includes('document')) return '<i class="fas fa-file-word" style="color:#2563eb"></i>';
    if (mime.includes('sheet') || mime.includes('excel')) return '<i class="fas fa-file-excel" style="color:#22c55e"></i>';
    if (mime.includes('csv')) return '<i class="fas fa-file-csv" style="color:#f59e0b"></i>';
    return '<i class="fas fa-file-alt" style="color:#6b7280"></i>';
  }
  function fmtDate(raw: { _seconds?: number } | string): string {
    let d: Date;
    if (typeof raw === 'string') d = new Date(raw);
    else if (raw?._seconds) d = new Date(raw._seconds * 1000);
    else return '-';
    
    const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
    return `${d.getDate()}, ${months[d.getMonth()]}, ${d.getFullYear()}`;
  }
  function fmtSize(b: number): string {
    if (!b) return '-';
    if (b < 1024) return `${b} B`;
    if (b < 1048576) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / 1048576).toFixed(1)} MB`;
  }
  function setLoading(btn: HTMLButtonElement, on: boolean) {
    btn.disabled = on;
    btn.querySelector('.btn-text')?.classList.toggle('hidden', on);
    btn.querySelector('.loader')?.classList.toggle('hidden', !on);
  }
  function showFb(el: HTMLElement, msg: string, type: 'error' | 'success') {
    el.textContent = msg;
    el.className = `feedback-msg ${type}`;
    setTimeout(() => { el.className = 'feedback-msg hidden'; }, 5000);
  }
</script>

<style>
  .files-page { max-width: 1000px; margin: 0 auto; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin: 0 0 0.5rem; font-size: 2rem; font-weight: 700; color: var(--color-text); }
  .text-muted { color: var(--color-text-muted); margin: 0; font-size: 1.05rem; }

  /* Cuota Storage */
  .storage-banner { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; margin-bottom: 2rem; box-shadow: var(--shadow-sm); transition: all 0.3s ease; }
  .storage-banner.storage-warning { border-color: #f59e0b; background: rgba(245, 158, 11, 0.05); }
  .storage-info { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; font-weight: 600; font-size: 0.95rem; color: var(--color-text); }
  .storage-info i { color: var(--color-primary); font-size: 1.2rem; }
  .storage-warning .storage-info i { color: #f59e0b; }
  .storage-bar-container { width: 100%; height: 8px; background: var(--color-border); border-radius: 4px; overflow: hidden; }
  .storage-bar { height: 100%; background: var(--color-primary); border-radius: 4px; transition: width 0.8s cubic-bezier(0.2, 0.9, 0.3, 1); }
  .storage-warning .storage-bar { background: #f59e0b; }

  /* Controles (Buscador y Subir) */
  .actions-row { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: stretch; justify-content: space-between; }
  .search-input-wrapper { flex: 1; max-width: 450px; position: relative; }
  .search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); }
  .search-input-wrapper input {
    width: 100%; padding: 0.875rem 1.2rem 0.875rem 3rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-surface); color: var(--color-text);
    font-family: inherit; font-size: 0.95rem; box-sizing: border-box; transition: all 0.2s; box-shadow: var(--shadow-sm);
  }
  .search-input-wrapper input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1); }
  .btn-upload {
    padding: 0 1.75rem; background: var(--color-primary); color: white; border: none;
    border-radius: var(--radius-md); font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 0.6rem; font-size: 0.95rem; white-space: nowrap; transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(var(--color-primary-rgb), 0.2);
  }
  .btn-upload:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 8px -1px rgba(var(--color-primary-rgb), 0.3); }

  /* Tabla de Archivos (Premium UI) */
  .table-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden; /* Mantiene bordes redondeados */
  }
  
  .table-container table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  /* Cabeceras */
  .files-table thead {
    background: rgba(0, 0, 0, 0.02);
    border-bottom: 2px solid var(--color-border);
  }
  .files-table th {
    padding: 1.25rem 1.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-right: 1px solid var(--color-border);
    vertical-align: middle;
  }
  .files-table th:last-child { border-right: none; }
  
  /* Celdas */
  .files-table :global(td) {
    padding: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    vertical-align: middle;
  }
  .files-table :global(td:last-child) { border-right: none; }
  .files-table :global(tbody tr:last-child td) {
    border-bottom: none;
  }
  .files-table :global(tbody tr) {
    transition: background-color 0.2s;
  }
  .files-table :global(tbody tr:hover) {
    background-color: rgba(var(--color-primary-rgb), 0.03);
  }

  /* Anchos de columnas (thead es estático, por ende seguro sin global) */
  .col-type { width: 80px; text-align: center; }
  .col-name { width: auto; }
  .col-size { width: 12%; text-align: center; }
  .col-date { width: 18%; text-align: center; }
  .col-actions { width: 120px; text-align: center; }

  /* Fila principal (icono + info) */
  .files-table :global(.col-type-data) { text-align: center; font-size: 1.6rem; vertical-align: middle; }
  
  .files-table :global(.col-name-data) { vertical-align: middle; }
  .files-table :global(.name-wrapper) { display: flex; flex-direction: column; }
  .files-table :global(.file-title) {
    font-weight: 500;
    font-size: 1rem;
    color: var(--color-text);
  }
  .files-table :global(.file-name-sub) {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  
  /* Textos secundarios */
  .files-table :global(.col-size-data), .files-table :global(.col-date-data) { text-align: center; color: var(--color-text); font-size: 0.95rem; vertical-align: middle; }

  /* Acciones */
  .files-table :global(.col-actions-data) { text-align: center; vertical-align: middle; }
  .files-table :global(.td-actions) {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
  }
  .files-table :global(.btn-action) {
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.25rem;
    transition: color 0.2s, transform 0.2s;
  }
  .files-table :global(.btn-action:hover) {
    transform: scale(1.1);
  }
  .files-table :global(.view-btn:hover) { color: #3b82f6; }
  .files-table :global(.dl-btn:hover) { color: #22c55e; }
  .files-table :global(.del-btn:hover) { color: #ef4444; }

  /* Estados vacíos y carga */
  .files-table :global(.loading-state), .files-table :global(.empty-state) {
    text-align: center;
    padding: 5rem 2rem;
    color: var(--color-text-muted);
  }
  .files-table :global(.loading-state i), .files-table :global(.empty-state i) {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    display: block;
    opacity: 0.4;
  }
  .files-table :global(.empty-state h3) { margin: 0 0 0.5rem; color: var(--color-text); font-size: 1.25rem; font-weight: 600; }
  .files-table :global(.empty-state p) { margin: 0; font-size: 0.95rem; }

  /* Modal de Subida */
  .upload-modal { position: fixed; inset: 0; z-index: 200; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .upload-modal.hidden { display: none; }
  .modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); }
  .modal-content { position: relative; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); width: 100%; max-width: 500px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.4); overflow: hidden; }
  .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-bottom: 1px solid var(--color-border); background: var(--color-background); }
  .modal-header h3 { margin: 0; font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.75rem; color: var(--color-text); }
  .modal-header i { color: var(--color-primary); }
  .modal-close { background: none; border: none; color: var(--color-text-muted); font-size: 1.75rem; cursor: pointer; line-height: 1; padding: 0; transition: color 0.2s; }
  .modal-close:hover { color: var(--color-text); }
  .upload-form { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group label { font-weight: 600; font-size: 0.95rem; color: var(--color-text); }
  .upload-form input[type="text"] { padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-surface); color: var(--color-text); font-family: inherit; font-size: 0.95rem; box-shadow: inset 0 1px 2px rgba(0,0,0,0.05); transition: border-color 0.2s; }
  .upload-form input[type="text"]:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.1); }
  
  .file-drop { border: 2px dashed var(--color-border); border-radius: var(--radius-md); padding: 2.5rem 1.5rem; text-align: center; cursor: pointer; position: relative; transition: all 0.2s; background: var(--color-background); }
  .file-drop i { font-size: 2.5rem; margin-bottom: 1rem; display: block; color: var(--color-text-muted); opacity: 0.6; transition: color 0.2s; }
  .file-drop p { margin: 0; font-size: 1.05rem; font-weight: 500; color: var(--color-text); }
  .file-types { font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.75rem; display: block; }
  .file-drop:hover, .file-drop.drag-over { border-color: var(--color-primary); background: rgba(var(--color-primary-rgb), 0.03); }
  .file-drop:hover i, .file-drop.drag-over i { color: var(--color-primary); opacity: 1; transform: scale(1.05); }
  .file-drop.has-file { border-color: #22c55e; background: rgba(34,197,94,0.03); }
