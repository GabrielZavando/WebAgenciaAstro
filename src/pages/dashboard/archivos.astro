---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import FileManager from '../../components/shared/FileManager.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout 
  title="Mis Archivos" 
  breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Archivos' }]} 
  role="client"
>
  <FileManager 
    role="client" 
    limitGB={5} 
    title="Mis Archivos"
    description="Gestiona tus documentos y recursos multimedia. Tu cuenta tiene un límite de 5GB."
  />
</DashboardLayout>
