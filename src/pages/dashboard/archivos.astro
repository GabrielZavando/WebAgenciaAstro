---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StorageVisualizer from '../../components/admin/StorageVisualizer.astro';
import ModalConfirm from '../../components/shared/ModalConfirm.astro';
import ModalMessage from '../../components/shared/ModalMessage.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Archivos" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Archivos' }]} role="client">
  <div class="files-page">
    <div class="page-header">
      <div class="header-text">
        <h1>Mis Archivos</h1>
        <p class="text-muted">Gestiona tus documentos y recursos multimedia. Tu cuenta tiene un límite de 5GB.</p>
      </div>

      <!-- Cuota de almacenamiento -->
      <div class="storage-banner-wrapper" id="storageBanner">
        <StorageVisualizer 
          id="files-storage-chart"
          usedFormatted="..." 
          limitFormatted="..." 
          usedBytes={0} 
          limitBytes={1} 
          variant="full"
        />
      </div>
    </div>

    <!-- Acciones -->
    <div class="actions-row">
      <form class="search-form" id="searchForm" onsubmit="return false;">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar por título, nombre o descripción..." autocomplete="off" />
        <button type="submit" class="search-btn">Buscar</button>
      </form>
      
      <button class="btn-cta" id="uploadBtn">
        <span class="btn-text">Subir Archivo</span>
        <span class="material-symbols-outlined">cloud_upload</span>
      </button>
    </div>

    <!-- Modal de subida -->
    <div class="modal modal--files-upload" id="uploadModal">
      <div class="modal__content">
        <div class="modal__header">
          <h3><span class="material-symbols-outlined">upload_file</span> Subir Archivo</h3>
          <button class="modal__close" id="closeModal">&times;</button>
        </div>
        
        <form id="uploadForm" class="upload-form">
          <div class="form-group">
            <label for="fileTitle" class="form-label">Título del Archivo <span class="required">*</span></label>
            <input type="text" id="fileTitle" name="title" required placeholder="Ej: Manual de Identidad Corporativa" />
          </div>
          
          <div class="form-group">
            <label for="fileDesc" class="form-label">Descripción Corta</label>
            <input type="text" id="fileDesc" name="description" placeholder="Ej: Versión final aprobada en PDF" />
          </div>
          
          <div class="form-group toggle-group">
            <label class="toggle">
              <input type="checkbox" id="fileIsPublic" name="isPublic" value="true" />
              <div class="toggle-col-text">
                <span class="label-text">Acceso Público</span>
                <span class="toggle-hint-text">Si es público, otros usuarios con el link podrán descargarlo.</span>
              </div>
            </label>
          </div>

          <div class="form-group">
            <label class="form-label">Archivo <span class="required">*</span></label>
            <div class="file-drop" id="fileDrop">
              <input type="file" id="fileInput" name="file" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.webp,.txt,.csv" required class="file-input-hidden" />
              <div class="drop-info">
                 <span class="material-symbols-outlined">cloud_upload</span>
                 <p id="fileLabel">Arrastra o selecciona un archivo aquí</p>
                 <span class="file-types">Formatos: PDF, Office, Imágenes (Máx 20MB)</span>
              </div>
            </div>
          </div>

          <p class="form-help-text" style="color:var(--color-text-muted); font-size: 0.85rem; margin-top: 1.5rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
            <span class="required">*</span> Los campos marcados con asterisco son obligatorios.
          </p>

          <div class="form-actions" style="justify-content: flex-end;">
            <button type="submit" class="btn btn-cta" id="submitUpload">
              <span class="material-symbols-outlined">upload</span>
              Cargar archivo
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Tabla de lista de archivos -->
    <div class="project-table-container">
      <table class="unified-project-table">
        <thead>
          <tr>
            <th class="col-type" style="width: 80px; text-align: center;">Tipo</th>
            <th class="col-name">Nombre</th>
            <th class="col-desc">Descripción</th>
            <th class="col-size">Tamaño</th>
            <th class="col-date">Fecha de carga</th>
            <th class="col-actions">Acciones</th>
          </tr>
        </thead>
        <tbody id="filesListBody">
          <tr>
            <td colspan="6">
              <div class="loading-state">
                <span class="material-symbols-outlined spinning">sync</span>
                <p>Cargando archivos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Modales en slot -->
    <ModalConfirm 
      slot="modals"
      id="deleteConfirmModal"
      title="¿Eliminar archivo?"
      message="Esta acción no se puede deshacer. El archivo se borrará permanentemente de tu cuenta."
      confirmText="Eliminar permanentemente"
      cancelText="Cancelar"
      type="danger"
    />

    <ModalMessage 
      slot="modals"
      id="errorFileRequestModal"
      title="Error de Solicitud"
      message="Hubo un problema al procesar la solicitud del archivo."
      type="error"
    />

    <ModalMessage 
      slot="modals"
      id="errorFileDeleteModal"
      title="Error al Eliminar"
      message="No se pudo eliminar el archivo. Por favor, inténtalo de nuevo."
      type="error"
    />

    <ModalMessage 
      slot="modals"
      id="successUploadModal"
      title="Subida Exitosa"
      message="El archivo se ha subido correctamente."
      type="success"
    />

    <ModalMessage 
      slot="modals"
      id="errorUploadModal"
      title="Error de Subida"
      message="No se pudo subir el archivo. Por favor, inténtalo de nuevo."
      type="error"
    />
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

  interface FileItem {
    id: string;
    title: string;
    description: string;
    fileName: string;
    mimeType: string;
    size: number;
    createdAt: { _seconds?: number } | string;
  }

  let allFiles: FileItem[] = [];

  async function getFreshToken() {
    if (!auth.currentUser) return null;
    return await auth.currentUser.getIdToken();
  }
  async function loadQuota() {
    const storageBanner = document.getElementById('storageBanner');
    const storageCircle = storageBanner?.querySelector('.chart-progress');
    const storagePercent = storageBanner?.querySelector('.percentage');
    const usedValue = storageBanner?.querySelector('.used-value');
    const limitValue = storageBanner?.querySelector('.limit-value');

    try {
      const t = await getFreshToken();
      if (!t) return;
      const res = await fetch(`${API}/files/storage/quota`, { headers: { 'Authorization': `Bearer ${t}` } });
      if (!res.ok) throw new Error();
      const q = await res.json();
      const pct = q.limitBytes > 0 ? (q.usedBytes / q.limitBytes) * 100 : 0;
      if (usedValue) usedValue.textContent = q.usedFormatted;
      if (limitValue) limitValue.textContent = q.limitFormatted;
      if (storageCircle) storageCircle.setAttribute('stroke-dasharray', `${Math.min(pct, 100)}, 100`);
      if (storagePercent) storagePercent.textContent = `${Math.round(pct)}%`;
      if (storageBanner) storageBanner.classList.toggle('warning', pct >= 90);
    } catch {
      if (usedValue) usedValue.textContent = 'Error cargando almacenamiento';
    }
  }

  async function loadFiles() {
    const tableBody = document.getElementById('filesListBody');
    try {
      const t = await getFreshToken();
      if (!t) return;
      const res = await fetch(`${API}/files`, { headers: { 'Authorization': `Bearer ${t}` } });
      if (!res.ok) throw new Error();
      allFiles = await res.json();
      renderFiles(allFiles);
    } catch (e) {
      console.error("Error loading files:", e);
      if (tableBody) tableBody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><span class="material-symbols-outlined">report</span><p>Error al cargar los archivos.</p></div></td></tr>`;
    }
  }

  function renderFiles(files: FileItem[]) {
    const tableBody = document.getElementById('filesListBody');
    if (!tableBody) return;
    if (files.length === 0) {
      tableBody.innerHTML = `
        <tr>
          <td colspan="6">
            <div class="empty-state">
              <span class="material-symbols-outlined">folder_open</span>
              <h3>Sin archivos</h3>
              <p>No hay archivos que coincidan con tu búsqueda o aún no has subido ninguno.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    tableBody.innerHTML = files.map(f => `
      <tr class="file-row">
        <td class="col-type-data">${getFileIcon(f.mimeType)}</td>
        <td class="col-name-data">
          <div class="name-wrapper">
            <span class="file-title" title="${f.title}">${f.title}</span>
            ${f.title !== f.fileName ? `<span class="file-name-sub">(${f.fileName})</span>` : ''}
          </div>
        </td>
        <td class="col-desc-data"><span class="file-desc-text" title="${f.description || ''}">${f.description || '-'}</span></td>
        <td class="col-size-data">${fmtSize(f.size)}</td>
        <td class="col-date-data">${fmtDate(f.createdAt)}</td>
        <td class="col-actions-data">
          <div class="td-actions">
            <button class="btn-icon view-btn" data-id="${f.id}" title="Ver">
              <span class="material-symbols-outlined">visibility</span>
            </button>
            <button class="btn-icon dl-btn" data-id="${f.id}" title="Descargar">
              <span class="material-symbols-outlined">download</span>
            </button>
            <button class="btn-icon del-btn" data-id="${f.id}" title="Eliminar">
              <span class="material-symbols-outlined">delete</span>
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    tableBody.querySelectorAll('.view-btn').forEach(b => b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'view')));
    tableBody.querySelectorAll('.dl-btn').forEach(b => b.addEventListener('click', () => handleDl(b.getAttribute('data-id')!, 'download')));
    tableBody.querySelectorAll('.del-btn').forEach(b => b.addEventListener('click', () => handleDelete(b.getAttribute('data-id')!)));
  }

  // Handlers
  async function handleDl(id: string, action: 'view' | 'download') {
    try {
      const t = await getFreshToken();
      if (!t) return;
      const isDl = action === 'download';
      const res = await fetch(`${API}/files/${id}/download?download=${isDl}`, { headers: { 'Authorization': `Bearer ${t}` } });
      if (!res.ok) throw new Error();
      const { url } = await res.json();
      if (action === 'view') window.open(url, '_blank');
      else {
        if (window.showToast) window.showToast('Iniciando descarga...', 'info');
        const a = document.createElement('a'); a.href = url; document.body.appendChild(a); a.click(); document.body.removeChild(a);
      }
    } catch { 
      if (window.modalHelpers) window.modalHelpers.openModal('errorFileRequestModal');
      else alert('Error al procesar la solicitud.'); 
    }
  }

  async function handleDelete(id: string) {
    if (!window.confirmModalHelpers) {
      if (!confirm('¿Estás seguro de eliminar este archivo?')) return;
      return await executeDelete(id);
    }
    window.confirmModalHelpers.open('deleteConfirmModal', async () => await executeDelete(id));
  }

  async function executeDelete(id: string) {
    try {
      const t = await getFreshToken();
      if (!t) return;
      const res = await fetch(`${API}/files/${id}`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${t}` } });
      if (!res.ok) throw new Error();
      if (window.showToast) window.showToast('Archivo eliminado.', 'success');
      await Promise.all([loadQuota(), loadFiles()]);
    } catch { 
      if (window.modalHelpers) window.modalHelpers.openModal('errorFileDeleteModal');
      else alert('Error al eliminar el archivo.'); 
    }
  }

  function initFiles() {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadModal = document.getElementById('uploadModal');
    const closeModal = document.getElementById('closeModal');
    const uploadForm = document.getElementById('uploadForm') as HTMLFormElement;
    const submitUpload = document.getElementById('submitUpload') as HTMLButtonElement;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const fileLabel = document.getElementById('fileLabel');
    const fileDrop = document.getElementById('fileDrop');

    // Modal de subida
    uploadBtn?.addEventListener('click', () => uploadModal?.classList.add('active'));
    closeModal?.addEventListener('click', closeUploadModal);
    
    // Cerrar modal al hacer clic fuera o en cancelar
    uploadModal?.addEventListener('click', (e) => {
        if (e.target === uploadModal) closeUploadModal();
    });

    function closeUploadModal() {
        uploadModal?.classList.remove('active');
        uploadForm?.reset();
        if (fileLabel) fileLabel.textContent = 'Arrastra o selecciona un archivo aquí';
    }

    fileInput?.addEventListener('change', () => {
        if (fileInput.files?.length && fileLabel) {
            fileLabel.textContent = fileInput.files[0].name;
            fileDrop?.classList.add('has-file');
        }
    });

    fileDrop?.addEventListener('dragover', (e) => { e.preventDefault(); fileDrop.classList.add('drag-over'); });
    fileDrop?.addEventListener('dragleave', () => fileDrop?.classList.remove('drag-over'));
    fileDrop?.addEventListener('drop', (e) => {
        e.preventDefault(); fileDrop?.classList.remove('drag-over');
        const files = (e as DragEvent).dataTransfer?.files;
        if (files?.length && fileInput) {
            fileInput.files = files;
            if (fileLabel) fileLabel.textContent = files[0].name;
            fileDrop?.classList.add('has-file');
        }
    });

    uploadForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitUpload) return;
        const titleVal = (document.getElementById('fileTitle') as HTMLInputElement).value;
        const descVal = (document.getElementById('fileDesc') as HTMLInputElement).value;
        const isPublicVal = (document.getElementById('fileIsPublic') as HTMLInputElement).checked;
        const fileVal = fileInput?.files?.[0];

        if (!fileVal) {
            if (window.showToast) window.showToast('Selecciona un archivo para subir.', 'error');
            return;
        }

        setLoading(submitUpload, true);
        try {
            const t = await getFreshToken();
            if (!t) throw new Error('No se pudo obtener el token de autenticación');
            const fd = new FormData();
            fd.append('file', fileVal);
            fd.append('title', titleVal);
            fd.append('description', descVal);
            if (isPublicVal) fd.append('isPublic', 'true');

            const res = await fetch(`${API}/files`, { method: 'POST', headers: { 'Authorization': `Bearer ${t}` }, body: fd });
            if (!res.ok) { const err = await res.json(); throw new Error(err.message || 'Error del servidor'); }

            if (window.showToast) window.showToast('Archivo subido correctamente.', 'success');

            closeUploadModal();
            await Promise.all([loadQuota(), loadFiles()]);
        } catch (error: unknown) {
            const msg = error instanceof Error ? error.message : 'Error de conexión';
            if (window.showToast) window.showToast(msg, 'error');
        } finally { setLoading(submitUpload, false); }
    });

    searchInput?.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase().trim();
        if (!q) { renderFiles(allFiles); return; }
        renderFiles(allFiles.filter(f => f.title.toLowerCase().includes(q) || f.fileName.toLowerCase().includes(q) || (f.description && f.description.toLowerCase().includes(q))));
    });
  }

  // Firebase integration
  let isInitialized = false;

  async function init() {
    if (isInitialized) return;
    if (!document.getElementById('filesListBody')) return;
    
    isInitialized = true;
    initFiles();
    await Promise.all([loadQuota(), loadFiles()]);
  }

  onAuthStateChanged(auth, async (user) => {
    if (user) await init();
  });

  document.addEventListener('astro:page-load', async () => {
    isInitialized = false; // Reset on navigation
    if (auth.currentUser) await init();
  });

  function getFileIcon(mime: string): string {
    if (mime.includes('pdf')) return '<span class="material-symbols-outlined" style="color:#ef4444">picture_as_pdf</span>';
    if (mime.includes('image')) return '<span class="material-symbols-outlined" style="color:#3b82f6">image</span>';
    if (mime.includes('word') || mime.includes('document')) return '<span class="material-symbols-outlined" style="color:#2563eb">description</span>';
    if (mime.includes('sheet') || mime.includes('excel')) return '<span class="material-symbols-outlined" style="color:#22c55e">table_chart</span>';
    if (mime.includes('csv')) return '<span class="material-symbols-outlined" style="color:#f59e0b">csv</span>';
    return '<span class="material-symbols-outlined" style="color:#6b7280">draft</span>';
  }
  function fmtDate(raw: { _seconds?: number } | string): string {
    let d: Date;
    if (typeof raw === 'string') d = new Date(raw);
    else if (raw?._seconds) d = new Date(raw._seconds * 1000);
    else return '-';
    
    const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
    return `${d.getDate()}, ${months[d.getMonth()]}, ${d.getFullYear()}`;
  }
  function fmtSize(b: number): string {
    if (!b) return '-';
    if (b < 1024) return `${b} B`;
    if (b < 1048576) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / 1048576).toFixed(1)} MB`;
  }
  function setLoading(btn: HTMLButtonElement, on: boolean) {
    btn.disabled = on;
    btn.classList.toggle('btn-loading', on);
  }

</script>

