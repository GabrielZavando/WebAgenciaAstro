---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StorageVisualizer from '../../components/admin/StorageVisualizer.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Mi Dashboard" breadcrumbs={[{ label: 'Dashboard' }]} role="client">
  <div class="dashboard-home">
    <div class="welcome-section">
      <h1 id="welcomeTitle">Hola, Bienvenido</h1>
      <p class="text-muted">Este es tu resumen de actividad personalizada. Aquí puedes ver el estado de tus proyectos, archivos y soporte técnico.</p>
    </div>

    <div class="stats-grid" id="statsGrid">
      <!-- Proyectos -->
      <div class="stat-card" draggable="true" data-id="projects">
        <div class="stat-icon project-icon">
          <span class="material-symbols-outlined">task</span>
        </div>
        <div class="stat-details">
          <h3>Proyectos</h3>
          <p id="projectsCount">Cargando proyectos...</p>
          <a href="/dashboard/proyectos" class="btn-stat">Ver Proyectos</a>
        </div>
      </div>

      <!-- Archivos -->
      <div class="stat-card" draggable="true" data-id="files">
        <div class="stat-icon files-icon">
          <span class="material-symbols-outlined">folder_open</span>
        </div>
        <div class="stat-details">
          <h3>Archivos</h3>
          <p id="filesCount">Gestión de archivos</p>
          <a href="/dashboard/archivos" class="btn-stat">Mis Archivos</a>
        </div>
      </div>

      <!-- Informes -->
      <div class="stat-card" draggable="true" data-id="reports">
        <div class="stat-icon reports-icon">
          <span class="material-symbols-outlined">picture_as_pdf</span>
        </div>
        <div class="stat-details">
          <h3>Informes</h3>
          <p id="reportsCount">Cargando informes...</p>
          <a href="/dashboard/informes" class="btn-stat">Ver Todo</a>
        </div>
      </div>

      <!-- Soporte -->
      <div class="stat-card" draggable="true" data-id="support">
        <div class="stat-icon support-icon">
          <span class="material-symbols-outlined">headset_mic</span>
        </div>
        <div class="stat-details">
          <h3>Soporte</h3>
          <p id="ticketsCount">Cargando tickets...</p>
          <a href="/dashboard/soporte" class="btn-stat">Nuevo Ticket</a>
        </div>
      </div>

      <!-- Perfil -->
      <div class="stat-card" draggable="true" data-id="profile">
        <div class="stat-icon profile-icon" id="profileIconContainer">
          <span class="material-symbols-outlined">account_circle</span>
        </div>
        <div class="stat-details">
          <h3 id="profileName">Mi Perfil</h3>
          <p>Gestiona tu cuenta y datos</p>
          <a href="/dashboard/perfil" class="btn-stat">Ajustes</a>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";

  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  let userDataLoaded = false;

  function initHome() {
    const welcomeTitle = document.getElementById('welcomeTitle');
    const statsGrid = document.getElementById('statsGrid');
    const projectsCount = document.getElementById('projectsCount');
    const reportsCount = document.getElementById('reportsCount');
    const ticketsCount = document.getElementById('ticketsCount');
    const filesCount = document.getElementById('filesCount');
    const profileName = document.getElementById('profileName');
    const profileIconContainer = document.getElementById('profileIconContainer');

    if (!statsGrid) return;

    // Aplicar orden guardado
    const savedOrder = localStorage.getItem('dashboard_cards_order');
    if (savedOrder) {
        try {
            const order = JSON.parse(savedOrder);
            const cards = Array.from(statsGrid.children);
            order.forEach((id: string) => {
                const card = cards.find(c => c.getAttribute('data-id') === id);
                if (card) statsGrid.appendChild(card);
            });
        } catch (e) {
            console.error("Error cargando orden del dashboard", e);
        }
    }

    // Función de carga de datos (usando token global si existe)
    async function loadDashboardData(token: string) {
        const headers = { 'Authorization': `Bearer ${token}` };
        // Proyectos
        try {
            const res = await fetch(`${API}/projects/my`, { headers });
            const projects = await res.json();
            if (projectsCount) projectsCount.textContent = `${projects.length} proyecto(s) activo(s)`;
        } catch { if (projectsCount) projectsCount.textContent = "Error al cargar"; }

        // Mensaje estático para archivos (coherencia con admin)
        if (filesCount) filesCount.textContent = "Gestión de archivos personales";

        // Informes
        try {
            const res = await fetch(`${API}/reports`, { headers });
            const reports = await res.json();
            if (reportsCount) reportsCount.textContent = `${reports.length} informe(s) disponible(s)`;
        } catch { if (reportsCount) reportsCount.textContent = "Error al cargar"; }

        // Tickets
        try {
            const res = await fetch(`${API}/support/tickets/my`, { headers });
            const tickets = await res.json();
            const openTickets = tickets.filter((t: any) => t.status !== 'resolved').length;
            if (ticketsCount) ticketsCount.textContent = `${openTickets} ticket(s) pendiente(s)`;
        } catch { if (ticketsCount) ticketsCount.textContent = "Error al cargar"; }
    }

    // Drag and Drop
    let draggedCard: HTMLElement | null = null;
    statsGrid.querySelectorAll('.stat-card').forEach(cardElement => {
        const card = cardElement as HTMLElement;
        card.addEventListener('dragstart', (e) => {
            draggedCard = card;
            draggedCard.classList.add('dragging');
            statsGrid.classList.add('is-dragging-any');
        });
        card.addEventListener('dragend', () => {
            draggedCard?.classList.remove('dragging');
            statsGrid.classList.remove('is-dragging-any');
            draggedCard = null;
            const order = Array.from(statsGrid.children).map(c => c.getAttribute('data-id'));
            localStorage.setItem('dashboard_cards_order', JSON.stringify(order));
        });
        card.addEventListener('dragover', (e) => {
            e.preventDefault();
            if (!draggedCard || draggedCard === card) return;
            const rect = card.getBoundingClientRect();
            const midpoint = rect.left + rect.width / 2;
            if ((e as MouseEvent).clientX < midpoint) statsGrid.insertBefore(draggedCard, card);
            else statsGrid.insertBefore(draggedCard, card.nextSibling);
        });
    });

    // Si ya tenemos usuario de Firebase, cargar datos
    const user = auth.currentUser;
    if (user) {
        if (welcomeTitle) welcomeTitle.textContent = `Hola, ${user.displayName || 'Bienvenido'}`;
        if (profileName) profileName.textContent = user.displayName || 'Mi Perfil';
        if (user.photoURL && profileIconContainer) {
            profileIconContainer.innerHTML = `<img src="${user.photoURL}" alt="${user.displayName}" class="profile-card-img" />`;
        } else if (profileIconContainer) {
            profileIconContainer.innerHTML = `<span class="material-symbols-outlined">account_circle</span>`;
        }
        user.getIdToken().then(loadDashboardData);
    }
  }

  onAuthStateChanged(auth, (user) => {
    if (user && document.getElementById('statsGrid')) {
        initHome();
    }
  });

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('statsGrid')) {
        initHome();
    }
  });
</script>


