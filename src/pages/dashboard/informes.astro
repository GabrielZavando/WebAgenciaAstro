---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ReportTable from '../../components/shared/ReportTable.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Informes" role="client">
  <div class="reports-page">
    <div class="page-header">
      <h1>Informes de Estado</h1>
      <p class="text-muted">Reportes mensuales de mantenimiento y mejoras desarrollados por Gabriel Zavando. El software es un sistema vivo que requiere evolución constante.</p>
    </div>

    <ReportTable role="client" />
  </div>
</DashboardLayout>

<style>
  .reports-page { width: 100%; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin: 0 0 0.5rem; font-size: 1.75rem; font-weight: 800; }
  .text-muted { color: var(--color-text-muted); margin: 0; }
</style>
