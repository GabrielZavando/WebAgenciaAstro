---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ReportTable from '../../components/admin/ReportTable.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Informes" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Informes' }]} role="client">
  <div class="reports-page">
    <div class="page-header">
      <h1>Informes de Estado</h1>
      <p class="text-muted">Reportes mensuales de mantenimiento y mejoras. El software es un sistema vivo que requiere evolución constante.</p>
    </div>

    <ReportTable role="client" />
  </div>
</DashboardLayout>
