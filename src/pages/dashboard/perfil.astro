---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

// Opcional: Obtener datos actuales del backend
let userProfile = null;
try {
  const response = await fetch(`${API_URL}/users/profile`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    userProfile = await response.json();
  }
} catch (e) {
  console.error("Error fetching profile details:", e);
}
---

<DashboardLayout title="Mi Perfil" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Perfil' }]} role="client">
  <div class="user-form-container profile-view fade-in">
    <div class="profile-grid">
    <!-- Columna 1: Datos Personales -->
    <div class="content-card">
      <div class="section-header">
        <h2 class="section-title"><span class="material-symbols-outlined">person</span> Datos Personales</h2>
      </div>
      
      <form id="profileForm" class="report-form" enctype="multipart/form-data">
        <div class="avatar-section">
          <div class="avatar-container">
            <img id="avatarPreview" src={userProfile?.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(userProfile?.displayName || 'User')}&background=random&color=fff`} alt="Profile Avatar" class="profile-avatar" />
            <button type="button" class="avatar-edit-btn" onclick="document.getElementById('avatar').click()" title="Cambiar foto">
              <span class="material-symbols-outlined">edit</span>
            </button>
            <input type="file" id="avatar" name="avatar" accept=".jpg, .jpeg, .png, .webp" class="hidden-file-input" />
          </div>
          <div class="user-info-text">
            <h3 class="user-display-name">{userProfile?.displayName || 'Usuario'}</h3>
            <span class="user-role-badge">Cliente Premium</span>
          </div>
        </div>

        <div class="form-group">
          <label for="displayName" class="form-label">Nombre Completo <span class="required">*</span></label>
          <input type="text" id="displayName" name="displayName" value={userProfile?.displayName || ''} placeholder="Tu nombre artístico o comercial" required />
        </div>
        
        <div class="form-group">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input type="email" id="email" value={userProfile?.email || ''} disabled />
          <p class="form-legend">El correo electrónico no puede ser modificado por seguridad.</p>
        </div>

        <div class="form-group">
          <label for="phone" class="form-label">Teléfono de contacto</label>
          <input type="tel" id="phone" name="phone" value={userProfile?.phone || ''} placeholder="+56 9 1234 5678" />
        </div>

        <div class="form-group">
          <label for="description" class="form-label">Descripción / Bio</label>
          <textarea id="description" name="description" rows="3" placeholder="Una breve descripción sobre ti o tu negocio...">{userProfile?.description || ''}</textarea>
        </div>
        
        <p class="form-help-text" style="color:var(--color-text-muted); font-size: 0.85rem; margin-top: 1.5rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
          <span class="required">*</span> Los campos marcados con asterisco son obligatorios.
        </p>

        <div class="form-actions">
          <button type="submit" class="btn-cta" id="saveProfileBtn">
            Guardar Cambios
            <span class="material-symbols-outlined">save</span>
          </button>
        </div>
      </form>
    </div>

    <!-- Columna 2: Seguridad -->
    <div class="content-card">
      <div class="section-header">
        <h2 class="section-title"><span class="material-symbols-outlined">security</span> Seguridad</h2>
      </div>
      
      <form id="passwordForm" class="report-form">
        <div class="form-group">
          <label for="newPassword" class="form-label">Nueva Contraseña <span class="required">*</span></label>
          <input type="password" id="newPassword" name="newPassword" placeholder="8+ caracteres, mayúsculas y números" minlength="8" required />
        </div>

        <div class="form-group">
          <label for="confirmPassword" class="form-label">Confirmar Contraseña <span class="required">*</span></label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repite la nueva contraseña" required />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-cta" id="savePasswordBtn">
            Actualizar Contraseña
            <span class="material-symbols-outlined">lock_reset</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { updatePassword } from "firebase/auth";
  import { validatePassword } from "../../lib/utils/security";

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

  /** FORM DATOS PERSONALES **/
  const profileForm = document.getElementById('profileForm') as HTMLFormElement;
  const saveProfileBtn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
  const profileFeedback = document.getElementById('profileFeedback');
  const avatarInput = document.getElementById('avatar') as HTMLInputElement;
  const avatarPreview = document.getElementById('avatarPreview') as HTMLImageElement;

  avatarInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      if (file.size > 2 * 1024 * 1024) {
        window.showToast('La imagen supera los 2MB permitidos.', 'error');
        avatarInput.value = '';
        return;
      }
      avatarPreview.src = URL.createObjectURL(file);
    }
  });

  profileForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!saveProfileBtn || !auth.currentUser) return;

    setLoading(saveProfileBtn, true);
    
    try {
      const token = await auth.currentUser.getIdToken();
      const formData = new FormData(profileForm);
      
      if (avatarInput?.files?.[0]) {
        if (avatarInput.files[0].size > 2 * 1024 * 1024) {
          window.showToast('La imagen supera los 2MB permitidos.', 'error');
          setLoading(saveProfileBtn, false);
          return;
        }
      }

      const response = await fetch(`${API_URL}/users/profile`, {
        method: 'PATCH',
        headers: {
          'Authorization': `Bearer ${token}`
        },
        body: formData
      });

      if (response.ok) {
        window.showToast('Perfil actualizado correctamente.', 'success');
        setTimeout(() => window.location.reload(), 1500);
      } else {
        window.showToast('Error al actualizar perfil.', 'error');
      }
    } catch (error) {
      window.showToast('Error de conexión.', 'error');
    } finally {
      setLoading(saveProfileBtn, false);
    }
  });


  /** FORM CONTRASEÑA **/
  const passwordForm = document.getElementById('passwordForm') as HTMLFormElement;
  const savePasswordBtn = document.getElementById('savePasswordBtn') as HTMLButtonElement;
  const passwordFeedback = document.getElementById('passwordFeedback');

  passwordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!savePasswordBtn || !auth.currentUser) return;

    const newPassword = (document.getElementById('newPassword') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    const validation = validatePassword(newPassword);
    if (!validation.isValid) {
      window.showToast(validation.errors[0], 'error');
      return;
    }

    if (newPassword !== confirmPassword) {
      window.showToast('Las contraseñas no coinciden.', 'error');
      return;
    }

    setLoading(savePasswordBtn, true);
    
    try {
      await updatePassword(auth.currentUser, newPassword);
      window.showToast('Contraseña cambiada exitosamente.', 'success');
      passwordForm.reset();
    } catch (error: any) {
      if (error.code === 'auth/requires-recent-login') {
        window.showToast('Por seguridad, debes cerrar sesión y volver a entrar.', 'error');
      } else {
        window.showToast(`Error: ${error.message}`, 'error');
      }
    } finally {
      setLoading(savePasswordBtn, false);
    }
  });

  function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
    btn.disabled = isLoading;
    btn.classList.toggle('btn-loading', isLoading);
  }
</script>
