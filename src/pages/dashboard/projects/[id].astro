
---
import Layout from '../../../layouts/MainLayout.astro';
const { id } = Astro.params;
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
---

<Layout title="Detalle de Proyecto">
  <main class="dashboard-container">
    <div style="margin-bottom: 2rem;">
        <a href="/dashboard" style="color: var(--color-text-muted); text-decoration: none;">&larr; Volver a Mis Proyectos</a>
    </div>

    <div id="projectDetails">
        <div class="loading">Cargando proyecto...</div>
    </div>
  </main>
</Layout>

<script define:vars={{ id, API_BASE_URL }}>
    async function loadProject() {
        try {
            const token = document.cookie.split('; ').find(row => row.startsWith('session='))?.split('=')[1];
            if (!token) return;

            const response = await fetch(`${API_BASE_URL}/projects/${id}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });

            if (!response.ok) {
                if (response.status === 403) throw new Error('No tienes permiso para ver este proyecto');
                if (response.status === 404) throw new Error('Proyecto no encontrado');
                throw new Error('Error cargando el proyecto');
            }

            const p = await response.json();
            const container = document.getElementById('projectDetails');

            // Renderizado de archivos y reportes (mockup visual por ahora)
            const filesHtml = (p.files || []).length > 0 
                ? p.files.map(f => `<li><a href="${f}" target="_blank" class="file-link">📄 ${f.split('/').pop()}</a></li>`).join('')
                : '<p class="empty-list">No hay archivos compartidos.</p>';

            const reportsHtml = (p.reports || []).length > 0
                 ? p.reports.map(r => `<li><a href="${r}" target="_blank" class="report-link">📊 ${r.split('/').pop()}</a></li>`).join('')
                 : '<p class="empty-list">No hay informes disponibles.</p>';

            container.innerHTML = `
                <div class="project-header fade-in">
                    <h1>${p.title}</h1>
                    <span class="status-badge status-${p.status || 'pending'}">${p.status || 'pending'}</span>
                </div>
                
                <div class="project-content fade-in">
                    <section class="info-section">
                        <h3>Descripción</h3>
                        <p>${p.description || 'Sin descripción detallada.'}</p>
                    </section>

                    <div class="grid-sections">
                        <section class="info-section">
                            <h3>📂 Archivos y Entregables</h3>
                            <ul class="file-list">${filesHtml}</ul>
                        </section>

                        <section class="info-section">
                            <h3>📈 Informes de Avance</h3>
                            <ul class="file-list">${reportsHtml}</ul>
                        </section>
                    </div>
                </div>
            `;

        } catch (error) {
            console.error(error);
            document.getElementById('projectDetails').innerHTML = `
                <div style="text-align: center; padding: 4rem;">
                    <h2 style="color: var(--color-error)">Error</h2>
                    <p>${error.message}</p>
                </div>
            `;
        }
    }

    loadProject();
</script>

<style>
  .dashboard-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      min-height: 80vh;
  }

  .project-header {
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
  }
  
  h1 { margin: 0; font-size: 2rem; color: var(--color-text); }
  
  .status-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      color: white;
  }
  .status-pending { background: #d97706; }
  .status-active { background: #059669; }
  .status-completed { background: #2563eb; }
  
  .info-section {
      background: var(--color-surface);
      padding: 1.5rem;
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
      margin-bottom: 1.5rem;
  }
  
  .info-section h3 { margin-top: 0; color: var(--color-text); border-bottom: 1px solid var(--color-border-secondary); padding-bottom: 0.5rem; margin-bottom: 1rem; }
  .info-section p { color: var(--color-text-secondary); line-height: 1.6; }
  
  .grid-sections {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
  }
  
  @media (max-width: 768px) {
      .grid-sections { grid-template-columns: 1fr; }
  }
  
  .file-list { list-style: none; padding: 0; margin: 0; }
  .file-list li { margin-bottom: 0.75rem; }
  
  .file-link, .report-link {
      display: block;
      padding: 0.75rem;
      background: var(--color-background);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      color: var(--color-primary);
      text-decoration: none;
      transition: all 0.2s;
  }
  
  .file-link:hover, .report-link:hover {
      border-color: var(--color-primary);
      transform: translateX(5px);
  }
  
  .empty-list { color: var(--color-text-muted); font-style: italic; font-size: 0.9rem; }
</style>
