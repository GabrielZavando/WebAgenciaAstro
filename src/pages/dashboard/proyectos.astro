---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Proteger la ruta y obtener el token SSR
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Mis Proyectos" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Proyectos' }]} role="client">
  <div class="projects-page">
    <div class="page-header">
      <h1>Mis Proyectos</h1>
      <p class="text-muted">Visualiza y gestiona el estado de tus proyectos activos en curso.</p>
    </div>

    <div class="projects-placeholder">
      <div class="empty-state">
        <span class="material-symbols-outlined">task</span>
        <h3 class="empty-title">Próximamente</h3>
        <p class="empty-message">Estoy preparando el listado detallado de tus proyectos. Muy pronto podrás ver el progreso en tiempo real.</p>
      </div>
    </div>
  </div>
</DashboardLayout>
