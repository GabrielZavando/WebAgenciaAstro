---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TicketTable from '../../components/admin/TicketTable.astro';
import FormModal from '../../components/shared/FormModal.astro';
import ModalMessage from '../../components/shared/ModalMessage.astro';
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Soporte" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Soporte' }]} role="client">
  <div class="support-page">
    <div id="listView">
      <div class="page-header">
        <h1>Centro de Soporte</h1>
        <p class="text-muted">Solicita ayuda y revisa el estado de tus tickets de forma sencilla.</p>
      </div>

      <!-- Acciones principales -->
      <div class="actions-row">
        <form class="search-form" onsubmit="return false;">
          <input type="text" id="searchInput" class="search-input" placeholder="Buscar por asunto del ticket..." autocomplete="off" />
          <button type="submit" class="search-btn">Buscar</button>
        </form>
        
        <div class="filter-group">
          <div class="select-wrapper project-select-wrapper">
             <select id="projectQuerySelect">
                <option value="">Todos los proyectos</option>
             </select>
          </div>
        </div>

        <button class="btn-cta" id="toggleFormBtn">
          <span class="btn-text">Nuevo Ticket</span>
          <span class="material-symbols-outlined">add_circle</span>
        </button>
      </div>
    </div>

    <FormModal id="ticketModal" title="Nuevo Ticket" icon="add_circle" width="90%" maxWidth="1440px" largeHeader={true}>
      <form id="ticketForm" class="report-form">
        <div class="form-row">
          <div class="form-group">
            <label for="projectSelect">Proyecto <span class="required">*</span></label>
            <div class="select-wrapper">
              <select id="projectSelect" name="projectId" required>
                <option value="" disabled selected>Selecciona un proyecto</option>
              </select>
            </div>
            <input type="hidden" id="projectName" name="projectName" value="" />
          </div>

          <div class="form-group">
            <label for="priority">Prioridad <span class="required">*</span></label>
            <div class="select-wrapper">
               <select id="priority" name="priority" required>
                  <option value="low">Baja</option>
                  <option value="medium" selected>Media</option>
                  <option value="high">Alta</option>
               </select>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label for="subject">Asunto <span class="required">*</span></label>
          <input type="text" id="subject" name="subject" placeholder="Ej: Error al cargar imágenes en el banner" required />
        </div>

        <div class="form-group">
          <label for="message">Mensaje <span class="required">*</span></label>
          <textarea id="message" name="message" rows="5" placeholder="Explica tu problema detalladamente para ayudarte mejor..." required></textarea>
        </div>

        <div class="form-group">
          <label>Captura de Pantalla (Opcional)</label>
          <div class="file-drop file-drop--mini" id="dropZone">
             <input type="file" id="attachment" name="attachment" accept="image/*" class="file-input-hidden" />
             <div id="uploadInfo">
                <span class="material-symbols-outlined">add_photo_alternate</span>
                <p id="fileNameLabel">Arrastra o selecciona una imagen</p>
             </div>
          </div>
        </div>

        <div id="ticketFeedback" class="feedback-message hidden"></div>
        
        <p class="form-help-text" style="color:var(--color-text-muted); font-size: 0.85rem; margin-top: 1.5rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
          <span class="required">*</span> Los campos marcados con asterisco son obligatorios.
        </p>

        <div class="form-actions">
          <button type="button" class="btn-cta__border" id="cancelTicketBtn">Cancelar</button>
          <button type="submit" class="btn-cta" id="submitTicketBtn" disabled>
            Enviar Ticket
            <span class="material-symbols-outlined">send</span>
          </button>
        </div>
      </form>
    </FormModal>

    <TicketTable role="client" id="ticketsListBody" />
    
    <ModalMessage 
      id="successTicketModal" 
      type="success" 
      title="¡Ticket Creado!" 
      message="Tu solicitud de soporte ha sido enviada correctamente. Te responderemos a la brevedad." 
    />
  </div>
</DashboardLayout>

<style>
  .file-drop.file-selected {
    border-color: var(--color-success, #10b981) !important;
    background-color: rgba(16, 185, 129, 0.05) !important;
    border-style: solid !important;
  }
  .file-drop.file-selected #uploadInfo {
    color: var(--color-success, #10b981) !important;
  }
  .file-drop.file-selected #uploadInfo span {
    color: var(--color-success, #10b981) !important;
  }
</style>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";
  import { formatDate, getStatusInfo, getPriorityInfo, getRawDate } from "../../lib/support-utils";
  import type { TicketResponseDto, ProjectResponseDto } from "../../types/api";

  const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

  let allTickets: TicketResponseDto[] = [];
  let allProjects: ProjectResponseDto[] = [];
  let currentToken = '';

  async function loadTickets(token: string) {
    const ticketsListBody = document.getElementById('ticketsListBody');
    if (!ticketsListBody) return;
    
    try {
      const res = await fetch(`${API_URL}/support/tickets/my`, { 
        headers: { 'Authorization': `Bearer ${token}` } 
      });
      if (!res.ok) throw new Error();
      allTickets = await res.json();
      applyFilters();
    } catch {
      ticketsListBody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><span class="material-symbols-outlined">report</span><p>Error al cargar tickets.</p></div></td></tr>`;
    }
  }

  async function loadProjects(token: string) {
    try {
      const res = await fetch(`${API_URL}/projects/my`, { 
        headers: { 'Authorization': `Bearer ${token}` } 
      });
      if (res.ok) {
        allProjects = await res.json();
        populateProjectSelect();
      }
    } catch (e) {
      console.error('Error cargando proyectos', e);
    }
  }

  function populateProjectSelect() {
    const projectSelect = document.getElementById('projectSelect') as HTMLSelectElement;
    const projectQuerySelect = document.getElementById('projectQuerySelect') as HTMLSelectElement;
    if (!projectSelect) return;
    
    const options = allProjects.map(p => `<option value="${p.id}">${p.name}</option>`);
    projectSelect.innerHTML = '<option value="" disabled selected>Selecciona un proyecto</option>' + options.join('');
    if (projectQuerySelect) projectQuerySelect.innerHTML = '<option value="">Todos los proyectos</option>' + options.join('');
  }

  function applyFilters() {
    const ticketsListBody = document.getElementById('ticketsListBody');
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const projectQuerySelect = document.getElementById('projectQuerySelect') as HTMLSelectElement;
    if (!ticketsListBody) return;
    
    const query = searchInput?.value.toLowerCase().trim() || '';
    const selectedProjectId = projectQuerySelect?.value || '';
    let filtered = allTickets.filter(t => 
      (!query || t.subject.toLowerCase().includes(query)) && 
      (!selectedProjectId || t.projectId === selectedProjectId)
    );
    renderTickets(filtered);
  }

  function renderTickets(tickets: TicketResponseDto[]) {
    const ticketsListBody = document.getElementById('ticketsListBody');
    if (!ticketsListBody) return;
    
    if (tickets.length === 0) {
      ticketsListBody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><span class="material-symbols-outlined">inbox</span><h3>Sin resultados</h3><p>No se encontraron tickets.</p></div></td></tr>`;
      return;
    }

    // Group monthly tickets by project to calculate order
    const startOfMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    const monthlyTicketsByProject: Record<string, TicketResponseDto[]> = {};
    
    allTickets.forEach(t => { 
      if (getRawDate(t.createdAt) >= startOfMonth && t.projectId) {
        if (!monthlyTicketsByProject[t.projectId]) {
          monthlyTicketsByProject[t.projectId] = [];
        }
        monthlyTicketsByProject[t.projectId].push(t);
      }
    });

    // Sort chronologically within each project group
    Object.keys(monthlyTicketsByProject).forEach(projectId => {
      monthlyTicketsByProject[projectId].sort((a, b) => 
        getRawDate(a.createdAt).getTime() - getRawDate(b.createdAt).getTime()
      );
    });

    ticketsListBody.innerHTML = tickets.map(ticket => {
      const statusInfo = getStatusInfo(ticket.status);
      const priorityInfo = getPriorityInfo(ticket.priority);
      const proj = ticket.projectId ? allProjects.find(p => p.id === ticket.projectId) : null;
      
      // Calculate index / total for this project this month
      const projTickets = ticket.projectId ? monthlyTicketsByProject[ticket.projectId] || [] : [];
      let ticketPos = '-';
      if (ticket.projectId && projTickets.length > 0) {
        const index = projTickets.findIndex(t => t.id === ticket.id);
        if (index !== -1) {
          ticketPos = `${index + 1}/${projTickets.length}`;
        }
      }
      
      return `
        <tr>
          <td data-label="Proyecto">${proj ? `<span class="project-badge">${proj.name}</span>` : `<span class="project-badge" style="background:#e2e8f0;color:#64748b">S/P</span>`}</td>
          <td style="text-align: center;" data-label="Tickets"><strong>${ticketPos}</strong></td>
          <td data-label="Estado"><span class="status-badge ${statusInfo.className}" title="${statusInfo.label}"><span class="material-symbols-outlined" style="font-size:1rem;margin-right:0.25rem">${statusInfo.icon}</span> ${statusInfo.label}</span></td>
          <td data-label="Prioridad"><div class="priority-badge-wrapper" title="${priorityInfo.label}"><span class="priority-dot" style="background-color: ${priorityInfo.color}"></span> ${priorityInfo.label}</div></td>
          <td data-label="Asunto"><div class="ticket-subject-cell"><span class="file-title" title="${ticket.subject}">${ticket.subject}</span></div></td>
          <td class="col-date-data" data-label="Fecha Enviado">${formatDate(ticket.createdAt)}</td>
          <td class="col-date-data ${ticket.status === 'resolved' ? 'resolved-date' : ''}" data-label="Fecha Resuelto">${ticket.status === 'resolved' && ticket.updatedAt ? formatDate(ticket.updatedAt) : '-'}</td>
          <td class="col-actions-data" data-label="Ver Ticket"><div class="td-actions"><a href="/dashboard/soporte/${ticket.id}" class="btn-details" title="Ver Ticket"><span class="material-symbols-outlined">visibility</span><span class="btn-text">Ver</span></a></div></td>
        </tr>`;
    }).join('');
  }

  function initSupport() {
    const ticketForm = document.getElementById('ticketForm') as HTMLFormElement;
    if (!ticketForm || ticketForm.dataset.initialized === 'true') {
      // Si ya está inicializado pero tenemos token, recargar datos
      if (currentToken) {
        loadProjects(currentToken);
        loadTickets(currentToken);
      }
      return;
    }
    
    ticketForm.dataset.initialized = 'true';
    const submitBtn = document.getElementById('submitTicketBtn') as HTMLButtonElement;
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const projectSelect = document.getElementById('projectSelect') as HTMLSelectElement;
    const subjectInput = document.getElementById('subject') as HTMLInputElement;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement;
    const prioritySelect = document.getElementById('priority') as HTMLSelectElement;
    const attachmentInput = document.getElementById('attachment') as HTMLInputElement;
    const fileNameLabel = document.getElementById('fileNameLabel');
    const projectNameInput = document.getElementById('projectName') as HTMLInputElement;
    const projectQuerySelect = document.getElementById('projectQuerySelect') as HTMLSelectElement;
    const feedback = document.getElementById('ticketFeedback') as HTMLDivElement;
    const toggleFormBtn = document.getElementById('toggleFormBtn');
    const closeFormBtn = document.getElementById('closeFormBtn');
    const cancelTicketBtn = document.getElementById('cancelTicketBtn');

    function validateForm() {
      if (!submitBtn) return;
      const isValid = !!projectSelect?.value && !!subjectInput?.value.trim() && !!messageInput?.value.trim() && !!prioritySelect?.value;
      submitBtn.disabled = !isValid;
      submitBtn.title = isValid ? 'Enviar Ticket' : 'Completa todos los campos obligatorios';
    }

    projectSelect?.addEventListener('change', () => {
      if (projectNameInput) {
        const selectedProject = allProjects.find(p => p.id === projectSelect.value);
        projectNameInput.value = selectedProject?.name || '';
      }
      validateForm();
    });

    [subjectInput, messageInput].forEach(el => el?.addEventListener('input', validateForm));
    prioritySelect?.addEventListener('change', validateForm);

    attachmentInput?.addEventListener('change', () => {
      const dropZone = document.getElementById('dropZone');
      if (fileNameLabel) {
        const hasFile = !!attachmentInput.files?.length;
        fileNameLabel.textContent = hasFile ? attachmentInput.files![0].name : 'Arrastra o selecciona una imagen';
        fileNameLabel.classList.toggle('file-selected', hasFile);
        if (dropZone) dropZone.classList.toggle('file-selected', hasFile);
      }
    });

    searchInput?.addEventListener('input', applyFilters);
    projectQuerySelect?.addEventListener('change', applyFilters);

    function closeForm() { 
      if ((window as any).formModalHelpers) (window as any).formModalHelpers.close('ticketModal');
      ticketForm?.reset(); 
      if(fileNameLabel) fileNameLabel.textContent = 'Arrastra o selecciona una imagen'; 
      validateForm(); 
      if(feedback) feedback.className = 'feedback-message hidden'; 
      const dropZone = document.getElementById('dropZone');
      if (dropZone) dropZone.classList.remove('file-selected');
    }

    toggleFormBtn?.addEventListener('click', () => {
      if ((window as any).formModalHelpers) (window as any).formModalHelpers.open('ticketModal');
    });
    closeFormBtn?.addEventListener('click', closeForm);
    cancelTicketBtn?.addEventListener('click', closeForm);

    ticketForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !feedback || !currentToken) return;
      setLoading(submitBtn, true);
      try {
        const res = await fetch(`${API_URL}/support/tickets`, { 
          method: 'POST', 
          headers: { 'Authorization': `Bearer ${currentToken}` }, 
          body: new FormData(ticketForm) 
        });
        if (!res.ok) throw new Error((await res.json()).message || 'Error creando ticket');
        
        closeForm();
        if ((window as any).modalHelpers) {
          (window as any).modalHelpers.openModal('successTicketModal');
        }
        
        await loadTickets(currentToken);
      } catch (error: any) { 
        showFeedback(feedback, error.message || 'Error de conexión', 'error'); 
      } finally { 
        setLoading(submitBtn, false); 
      }
    });

    if (currentToken) {
      loadProjects(currentToken);
      loadTickets(currentToken);
    }
  }

  function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
    btn.disabled = isLoading;
    btn.classList.toggle('btn-loading', isLoading);
  }

  function showFeedback(el: HTMLElement, message: string, type: 'error' | 'success') {
    el.textContent = message;
    el.className = `feedback-message ${type}`;
    setTimeout(() => { if (el) el.className = 'feedback-message hidden'; }, 5000);
  }

  onAuthStateChanged(auth, async (user) => {
    if (!user) return;
    currentToken = await user.getIdToken();
    initSupport();
  });

  document.addEventListener('astro:page-load', () => {
    initSupport();
  });
</script>
