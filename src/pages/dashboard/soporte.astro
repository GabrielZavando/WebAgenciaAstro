---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TicketTable from '../../components/shared/TicketTable.astro';
const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Soporte" role="client">
  <div class="support-page">
    <div id="listView">
      <div class="page-header">
        <div>
          <h1>Centro de Soporte</h1>
          <p class="text-muted">Solicita ayuda y revisa el estado de tus tickets.</p>
        </div>
      </div>

      <!-- Acciones principales -->
      <div class="actions-row">
        <div class="search-input-wrapper">
          <i class="fas fa-search search-icon"></i>
          <input type="text" id="searchInput" placeholder="Buscar por asunto del ticket..." autocomplete="off" />
        </div>
        <div class="filter-group">
          <i class="fas fa-filter filter-icon"></i>
          <select id="projectQuerySelect">
            <option value="">Todos los proyectos</option>
          </select>
        </div>
        <button class="btn-primary" id="toggleFormBtn">
          <i class="fas fa-plus"></i> Nuevo Ticket
        </button>
      </div>
    </div>

    <div class="content-card form-container hidden" id="formContainer">
      <div class="card-header">
        <h3><i class="fas fa-plus-circle"></i> Nuevo Ticket</h3>
        <button type="button" class="btn-close" id="closeFormBtn" aria-label="Cerrar"><i class="fas fa-times"></i></button>
      </div>
      <div class="card-body">
        <form id="ticketForm" class="ticket-form">
          <!-- 1. Proyecto -->
          <div class="form-group">
            <label for="projectSelect">Proyecto <span class="required">*</span></label>
            <div class="select-field-wrapper">
              <select id="projectSelect" name="projectId" required>
                <option value="" disabled selected>Selecciona un proyecto</option>
              </select>
              <i class="fas fa-chevron-down select-field-arrow"></i>
            </div>
            <input type="hidden" id="projectName" name="projectName" value="" />
          </div>

          <!-- 2. Asunto -->
          <div class="form-group">
            <label for="subject">Asunto <span class="required">*</span></label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="Describe brevemente tu problema"
              required
            />
          </div>

          <!-- 3. Mensaje -->
          <div class="form-group">
            <label for="message">Mensaje <span class="required">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Explica tu problema en detalle..."
              required
            ></textarea>
          </div>

          <!-- 4. Adjuntar Imagen y Prioridad -->
          <div class="form-group row-group">
            <div class="col-group">
              <label for="attachment">Adjuntar Imagen (Opcional)</label>
              <div class="file-upload-wrapper">
                <label for="attachment" class="file-upload-icon-btn" title="Adjuntar imagen">
                  <i class="fas fa-cloud-upload-alt"></i>
                  <span id="fileNameLabel">Seleccionar imagen</span>
                </label>
                <input 
                  type="file" 
                  id="attachment" 
                  name="attachment" 
                  accept="image/png, image/jpeg, image/webp" 
                  class="file-input-hidden" 
                />
              </div>
            </div>
            
            <div class="col-group">
              <label for="priority">Prioridad <span class="required">*</span></label>
              <div class="select-field-wrapper">
                <select id="priority" name="priority" required>
                  <option value="low">Baja</option>
                  <option value="medium" selected>Media</option>
                  <option value="high">Alta</option>
                </select>
                <i class="fas fa-chevron-down select-field-arrow"></i>
              </div>
            </div>
          </div>

          <p class="form-legend">(*) Campos obligatorios</p>

          <div id="ticketFeedback" class="feedback-message hidden"></div>

          <div class="form-actions">
            <button type="button" class="btn-secondary" id="cancelTicketBtn">Cancelar</button>
            <button type="submit" class="btn-primary" id="submitTicketBtn" disabled title="Completa todos los campos obligatorios">
              <span class="btn-text">Enviar Ticket</span>
              <span class="loader hidden"></span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <TicketTable role="client" id="ticketsListBody" />
  </div>
</DashboardLayout>

<script>
  import { auth } from "../../lib/firebase/client";
  import { onAuthStateChanged } from "firebase/auth";
  import { formatDate, getStatusInfo, getPriorityInfo, getRawDate } from "../../lib/support-utils";

  const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';

  const ticketForm = document.getElementById('ticketForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitTicketBtn') as HTMLButtonElement;
  const ticketsListBody = document.getElementById('ticketsListBody');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const projectSelect = document.getElementById('projectSelect') as HTMLSelectElement;
  const subjectInput = document.getElementById('subject') as HTMLInputElement;
  const messageInput = document.getElementById('message') as HTMLTextAreaElement;
  const prioritySelect = document.getElementById('priority') as HTMLSelectElement;
  const attachmentInput = document.getElementById('attachment') as HTMLInputElement;
  const fileNameLabel = document.getElementById('fileNameLabel');
  const projectNameInput = document.getElementById('projectName') as HTMLInputElement;
  const projectQuerySelect = document.getElementById('projectQuerySelect') as HTMLSelectElement;
  const feedback = document.getElementById('ticketFeedback') as HTMLDivElement;

  // Nodos UI
  const toggleFormBtn = document.getElementById('toggleFormBtn');
  const closeFormBtn = document.getElementById('closeFormBtn');
  const cancelTicketBtn = document.getElementById('cancelTicketBtn');
  const formContainer = document.getElementById('formContainer');
  const listView = document.getElementById('listView');

  interface Ticket {
    id: string;
    subject: string;
    priority: 'low' | 'medium' | 'high';
    status: 'open' | 'in-progress' | 'resolved';
    createdAt: { _seconds?: number } | string;
    updatedAt: { _seconds?: number } | string;
    projectId?: string;
  }

  interface Project {
    id: string;
    clientId: string;
    name: string;
    description?: string;
    monthlyTicketLimit?: number;
  }

  let allTickets: Ticket[] = [];
  let allProjects: Project[] = [];
  let currentToken = '';

  onAuthStateChanged(auth, async (user) => {
    if (!user) return;
    currentToken = await user.getIdToken();
    await Promise.all([
      loadProjects(currentToken),
      loadTickets(currentToken),
    ]);
  });

  async function loadTickets(token: string) {
    try {
      const res = await fetch(`${API_URL}/support/tickets/my`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) throw new Error();
      allTickets = await res.json();
      applyFilters(); // Renders the table
    } catch {
      if (ticketsListBody) {
        ticketsListBody.innerHTML = `<tr><td colspan="8"><div class="empty-state"><i class="fas fa-exclamation-triangle"></i><p>Error al cargar tickets.</p></div></td></tr>`;
      }
    }
  }

  async function loadProjects(token: string) {
    try {
      const res = await fetch(`${API_URL}/projects/my`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        allProjects = await res.json();
        populateProjectSelect();
      }
    } catch (e) {
      console.error('Error cargando proyectos', e);
    }
  }

  function populateProjectSelect() {
    if (!projectSelect) return;
    const defaultOption = '<option value="" disabled selected>Selecciona un proyecto</option>';
    const options = allProjects.map(p => `<option value="${p.id}">${p.name}</option>`);
    projectSelect.innerHTML = defaultOption + options.join('');

    // También poblar el filtro de consulta
    if (projectQuerySelect) {
      projectQuerySelect.innerHTML = '<option value="">Todos los proyectos</option>' + options.join('');
    }

    projectSelect.addEventListener('change', () => {
      if (projectNameInput) {
        if (projectSelect.value) {
          const selectedProject = allProjects.find(p => p.id === projectSelect.value);
          projectNameInput.value = selectedProject?.name || '';
        } else {
          projectNameInput.value = '';
        }
      }
      validateForm();
    });
  }

  // Validación de formulario
  function validateForm() {
    const isProjectValid = !!projectSelect.value;
    const isSubjectValid = !!subjectInput.value.trim();
    const isMessageValid = !!messageInput.value.trim();
    const isPriorityValid = !!prioritySelect.value;

    const isValid = isProjectValid && isSubjectValid && isMessageValid && isPriorityValid;
    
    if (submitBtn) {
      submitBtn.disabled = !isValid;
      submitBtn.title = isValid ? 'Enviar Ticket' : 'Completa todos los campos obligatorios';
    }
  }

  // Listeners para validación
  [subjectInput, messageInput].forEach(el => {
    el?.addEventListener('input', validateForm);
  });
  prioritySelect?.addEventListener('change', validateForm);

  // Manejo de archivo (Label icon)
  attachmentInput?.addEventListener('change', () => {
    if (fileNameLabel && attachmentInput.files && attachmentInput.files.length > 0) {
      fileNameLabel.textContent = attachmentInput.files[0].name;
      fileNameLabel.classList.add('file-selected');
    } else if (fileNameLabel) {
      fileNameLabel.textContent = 'Seleccionar imagen';
      fileNameLabel.classList.remove('file-selected');
    }
  });

  searchInput?.addEventListener('input', applyFilters);
  projectQuerySelect?.addEventListener('change', applyFilters);

  function applyFilters() {
    if (!ticketsListBody) return;
    
    const query = searchInput?.value.toLowerCase().trim() || '';
    const selectedProjectId = projectQuerySelect?.value || '';
    
    let filtered = [...allTickets];

    if (query) {
      filtered = filtered.filter(t => t.subject.toLowerCase().includes(query));
    }

    if (selectedProjectId) {
      filtered = filtered.filter(t => t.projectId === selectedProjectId);
    }

    renderTickets(filtered);
  }

  function openForm() {
    formContainer?.classList.remove('hidden');
    listView?.classList.add('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function closeForm() {
    formContainer?.classList.add('hidden');
    listView?.classList.remove('hidden');
    ticketForm?.reset();
    if(fileNameLabel) fileNameLabel.textContent = 'Seleccionar imagen';
    validateForm();
    if(feedback) feedback.className = 'feedback-message hidden';
  }

  toggleFormBtn?.addEventListener('click', openForm);
  closeFormBtn?.addEventListener('click', closeForm);
  cancelTicketBtn?.addEventListener('click', closeForm);

  function renderTickets(tickets: Ticket[]) {
    if (!ticketsListBody) return;

    if (tickets.length === 0) {
      ticketsListBody.innerHTML = `
        <tr>
      <td colspan="8">
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <h3>Sin resultados</h3>
          <p>No se encontraron tickets en tu historial o con la búsqueda actual.</p>
        </div>
      </td>
    </tr>`;
      return;
    }

    // Calcula cuotas consumidas este mes por cada proyecto
    const projectUsage: Record<string, number> = {};
    const now = new Date();
    const startOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
    
    allTickets.forEach(t => {
      const tDate = getRawDate(t.createdAt);
      if (tDate >= startOfMonth && t.projectId) {
        projectUsage[t.projectId] = (projectUsage[t.projectId] || 0) + 1;
      }
    });

    ticketsListBody.innerHTML = tickets.map(ticket => {
      const dateCreated = formatDate(ticket.createdAt);
      const dateResolved = ticket.status === 'resolved' && ticket.updatedAt ? formatDate(ticket.updatedAt) : '-';
      const statusInfo = getStatusInfo(ticket.status);
      const priorityInfo = getPriorityInfo(ticket.priority);

      const proj = ticket.projectId ? allProjects.find(p => p.id === ticket.projectId) : null;
      const limit = proj?.monthlyTicketLimit || 10;
      const used = ticket.projectId ? (projectUsage[ticket.projectId] || 0) : 0;
      
      const badgeHtml = proj ? `<span class="project-badge">${proj.name}</span>` : `<span class="project-badge" style="background:#e2e8f0;color:#64748b">S/P</span>`;
      const quotaHtml = proj ? `<strong>${used}</strong> de ${limit}` : '-';

      return `
        <tr>
          <td data-label="Proyecto">${badgeHtml}</td>
          <td style="text-align: center;" data-label="Tickets">${quotaHtml}</td>
          <td data-label="Estado">
            <span class="status-badge ${statusInfo.className}" title="${statusInfo.label}">
              <i class="${statusInfo.icon}"></i> ${statusInfo.label}
            </span>
          </td>
          <td data-label="Prioridad">
            <div class="priority-badge-wrapper" title="${priorityInfo.label}">
              <span class="priority-dot" style="background-color: ${priorityInfo.color}"></span> ${priorityInfo.label}
            </div>
          </td>
          <td data-label="Asunto">
            <div class="ticket-subject-cell"><span class="file-title" title="${ticket.subject}">${ticket.subject}</span></div>
          </td>
          <td class="col-date-data" data-label="Fecha Enviado">${dateCreated}</td>
          <td class="col-date-data ${ticket.status === 'resolved' ? 'resolved-date' : ''}" data-label="Fecha Resuelto">${dateResolved}</td>
          <td class="col-actions-data" data-label="Ver Ticket">
            <div class="td-actions">
              <a href="/dashboard/soporte/${ticket.id}" class="btn-action view-btn" title="Ver Ticket">
                <i class="fas fa-eye"></i> Ver
              </a>
            </div>
          </td>
        </tr>
      `;
    }).join('');
  }

  // Enviar nuevo ticket
  ticketForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !feedback || !currentToken) return;

    setLoading(submitBtn, true);

    try {
      const formData = new FormData(ticketForm);
      if (!formData.get('projectId')) {
        throw new Error('Debes seleccionar un proyecto válido');
      }

      const res = await fetch(`${API_URL}/support/tickets`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${currentToken}` },
        body: formData,
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.message || 'Error creando ticket');
      }

      showFeedback(feedback, 'Ticket creado exitosamente.', 'success');
      await loadTickets(currentToken);
      setTimeout(() => { closeForm(); }, 1500);
    } catch (error: unknown) {
      const msg = error instanceof Error ? error.message : 'Error de conexión';
      showFeedback(feedback, msg, 'error');
    } finally {
      setLoading(submitBtn, false);
    }
  });

  function setLoading(btn: HTMLButtonElement, isLoading: boolean) {
    const text = btn.querySelector('.btn-text');
    const loader = btn.querySelector('.loader');
    btn.disabled = isLoading;
    if (isLoading) {
      text?.classList.add('hidden');
      loader?.classList.remove('hidden');
    } else {
      text?.classList.remove('hidden');
      loader?.classList.add('hidden');
    }
  }

  function showFeedback(el: HTMLElement, message: string, type: 'error' | 'success') {
    el.textContent = message;
    el.className = `feedback-message ${type}`;
    setTimeout(() => { el.className = 'feedback-message hidden'; }, 5000);
  }
</script>

<style>
  .support-page { width: 100%; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin: 0 0 0.5rem; font-size: 2rem; font-weight: 700; color: var(--color-text); }
  .text-muted { color: var(--color-text-muted); margin: 0; font-size: 1.05rem; }

  /* Controles (Buscador y Subir) */
  .actions-row { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: stretch; justify-content: space-between; }
  .search-input-wrapper { flex: 1; max-width: 450px; position: relative; }
  .search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); }
  .search-input-wrapper input {
    width: 100%; padding: 0.875rem 1.2rem 0.875rem 3rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-surface); color: var(--color-text);
    font-family: inherit; font-size: 0.95rem; box-sizing: border-box; transition: all 0.2s; box-shadow: var(--shadow-sm);
  }
  .search-input-wrapper input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1); }

  .filter-group {
    position: relative;
    min-width: 220px;
  }
  .filter-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    pointer-events: none;
  }
  .filter-group select {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s;
    appearance: none;
  }
  .filter-group select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1);
  }
  .btn-primary {
    padding: 0 1.75rem; background: var(--color-primary); color: white; border: none;
    border-radius: var(--radius-md); font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 0.6rem; font-size: 0.95rem; white-space: nowrap; transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(var(--color-primary-rgb), 0.2);
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 6px 8px -1px rgba(var(--color-primary-rgb), 0.3); }

  /* Formulario Animado */
  .content-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 2rem; }
  .card-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; }
  .card-header h3 { margin: 0; font-size: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .card-header i { color: var(--color-primary); }
  .card-body { padding: 1.5rem; }
  .btn-close { background: none; border: none; color: var(--color-text-muted); font-size: 1.2rem; cursor: pointer; transition: color 0.2s; padding: 0.2rem; }
  .btn-close:hover { color: var(--color-error); }
  
  .form-container { transition: all 0.3s ease-in-out; opacity: 1; transform: translateY(0); }
  .form-container.hidden { display: none !important; opacity: 0; transform: translateY(-10px); }

  .ticket-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group label { font-weight: 500; font-size: 0.9rem; color: var(--color-text); }
  .required { color: #ef4444; margin-left: 0.2rem; }
  .form-legend { font-size: 0.8rem; color: var(--color-text-muted); margin-top: -0.5rem; }
  
  /* Select wrapper para flecha */
  .select-field-wrapper {
    position: relative;
    width: 100%;
  }
  .select-field-arrow {
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    pointer-events: none;
  }
  
  .ticket-form input, .ticket-form textarea, .ticket-form select {
    padding: 0.875rem 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-background); color: var(--color-text); font-family: inherit; font-size: 0.95rem; transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .ticket-form select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    padding-right: 3rem;
  }
  .ticket-form input:focus, .ticket-form textarea:focus, .ticket-form select:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb), 0.1); }
  .ticket-form textarea { resize: vertical; min-height: 120px; }

  /* Grid layouts */
  .row-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  
  /* Diseño de Adjunto (Icono) */
  .file-upload-wrapper {
    position: relative;
    width: 100%;
  }
  .file-input-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }
  .file-upload-icon-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .file-upload-icon-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(var(--color-primary-rgb), 0.05);
  }
  .file-upload-icon-btn i {
    font-size: 1.25rem;
  }
  .file-selected {
    color: var(--color-primary);
    font-weight: 600;
  }

  .form-actions { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem; }
  .btn-secondary { padding: 0.875rem 1.5rem; border-radius: var(--radius-md); font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.9rem; transition: all 0.2s; background: transparent; color: var(--color-text); border: 1px solid var(--color-border); }
  .btn-secondary:hover { background: var(--color-background); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

  .feedback-message { padding: 0.875rem; border-radius: var(--radius-md); text-align: center; font-weight: 500; font-size: 0.95rem; margin-top: 1rem; }
  .feedback-message.error { background: rgba(var(--color-error-rgb),0.1); color: var(--color-error); border: 1px solid rgba(var(--color-error-rgb),0.2); }
  .feedback-message.success { background: rgba(34,197,94,0.1); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
  .hidden { display: none !important; }
  .loader { width: 18px; height: 18px; border: 2px solid #fff; border-bottom-color: transparent; border-radius: 50%; display: inline-block; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  @media (max-width: 600px) {
    .page-header { flex-direction: column; align-items: flex-start; }
    .row-group { grid-template-columns: 1fr; }
  }
</style>
