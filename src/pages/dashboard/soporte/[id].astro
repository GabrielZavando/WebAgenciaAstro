---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ModalMessage from '../../../components/shared/ModalMessage.astro';
import TicketDetailView from '../../../components/support/TicketDetailView.astro';
import type { TicketResponseDto } from '../../../types/api';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const { id } = Astro.params;

let ticket: TicketResponseDto | null = null;
let errorMsg = null;

try {
  const response = await fetch(`${API_URL}/support/tickets/${id}`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    ticket = await response.json();
  } else {
    errorMsg = `Error al cargar datos del ticket: ${response.statusText}`;
    if (response.status === 404 || response.status === 403) {
      errorMsg = "No se encontró el ticket solicitado o no tienes permisos para verlo.";
    }
  }
} catch (e) {
  errorMsg = "No se pudo conectar con el servidor.";
  console.error("Error fetching ticket data:", e);
}

if (!ticket && !errorMsg) {
  errorMsg = "Ticket no encontrado.";
}

// Format the date properly
function formatFullDate(raw: { _seconds?: number } | string): string {
  let d: Date;
  if (typeof raw === 'string') d = new Date(raw);
  else if (raw && raw._seconds) d = new Date(raw._seconds * 1000);
  else return '-';

  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()} a las ${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
}

const getStatusInfo = (status: string) => {
  const map: Record<string, { label: string; className: string; icon: string }> = {
    open: { label: 'Enviado', className: 'status-open', icon: 'send' },
    'in-progress': { label: 'En progreso', className: 'status-progress', icon: 'schedule' },
    resolved: { label: 'Resuelto', className: 'status-resolved', icon: 'check' },
  };
  return map[status] || map.open;
};

const getPriorityInfo = (priority: string) => {
  const map: Record<string, { label: string; color: string }> = {
    low: { label: 'Baja', color: '#22c55e' },
    medium: { label: 'Media', color: '#f59e0b' },
    high: { label: 'Alta', color: '#ef4444' },
  };
  return map[priority] || map.medium;
};

let statusInfo = null;
let priorityInfo = null;
if (ticket) {
  statusInfo = getStatusInfo(ticket.status);
  priorityInfo = getPriorityInfo(ticket.priority);
}
---

<DashboardLayout title="Ver Ticket" breadcrumbs={[{ label: 'Dashboard', href: '/dashboard' }, { label: 'Soporte', href: '/dashboard/soporte' }, { label: 'Detalle' }]} role="client">
  <div class="header-actions">
    <div>
        <a href="/dashboard/soporte" class="back-link">
          <span class="material-symbols-outlined">arrow_back</span> Volver a Mis Tickets
        </a>
      {ticket && <h1>Asunto: {ticket.subject}</h1>}
    </div>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <span class="material-symbols-outlined">report</span> {errorMsg}
    </div>
  )}

  {!errorMsg && ticket && (
    <TicketDetailView ticket={ticket} role="client" />
  )}

  <Fragment slot="modals">
    <ModalMessage 
      id="ticketResponseErrorModal"
      type="error"
      title="Error"
      message="Ocurrió un error."
    />
  </Fragment>
</DashboardLayout>

<script>
  // El componente TicketDetailView ya maneja toda la lógica de mensajes y comunicación.
  // Aquí solo mantenemos lógica específica de la página del dashboard si fuera necesaria.
</script>

<style is:global>
  .header-actions {
    margin-bottom: 1.5rem;
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--color-primary);
  }

  .header-actions h1 {
    margin: 0;
    font-size: 1.75rem;
    color: var(--color-text);
  }

  .error-banner {
    background: rgba(var(--color-error-rgb), 0.1);
    color: var(--color-error);
    padding: 1rem;
    border-radius: 0;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-left: 4px solid var(--color-error);
  }

  .ticket-details-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Tarjeta de Metadatos */
  .ticket-meta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .meta-value {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }
  .ticket-id {
    font-family: monospace;
    background: rgba(150, 150, 150, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 0;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  /* Badges y estados */
  .status-badge {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
  }
  .status-open { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .status-progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .status-resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

  .priority-badge-wrapper {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.95rem; font-weight: 500; color: var(--color-text); text-transform: capitalize;
  }
  .priority-dot { width: 12px; height: 12px; border-radius: 0; display: inline-block; }

  .resolved-date { color: #22c55e; font-weight: 600; }

  .resolved-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 0;
    color: #22c55e;
    font-size: 0.95rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

  .feedback-message {
    padding: 0.75rem 1rem;
    border-radius: 0;
    text-align: center;
    font-weight: 500;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }
  .feedback-message.error { background: rgba(var(--color-error-rgb), 0.1); color: var(--color-error); }
  .feedback-message.success { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
  .hidden { display: none !important; }

  .loader {
    width: 16px; height: 16px;
    border: 2px solid #fff;
    border-bottom-color: transparent;
    border-radius: 50%;
    display: inline-block;
    animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  textarea {
    width: 100%;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-background);
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s;
    resize: vertical;
    box-sizing: border-box;
  }
  textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1);
  }

  /* Conversacion */
  .conversation {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border: 2px solid var(--color-border);
    padding: 1.5rem;
  }

  .message {
    padding: 1.5rem;
    border-radius: 0;
    background: var(--color-background);
  }
  .message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
  }
  .client-avatar { background: var(--color-text-muted); }
  .admin-avatar { background: var(--color-primary); }

  .name-time {
    display: flex;
    flex-direction: column;
  }
  .name-time strong {
    color: var(--color-text);
    font-size: 1rem;
  }
  .name-time .time {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .message-body {
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: var(--color-text);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .message-body p {
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .message-body p:last-child {
    margin-bottom: 0;
  }

  .attachment-container {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }


  .client-message {
    background: rgba(59, 130, 246, 0.1) !important;
    border: 1px solid rgba(59, 130, 246, 0.2) !important;
    align-self: flex-end !important;
    width: 50% !important;
  }

  .admin-message {
    border: 1px solid var(--color-border) !important;
    align-self: flex-start !important;
    width: 50% !important;
    background: rgba(var(--color-neutral-rgb), 0.05) !important;
  }
  
  html[data-theme="dark"] .admin-message {
    background: rgba(255, 255, 255, 0.03) !important;
  }

  .message.admin-message.focus-message,
  .message.client-message.reply-area {
    width: 100% !important;
    align-self: stretch !important;
    background: var(--color-surface) !important;
    border: 2px solid var(--color-primary) !important;
  }

  .avatar-wrapper {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .msg-avatar-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    display: block;
  }

  .msg-avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
  }
  .msg-avatar-placeholder.client { background: #ccc; }
  .msg-avatar-placeholder.admin { background: var(--color-primary); }

  .meta-avatar-img {
    width: 24px !important;
    height: 24px !important;
    object-fit: cover;
    margin-right: 0.5rem;
    display: block;
  }

  .message-header {
    border-bottom: none !important;
    padding-bottom: 0.5rem !important;
  }
  
  /* Forzar diseño flat absoluto */
  * {
    border-radius: 0 !important;
  }

  .reply-area {
    border: 1px solid var(--color-border);
    background: var(--color-background);
    align-self: flex-start;
    width: 50%;
  }
  .message-body p:last-child {
    margin-bottom: 0;
  }

  .attachment-container {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }
  .attachment-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem !important;
  }
  .attachment-label i {
    margin-right: 0.4rem;
  }
  .ticket-attachment-img {
    max-width: 100%;
    max-height: 400px;
    border-radius: 0;
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .ticket-attachment-img:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-md);
  }

  /* Distingue mensaje de admin */
  .admin-message {
    border: 1px solid var(--color-border);
    align-self: flex-end;
    width: 50%;
    border-radius: 0;
    border-top-right-radius: 0;
    background: #f8fafc;
  }

  .waiting-response {
    margin-left: 2rem;
    padding: 2rem;
    text-align: center;
    background: rgba(var(--color-primary-rgb), 0.03);
    border: 1px dashed var(--color-border);
    border-radius: 0;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .loader-pulse {
    width: 12px;
    height: 12px;
    background-color: var(--color-primary);
    border-radius: 0;
    animation: pulse 1.5s infinite ease-in-out;
  }

  @keyframes pulse {
    0% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb), 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(var(--color-primary-rgb), 0); }
    100% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb), 0); }
  }

  .attachment-input-wrapper {
    margin-top: 1rem;
  }

  .attachment-label-btn {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-surface-secondary);
    padding: 0.75rem 1rem;
    border: 2px dashed var(--color-border);
    width: 100%;
    box-sizing: border-box;
    transition: all 0.25s ease;
  }

  .attachment-label-btn:hover {
    border-color: var(--color-primary);
    background: rgba(var(--color-primary-rgb), 0.04);
    color: var(--color-primary);
  }

  .attachment-label-btn:hover .material-symbols-outlined {
    transform: translateY(-2px);
  }

  .attachment-label-btn .material-symbols-outlined {
    font-size: 1.25rem;
    transition: transform 0.2s ease;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .ticket-meta-card {
      flex-direction: column;
      gap: 1.25rem;
    }
    .admin-message, .waiting-response {
      margin-left: 0; /* Full width en movil */
    }
  }
</style>
