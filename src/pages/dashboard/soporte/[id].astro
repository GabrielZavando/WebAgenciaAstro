---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const { id } = Astro.params;

let ticket = null;
let errorMsg = null;

try {
  const response = await fetch(`${API_URL}/support/tickets/${id}`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    ticket = await response.json();
  } else {
    errorMsg = `Error al cargar datos del ticket: ${response.statusText}`;
    if (response.status === 404 || response.status === 403) {
      errorMsg = "No se encontró el ticket solicitado o no tienes permisos para verlo.";
    }
  }
} catch (e) {
  errorMsg = "No se pudo conectar con el servidor.";
  console.error("Error fetching ticket data:", e);
}

if (!ticket && !errorMsg) {
  errorMsg = "Ticket no encontrado.";
}

// Format the date properly
function formatFullDate(raw: { _seconds?: number } | string): string {
  let d: Date;
  if (typeof raw === 'string') d = new Date(raw);
  else if (raw && raw._seconds) d = new Date(raw._seconds * 1000);
  else return '-';

  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()} a las ${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
}

const getStatusInfo = (status: string) => {
  const map: Record<string, { label: string; className: string; icon: string }> = {
    open: { label: 'Enviado', className: 'status-open', icon: 'fas fa-paper-plane' },
    'in-progress': { label: 'En progreso', className: 'status-progress', icon: 'fas fa-hourglass-half' },
    resolved: { label: 'Resuelto', className: 'status-resolved', icon: 'fas fa-check' },
  };
  return map[status] || map.open;
};

const getPriorityInfo = (priority: string) => {
  const map: Record<string, { label: string; color: string }> = {
    low: { label: 'Baja', color: '#22c55e' },
    medium: { label: 'Media', color: '#f59e0b' },
    high: { label: 'Alta', color: '#ef4444' },
  };
  return map[priority] || map.medium;
};

let statusInfo = null;
let priorityInfo = null;
if (ticket) {
  statusInfo = getStatusInfo(ticket.status);
  priorityInfo = getPriorityInfo(ticket.priority);
}
---

<DashboardLayout title="Ver Ticket" role="client">
  <div class="header-actions">
    <div>
      <a href="/dashboard/soporte" class="back-link">
        <i class="fas fa-arrow-left"></i> Volver a Mis Tickets
      </a>
      {ticket && <h1>Asunto: {ticket.subject}</h1>}
    </div>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <i class="fas fa-exclamation-triangle"></i> {errorMsg}
    </div>
  )}

  {!errorMsg && ticket && (
    <div class="ticket-details-container fade-in">
      <div class="ticket-meta-card">
        <div class="meta-item">
          <span class="meta-label">ID Ticket</span>
          <span class="meta-value ticket-id">#{ticket.id.slice(0, 8).toUpperCase()}</span>
        </div>
        {ticket.projectName && (
          <div class="meta-item">
            <span class="meta-label">Proyecto</span>
            <span class="meta-value">{ticket.projectName}</span>
          </div>
        )}
        <div class="meta-item">
          <span class="meta-label">Estado</span>
          <span class={`status-badge ${statusInfo?.className}`}>
            <i class={statusInfo?.icon}></i> {statusInfo?.label}
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Prioridad</span>
          <div class="priority-badge-wrapper">
            <span class="priority-dot" style={`background-color: ${priorityInfo?.color}`}></span>
            {priorityInfo?.label}
          </div>
        </div>
        <div class="meta-item">
          <span class="meta-label">Fecha de Envío</span>
          <span class="meta-value"><i class="far fa-calendar-alt"></i> {formatFullDate(ticket.createdAt)}</span>
        </div>
        {ticket.status === 'resolved' && (
          <div class="meta-item resolved-meta">
            <span class="meta-label">Resuelto el</span>
            <span class="meta-value resolved-date"><i class="fas fa-check-double"></i> {formatFullDate(ticket.updatedAt)}</span>
          </div>
        )}
      </div>

      <div class="conversation" id="conversationBox">
        <!-- Mensaje inicial del cliente -->
        <div class="message client-message">
          <div class="message-header">
            <div class="user-info">
              <div class="avatar-wrapper">
                {ticket.clientPhotoUrl ? (
                  <img src={ticket.clientPhotoUrl} alt="Avatar" class="msg-avatar-img" />
                ) : (
                  <div class="msg-avatar-placeholder client"></div>
                )}
              </div>
              <div class="name-time">
                <strong>Tú (Cliente)</strong>
                <span class="time">{formatFullDate(ticket.createdAt)}</span>
              </div>
            </div>
          </div>
          <div class="message-body">
            {ticket.message.split('\n').map((line: string) => (<p>{line}</p>))}
            {ticket.attachmentUrl && (
              <div class="attachment-container">
                <hr class="attachment-divider" />
                <p class="attachment-label"><i class="fas fa-paperclip"></i> Archivo Adjunto</p>
                <a href={ticket.attachmentUrl} target="_blank" rel="noopener noreferrer" class="attachment-link">
                  <img src={ticket.attachmentUrl} alt="Adjunto" class="ticket-attachment-img" />
                </a>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Banner de ticket resuelto -->
      {ticket.status === 'resolved' && (
        <div class="resolved-banner">
          <i class="fas fa-check-circle"></i>
          <span>Este ticket está <strong>resuelto</strong>. Ya no se pueden enviar más mensajes.</span>
        </div>
      )}

      <!-- Formulario de respuesta del cliente (solo si no está resuelto) -->
      {ticket.status !== 'resolved' && (
        <div class="message client-message reply-area" id="replyArea">
          <div class="message-header">
            <div class="user-info">
              <div class="avatar-wrapper">
                <div class="msg-avatar-placeholder client" id="replyAvatarContainer"></div>
              </div>
              <div class="name-time"><strong>Responder al Equipo de Soporte</strong></div>
            </div>
          </div>
          <div class="message-body">
            <form id="clientReplyForm" data-id={ticket.id}>
              <textarea name="body" placeholder="Escribe tu mensaje para el equipo de soporte..." rows="4" required></textarea>
              <div class="attachment-input-wrapper" style="margin-top: 0.5rem;">
                <label for="clientAttachment" style="font-size: 0.85rem; color: var(--color-text-muted); cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-surface); padding: 0.5rem; border: 1px dashed var(--color-border); width: 100%; box-sizing: border-box;">
                  <i class="fas fa-image"></i>
                  <span>Adjuntar imagen (opcional)</span>
                  <input type="file" id="clientAttachment" name="attachment" accept="image/*" style="display: none;" onchange="this.previousElementSibling.textContent = this.files[0]?.name || 'Adjuntar imagen (opcional)'" />
                </label>
              </div>
              <div style="display: flex; justify-content: flex-end; margin-top: 0.75rem;">
                <button type="submit" class="btn-primary">
                  <span class="btn-text"><i class="fas fa-paper-plane"></i> Enviar Mensaje</span>
                  <span class="loader hidden"></span>
                </button>
              </div>
              <div class="feedback-message hidden" id="replyFeedback"></div>
            </form>
          </div>
        </div>
      )}
    </div>
  )}
</DashboardLayout>

<script>
  import { auth } from '../../../lib/firebase/client';
  import { onAuthStateChanged } from 'firebase/auth';

  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
  const ticketId = window.location.pathname.split('/').pop()!;
  let token = '';

  function fmtDate(raw: any): string {
    if (!raw) return '';
    const d = raw._seconds ? new Date(raw._seconds * 1000) : new Date(raw);
    if (isNaN(d.getTime())) return '';
    const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
    return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()} ${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}`;
  }

  function renderMessages(messages: any[]) {
    const box = document.getElementById('conversationBox')!;
    if (!messages.length) return;
    
    // Mantener el primer mensaje (el del servidor) y limpiar el resto
    const initialMsg = box.firstElementChild;
    box.innerHTML = '';
    if (initialMsg) box.appendChild(initialMsg);
    
    const clientPhotoUrl = document.querySelector('.client-message .msg-avatar-img')?.getAttribute('src') || '';
    
    messages.forEach(m => {
      const isAdmin = m.senderRole === 'admin';
      
      let avatarHtml = '';
      if (m.senderPhotoUrl) {
        avatarHtml = `<img src="${m.senderPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
      } else if (!isAdmin && clientPhotoUrl) {
        avatarHtml = `<img src="${clientPhotoUrl}" alt="Avatar" class="msg-avatar-img" />`;
      } else if (!isAdmin) {
        avatarHtml = `<div class="msg-avatar-placeholder client"></div>`;
      } else {
        avatarHtml = `<div class="msg-avatar-placeholder admin"><i class="fas fa-headset"></i></div>`;
      }
      
      const msgDiv = document.createElement('div');
      msgDiv.className = `message ${isAdmin ? 'admin-message' : 'client-message'}`;
      msgDiv.innerHTML = `
          <div class="message-header">
            <div class="user-info">
              <div class="avatar-wrapper">
                ${avatarHtml}
              </div>
              <div class="name-time">
                <strong>${isAdmin ? 'Equipo de Soporte' : 'Tú'}</strong>
                <span class="time">${fmtDate(m.createdAt)}</span>
              </div>
            </div>
          </div>
          <div class="message-body">
            ${m.body.split('\n').map((l: string) => `<p>${l}</p>`).join('')}
            ${m.attachmentUrl ? `
              <div class="attachment-container">
                <p class="attachment-label"><i class="fas fa-paperclip"></i> Archivo Adjunto</p>
                <a href="${m.attachmentUrl}" target="_blank" rel="noopener noreferrer">
                  <img src="${m.attachmentUrl}" alt="Adjunto" class="ticket-attachment-img" />
                </a>
              </div>` : ''}
          </div>`;
      box.appendChild(msgDiv);
    });
  }

  async function loadMessages() {
    if (!token) return;
    try {
      const res = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) renderMessages(await res.json());
    } catch {}
  }

  const form = document.getElementById('clientReplyForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const feedback = document.getElementById('replyFeedback') as HTMLElement;
      const bodyEl = form.querySelector<HTMLTextAreaElement>('[name="body"]')!;
      const body = bodyEl.value.trim();
      if (!body) return;

      submitBtn.disabled = true;
      submitBtn.querySelector('.btn-text')?.classList.add('hidden');
      submitBtn.querySelector('.loader')?.classList.remove('hidden');

      try {
        const formData = new FormData();
        formData.append('body', body);
        formData.append('senderRole', 'client');
        if (auth.currentUser?.photoURL) {
          formData.append('senderPhotoUrl', auth.currentUser.photoURL);
        }
        const fileInput = form.querySelector<HTMLInputElement>('[name="attachment"]');
        if (fileInput?.files?.[0]) {
          formData.append('attachment', fileInput.files[0]);
        }

        const res = await fetch(`${API_URL}/support/tickets/${ticketId}/messages`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: formData
        });
        if (!res.ok) throw new Error('Error al enviar el mensaje');
        bodyEl.value = '';
        if (fileInput) fileInput.value = '';
        const fileLabel = form.querySelector('.attachment-input-wrapper span');
        if (fileLabel) fileLabel.textContent = 'Adjuntar imagen (opcional)';
        
        feedback.textContent = 'Mensaje enviado correctamente.';
        feedback.className = 'feedback-message success';
        await loadMessages();
      } catch (err: any) {
        feedback.textContent = err.message || 'Error al enviar';
        feedback.className = 'feedback-message error';
        setTimeout(() => { feedback.className = 'feedback-message hidden'; }, 4000);
      } finally {
        submitBtn.disabled = false;
        submitBtn.querySelector('.btn-text')?.classList.remove('hidden');
        submitBtn.querySelector('.loader')?.classList.add('hidden');
      }
    });
  }

  onAuthStateChanged(auth, async (user) => {
    if (user) {
      token = await user.getIdToken();
      
      // Actualizar avatar en el área de respuesta
      const replyAvatarContainer = document.getElementById('replyAvatarContainer');
      if (replyAvatarContainer) {
        if (user.photoURL) {
          replyAvatarContainer.innerHTML = `<img src="${user.photoURL}" alt="Avatar" class="msg-avatar-img" />`;
        } else {
          replyAvatarContainer.innerHTML = `<div class="msg-avatar-placeholder client"></div>`;
        }
      }

      await loadMessages();
    }
  });
</script>

<style is:global>
  .header-actions {
    margin-bottom: 1.5rem;
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--color-primary);
  }

  .header-actions h1 {
    margin: 0;
    font-size: 1.75rem;
    color: var(--color-text);
  }

  .error-banner {
    background: rgba(var(--color-error-rgb), 0.1);
    color: var(--color-error);
    padding: 1rem;
    border-radius: 0;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-left: 4px solid var(--color-error);
  }

  .ticket-details-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Tarjeta de Metadatos */
  .ticket-meta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .meta-value {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }
  .ticket-id {
    font-family: monospace;
    background: rgba(150, 150, 150, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 0;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  /* Badges y estados */
  .status-badge {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
  }
  .status-open { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .status-progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .status-resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

  .priority-badge-wrapper {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.95rem; font-weight: 500; color: var(--color-text); text-transform: capitalize;
  }
  .priority-dot { width: 12px; height: 12px; border-radius: 0; display: inline-block; }

  .resolved-date { color: #22c55e; font-weight: 600; }

  .resolved-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 0;
    color: #22c55e;
    font-size: 0.95rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

  .feedback-message {
    padding: 0.75rem 1rem;
    border-radius: 0;
    text-align: center;
    font-weight: 500;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }
  .feedback-message.error { background: rgba(var(--color-error-rgb), 0.1); color: var(--color-error); }
  .feedback-message.success { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
  .hidden { display: none !important; }

  .loader {
    width: 16px; height: 16px;
    border: 2px solid #fff;
    border-bottom-color: transparent;
    border-radius: 0;
    display: inline-block;
    animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  textarea {
    width: 100%;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-background);
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s;
    resize: vertical;
    box-sizing: border-box;
  }
  textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(var(--color-primary-rgb), 0.1);
  }

  /* Conversacion */
  .conversation {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border: 2px solid var(--color-border);
    padding: 1.5rem;
  }

  .message {
    padding: 1.5rem;
    border-radius: 0;
    background: var(--color-background);
  }
  .message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
  }
  .client-avatar { background: var(--color-text-muted); }
  .admin-avatar { background: var(--color-primary); }

  .name-time {
    display: flex;
    flex-direction: column;
  }
  .name-time strong {
    color: var(--color-text);
    font-size: 1rem;
  }
  .name-time .time {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .message-body {
    padding: 0 1.5rem 1.5rem 1.5rem;
    color: var(--color-text);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .message-body p {
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .message-body p:last-child {
    margin-bottom: 0;
  }

  .attachment-container {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }


  .client-message {
    background: rgba(59, 130, 246, 0.1) !important;
    border: 1px solid rgba(59, 130, 246, 0.2) !important;
    align-self: flex-end !important;
    width: 50% !important;
  }

  .admin-message {
    border: 1px solid var(--color-border) !important;
    align-self: flex-start !important;
    width: 50% !important;
    background: rgba(var(--color-neutral-rgb), 0.05) !important;
  }
  
  html[data-theme="dark"] .admin-message {
    background: rgba(255, 255, 255, 0.03) !important;
  }

  .message.admin-message.focus-message,
  .message.client-message.reply-area {
    width: 100% !important;
    align-self: stretch !important;
    background: var(--color-surface) !important;
    border: 2px solid var(--color-primary) !important;
  }

  .avatar-wrapper {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .msg-avatar-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    display: block;
  }

  .msg-avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
  }
  .msg-avatar-placeholder.client { background: #ccc; }
  .msg-avatar-placeholder.admin { background: var(--color-primary); }

  .meta-avatar-img {
    width: 24px !important;
    height: 24px !important;
    object-fit: cover;
    margin-right: 0.5rem;
    display: block;
  }

  .message-header {
    border-bottom: none !important;
    padding-bottom: 0.5rem !important;
  }
  
  /* Forzar diseño flat absoluto */
  * {
    border-radius: 0 !important;
  }

  .reply-area {
    border: 1px solid var(--color-border);
    background: var(--color-background);
    align-self: flex-start;
    width: 50%;
  }
  .message-body p:last-child {
    margin-bottom: 0;
  }

  .attachment-container {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }
  .attachment-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem !important;
  }
  .attachment-label i {
    margin-right: 0.4rem;
  }
  .ticket-attachment-img {
    max-width: 100%;
    max-height: 400px;
    border-radius: 0;
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .ticket-attachment-img:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-md);
  }

  /* Distingue mensaje de admin */
  .admin-message {
    border: 1px solid var(--color-border);
    align-self: flex-end;
    width: 50%;
    border-radius: 0;
    border-top-right-radius: 0;
    background: #f8fafc;
  }

  .waiting-response {
    margin-left: 2rem;
    padding: 2rem;
    text-align: center;
    background: rgba(var(--color-primary-rgb), 0.03);
    border: 1px dashed var(--color-border);
