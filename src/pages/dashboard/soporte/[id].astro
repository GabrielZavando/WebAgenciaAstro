---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const token = Astro.cookies.get('session')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const { id } = Astro.params;

let ticket = null;
let errorMsg = null;

try {
  const response = await fetch(`${API_URL}/support/tickets/${id}`, {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  if (response.ok) {
    ticket = await response.json();
  } else {
    errorMsg = `Error al cargar datos del ticket: ${response.statusText}`;
    if (response.status === 404 || response.status === 403) {
      errorMsg = "No se encontró el ticket solicitado o no tienes permisos para verlo.";
    }
  }
} catch (e) {
  errorMsg = "No se pudo conectar con el servidor.";
  console.error("Error fetching ticket data:", e);
}

if (!ticket && !errorMsg) {
  errorMsg = "Ticket no encontrado.";
}

// Format the date properly
function formatFullDate(raw: { _seconds?: number } | string): string {
  let d: Date;
  if (typeof raw === 'string') d = new Date(raw);
  else if (raw && raw._seconds) d = new Date(raw._seconds * 1000);
  else return '-';

  const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
  return `${d.getDate()} de ${months[d.getMonth()]} de ${d.getFullYear()} a las ${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
}

const getStatusInfo = (status: string) => {
  const map: Record<string, { label: string; className: string; icon: string }> = {
    open: { label: 'Enviado', className: 'status-open', icon: 'fas fa-paper-plane' },
    'in-progress': { label: 'En progreso', className: 'status-progress', icon: 'fas fa-hourglass-half' },
    resolved: { label: 'Resuelto', className: 'status-resolved', icon: 'fas fa-check-circle' },
  };
  return map[status] || map.open;
};

const getPriorityInfo = (priority: string) => {
  const map: Record<string, { label: string; color: string }> = {
    low: { label: 'Baja', color: '#22c55e' },
    medium: { label: 'Media', color: '#f59e0b' },
    high: { label: 'Alta', color: '#ef4444' },
  };
  return map[priority] || map.medium;
};

let statusInfo = null;
let priorityInfo = null;
if (ticket) {
  statusInfo = getStatusInfo(ticket.status);
  priorityInfo = getPriorityInfo(ticket.priority);
}
---

<DashboardLayout title="Ver Ticket" role="client">
  <div class="header-actions">
    <div>
      <a href="/dashboard/soporte" class="back-link">
        <i class="fas fa-arrow-left"></i> Volver a Mis Tickets
      </a>
      {ticket && <h1>Asunto: {ticket.subject}</h1>}
    </div>
  </div>

  {errorMsg && (
    <div class="error-banner">
      <i class="fas fa-exclamation-triangle"></i> {errorMsg}
    </div>
  )}

  {!errorMsg && ticket && (
    <div class="ticket-details-container fade-in">
      <div class="ticket-meta-card">
        <div class="meta-item">
          <span class="meta-label">ID Ticket</span>
          <span class="meta-value ticket-id">#{ticket.id.slice(0, 8).toUpperCase()}</span>
        </div>
        {ticket.projectName && (
          <div class="meta-item">
            <span class="meta-label">Proyecto</span>
            <span class="meta-value"><i class="fas fa-folder" style="color: var(--color-text-muted); margin-right: 0.25rem;"></i> {ticket.projectName}</span>
          </div>
        )}
        <div class="meta-item">
          <span class="meta-label">Estado</span>
          <span class={`status-badge ${statusInfo?.className}`}>
            <i class={statusInfo?.icon}></i> {statusInfo?.label}
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Prioridad</span>
          <div class="priority-badge-wrapper">
            <span class="priority-dot" style={`background-color: ${priorityInfo?.color}`}></span>
            {priorityInfo?.label}
          </div>
        </div>
        <div class="meta-item">
          <span class="meta-label">Fecha de Envío</span>
          <span class="meta-value"><i class="far fa-calendar-alt"></i> {formatFullDate(ticket.createdAt)}</span>
        </div>
        {ticket.status === 'resolved' && (
          <div class="meta-item resolved-meta">
            <span class="meta-label">Resuelto el</span>
            <span class="meta-value resolved-date"><i class="fas fa-check-double"></i> {formatFullDate(ticket.updatedAt)}</span>
          </div>
        )}
      </div>

      <div class="conversation">
        <!-- Client initial message -->
        <div class="message client-message">
          <div class="message-header">
            <div class="user-info">
              <div class="avatar client-avatar">
                <i class="fas fa-user"></i>
              </div>
              <div class="name-time">
                <strong>Tú (Cliente)</strong>
                <span class="time">{formatFullDate(ticket.createdAt)}</span>
              </div>
            </div>
          </div>
          <div class="message-body">
            {ticket.message.split('\n').map((line: string) => (
              <p>{line}</p>
            ))}
            
            {ticket.attachmentUrl && (
              <div class="attachment-container">
                <hr class="attachment-divider" />
                <p class="attachment-label"><i class="fas fa-paperclip"></i> Archivo Adjunto</p>
                <a href={ticket.attachmentUrl} target="_blank" rel="noopener noreferrer" class="attachment-link">
                  <img src={ticket.attachmentUrl} alt="Adjunto del ticket" class="ticket-attachment-img" />
                </a>
              </div>
            )}
          </div>
        </div>

        <!-- Admin Response (if any) -->
        {ticket.adminResponse ? (
          <div class="message admin-message">
            <div class="message-header">
              <div class="user-info">
                <div class="avatar admin-avatar">
                  <i class="fas fa-headset"></i>
                </div>
                <div class="name-time">
                  <strong>Equipo de Soporte</strong>
                  <span class="time">{formatFullDate(ticket.updatedAt)}</span>
                </div>
              </div>
            </div>
            <div class="message-body">
              {ticket.adminResponse.split('\n').map((line: string) => (
                <p>{line}</p>
              ))}
            </div>
          </div>
        ) : (
          <div class="waiting-response">
            <div class="loader-pulse"></div>
            <p>El equipo de soporte está revisando tu caso. Recibirás una respuesta pronto.</p>
          </div>
        )}
      </div>
    </div>
  )}
</DashboardLayout>

<style>
  .header-actions {
    margin-bottom: 1.5rem;
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--color-primary);
  }

  .header-actions h1 {
    margin: 0;
    font-size: 1.75rem;
    color: var(--color-text);
  }

  .error-banner {
    background: rgba(var(--color-error-rgb), 0.1);
    color: var(--color-error);
    padding: 1rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-left: 4px solid var(--color-error);
  }

  .ticket-details-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Tarjeta de Metadatos */
  .ticket-meta-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .meta-value {
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 500;
  }
  .ticket-id {
    font-family: monospace;
    background: rgba(150, 150, 150, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 1px;
    color: var(--color-text-muted);
  }

  /* Badges y estados */
  .status-badge {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
  }
  .status-open { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .status-progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .status-resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

  .priority-badge-wrapper {
    display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.95rem; font-weight: 500; color: var(--color-text); text-transform: capitalize;
  }
  .priority-dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }

  .resolved-date { color: #22c55e; font-weight: 600; }

  /* Conversacion */
  .conversation {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .message {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .message-header {
    background: rgba(0, 0, 0, 0.02);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.1rem;
  }
  .client-avatar { background: var(--color-primary); }
  .admin-avatar { background: #3b82f6; }

  .name-time {
    display: flex;
    flex-direction: column;
  }
  .name-time strong {
    color: var(--color-text);
    font-size: 1rem;
  }
  .name-time .time {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .message-body {
    padding: 1.5rem;
    color: var(--color-text);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .message-body p {
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .message-body p:last-child {
    margin-bottom: 0;
  }

  .attachment-container {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }
  .attachment-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem !important;
  }
  .attachment-label i {
    margin-right: 0.4rem;
  }
  .ticket-attachment-img {
    max-width: 100%;
    max-height: 400px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .ticket-attachment-img:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-md);
  }

  /* Distingue mensaje de admin */
  .admin-message {
    border-left: 4px solid #3b82f6;
    margin-left: 2rem;
  }

  .waiting-response {
    margin-left: 2rem;
    padding: 2rem;
    text-align: center;
    background: rgba(var(--color-primary-rgb), 0.03);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .loader-pulse {
    width: 12px;
    height: 12px;
    background-color: var(--color-primary);
    border-radius: 50%;
    animation: pulse 1.5s infinite ease-in-out;
  }

  @keyframes pulse {
    0% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb), 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(var(--color-primary-rgb), 0); }
    100% { transform: scale(0.8); box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb), 0); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .ticket-meta-card {
      flex-direction: column;
      gap: 1.25rem;
    }
    .admin-message, .waiting-response {
      margin-left: 0; /* Full width en movil */
    }
  }
</style>
