---
import AuthLayout from '../layouts/AuthLayout.astro';
import { Image } from 'astro:assets';
import banner from '../assets/img/banner-web.jpg';
import logo from '../assets/img/logo-full.png';
import ForgotPasswordModal from '../components/auth/ForgotPasswordModal.astro';
---

<AuthLayout title="Iniciar Sesión | Agencia Digital">
  <main class="login-page">
    <div class="banner__background">
        <Image 
            src={banner} 
            alt="Fondo de pantalla"
            width={1920}
            height={1080}
            class="banner__image"
        />
    </div>

    <!-- Logo superior izquierda -->
    <a href="/" class="login-logo-link">
        <Image 
            src={logo} 
            alt="Agencia Digital Logo"
            width={120}
            class="login-logo"
        />
    </a>
    
    <div class="login-container fade-in">
      <div class="login-header">
        <h1>Bienvenido</h1>
        <p>Ingresa a tu panel de control</p>
      </div>
      
      <div id="loginForm" class="login-form">
        <div class="form-group">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="tu@email.com" 
            class="form-input"
          />
        </div>
        
        <div class="form-group password-group">
          <label for="password" class="form-label">Contraseña</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="••••••••" 
            class="form-input"
          />
          <div class="forgot-password-wrapper">
            <button type="button" id="openForgotBtn" class="forgot-link">¿Olvidaste tu contraseña?</button>
          </div>
        </div>

        <div id="errorMessage" class="error-message"></div>
        
        <button type="button" class="btn-primary" id="loginBtn" disabled>
            <span class="btn-text">Iniciar sesión</span>
        </button>
      </div>
    </div>

    <ForgotPasswordModal />

    <!-- Footer pegado al borde inferior -->
    <footer class="login-footer">
        <p>© 2026 Gabriel Zavando. Todos los derechos reservados.</p>
        <p>Desarrollado por: <a href="https://gabrielzavando.cl" class="credit-link">Gabriel Zavando</a></p>
    </footer>
  </main>
</AuthLayout>

<script>
  import { signInWithEmailAndPassword } from "firebase/auth";
  import { auth } from "../lib/firebase/client";

  const errorMessage = document.getElementById('errorMessage');
  const loginBtn = document.getElementById('loginBtn') as HTMLButtonElement;
  const loginForm = document.getElementById('loginForm');
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const openForgotBtn = document.getElementById('openForgotBtn');

  // Función para validar campos y habilitar/deshabilitar botón
  const validateFields = () => {
    if (!loginBtn) return;
    const isEmailValid = emailInput?.value.trim() !== '' && emailInput?.value.includes('@');
    const isPasswordValid = passwordInput?.value !== '';
    
    if (isEmailValid && isPasswordValid) {
      loginBtn.disabled = false;
    } else {
      loginBtn.disabled = true;
    }
  };

  emailInput?.addEventListener('input', validateFields);
  passwordInput?.addEventListener('input', validateFields);

  loginForm?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      if (!loginBtn?.disabled) {
        e.preventDefault();
        loginBtn?.click();
      }
    }
  });

  loginBtn?.addEventListener('click', async () => {
    if (!loginBtn || !errorMessage) return;

    // Loading state
    loginBtn.disabled = true;
    loginBtn.classList.add('loading');
    errorMessage.textContent = '';
    
    const email = emailInput?.value?.trim() || '';
    const password = passwordInput?.value || '';

    try {
      const userCredential =
        await signInWithEmailAndPassword(auth, email, password);

      const tokenResult =
        await userCredential.user.getIdTokenResult();
      const role = tokenResult.claims.role || 'client';

      // Cookie de sesión para el middleware SSR de Astro
      const idToken = await userCredential.user.getIdToken();
      
      // Pedimos la Session Cookie al backend de NestJS
      const API_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://localhost:8080';
      const response = await fetch(`${API_URL}/auth/session`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ idToken }),
      });

      if (!response.ok) {
         throw new Error('Error al establecer la sesión prolongada');
      }

      const { sessionCookie } = await response.json();

      // Guardamos la Cookie de Sesión con duración de 14 días (1209600s) a nivel del explorador
      document.cookie =
        `session=${sessionCookie}; path=/; max-age=1209600; SameSite=Lax`;

      // Redirección basada en rol
      if (role === 'admin') {
        window.location.href = '/admin';
      } else {
        window.location.href = '/dashboard';
      }

    } catch (err: unknown) {
      const error = err as { code?: string; message?: string };

      let msg = "Error al iniciar sesión.";
      if (
        error.code === 'auth/invalid-credential'
        || error.code === 'auth/wrong-password'
        || error.code === 'auth/user-not-found'
        || error.code === 'auth/invalid-email'
      ) {
        msg = "Credenciales incorrectas o usuario inexistente.";
      }
      if (error.code === 'auth/too-many-requests') {
        msg = "Demasiados intentos. Intenta más tarde.";
      }
      
      errorMessage.textContent = msg;
      
      validateFields();
    }
  });

  // Abrir modal de recuperación
  openForgotBtn?.addEventListener('click', () => {
    if ((window as any).openForgotPasswordModal) {
      (window as any).openForgotPasswordModal();
    }
  });
</script>

<style lang="scss">
  .login-page {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 1rem;
    overflow: hidden;
    isolation: isolate;
  }

  /* Capa degradada transparente */
  .login-page::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, var(--banner-overlay-start), var(--banner-overlay-end));
    z-index: -1;
    opacity: 0.85;
  }

  /* Variables the theme exactly like Contact.astro */
  :global(html[data-theme="light"]) .login-page {
    --card-bg: var(--color-white);
    --input-bg: var(--color-white);
    --input-border: var(--color-secondary);
    --input-text: var(--color-input-text);
    --input-focus-shadow: rgba(255, 0, 128, 0.1);
    --placeholder: var(--color-text-muted);
    --btn-spinner-color: var(--color-white);
  }

  :global(html[data-theme="dark"]) .login-page {
    --card-bg: var(--color-surface);
    --input-bg: var(--color-surface-secondary);
    --input-border: var(--color-border-secondary);
    --input-text: var(--color-text);
    --input-focus-shadow: rgba(255, 0, 128, 0.14);
    --placeholder: rgba(249, 250, 251, 0.56);
    --btn-spinner-color: var(--color-surface);
  }

  /* Fondo con imagen */
  .banner__background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -2;
  }

  .banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(2px);
  }

  /* Logo superior izquierda */
  .login-logo-link {
    position: absolute;
    top: 2rem;
    left: 2rem;
    z-index: 10;
    transition: transform 0.3s ease;

    &:hover {
        transform: scale(1.05);
    }

    @media (max-width: 768px) {
        top: 1.5rem;
        left: 1.5rem;
        .login-logo {
            width: 100px;
        }
    }
  }

  .login-container {
    background: var(--card-bg); /* Fondo dinámico según tema (blanco o dark) */
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 440px;
    border: 1px solid var(--color-border);
    position: relative;
    z-index: 1;
  }

  .login-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .login-header h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-family: var(--font-headings);
    font-weight: 700;
  }

  .login-header p {
    color: var(--color-text-secondary);
  }

  .form-group {
    margin-bottom: 1.5rem;
    
    &.password-group {
      margin-bottom: 1rem;
    }
  }

  .forgot-password-wrapper {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .forgot-link {
    background: none;
    border: none;
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
    font-family: var(--font-primary);

    &:hover {
      text-decoration: underline;
      opacity: 0.8;
    }
  }

  .form-label {
    display: block;
    font-family: var(--font-headings);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-input {
    width: 100%;
    padding: var(--space-md);
    border: 1px solid var(--input-border);
    border-radius: 0; /* Flat design */
    background: var(--input-bg);
    font-family: var(--font-primary);
    font-size: 1rem;
    color: var(--input-text);
    transition: all var(--transition-normal) ease;
    outline: none;

    &::placeholder {
      color: var(--placeholder);
      opacity: 0.9;
    }

    &:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-shadow);
    }
  }

  .btn-primary {
    width: 100%;
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 3.5rem; /* Asegura que el botón no se achique */
    position: relative;
  }

  .btn-primary:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:active:not(:disabled) {
    transform: translateY(0);
  }
  
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary.loading {
    cursor: wait;
    
    .btn-text {
        opacity: 0.5;
    }

    &::after {
        content: "";
        position: absolute;
        right: 1.5rem;
        width: 20px;
        height: 20px;
        border: 2px solid transparent;
        border-top: 2px solid var(--btn-spinner-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .error-message {
    color: var(--color-error);
    font-size: 0.875rem;
    margin-bottom: 1rem;
    text-align: center;
    min-height: 1.25rem;
  }

  /* Footer pegado al borde inferior */
  .login-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    text-align: center;
    z-index: 10;
    /* Aseguramos que NO tenga fondo */
    background: transparent !important;
    backdrop-filter: none !important;

    p {
        color: white;
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
        opacity: 0.9;
        font-family: var(--font-primary);
        text-shadow: 0 1px 2px rgba(0,0,0,0.5); /* Sombra para legibilidad sobre la imagen */
    }

    .credit-link {
        color: var(--color-accent);
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.2s;

        &:hover {
            opacity: 0.8;
            text-decoration: underline;
        }
    }
  }
</style>
