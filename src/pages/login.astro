---
import AuthLayout from '../layouts/AuthLayout.astro';
---

<AuthLayout title="Iniciar Sesión | Agencia Digital">
  <main class="login-page">
    <div class="login-container fade-in">
      <div class="login-header">
        <h1>Bienvenido</h1>
        <p>Ingresa a tu panel de control</p>
      </div>
      
      <div id="loginForm" class="login-form">
        <div class="form-group">
          <label for="email">Correo Electrónico</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" />
        </div>
        
        <div class="form-group">
          <label for="password">Contraseña</label>
          <input type="password" id="password" name="password" placeholder="••••••••" />
        </div>

        <div id="errorMessage" class="error-message"></div>
        
        <button type="button" class="btn-primary" id="loginBtn">
            <span class="btn-text">Ingresar</span>
        </button>
      </div>
    </div>
  </main>
</AuthLayout>

<script>
  import { signInWithEmailAndPassword } from "firebase/auth";
  import { auth } from "../lib/firebase/client";

  const errorMessage = document.getElementById('errorMessage');
  const loginBtn = document.getElementById('loginBtn');
  const btnText = loginBtn?.querySelector('.btn-text');
  const loginForm = document.getElementById('loginForm');

  loginForm?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      loginBtn?.click();
    }
  });

  loginBtn?.addEventListener('click', async () => {
    if (!loginBtn || !errorMessage) return;

    // Loading state
    loginBtn.setAttribute('disabled', 'true');
    btnText?.classList.add('hidden');
    errorMessage.textContent = '';
    
    // Obtener valores
    const container = document.getElementById('loginForm');
    const emailInput = container?.querySelector(
      'input[name="email"]'
    ) as HTMLInputElement;
    const passwordInput = container?.querySelector(
      'input[name="password"]'
    ) as HTMLInputElement;
    
    const email = emailInput?.value?.trim() || '';
    const password = passwordInput?.value || '';

    if (!email || !password) {
      errorMessage.textContent =
        "Por favor ingresa correo y contraseña.";
      loginBtn.removeAttribute('disabled');
      btnText?.classList.remove('hidden');
      return;
    }

    try {
      const userCredential =
        await signInWithEmailAndPassword(auth, email, password);

      const tokenResult =
        await userCredential.user.getIdTokenResult();
      const role = tokenResult.claims.role || 'client';

      // Cookie de sesión para el middleware SSR de Astro
      const token = await userCredential.user.getIdToken();
      document.cookie =
        `session=${token}; path=/; max-age=3600; SameSite=Lax`;

      // Redirección basada en rol
      if (role === 'admin') {
        window.location.href = '/admin';
      } else {
        window.location.href = '/dashboard';
      }

    } catch (err: unknown) {
      const error = err as { code?: string; message?: string };

      let msg = "Error al iniciar sesión.";
      if (
        error.code === 'auth/invalid-credential'
        || error.code === 'auth/wrong-password'
        || error.code === 'auth/user-not-found'
        || error.code === 'auth/invalid-email'
      ) {
        msg = "Credenciales incorrectas o usuario inexistente.";
      }
      if (error.code === 'auth/too-many-requests') {
        msg = "Demasiados intentos. Intenta más tarde.";
      }
      
      errorMessage.textContent = msg;
      
      // Reset button
      loginBtn.removeAttribute('disabled');
      btnText?.classList.remove('hidden');
    }
  });
</script>

<style>
  .login-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    padding: 1rem;
    background-color: var(--color-background);
  }

  .login-container {
    background: var(--color-surface);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 400px;
    border: 1px solid var(--color-border);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-header h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .login-header p {
    color: var(--color-text-muted);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-weight: 500;
  }

  input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-background);
    color: var(--color-text);
    transition: all 0.2s;
  }

  input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(var(--color-primary-rgb), 0.1);
  }

  .btn-primary {
    width: 100%;
    padding: 0.875rem;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }
  
  .btn-primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .error-message {
    color: var(--color-error);
    font-size: 0.875rem;
    margin-bottom: 1rem;
    text-align: center;
    min-height: 1.25rem;
  }
  
  .hidden {
    display: none;
  }
</style>
