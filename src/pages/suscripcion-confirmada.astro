---
import MainLayout from "../layouts/MainLayout.astro";
import { getSystemConfig } from "../utils/config";

const config = await getSystemConfig();
const status = Astro.url.searchParams.get("status");
const isOk = status === "ok";
---

<MainLayout
  title={isOk ? "¡Suscripción confirmada!" : "Error al confirmar"}
  description="Confirmación de suscripción al newsletter de Gabriel Zavando"
  hideHeader={true}
  hideFooter={true}
>
  <nav class="assessment-nav fade-in-down">
    <div class="assessment-nav__container">
      <a href="/" class="assessment-nav__logo" title="Volver al inicio">
        <img
          src={config.logoUrl}
          alt={config.name}
          width="150"
          height="150"
          class="logo"
        />
      </a>
      <a href="/" class="btn-cta__border btn-sm assessment-nav__back">
        <span class="material-symbols-outlined">arrow_back</span>
        Volver al home
      </a>
    </div>
  </nav>

  <section class="confirm-section fade-in">
    <div class="confirm-container">
      {isOk ? (
        <div class="state-content">
          <div class="icon-circle success">
            <span class="material-symbols-outlined">check</span>
          </div>
          <h1 class="state-title">¡Suscripción confirmada!</h1>
          <p class="state-text">
            Genial, ya estás en la lista. Pronto recibirás tips de
            transformación digital directamente en tu bandeja de entrada.
          </p>
          <a href="/" class="btn-cta">Ir al inicio</a>
        </div>
      ) : (
        <div class="state-content">
          <div class="icon-circle error">
            <span class="material-symbols-outlined">warning</span>
          </div>
          <h1 class="state-title">Enlace inválido o expirado</h1>
          <p class="state-text">
            El enlace de confirmación no es válido o ya fue usado. Si crees que
            es un error, intenta suscribirte nuevamente.
          </p>
          <a href="/" class="btn-cta">Volver al inicio</a>
        </div>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .confirm-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: var(--color-background);
  }

  .confirm-container {
    max-width: 480px;
    width: 100%;
    text-align: center;
  }

  .state-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .icon-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .icon-circle span {
    font-size: 3rem;
  }

  .icon-circle.success {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 2px solid #10b981;
  }

  .icon-circle.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 2px solid #ef4444;
  }

  .state-title {
    font-family: var(--font-headings);
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .state-text {
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .btn-cta {
    margin-top: 1rem;
    width: 100%;
  }

  /* Animación */
  .fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

